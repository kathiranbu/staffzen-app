        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .bp-notif-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 16px 10px;
        border-bottom: 1px solid #f3f4f6;
        flex-shrink: 0;
