        box-shadow: 0 8px 32px rgba(0,0,0,.14) !important;
        overflow: hidden !important;
        z-index: 1100 !important;
        background: #fff !important;
        padding: 0 !important;
    }
    .flatpickr-calendar::before,
    .flatpickr-calendar::after { display: none !important; }

