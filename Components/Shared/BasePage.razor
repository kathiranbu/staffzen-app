    private static string Ago(DateTime dt)
    {
        var d = DateTime.Now - dt;
        if (d.TotalSeconds < 60)  return "a few seconds ago";
        if (d.TotalMinutes < 60)  return $"{(int)d.TotalMinutes} mins ago";
        return $"{(int)d.TotalHours} hours ago";
    }

