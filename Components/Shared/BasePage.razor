    private string _reviewSuccess   = "";

    // ── Toast notification system ─────────────────────────────────────────────
    private record ToastItem(string Id, string Kind, string Icon, string Title, string Message);
    private List<ToastItem> _toasts = new();

    private async Task ShowToastAsync(string kind, string icon, string title, string message)
    {
        var id = Guid.NewGuid().ToString("N")[..8];
        var toast = new ToastItem(id, kind, icon, title, message);
        _toasts.Add(toast);
        await InvokeAsync(StateHasChanged);

        // Map kind → API notification type and persist to DB so it appears in bell panel
        var notifType = kind switch
        {
            "clockin"  => "ClockIn",
            "clockout" => "ClockOut",
            "break"    => "BreakEnd",
            "shift"    => "ShiftAlert",
            _          => ""
        };
        if (!string.IsNullOrEmpty(notifType) && SessionService.IsLoggedIn)
        {
            _ = Task.Run(async () =>
            {
                await NotificationService.SaveClockEventAsync(notifType, title, message);
                await LoadPersistentNotificationsAsync();
            });
        }

        // Auto-dismiss after 5 seconds
        _ = Task.Run(async () =>
        {
            await Task.Delay(5000);
            await InvokeAsync(() => { DismissToast(id); return Task.CompletedTask; });
        });
    }

    private void DismissToast(string id)
    {
        _toasts.RemoveAll(t => t.Id == id);
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnPushReceived(string title, string body)
    {
        // Detect type from title for icon/colour
        var kind = title.Contains("Clocked In") || title.Contains("Clock In")  ? "clockin"
                 : title.Contains("Clocked Out") || title.Contains("Clock Out") ? "clockout"
                 : title.Contains("Break")  ? "break"
                 : title.Contains("Shift")  ? "shift"
                 : "info";
        var icon = kind switch
        {
            "clockin"  => "bi-box-arrow-in-right",
            "clockout" => "bi-box-arrow-right",
            "break"    => "bi-cup-hot",
            "shift"    => "bi-alarm",
            _          => "bi-bell-fill"
        };

        _ = Task.Run(async () =>
        {
            await ShowToastAsync(kind, icon, title, body);
            await Task.Delay(300);
            await LoadPersistentNotificationsAsync();
        });

        return Task.CompletedTask;
    }

