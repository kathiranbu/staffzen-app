    private void SetHour(int h)
    {
        bool isPm = confirmTime.Hour >= 12;
        int newHour = isPm ? (h == 12 ? 12 : h + 12) : (h == 12 ? 0 : h);
        confirmTime = new TimeOnly(newHour, confirmTime.Minute);
        showTimePicker = false;
    }

    private void SetMinute(int m)
    {
        confirmTime = new TimeOnly(confirmTime.Hour, m);
        showTimePicker = false;
    }

    private void SetAmPm(string ampm)
    {
        int h = confirmTime.Hour;
        if (ampm == "AM" && h >= 12) h -= 12;
        else if (ampm == "PM" && h < 12) h += 12;
        confirmTime = new TimeOnly(h, confirmTime.Minute);
    }

