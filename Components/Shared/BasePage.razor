@inject IHttpClientFactory HttpClientFactory
@inject SessionService SessionService
@inject AttendanceService AttendanceService
@inject WorkScheduleService WorkScheduleService
@inject IJSRuntime JS
@inject Microsoft.Extensions.Options.IOptions<APM.StaffZen.Blazor.Configuration.ApiSettings> ApiOptions
@inject NotificationBus NotificationBus
@inject NotificationService NotificationService
@implements IDisposable
@rendermode RenderMode.InteractiveServer

<div class="page-container">

    <!-- HEADER -->
    <div class="top-header">
        <div class="header-left">
            <button class="menu-toggle" @onclick="ToggleSidebar">
                <i class="bi bi-list"></i>
            </button>
            <h4 class="page-title">@Title</h4>
        </div>

        <div class="header-right">

            @if (isClockedIn)
            {
                <div class="bp-clock-pill">
                    <div class="bp-clock-pill-in">
                        <i class="bi bi-clock"></i>
                        <span>@clockInTime.ToString("hh:mm tt")</span>
                    </div>
                    <div class="bp-clock-pill-divider"></div>
                    <div class="bp-clock-pill-elapsed">@ElapsedDisplay</div>
                </div>
            }

            @if (!isClockedIn && lastClockOut != default)
            {
                <div class="bp-clocked-out-pill">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Out: @lastClockOut.ToString("hh:mm tt")</span>
                </div>
            }

            <button class="@("icon-btn " + (isClockedIn ? "stop-btn" : "play-btn"))"
                    @onclick="async () => await OpenConfirmPanel()"
                    title="@(isClockedIn ? "Clock Out" : "Clock In")"
                    disabled="@isClocking">
                @if (isClocking)
                {
                    <span class="bp-mini-spinner"></span>
                }
                else if (isClockedIn)
                {
                    <i class="bi bi-stop-fill"></i>
                }
                else
                {
                    <i class="bi bi-play-fill"></i>
                }
            </button>

            <div class="bp-team-wrap">
                <button class="icon-btn bp-team-btn"
                        title="Clock in for team members"
                        @onclick="ToggleTeamPanel">
                    <i class="bi bi-people-fill"></i>
                </button>

                @if (showTeamPanel)
                {
                    <div class="bp-team-backdrop" @onclick="CloseTeamPanel"></div>
                    <div class="bp-team-panel">
                        <div class="bp-team-panel-header">
                            <span class="bp-team-panel-title">ADD TIME ENTRY FOR…</span>
                            <button class="bp-team-clock-all-btn" @onclick="ClockInAllMembers" disabled="@teamLoading">
                                <i class="bi bi-people"></i> Clock in for team members
                            </button>
                        </div>
                        <div class="bp-team-search-wrap">
                            <i class="bi bi-search bp-team-search-icon"></i>
                            <input class="bp-team-search" placeholder="Search group members"
                                   @bind="memberSearch" @bind:event="oninput" />
                        </div>
                        @if (teamLoading)
                        {
                            <div class="bp-team-loading"><span class="bp-team-spinner"></span> Loading…</div>
                        }
                        else if (!groupMembers.Any())
                        {
                            <div class="bp-team-empty">No group members found</div>
                        }
                        else
                        {
                            <div class="bp-team-list">
                                @foreach (var m in FilteredMembers)
                                {
                                    <div class="bp-team-member">
                                        <div class="@("bp-team-avatar " + (m.IsClockedIn ? "bp-avatar-in" : ""))">@m.FullName[0]</div>
                                        <div class="bp-team-info">
                                            <span class="bp-team-name">@m.FullName</span>
                                            <span class="@("bp-team-status " + (m.IsClockedIn ? "bp-status-in" : "bp-status-out"))">
                                                @(m.IsClockedIn ? "Clocked in" : "Clocked out")
                                            </span>
                                        </div>
                                        <div class="bp-team-actions">
                                            @if (!m.IsClockedIn)
                                            {
                                                <button class="bp-team-action-btn bp-action-in" @onclick="() => ClockInMember(m)">
                                                    <i class="bi bi-play-fill"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="bp-team-action-btn bp-action-out" @onclick="() => ClockOutMember(m)">
                                                    <i class="bi bi-stop-fill"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="bp-notif-wrap">
                <button class="icon-btn bp-notif-btn" @onclick="async () => await ToggleNotifPanel()" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                    @if (_unreadCount > 0)
                    {
                        <span class="bp-notif-badge">@(_unreadCount > 9 ? "9+" : _unreadCount.ToString())</span>
                    }
                </button>

                @if (_showNotifPanel)
                {
                    <div class="bp-notif-backdrop" @onclick="CloseNotifPanel"></div>
                    <div class="bp-notif-panel">
                        <div class="bp-notif-panel-header">
                            <span class="bp-notif-panel-title">Notifications</span>
                            @if (_persistentNotifications.Any())
                            {
                                <button class="bp-notif-clear-btn" @onclick="ClearAllNotifications">Clear all</button>
                            }
                        </div>
                        @if (_notifLoading)
                        {
                            <div class="bp-notif-empty">
                                <span class="bp-mini-spinner"></span>
                                <p style="margin-top:8px;">Loading…</p>
                            </div>
                        }
                        else if (!_persistentNotifications.Any())
                        {
                            <div class="bp-notif-empty">
                                <i class="bi bi-bell-slash" style="font-size:28px;color:#d1d5db;"></i>
                                <p>No notifications</p>
                            </div>
                        }
                        else
                        {
                            <div class="bp-notif-list">
                                @foreach (var n in _persistentNotifications)
                                {
                                    <div class="bp-notif-item @(n.IsRead ? "" : "bp-notif-item--unread")"
                                         @onclick="() => OnNotificationClick(n)"
                                         style="cursor:pointer;">
                                        <div class="bp-notif-icon @n.IconBgCss">
                                            <i class="bi @n.Icon"></i>
                                        </div>
                                        <div class="bp-notif-body">
                                            <div class="bp-notif-title">@n.Title</div>
                                            <div class="bp-notif-msg">@n.Message</div>
                                            <div class="bp-notif-time">@n.TimeAgo</div>
                                        </div>
                                        <button class="bp-notif-dismiss"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => DismissNotification(n)"
                                                title="Dismiss">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @* ── Leave Detail Modal (opened when a leave notification is clicked) ── *@
            @if (_showLeaveModal)
            {
                <div class="lnd-backdrop" @onclick="CloseLeaveModal"></div>
                <div class="lnd-modal" @onclick:stopPropagation="true">

                    @* Header *@
                    <div class="lnd-header">
                        <div class="lnd-header-left">
                            <div class="lnd-header-icon @(_activeNotif?.Type == "LeaveApplied" ? "lnd-icon--applied" : _activeNotif?.Type == "LeaveApproved" ? "lnd-icon--approved" : "lnd-icon--rejected")">
                                <i class="bi @(_activeNotif?.Type == "LeaveApplied" ? "bi-person-lines-fill" : _activeNotif?.Type == "LeaveApproved" ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                            </div>
                            <div>
                                <h3 class="lnd-title">@(_activeNotif?.Title ?? "Leave Request")</h3>
                                <p class="lnd-subtitle">Leave request details</p>
                            </div>
                        </div>
                        <button class="lnd-close" @onclick="CloseLeaveModal"><i class="bi bi-x-lg"></i></button>
                    </div>

                    @* Body *@
                    @if (_leaveDetailLoading)
                    {
                        <div class="lnd-loading">
                            <span class="bp-mini-spinner"></span>
                            <span>Loading details…</span>
                        </div>
                    }
                    else if (_leaveDetail == null)
                    {
                        <div class="lnd-loading">
                            <i class="bi bi-exclamation-triangle" style="color:#f59e0b;font-size:22px;"></i>
                            <span>Could not load request details.</span>
                        </div>
                    }
                    else
                    {
                        <div class="lnd-body">

                            @* ── ADMIN VIEW: show details + approve/reject ─────────── *@
                            @if (_activeNotif?.Type == "LeaveApplied")
                            {
                                <div class="lnd-info-grid">
                                    <div class="lnd-info-row">
                                        <span class="lnd-info-label"><i class="bi bi-person me-1"></i>Employee</span>
                                        <span class="lnd-info-value lnd-value--strong">@_leaveDetail.EmployeeName</span>
                                    </div>
                                    <div class="lnd-info-row">
                                        <span class="lnd-info-label"><i class="bi bi-calendar-event me-1"></i>Start Date</span>
                                        <span class="lnd-info-value">@_leaveDetail.StartDate.ToString("MMMM dd, yyyy")</span>
                                    </div>
                                    <div class="lnd-info-row">
                                        <span class="lnd-info-label"><i class="bi bi-calendar-check me-1"></i>End Date</span>
                                        <span class="lnd-info-value">@((_leaveDetail.EndDate ?? _leaveDetail.StartDate).ToString("MMMM dd, yyyy"))</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_leaveDetail.Reason))
                                    {
                                        <div class="lnd-info-row lnd-info-row--full">
                                            <span class="lnd-info-label"><i class="bi bi-chat-left-text me-1"></i>Reason</span>
                                            <span class="lnd-info-value">@_leaveDetail.Reason</span>
                                        </div>
                                    }
                                </div>

                                @if (_leaveDetail.IsPending)
                                {
                                    @* ── Current approval stage badge ── *@
                                    <div class="lnd-stage-row">
                                        <span class="lnd-stage-badge @(_leaveDetail.Status == "Pending_HR" ? "lnd-stage--hr" : "lnd-stage--tl")">
                                            <i class="bi @(_leaveDetail.Status == "Pending_HR" ? "bi-building" : "bi-person-badge") me-1"></i>
                                            @(_leaveDetail.Status == "Pending_HR" ? "Pending HR Approval" : "Pending Team Lead Approval")
                                        </span>
                                    </div>

                                    @* ── Approval timeline ── *@
                                    <div class="lnd-timeline">
                                        <div class="lnd-tl-step @(_leaveDetail.Status == "Pending_TeamLead" ? "lnd-tl-step--active" : (_leaveDetail.Status == "Pending_HR" || _leaveDetail.Status == "Approved" ? "lnd-tl-step--done" : "lnd-tl-step--skip"))">
                                            <div class="lnd-tl-dot"><i class="bi @(_leaveDetail.Status == "Pending_HR" || _leaveDetail.Status == "Approved" ? "bi-check-lg" : "bi-hourglass-split")"></i></div>
                                            <div class="lnd-tl-label">Team Lead Review</div>
                                        </div>
                                        <div class="lnd-tl-line"></div>
                                        <div class="lnd-tl-step @(_leaveDetail.Status == "Pending_HR" ? "lnd-tl-step--active" : (_leaveDetail.Status == "Approved" ? "lnd-tl-step--done" : "lnd-tl-step--wait"))">
                                            <div class="lnd-tl-dot"><i class="bi @(_leaveDetail.Status == "Approved" ? "bi-check-lg" : "bi-hourglass-split")"></i></div>
                                            <div class="lnd-tl-label">HR Review</div>
                                        </div>
                                    </div>

                                    @* ── Admin action panel ── *@
                                    <div class="lnd-action-panel">
                                        <div class="lnd-action-label">Take Action</div>

                                        @if (!_showRejectInput)
                                        {
                                            @if (_leaveDetail.Status == "Pending_TeamLead")
                                            {
                                                @* Team Lead actions: Approve, Forward to HR, Reject *@
                                                <div class="lnd-action-row" style="flex-wrap:wrap;">
                                                    <button class="lnd-btn lnd-btn--approve"
                                                            disabled="@_reviewBusy"
                                                            @onclick="() => AdminApprove()">
                                                        @if (_reviewBusy && _reviewingAction == "approve")
                                                        { <span class="bp-mini-spinner"></span> }
                                                        else
                                                        { <i class="bi bi-check-lg me-1"></i> }
                                                        Approve
                                                    </button>
                                                    <button class="lnd-btn lnd-btn--forward"
                                                            disabled="@_reviewBusy"
                                                            @onclick="() => AdminForwardToHR()">
                                                        @if (_reviewBusy && _reviewingAction == "forward_to_hr")
                                                        { <span class="bp-mini-spinner"></span> }
                                                        else
                                                        { <i class="bi bi-arrow-right-circle me-1"></i> }
                                                        Forward to HR
                                                    </button>
                                                    <button class="lnd-btn lnd-btn--reject"
                                                            disabled="@_reviewBusy"
                                                            @onclick="() => _showRejectInput = true">
                                                        <i class="bi bi-x-lg me-1"></i>Reject
                                                    </button>
                                                </div>
                                            }
                                            else if (_leaveDetail.Status == "Pending_HR")
                                            {
                                                @* HR actions: Approve, Reject *@
                                                <div class="lnd-action-row">
                                                    <button class="lnd-btn lnd-btn--approve"
                                                            disabled="@_reviewBusy"
                                                            @onclick="() => AdminApproveAsHR()">
                                                        @if (_reviewBusy && _reviewingAction == "hr_approve")
                                                        { <span class="bp-mini-spinner"></span> }
                                                        else
                                                        { <i class="bi bi-check-lg me-1"></i> }
                                                        Approve (HR)
                                                    </button>
                                                    <button class="lnd-btn lnd-btn--reject"
                                                            disabled="@_reviewBusy"
                                                            @onclick="() => _showRejectInput = true">
                                                        <i class="bi bi-x-lg me-1"></i>Reject
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="lnd-reject-form">
                                                <label class="lnd-reject-label">Reason for rejection <span style="color:#ef4444;">*</span></label>
                                                <textarea class="lnd-reject-textarea"
                                                          rows="3"
                                                          placeholder="Enter reason…"
                                                          @bind="_rejectReason"></textarea>
                                                @if (!string.IsNullOrEmpty(_reviewError))
                                                {
                                                    <div class="lnd-error"><i class="bi bi-exclamation-circle me-1"></i>@_reviewError</div>
                                                }
                                                <div class="lnd-action-row" style="margin-top:10px;">
                                                    <button class="lnd-btn lnd-btn--reject"
                                                            disabled="@_reviewBusy"
                                                            @onclick="() => AdminReject()">
                                                        @if (_reviewBusy && _reviewingAction == "reject")
                                                        { <span class="bp-mini-spinner"></span> }
                                                        else
                                                        { <i class="bi bi-send me-1"></i> }
                                                        Confirm Rejection
                                                    </button>
                                                    <button class="lnd-btn lnd-btn--cancel"
                                                            @onclick="CancelRejectInput">
                                                        Cancel
                                                    </button>
                                                </div>
                                            </div>
                                        }

                                        @if (!string.IsNullOrEmpty(_reviewError) && !_showRejectInput)
                                        {
                                            <div class="lnd-error"><i class="bi bi-exclamation-circle me-1"></i>@_reviewError</div>
                                        }
                                        @if (!string.IsNullOrEmpty(_reviewSuccess))
                                        {
                                            <div class="lnd-success"><i class="bi bi-check-circle me-1"></i>@_reviewSuccess</div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="lnd-status-badge @(_leaveDetail.IsApproved ? "lnd-badge--approved" : "lnd-badge--rejected")">
                                        <i class="bi @(_leaveDetail.IsApproved ? "bi-check-circle-fill" : "bi-x-circle-fill") me-1"></i>
                                        @_leaveDetail.DisplayStatus
                                    </div>
                                }
                            }

                            @* ── USER VIEW: read-only result ──────────────────────── *@
                            else
                            {
                                <div class="lnd-info-grid">
                                    <div class="lnd-info-row">
                                        <span class="lnd-info-label"><i class="bi bi-flag me-1"></i>Status</span>
                                        <span class="lnd-status-badge @(_leaveDetail.IsApproved ? "lnd-badge--approved" : _leaveDetail.IsRejected ? "lnd-badge--rejected" : "lnd-badge--pending")" style="display:inline-flex;">
                                            <i class="bi @(_leaveDetail.IsApproved ? "bi-check-circle-fill" : _leaveDetail.IsRejected ? "bi-x-circle-fill" : "bi-hourglass-split") me-1"></i>
                                            @_leaveDetail.DisplayStatus
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_leaveDetail.ReviewedBy))
                                    {
                                        <div class="lnd-info-row">
                                            <span class="lnd-info-label"><i class="bi bi-person-check me-1"></i>Action taken by</span>
                                            <span class="lnd-info-value">@_leaveDetail.ReviewedBy</span>
                                        </div>
                                    }
                                    <div class="lnd-info-row">
                                        <span class="lnd-info-label"><i class="bi bi-calendar-event me-1"></i>Start Date</span>
                                        <span class="lnd-info-value">@_leaveDetail.StartDate.ToString("MMMM dd, yyyy")</span>
                                    </div>
                                    <div class="lnd-info-row">
                                        <span class="lnd-info-label"><i class="bi bi-calendar-check me-1"></i>End Date</span>
                                        <span class="lnd-info-value">@((_leaveDetail.EndDate ?? _leaveDetail.StartDate).ToString("MMMM dd, yyyy"))</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_leaveDetail.RejectReason))
                                    {
                                        <div class="lnd-info-row lnd-info-row--full">
                                            <span class="lnd-info-label" style="color:#ef4444;"><i class="bi bi-chat-left-text me-1"></i>Rejection Reason</span>
                                            <span class="lnd-info-value" style="color:#ef4444;">@_leaveDetail.RejectReason</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <button class="icon-btn bp-hide-mobile"><i class="bi bi-person"></i></button>
            <button class="icon-btn bp-hide-mobile"><i class="bi bi-question-circle"></i></button>
            <button class="icon-btn"><i class="bi bi-gear"></i></button>
        </div>
    </div>

    <div class="page-body">
        @ChildContent
    </div>

</div>


@* ── Selfie-only camera modal ─────────────────────────────────────────────── *@
@if (showSelfieModal)
{
    <div class="cci-backdrop" @onclick="CancelSelfieModal"></div>

    <div class="cci-drawer face-verify-drawer">

        <!-- Header -->
        <div class="fv-header">
            <div class="fv-header-left">
                <span class="fv-title"><i class="bi bi-camera me-2"></i>@(isClockedIn ? "Clock Out" : "Clock In")</span>
                <p class="fv-subtitle">Selfie required</p>
            </div>
            <button class="fv-close" @onclick="CancelSelfieModal" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Camera feed -->
        <div class="fv-video-frame">
            <span class="fv-scan-pill fv-scan-pill--idle"><i class="bi bi-camera me-1"></i>Scanning</span>
            <video id="selfieClockVideo" autoplay muted playsinline class="fv-video"></video>
            <canvas id="selfieClockCanvas" class="fv-canvas"></canvas>
        </div>

        <!-- Status -->
        <div class="fv-status-row fv-status--info">
            <i class="bi bi-camera fv-status-icon"></i>
            <span>@selfieModalMessage</span>
        </div>

        <!-- Tip -->
        <div class="fv-tip-row">
            <span><i class="bi bi-lightbulb me-1"></i>Good lighting helps. Face the camera directly.</span>
        </div>

        <button class="fv-skip-btn" @onclick="CancelSelfieModal">
            <i class="bi bi-x me-1"></i>Cancel
        </button>
    </div>
}

@if (showFaceModal)
{
    <div class="cci-backdrop" @onclick="CancelFaceModal"></div>

    <div class="cci-drawer face-verify-drawer">

        <!-- ── Header ── -->
        <div class="fv-header">
            <div class="fv-header-left">
                <div class="fv-action-badge @(isClockedIn ? "fv-badge--out" : "fv-badge--in")">
                    <i class="bi @(isClockedIn ? "bi-box-arrow-right" : "bi-box-arrow-in-right")"></i>
                </div>
                <div>
                    <h3 class="fv-title">@(isClockedIn ? "Clock Out" : "Clock In")</h3>
                    <p class="fv-subtitle">Face verification required</p>
                </div>
            </div>
            <button class="fv-close" @onclick="CancelFaceModal" title="Close" disabled="@isClocking">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="fv-body">

            @if (isClocking)
            {
                <div class="fv-processing">
                    <div class="fv-processing-ring"></div>
                    <p class="fv-processing-label">@(isClockedIn ? "Clocking out..." : "Clocking in...")</p>
                </div>
            }
            else
            {
                <!-- Camera feed -->
                <div class="fv-video-frame @(faceModalMsgType == "success" ? "fv-frame--matched" : faceModalMsgType == "danger" ? "fv-frame--mismatch" : "")">
                    <div class="fv-scan-label">
                        @if (faceModalMatched)
                        {
                            <span class="fv-scan-pill fv-scan-pill--ok"><i class="bi bi-check-circle-fill me-1"></i>Matched</span>
                        }
                        else if (faceModalMsgType == "danger")
                        {
                            <span class="fv-scan-pill fv-scan-pill--err"><i class="bi bi-x-circle-fill me-1"></i>Mismatch</span>
                        }
                        else
                        {
                            <span class="fv-scan-pill fv-scan-pill--idle"><i class="bi bi-camera me-1"></i>Scanning</span>
                        }
                    </div>
                    <video id="faceClockVideo" autoplay muted playsinline class="fv-video"></video>
                    <canvas id="faceClockCanvas" class="fv-canvas"></canvas>
                    @if (faceModalMatched)
                    {
                        <div class="fv-matched-overlay">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                    }
                </div>

                <!-- Status message -->
                <div class="fv-status-row fv-status--@faceModalMsgType">
                    <i class="bi @(string.IsNullOrEmpty(faceModalMsgIcon) ? "bi-camera" : faceModalMsgIcon) fv-status-icon"></i>
                    <span class="fv-status-text">
                        @(string.IsNullOrEmpty(faceModalMessage)
                            ? $"Look at the camera to {(isClockedIn ? "clock out" : "clock in")} automatically"
                            : faceModalMessage)
                    </span>
                </div>

                <!-- Tips -->
                <div class="fv-tips">
                    <span><i class="bi bi-lightbulb me-1"></i>Good lighting helps. Face the camera directly.</span>
                </div>

                <button class="fv-skip-btn" @onclick="CancelFaceModal">
                    Use manual @(isClockedIn ? "clock-out" : "clock-in") instead
                </button>
            }

        </div>
    </div>
}

@if (showConfirmPanel)
{
    <div class="cci-backdrop" @onclick="CloseConfirmPanel"></div>

    <div class="cci-drawer">

        <div class="cci-header">
            <h3 class="cci-title">@(isClockedIn ? "Confirm Clock Out" : "Confirm Clock In")</h3>
            <button class="cci-close" @onclick="CloseConfirmPanel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="cci-user-strip">
            <div class="cci-user-av">@(SessionService.FullName?[0].ToString().ToUpper() ?? "U")</div>
            <div class="cci-user-info">
                <div class="cci-user-name">@(SessionService.FullName ?? "User")</div>
                <div class="cci-user-meta">Clocking from GMT+5:30</div>
                @if (isClockedIn)
                {
                    <div class="cci-user-meta">Clocked in @clockInTime.ToString("hh:mm tt").ToLower()</div>
                }
                else if (lastClockOut != default)
                {
                    <div class="cci-user-meta">Last out @Ago(lastClockOut)</div>
                }
                <div class="cci-user-meta">Split time: 12:00 am</div>
            </div>
        </div>

        @if (!isClockedIn)
        {
            <div class="cci-tabs">
                <button class="@("cci-tab " + (confirmTab == "clock" ? "cci-tab--active" : ""))"
                        @onclick='() => confirmTab = "clock"'>
                    <i class="bi bi-arrow-right-circle"></i>
                    Clock in
                    <i class="bi bi-info-circle cci-tab-info"></i>
                </button>
                <button class="@("cci-tab " + (confirmTab == "hours" ? "cci-tab--active" : ""))"
                        @onclick='() => confirmTab = "hours"'>
                    <i class="bi bi-clock-history"></i>
                    Add hours
                    <i class="bi bi-info-circle cci-tab-info"></i>
                </button>
            </div>
        }

        <div class="cci-form">

            <div class="cci-time-wrap">
                <div class="@("cci-field" + (showTimePicker ? " cci-field--active" : ""))" @onclick="ToggleTimePicker">
                    <input class="cci-input" readonly placeholder="Select time"
                           value="@confirmTime.ToString("hh:mm tt").ToLower()" />
                    <i class="bi bi-clock cci-icon-post"></i>
                </div>
                @if (showTimePicker)
                {
                    <div class="cci-scroll-picker">
                        <!-- Hours column -->
                        <div class="cci-col" id="cci-col-h">
                            @for (int h = 1; h <= 12; h++)
                            {
                                var hv = h;
                                <div class="@("cci-col-item" + (confirmTime.Hour % 12 == hv % 12 ? " cci-col-item--sel" : ""))"
                                     @onclick="() => SetHour(hv)">@hv</div>
                            }
                        </div>
                        <div class="cci-col-sep"></div>
                        <!-- Minutes column -->
                        <div class="cci-col" id="cci-col-m">
                            @for (int m = 0; m < 60; m++)
                            {
                                var mv = m;
                                <div class="@("cci-col-item" + (confirmTime.Minute == mv ? " cci-col-item--sel" : ""))"
                                     @onclick="() => SetMinute(mv)">@mv.ToString("D2")</div>
                            }
                        </div>
                        <!-- AM/PM column -->
                        <div class="cci-col cci-col-ampm">
                            <div class="@("cci-ampm-item" + (confirmTime.Hour < 12 ? " cci-ampm-item--sel" : ""))"
                                 @onclick='() => SetAmPm("AM")'>am</div>
                            <div class="@("cci-ampm-item" + (confirmTime.Hour >= 12 ? " cci-ampm-item--sel" : ""))"
                                 @onclick='() => SetAmPm("PM")'>pm</div>
                        </div>
                    </div>
                }
            </div>

            <div class="@("cci-field" + (showDatePicker ? " cci-field--active" : ""))" @onclick="ToggleDatePicker">
                <input id="cci-fp-date" class="cci-input cci-input-no-events" readonly
                       placeholder="Select date"
                       value="@(confirmDate == DateOnly.FromDateTime(DateTime.Today) ? "Today" : confirmDate.ToString("dd MMM yyyy"))" />
                <i class="bi bi-calendar cci-icon-post"></i>
            </div>

            @if (!isClockedIn)
            {
                <div class="cci-field cci-field--select">
                    <select class="cci-input cci-select" @bind="confirmActivity">
                        <option value="">Select an activity</option>
                        <option value="Work">Work</option>
                        <option value="Meeting">Meeting</option>
                        <option value="Training">Training</option>
                    </select>
                    <i class="bi bi-chevron-down cci-field-icon"></i>
                </div>

                <div class="cci-field cci-field--select">
                    <select class="cci-input cci-select" @bind="confirmProject">
                        <option value="">Select a project</option>
                        <option value="General">General</option>
                        <option value="Internal">Internal</option>
                    </select>
                    <i class="bi bi-chevron-down cci-field-icon"></i>
                </div>
            }

            <div class="cci-field cci-field--note">
                <textarea class="cci-input cci-textarea" placeholder="Add a note" @bind="confirmNote"></textarea>
            </div>

            @if (isClockedIn)
            {
                <div class="cci-checkbox-row">
                    <input type="checkbox" id="endWorkDay" class="cci-checkbox" @bind="endWorkForDay" />
                    <label for="endWorkDay" class="cci-checkbox-label">
                        End work for the day?
                        <i class="bi bi-info-circle cci-checkbox-info"></i>
                    </label>
                </div>
            }

            <div class="cci-pills">
                <button class="cci-pill">
                    <i class="bi bi-bell"></i> Add reminder
                </button>
                @if (!isClockedIn)
                {
                    <button class="cci-pill">
                        <i class="bi bi-arrow-clockwise"></i> Auto clock out
                    </button>
                }
            </div>

        </div>

        @if (!string.IsNullOrEmpty(confirmError))
        {
            <div class="cci-error">
                <i class="bi bi-exclamation-circle"></i> @confirmError
            </div>
        }

        <div class="cci-footer">
            <button class="cci-cancel-btn" @onclick="CloseConfirmPanel" disabled="@isClocking">Cancel</button>
            <button class="cci-save-btn" @onclick="ExecuteClockAction" disabled="@isClocking">
                @if (isClocking)
                {
                    <span class="bp-mini-spinner"></span>
                }
                else
                {
                    <span>Save</span>
                }
            </button>
        </div>

    </div>
}

@* ── In-app toast notifications (clock-in/out/shift alerts) ── *@
@if (_toasts.Any())
{
    <div class="bp-toast-container">
        @foreach (var t in _toasts)
        {
            <div class="bp-toast bp-toast--@t.Kind" @key="t.Id">
                <div class="bp-toast-icon">
                    <i class="bi @t.Icon"></i>
                </div>
                <div class="bp-toast-body">
                    <div class="bp-toast-title">@t.Title</div>
                    <div class="bp-toast-msg">@t.Message</div>
                </div>
                <button class="bp-toast-close" @onclick="() => DismissToast(t.Id)">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClockAction { get; set; }
    [CascadingParameter] public AppLayout? Layout { get; set; }

    private DotNetObjectReference<BasePage>? _dotNetRef;

    private bool     isClockedIn   = false;
    private bool     isClocking    = false;
    private int      activeEntryId = 0;
    private DateTime clockInTime;
    private DateTime lastClockOut;
    private bool     _gpsStarted   = false;  // prevents GPS from starting twice on re-renders

    private System.Threading.Timer? _timer;
    private string ElapsedDisplay = "0:00:00";

    private List<TimeEntryRecord> todayEntries = new();

    private bool              showTeamPanel = false;
    private bool              teamLoading   = false;
    private List<GroupMember> groupMembers  = new();
    private string            memberSearch  = "";

    // ── Face verification modal state ────────────────────────────────────────
    private bool   showFaceModal      = false;
    private bool   faceModalMatched   = false;
    private string faceModalMessage   = string.Empty;
    private string faceModalMsgType   = "info";   // info | success | danger | warning
    private string faceModalMsgIcon   = "bi-camera";
    private bool   _hasFaceEnrolled   = false;
    private string? _verifiedSelfieBase64 = null;  // selfie captured at face-match moment
    private DotNetObjectReference<BasePage>? _faceClockRef;
    private CancellationTokenSource? _faceVerifCts; // hard-stop if JS never resolves

    // ── Time Tracking Policy (loaded from default work schedule) ─────────────
    private bool _policyRequireSelfie      = false;  // RequireSelfie checkbox
    private bool _policyRequireFaceVerif   = false;  // RequireFaceVerification checkbox

    // ── Selfie-only camera modal (no face recognition — just snap & clock) ───
    private bool   showSelfieModal    = false;
    private string selfieModalMessage = "Hold still — capturing selfie...";

    private bool     showConfirmPanel      = false;
    private bool     _flatpickrInitialized = false;
    private bool     showTimePicker        = false;
    private bool     showDatePicker        = false;
    private string   confirmTab            = "clock";
    private TimeOnly confirmTime;
    private DateOnly confirmDate;
    private string   confirmActivity       = "";
    private string   confirmProject        = "";
    private string   confirmNote           = "";
    private string   confirmError          = "";
    private bool     endWorkForDay         = false;

    private IEnumerable<GroupMember> FilteredMembers =>
        string.IsNullOrWhiteSpace(memberSearch)
            ? groupMembers
            : groupMembers.Where(m => m.FullName.Contains(memberSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        SessionService.OnSessionReady += LoadAsync;
        NotificationBus.OnNotify += OnPushReceived;   // receive cross-component notifications
        if (!SessionService.IsLoggedIn) return;
        await LoadAsync();
        // Load persistent notifications from DB on first render
        await LoadPersistentNotificationsAsync();
    }

    private async Task LoadAsync()
    {
        if (!SessionService.IsLoggedIn) return;

        todayEntries = await AttendanceService.GetHistoryAsync(SessionService.Id, SessionService.ActiveOrganizationId);

        var status = await AttendanceService.GetStatusAsync(SessionService.Id, SessionService.ActiveOrganizationId);
        if (status.IsClockedIn)
        {
            isClockedIn   = true;
            activeEntryId = status.EntryId;
            clockInTime   = status.ClockIn;
            StartTimer();
            // Start GPS tracking — employee is already clocked in (page load / refresh / navigation)
            await StartGpsTrackingAsync();
        }
        else
        {
            isClockedIn = false;
            _gpsStarted = false;
            StopTimer();
            if (todayEntries.Any(e => e.ClockOut != null))
                lastClockOut = todayEntries.Where(e => e.ClockOut != null).Max(e => e.ClockOut!.Value);
        }

        // Check if current user has face data enrolled (for face-clock-in)
        try
        {
            var http2 = HttpClientFactory.CreateClient("API");
            var faceRes = await http2.GetAsync($"api/employees/{SessionService.Id}/face-descriptor");
            if (faceRes.IsSuccessStatusCode)
            {
                var faceJson = await faceRes.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                _hasFaceEnrolled = faceJson.TryGetProperty("hasFaceData", out var hfd) && hfd.GetBoolean();
            }
        }
        catch { _hasFaceEnrolled = false; }

        // Load Time Tracking Policy (RequireSelfie / RequireFaceVerification)
        // Read each flag independently — exactly what is stored in the DB.
        // No implicit coupling: face rec does NOT automatically mean selfie at read time.
        try
        {
            var schedules = await WorkScheduleService.GetAllAsync();
            var def = schedules?.FirstOrDefault(s => s.IsDefault) ?? schedules?.FirstOrDefault();
            if (def != null)
            {
                _policyRequireFaceVerif = def.RequireFaceVerification;
                _policyRequireSelfie    = def.RequireSelfie;
            }
        }
        catch { /* policy stays false — safe default: no camera required */ }

        await InvokeAsync(StateHasChanged);
    }

    // ── GPS tracking helpers ──────────────────────────────────────────────
    private async Task StartGpsTrackingAsync()
    {
        if (_gpsStarted) return;
        _gpsStarted = true;
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);

            // Use HttpBaseUrl for GPS tracking — the dev HTTPS certificate is only
            // valid for "localhost". Phones on the LAN must use plain HTTP to avoid
            // SSL handshake failures (ERR_EMPTY_RESPONSE).
            // Set ApiSettings.HttpBaseUrl = "http://<your-laptop-LAN-IP>:5080" in appsettings.json
            var settings = ApiOptions.Value;
            var apiBase  = (!string.IsNullOrEmpty(settings.HttpBaseUrl)
                               ? settings.HttpBaseUrl
                               : settings.BaseUrl).TrimEnd('/');

            await JS.InvokeVoidAsync("liveLocation.start", SessionService.Id, apiBase);
        }
        catch
        {
            _gpsStarted = false;  // reset so it can be retried after render
        }
    }

    private async Task StopGpsTrackingAsync()
    {
        _gpsStarted = false;
        try { await JS.InvokeVoidAsync("liveLocation.stop"); }
        catch { }
    }

    public async Task RefreshStatusAsync() => await LoadAsync();

    private void ToggleSidebar() => Layout?.ToggleMobileSidebar();

    private async Task OpenConfirmPanel()
    {
        // ── Fetch policy FRESH at click time ─────────────────────────────────
        // Safe defaults = false. No camera opens unless the policy is explicitly ON in DB.
        bool requireFaceVerif = false;
        bool requireSelfie    = false;
        try
        {
            var schedules = await WorkScheduleService.GetAllAsync();
            var def = schedules?.FirstOrDefault(s => s.IsDefault) ?? schedules?.FirstOrDefault();
            if (def != null)
            {
                // Read each flag independently — exactly what is stored in the DB.
                // requireFaceVerif = true  → "Require verification by Face Recognition" checkbox is ON
                // requireSelfie    = true  → "Require selfies when clocking in and out" checkbox is ON
                // These are two separate checkboxes. No implicit coupling at read time.
                requireFaceVerif = def.RequireFaceVerification;
                requireSelfie    = def.RequireSelfie;
            }
        }
        catch { /* API unreachable — safe default: no camera, show plain confirm panel */ }

        // ── Route based on live policy ────────────────────────────────────────
        // 1. Face verification ON + face enrolled → face-rec modal
        if (requireFaceVerif && _hasFaceEnrolled)
        {
            await OpenFaceModal();
            return;
        }
        // 2. Face verification ON but face NOT yet enrolled → selfie modal (fallback)
        if (requireFaceVerif && !_hasFaceEnrolled)
        {
            await OpenSelfieModal();
            return;
        }
        // 3. Selfie-only ON (face rec OFF) → selfie modal
        if (requireSelfie)
        {
            await OpenSelfieModal();
            return;
        }
        // 4. Both OFF → plain confirm panel, no camera at all
        confirmError          = "";
        confirmActivity       = "";
        confirmProject        = "";
        confirmNote           = "";
        endWorkForDay         = false;
        confirmTab            = "clock";
        confirmTime           = TimeOnly.FromDateTime(DateTime.Now);
        confirmDate           = DateOnly.FromDateTime(DateTime.Today);
        _flatpickrInitialized = false;
        showConfirmPanel      = true;
    }

    // ── Selfie-only camera modal (no face-recognition comparison) ────────────
    // Used when RequireSelfie=ON but RequireFaceVerification=OFF,
    // OR when RequireFaceVerification=ON but the employee has not enrolled a face yet.
    private async Task OpenSelfieModal()
    {
        _verifiedSelfieBase64 = null;
        selfieModalMessage    = "Camera opening...";
        showSelfieModal       = true;
        StateHasChanged();

        await Task.Delay(150); // let DOM render the video element

        try
        {
            await JS.InvokeVoidAsync("startCamera", "selfieClockVideo");
            selfieModalMessage = "Face detected — capturing selfie automatically...";
            StateHasChanged();

            _faceClockRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("startSelfieCaptureLoop",
                "selfieClockVideo", "selfieClockCanvas", _faceClockRef);
        }
        catch (Exception ex)
        {
            selfieModalMessage = $"Camera error: {ex.Message}";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnSelfieCaptureDone(string selfieBase64)
    {
        // Store the captured selfie (keep full data URL — backend strips the header)
        _verifiedSelfieBase64 = string.IsNullOrEmpty(selfieBase64) ? null : selfieBase64;

        selfieModalMessage = "Selfie captured! Clocking " + (isClockedIn ? "out..." : "in...");
        await InvokeAsync(StateHasChanged);
        await Task.Delay(600);

        // Stop camera — but keep showSelfieModal=true so ExecuteClockWithSelfie
        // can show errors inside the selfie modal if the API call fails.
        try { await JS.InvokeVoidAsync("stopSelfieCaptureLoop"); } catch { }
        try { await JS.InvokeVoidAsync("stopCamera", "selfieClockVideo"); } catch { }
        _faceClockRef?.Dispose();
        _faceClockRef = null;

        await ExecuteClockWithSelfie();

        // Close selfie modal after clock action completes (success or error already handled)
        showSelfieModal = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CancelSelfieModal()
    {
        try { await JS.InvokeVoidAsync("stopSelfieCaptureLoop"); } catch { }
        try { await JS.InvokeVoidAsync("stopCamera", "selfieClockVideo"); } catch { }
        _faceClockRef?.Dispose();
        _faceClockRef   = null;
        showSelfieModal = false;
        StateHasChanged();
    }

    // ── Face verification modal ───────────────────────────────────────────
    private async Task OpenFaceModal()
    {
        faceModalMatched  = false;
        faceModalMessage  = string.Empty;
        showFaceModal     = true;
        StateHasChanged();

        await Task.Delay(150); // let DOM render the video element

        try
        {
            // ── Ensure face-api models are ready before doing anything ──────────────
            var modelsReady = await JS.InvokeAsync<bool>("areFaceModelsLoaded");
            if (!modelsReady)
            {
                faceModalMessage = "Loading face recognition models...";
                faceModalMsgType = "info";
                faceModalMsgIcon = "bi-hourglass-split";
                StateHasChanged();

                for (int i = 0; i < 30; i++)
                {
                    await Task.Delay(1000);
                    modelsReady = await JS.InvokeAsync<bool>("areFaceModelsLoaded");
                    if (modelsReady) break;
                }

                if (!modelsReady)
                {
                    faceModalMessage = "Face models could not be loaded. Check your connection and try again.";
                    faceModalMsgType = "danger";
                    faceModalMsgIcon = "bi-exclamation-circle";
                    StateHasChanged();
                    return;
                }
            }

            // Step 1: Fetch the stored descriptor HERE in Blazor (using HttpClient which
            // already has the correct BaseUrl) — avoids JS fetch hitting the wrong server.
            var http     = HttpClientFactory.CreateClient("API");
            var faceRes  = await http.GetAsync($"api/employees/{SessionService.Id}/face-descriptor");
            string? storedDescriptorJson = null;
            if (faceRes.IsSuccessStatusCode)
            {
                var faceDoc = System.Text.Json.JsonDocument.Parse(await faceRes.Content.ReadAsStringAsync());
                if (faceDoc.RootElement.TryGetProperty("descriptor", out var descEl)
                    && descEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                {
                    storedDescriptorJson = descEl.GetString();
                }
            }

            if (string.IsNullOrEmpty(storedDescriptorJson))
            {
                faceModalMessage  = "No face data enrolled. Please enroll your face first in Account Settings.";
                faceModalMsgType = "warning";
                faceModalMsgIcon  = "bi-exclamation-triangle";
                StateHasChanged();
                return;
            }

            // Step 2: Start camera
            await JS.InvokeVoidAsync("startCamera", "faceClockVideo");
            faceModalMessage  = "Look at the camera...";
            faceModalMsgType = "info";
            faceModalMsgIcon  = "bi-camera";
            StateHasChanged();

            // Step 3: Pass descriptor directly to JS — no fetch needed in the browser
            _faceClockRef = DotNetObjectReference.Create(this);

            // ── Safety timer: C# backstop in case JS 40s timer is unreliable.
            // If OnFaceStatus/OnFaceVerifiedWithSelfie is never called within 45s,
            // auto-cancel the modal so the user is never left stuck.
            _faceVerifCts?.Cancel();
            _faceVerifCts = new CancellationTokenSource();
            var cts = _faceVerifCts;
            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(45_000, cts.Token);
                    await InvokeAsync(async () =>
                    {
                        if (showFaceModal && !faceModalMatched && !isClocking)
                        {
                            faceModalMessage = "Verification timed out. Use manual clock-in instead.";
                            faceModalMsgType = "warning";
                            faceModalMsgIcon  = "bi-clock";
                            StateHasChanged();
                            await Task.Delay(1500);
                            await CancelFaceModal();
                        }
                    });
                }
                catch (TaskCanceledException) { /* cancelled by success/manual close — ignore */ }
            });

            await JS.InvokeVoidAsync("startLiveFaceVerificationWithDescriptor",
                "faceClockVideo", "faceClockCanvas",
                storedDescriptorJson,
                _faceClockRef);
        }
        catch (Exception ex)
        {
            faceModalMessage  = $"Camera error: {ex.Message}";
            faceModalMsgType = "danger";
            faceModalMsgIcon  = "bi-exclamation-circle";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnFaceVerifiedWithSelfie(double distance, string selfieBase64)
    {
        // Cancel the C# safety timeout — we succeeded
        _faceVerifCts?.Cancel();
        _faceVerifCts = null;

        // Store selfie — ExecuteClockAction() will use it when the user clicks Save
        _verifiedSelfieBase64 = string.IsNullOrEmpty(selfieBase64) ? null : selfieBase64;

        // Show "Face recognised" briefly so the user sees the green match state
        faceModalMatched = true;
        faceModalMessage = "Face recognised! Opening confirm panel...";
        faceModalMsgType = "success";
        faceModalMsgIcon = "bi-check-circle-fill";
        isClocking       = false; // NOT clocking yet — user must click Save in confirm panel
        await InvokeAsync(StateHasChanged);
        await Task.Delay(700);

        // ── STOP CAMERA NOW — fixes the "camera light stays on" bug ──────────
        // Camera must be stopped here, before the confirm panel opens.
        // ProceedAfterFaceMatch also calls these but the delay before it opens
        // the confirm panel can leave the camera running. Stop it immediately.
        try { await JS.InvokeVoidAsync("stopLiveFaceDetection", "faceClockCanvas"); } catch {}
        try { await JS.InvokeVoidAsync("stopCamera", "faceClockVideo"); } catch {}
        _faceClockRef?.Dispose();
        _faceClockRef = null;

        // Open confirm panel — actual clock in/out only happens when user clicks Save
        await ProceedAfterFaceMatch();
    }

    [JSInvokable]
    public async Task OnFaceVerified(bool matched, double distance)
    {
        await OnFaceStatus(matched ? "matched" : "mismatch", distance);
    }

    [JSInvokable]
    public async Task OnFaceStatus(string status, double distance)
    {
        switch (status)
        {
            case "matched":
                // This path is only reached via the legacy OnFaceVerified callback
                // (no selfie captured). The selfie path goes through OnFaceVerifiedWithSelfie directly.
                if (!isClocking)  // guard: don't re-enter if ExecuteClockWithSelfie already running
                {
                    faceModalMatched = true;
                    faceModalMessage = "Face recognised! Opening confirm panel...";
                    faceModalMsgType = "success";
                    faceModalMsgIcon = "bi-check-circle-fill";
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(700);
                    await ProceedAfterFaceMatch();
                }
                break;

            case "scanning":
                if (faceModalMsgType != "success")
                {
                    faceModalMessage = "Face detected — verifying...";
                    faceModalMsgType = "info";
                    faceModalMsgIcon = "bi-person-bounding-box";
                    await InvokeAsync(StateHasChanged);
                }
                break;

            case "mismatch":
                faceModalMessage = "Face not recognised. Please look directly at the camera.";
                faceModalMsgType = "danger";
                faceModalMsgIcon = "bi-x-circle-fill";
                await InvokeAsync(StateHasChanged);
                break;

            case "multiple_faces":
                faceModalMessage = "Multiple people detected — only one person should be in front of the camera.";
                faceModalMsgType = "warning";
                faceModalMsgIcon = "bi-people-fill";
                await InvokeAsync(StateHasChanged);
                break;

            case "no_face_scanning":
                if (string.IsNullOrEmpty(faceModalMessage) || faceModalMsgType == "info")
                {
                    faceModalMessage = "Look at the camera — move closer if needed.";
                    faceModalMsgType = "info";
                    faceModalMsgIcon = "bi-camera";
                    await InvokeAsync(StateHasChanged);
                }
                break;

            case "no_face":
                faceModalMessage = "No face detected. Please position your face in the camera and try again.";
                faceModalMsgType = "warning";
                faceModalMsgIcon = "bi-exclamation-circle";
                await InvokeAsync(StateHasChanged);
                break;
        }
    }

    private async Task ProceedAfterFaceMatch()
    {
        // Stop face loop + camera
        try { await JS.InvokeVoidAsync("stopLiveFaceDetection", "faceClockCanvas"); } catch {}
        try { await JS.InvokeVoidAsync("stopCamera", "faceClockVideo"); } catch {}
        _faceClockRef?.Dispose();
        _faceClockRef = null;

        // Close face modal, then open the confirm drawer so user clicks Save to confirm
        showFaceModal    = false;
        faceModalMatched = false;
        faceModalMessage = string.Empty;

        // Open confirm drawer — actual clock in/out only happens when user clicks Save
        confirmError          = "";
        confirmActivity       = "";
        confirmProject        = "";
        confirmNote           = "";
        endWorkForDay         = false;
        confirmTab            = "clock";
        confirmTime           = TimeOnly.FromDateTime(DateTime.Now);
        confirmDate           = DateOnly.FromDateTime(DateTime.Today);
        _flatpickrInitialized = false;
        showConfirmPanel      = true;

        StateHasChanged();
    }

    // ── Clock in/out directly after face verification (selfie already captured) ──
    private async Task ExecuteClockWithSelfie()
    {
        confirmError = "";

        if (!isClockedIn)
        {
            var (clockResult, clockError) = await AttendanceService.ClockInAsync(SessionService.Id, _verifiedSelfieBase64, SessionService.ActiveOrganizationId);
            if (clockResult != null)
            {
                isClockedIn   = true;
                activeEntryId = clockResult.EntryId;
                clockInTime   = clockResult.ClockIn;
                lastClockOut  = default;
                StartTimer();
                todayEntries.Add(new TimeEntryRecord { Id = clockResult.EntryId, ClockIn = clockResult.ClockIn, ClockInSelfieUrl = clockResult.ClockInSelfieUrl });
                await ShowToastAsync("clockin", "bi-box-arrow-in-right", "Clocked In ✅",
                    $"You clocked in at {clockResult.ClockIn.ToLocalTime():hh:mm tt}. Have a great shift!");
                await OnClockAction.InvokeAsync();
                await StartGpsTrackingAsync();
            }
            else
            {
                var errMsg = clockError ?? "Clock in failed. Please try again.";
                // Show error in whichever modal is currently open
                if (showSelfieModal)
                {
                    selfieModalMessage = errMsg;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(3000);
                    await CancelSelfieModal();
                }
                else
                {
                    faceModalMessage = errMsg;
                    faceModalMsgType = "danger";
                    faceModalMsgIcon = "bi-exclamation-circle";
                    showFaceModal    = true;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(3000);
                    showFaceModal = false;
                }
            }
        }
        else
        {
            var result = await AttendanceService.ClockOutAsync(SessionService.Id, _verifiedSelfieBase64, SessionService.ActiveOrganizationId);
            if (result != null)
            {
                StopTimer();
                isClockedIn  = false;
                lastClockOut = result.ClockOut!.Value;
                var open = todayEntries.FirstOrDefault(e => e.Id == activeEntryId);
                if (open != null)
                {
                    open.ClockOut         = result.ClockOut;
                    open.WorkedHours      = result.WorkedHours;
                    open.ClockInSelfieUrl  = result.ClockInSelfieUrl  ?? open.ClockInSelfieUrl;
                    open.ClockOutSelfieUrl = result.ClockOutSelfieUrl;
                }
                activeEntryId = 0;
                // ── In-app bell notification for clock-out ──
                var clockOutTimeStr = result.ClockOut!.Value.ToString("hh:mm tt");
                var workedStr = !string.IsNullOrEmpty(result.WorkedHours) ? $" Total: {result.WorkedHours}" : "";
                await ShowToastAsync("clockout", "bi-box-arrow-right", "Clocked Out 🟢",
                    $"You clocked out at {clockOutTimeStr}.{workedStr}");
                await OnClockAction.InvokeAsync();
                await StopGpsTrackingAsync();
            }
            else
            {
                var errMsg = "Clock out failed. Please try again.";
                if (showSelfieModal)
                {
                    selfieModalMessage = errMsg;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(3000);
                    await CancelSelfieModal();
                }
                else
                {
                    faceModalMessage = errMsg;
                    faceModalMsgType = "danger";
                    faceModalMsgIcon = "bi-exclamation-circle";
                    showFaceModal    = true;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(3000);
                    showFaceModal = false;
                }
            }
        }

        _verifiedSelfieBase64 = null;
        isClocking = false;
        faceModalMatched = false;
        faceModalMessage = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

