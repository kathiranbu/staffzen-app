        try { await JS.InvokeVoidAsync("stopCamera", "faceClockVideo"); } catch {}
    }

    private async Task ExecuteClockAction()
    {
        if (isClocking) return;
        isClocking   = true;
        confirmError = "";
        StateHasChanged();

        // Build the selected date+time from the confirm panel inputs.
        var selectedDateTime = confirmDate.ToDateTime(confirmTime);
        // "Is the selected time meaningfully different from now?" (>30s difference = custom time)
        bool isCustomTime = Math.Abs((selectedDateTime - DateTime.Now).TotalSeconds) > 30;
        bool isAdmin      = SessionService.CanManageActiveOrg;
        string dateStr    = confirmDate.ToString("yyyy-MM-dd");
        string timeStr    = confirmTime.ToString("HH:mm");

        if (!isClockedIn)
        {
            // ── Clock IN ────────────────────────────────────────────────────────
            if (isCustomTime && isAdmin)
            {
                // Admin selected a specific past time — use manual entry so the
                // exact time is honoured (ClockInAsync always uses DateTime.Now server-side).
                // The API creates a normal (IsManual=false) clock-in entry at the selected time
                // when no live session exists, OR back-dates the existing live session.
                var (ok, errMsg) = await AttendanceService.AddManualEntryAsync(
                    SessionService.Id, "in", dateStr, timeStr,
                    organizationId: SessionService.ActiveOrganizationId,
                    requesterId: SessionService.Id,
                    isAdminOverride: true);

                if (ok)
                {
                    // Fetch status to get entryId; use selectedDateTime for the timer
                    // so it counts elapsed time from the admin-chosen time, not DateTime.Now
                    var status = await AttendanceService.GetStatusAsync(SessionService.Id, SessionService.ActiveOrganizationId);
                    isClockedIn   = true;
                    activeEntryId = status.IsClockedIn ? status.EntryId : 0;
                    clockInTime   = selectedDateTime;
                    lastClockOut  = default;
                    StopTimer();
                    StartTimer();
                    todayEntries = await AttendanceService.GetHistoryAsync(SessionService.Id, SessionService.ActiveOrganizationId);
                    showConfirmPanel      = false;
                    _verifiedSelfieBase64 = null;
                    await OnClockAction.InvokeAsync();
                    await StartGpsTrackingAsync();
                }
                else
                {
                    confirmError = errMsg ?? "Clock in failed. Please try again.";
                }
            }
            else
            {
                // Standard real-time clock-in
                var (clockResult, clockError) = await AttendanceService.ClockInAsync(SessionService.Id, _verifiedSelfieBase64, SessionService.ActiveOrganizationId);
                if (clockResult != null)
                {
                    isClockedIn   = true;
                    activeEntryId = clockResult.EntryId;
                    clockInTime   = clockResult.ClockIn;
                    lastClockOut  = default;
                    StartTimer();
                    todayEntries.Add(new TimeEntryRecord { Id = clockResult.EntryId, ClockIn = clockResult.ClockIn, ClockInSelfieUrl = clockResult.ClockInSelfieUrl });
                    showConfirmPanel      = false;
                    _verifiedSelfieBase64 = null;
                    await ShowToastAsync("clockin", "bi-box-arrow-in-right", "Clocked In ✅",
                        $"You clocked in at {clockResult.ClockIn.ToLocalTime():hh:mm tt}. Have a great shift!");
                    await OnClockAction.InvokeAsync();
                    await StartGpsTrackingAsync();
                }
                else
                {
                    confirmError = clockError ?? "Clock in failed. Please try again.";
                }
            }
        }
        else if (isClockedIn && isCustomTime && isAdmin && confirmTab == "clock")
        {
            // ── Admin BACK-DATING an active live session ────────────────────────
            // The user is already clocked in and the admin is adjusting the start time.
            // Call AddManualEntryAsync with IsAdminOverride=true — the API will:
            //   • Find the live session and move its ClockIn to the earlier time
            //   • Keep IsManual=false so GetStatus still recognises it as live
            //   • Remove any conflicting manual entries between new and old start
            //   • Log the override in change history
            var (ok, errMsg) = await AttendanceService.AddManualEntryAsync(
                SessionService.Id, "in", dateStr, timeStr,
                organizationId: SessionService.ActiveOrganizationId,
                requesterId: SessionService.Id,
                isAdminOverride: true);

            if (ok)
            {
                // Update the local timer to count from the new (earlier) start time.
                // activeEntryId is unchanged — it is still the same live session entry.
                clockInTime = selectedDateTime;
                StopTimer();
                StartTimer();

                // Refresh today's entries so the Time Entries list shows updated start time
                todayEntries = await AttendanceService.GetHistoryAsync(SessionService.Id, SessionService.ActiveOrganizationId);
                showConfirmPanel      = false;
                _verifiedSelfieBase64 = null;
                await OnClockAction.InvokeAsync();
            }
            else
            {
                confirmError = errMsg ?? "Failed to update clock-in time. Please try again.";
            }
        }
        else
        {
            // ── Standard clock OUT ──────────────────────────────────────────────
            var result = await AttendanceService.ClockOutAsync(SessionService.Id, _verifiedSelfieBase64, SessionService.ActiveOrganizationId);
            if (result != null)
            {
                StopTimer();
                isClockedIn  = false;
                lastClockOut = result.ClockOut!.Value;
                var open = todayEntries.FirstOrDefault(e => e.Id == activeEntryId);
                if (open != null)
                {
                    open.ClockOut          = result.ClockOut;
                    open.WorkedHours       = result.WorkedHours;
                    open.ClockInSelfieUrl  = result.ClockInSelfieUrl  ?? open.ClockInSelfieUrl;
                    open.ClockOutSelfieUrl = result.ClockOutSelfieUrl;
                }
                activeEntryId         = 0;
                showConfirmPanel      = false;
                _verifiedSelfieBase64 = null;
                // ── In-app bell notification for clock-out ──
                var clockOutTimeStr2 = result.ClockOut!.Value.ToString("hh:mm tt");
                var workedStr2 = !string.IsNullOrEmpty(result.WorkedHours) ? $" Total: {result.WorkedHours}" : "";
                await ShowToastAsync("clockout", "bi-box-arrow-right", "Clocked Out 🟢",
                    $"You clocked out at {clockOutTimeStr2}.{workedStr2}");
                await OnClockAction.InvokeAsync();
                await StopGpsTrackingAsync();
            }
            else
            {
                confirmError = "Clock out failed. Please try again.";
            }
        }

        // Final safety stop — camera must be off after every clock action
        try { await JS.InvokeVoidAsync("stopLiveFaceDetection", "faceClockCanvas"); } catch {}
        try { await JS.InvokeVoidAsync("stopCamera", "faceClockVideo"); } catch {}

        isClocking = false;
        StateHasChanged();
    }

    private int _pollTick = 0;  // counts timer ticks to throttle the server poll

    private void StartTimer()
    {
        _pollTick = 0;
        _timer?.Dispose();
        _timer = new System.Threading.Timer(_ =>
        {
            var e = DateTime.Now - clockInTime;
            ElapsedDisplay = $"{(int)e.TotalHours}:{e.Minutes:D2}:{e.Seconds:D2}";

            // Poll the server every 60 ticks (60 seconds) to detect auto clock-out
            _pollTick++;
            if (_pollTick >= 60)
            {
                _pollTick = 0;
                // Fire-and-forget on the Blazor sync context
                InvokeAsync(async () =>
                {
                    try
                    {
                        var status = await AttendanceService.GetStatusAsync(
                            SessionService.Id, SessionService.ActiveOrganizationId);

                        // Auto clock-out happened on the server — update UI without refresh
                        if (!status.IsClockedIn && isClockedIn)
                        {
                            isClockedIn   = false;
                            activeEntryId = 0;
                            StopTimer();

                            // Reload today's entries so the clock-out time shows in the list
                            todayEntries = await AttendanceService.GetHistoryAsync(
                                SessionService.Id, SessionService.ActiveOrganizationId);

                            if (todayEntries.Any(x => x.ClockOut != null))
                                lastClockOut = todayEntries
                                    .Where(x => x.ClockOut != null)
                                    .Max(x => x.ClockOut!.Value);

                            await StopGpsTrackingAsync();
                            await OnClockAction.InvokeAsync();
                            StateHasChanged();
                        }
                    }
                    catch { /* network hiccup — ignore, will retry next tick */ }
                });
            }
            else
            {
                InvokeAsync(StateHasChanged);
            }
        }, null, 0, 1000);
    }

    private void StopTimer()
    {
        _timer?.Dispose();
        _timer = null;
        ElapsedDisplay = "0:00:00";
    }

