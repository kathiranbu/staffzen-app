        font-size: 14px;
        font-weight: 700;
        color: #111827;
    }

    .bp-notif-clear-btn {
        background: none;
        border: none;
        font-size: 12px;
        color: #6b7280;
        cursor: pointer;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: inherit;
    }

    .bp-notif-clear-btn:hover { background: #f3f4f6; color: #374151; }

    .bp-notif-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 36px 20px;
        color: #9ca3af;
        font-size: 13px;
    }

    .bp-notif-list {
        overflow-y: auto;
        flex: 1;
    }

    .bp-notif-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 14px;
        border-bottom: 1px solid #f9fafb;
        transition: background .1s;
    }

    .bp-notif-item:hover { background: #f9fafb; }

    .bp-notif-item--unread { background: #eff6ff; border-left: 3px solid #3b82f6; }
    .bp-notif-item--unread:hover { background: #dbeafe; }

    .bp-notif-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #e0e7ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .bp-notif-body { flex: 1; min-width: 0; }
    .bp-notif-title { font-size: 13px; font-weight: 600; color: #111827; margin-bottom: 2px; }
    .bp-notif-msg   { font-size: 12px; color: #6b7280; line-height: 1.4; }
    .bp-notif-time  { font-size: 11px; color: #9ca3af; margin-top: 4px; }

    .bp-notif-dismiss {
        background: none;
        border: none;
        color: #9ca3af;
        cursor: pointer;
        font-size: 14px;
        padding: 2px 4px;
        border-radius: 4px;
        flex-shrink: 0;
        align-self: flex-start;
        margin-top: 1px;
    }

    .bp-notif-dismiss:hover { color: #374151; background: #f3f4f6; }

    /* Notification icon colour variants */
    .notif-icon--applied  { background: #dbeafe; color: #1d4ed8; }
    .notif-icon--approved { background: #dcfce7; color: #15803d; }
    .notif-icon--rejected { background: #fee2e2; color: #b91c1c; }
    .notif-icon--clockin  { background: #dcfce7; color: #16a34a; }
    .notif-icon--clockout { background: #dbeafe; color: #2563eb; }
    .notif-icon--break    { background: #fef3c7; color: #d97706; }
    .notif-icon--shift    { background: #ede9fe; color: #7c3aed; }

    /* ═══════════════════════════════════════════════════════════════
       LEAVE NOTIFICATION DETAIL MODAL (lnd-*)
       ═══════════════════════════════════════════════════════════════ */

    .lnd-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1100;
        animation: lnd-fade .2s ease;
    }
    @@keyframes lnd-fade { from { opacity:0; } to { opacity:1; } }

    .lnd-modal {
        position: fixed;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: min(480px, 95vw);
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        z-index: 1101;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: lnd-pop .2s cubic-bezier(.175,.885,.32,1.275);
    }
    @@keyframes lnd-pop {
        from { opacity:0; transform: translate(-50%,-50%) scale(.92); }
        to   { opacity:1; transform: translate(-50%,-50%) scale(1); }
    }

    .lnd-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 20px 14px;
        border-bottom: 1px solid #f3f4f6;
    }
    .lnd-header-left { display: flex; align-items: center; gap: 12px; }
    .lnd-header-icon {
        width: 42px; height: 42px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
    }
    .lnd-icon--applied  { background: #dbeafe; color: #1d4ed8; }
    .lnd-icon--approved { background: #dcfce7; color: #15803d; }
    .lnd-icon--rejected { background: #fee2e2; color: #b91c1c; }

    .lnd-title    { font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 2px; }
    .lnd-subtitle { font-size: 12px; color: #9ca3af; margin: 0; }

    .lnd-close {
        background: none; border: none; color: #9ca3af;
        cursor: pointer; font-size: 16px;
        width: 30px; height: 30px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        transition: background .12s, color .12s;
    }
    .lnd-close:hover { background: #f3f4f6; color: #374151; }

    .lnd-loading {
        display: flex; align-items: center; gap: 10px;
        justify-content: center; padding: 36px 20px;
        color: #6b7280; font-size: 14px;
    }

    .lnd-body { padding: 20px; }

    .lnd-info-grid {
        display: flex; flex-direction: column; gap: 0;
        border: 1px solid #f3f4f6; border-radius: 10px;
        overflow: hidden; margin-bottom: 16px;
    }
    .lnd-info-row {
        display: flex; justify-content: space-between; align-items: flex-start;
        gap: 10px; padding: 11px 14px;
        border-bottom: 1px solid #f9fafb;
    }
    .lnd-info-row:last-child { border-bottom: none; }
    .lnd-info-row--full { flex-direction: column; gap: 4px; }
    .lnd-info-label {
        font-size: 12px; color: #6b7280; font-weight: 500;
        white-space: nowrap; flex-shrink: 0;
    }
    .lnd-info-value { font-size: 13px; color: #111827; text-align: right; }
    .lnd-value--strong { font-weight: 700; }

    .lnd-status-badge {
        display: inline-flex; align-items: center;
        padding: 4px 10px; border-radius: 20px;
        font-size: 12px; font-weight: 600;
    }
    .lnd-badge--approved { background: #dcfce7; color: #15803d; }
    .lnd-badge--rejected { background: #fee2e2; color: #b91c1c; }
    .lnd-badge--pending  { background: #fef9c3; color: #a16207; }

    .lnd-action-panel {
        border: 1px solid #f3f4f6; border-radius: 10px;
        padding: 14px;
    }
    .lnd-action-label {
        font-size: 12px; font-weight: 600; color: #6b7280;
        text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px;
    }
    .lnd-action-row { display: flex; gap: 10px; }

    .lnd-btn {
        flex: 1; padding: 9px 16px; border: none; border-radius: 8px;
        font-size: 13px; font-weight: 600; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        gap: 4px; transition: opacity .12s;
        font-family: inherit;
    }
    .lnd-btn:disabled { opacity: .6; cursor: not-allowed; }
    .lnd-btn--approve  { background: #16a34a; color: #fff; }
    .lnd-btn--approve:hover:not(:disabled) { background: #15803d; }
    .lnd-btn--reject   { background: #ef4444; color: #fff; }
    .lnd-btn--reject:hover:not(:disabled)  { background: #dc2626; }
    .lnd-btn--cancel   { background: #f3f4f6; color: #374151; flex: none; padding: 9px 14px; }
    .lnd-btn--cancel:hover { background: #e5e7eb; }

    .lnd-reject-form { display: flex; flex-direction: column; gap: 6px; }
    .lnd-reject-label { font-size: 12px; font-weight: 600; color: #374151; }
    .lnd-reject-textarea {
        border: 1px solid #d1d5db; border-radius: 8px;
        padding: 8px 10px; font-size: 13px; resize: vertical;
        font-family: inherit; color: #111827;
        outline: none; transition: border .15s;
    }
    .lnd-reject-textarea:focus { border-color: #6366f1; }

    .lnd-error   { color: #dc2626; font-size: 12px; display: flex; align-items: center; margin-top: 6px; }
    .lnd-success { color: #16a34a; font-size: 13px; display: flex; align-items: center; gap: 4px; margin-top: 8px; font-weight: 500; }

    /* ═══════════════════════════════════════════════════════════════
       CONFIRM CLOCK IN/OUT DRAWER
       ═══════════════════════════════════════════════════════════════ */

    .cci-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        z-index: 1050;
        animation: cci-fade-in .2s ease;
    }
    @@keyframes cci-fade-in { from { opacity: 0; } to { opacity: 1; } }

    .cci-drawer {
        position: fixed;
        top: 0; right: 0; bottom: 0;
        width: 400px;
        background: #fff;
        box-shadow: -8px 0 40px rgba(0,0,0,.15);
        z-index: 1051;
        display: flex;
        flex-direction: column;
        animation: cci-slide-in .22s cubic-bezier(.25,.46,.45,.94);
        overflow: hidden;
    }
    @@keyframes cci-slide-in {
        from { transform: translateX(100%); opacity: 0; }
        to   { transform: translateX(0);    opacity: 1; }
    }
    @@media (max-width: 480px) { .cci-drawer { width: 100%; } }

    .cci-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px 16px;
        border-bottom: 1px solid #f3f4f6;
        flex-shrink: 0;
    }
    .cci-title { font-size: 20px; font-weight: 700; color: #111827; margin: 0; }
    .cci-close {
        width: 32px; height: 32px; border-radius: 8px;
        border: none; background: #f9fafb;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #6b7280; font-size: 14px;
        transition: background .15s, color .15s; flex-shrink: 0;
    }
    .cci-close:hover { background: #f3f4f6; color: #111827; }

    .cci-user-strip {
        display: flex; align-items: flex-start; gap: 14px;
        padding: 16px 24px; border-bottom: 1px solid #f3f4f6; flex-shrink: 0;
    }
    .cci-user-av {
        width: 52px; height: 52px; border-radius: 50%;
        background: #e5e7eb; color: #374151;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; font-weight: 700; flex-shrink: 0;
    }
    .cci-user-name { font-size: 15px; font-weight: 700; color: #111827; }
    .cci-user-meta { font-size: 12px; color: #6b7280; margin-top: 2px; }

    .cci-tabs {
        display: flex; border-bottom: 1px solid #e5e7eb;
        flex-shrink: 0; padding: 0 24px;
    }
    .cci-tab {
        display: flex; align-items: center; gap: 6px;
        padding: 12px 4px; margin-right: 24px;
        background: none; border: none;
        font-size: 14px; font-weight: 600; color: #9ca3af;
        cursor: pointer; font-family: inherit;
        border-bottom: 2.5px solid transparent;
        transition: color .15s, border-color .15s;
        position: relative; bottom: -1px;
    }
    .cci-tab--active { color: #ff7a00; border-bottom-color: #ff7a00; }
    .cci-tab:hover:not(.cci-tab--active) { color: #6b7280; }
    .cci-tab-info { font-size: 12px; opacity: .5; }

    .cci-form {
        flex: 1; overflow-y: auto; padding: 20px 24px;
        display: flex; flex-direction: column; gap: 12px; scrollbar-width: thin;
    }

    /* ── Time field wrapper ── */
    .cci-time-wrap {
        display: flex;
        flex-direction: column;
        position: relative;
    }

    /* ── Custom scroll-column time picker ── */
    .cci-scroll-picker {
        display: flex;
        background: #f8f9fb;
        border-radius: 10px;
        border: 1.5px solid #e5e7eb;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,.22);
        margin-top: 4px;
        user-select: none;
    }

    .cci-col {
        flex: 1;
        max-height: 180px;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .cci-col::-webkit-scrollbar { display: none; }

    .cci-col-ampm {
        flex: 0 0 64px;
        display: flex;
        flex-direction: column;
        background: #f0f2f5;
        border-left: 1px solid #e5e7eb;
    }

    .cci-col-sep {
        width: 1px;
        background: #e5e7eb;
        flex-shrink: 0;
    }

    .cci-col-item {
        padding: 10px 0;
        text-align: center;
        font-size: 15px;
        font-weight: 500;
        color: #6b7280;
        cursor: pointer;
        transition: background .12s, color .12s;
        line-height: 1;
    }
    .cci-col-item:hover {
        background: #fff3e8;
        color: #ff7a00;
    }
    .cci-col-item--sel {
        background: #ff7a00;
        color: #fff;
        font-weight: 700;
        border-radius: 6px;
    }

    .cci-ampm-item {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
        cursor: pointer;
        transition: background .12s, color .12s;
        padding: 0 8px;
    }
    .cci-ampm-item:hover { background: #fff3e8; color: #ff7a00; }
    .cci-ampm-item--sel {
        background: #ff7a00;
        color: #fff;
        font-weight: 700;
        border-radius: 6px;
    }

    .cci-field {
        position: relative; display: flex; align-items: center;
        background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px;
        overflow: visible; transition: border-color .2s, box-shadow .2s; cursor: pointer;
    }
    .cci-field:focus-within,
    .cci-field:hover,
    .cci-field--active { border-color: #ff7a00; box-shadow: 0 0 0 3px rgba(255,122,0,.08); }
    .cci-field--note   { align-items: flex-start; cursor: default; }
    .cci-field--select { cursor: pointer; }

    .cci-icon-pre {
        padding: 0 0 0 14px; font-size: 14px;
        flex-shrink: 0; pointer-events: none;
    }
    .cci-icon-orange { color: #ff7a00; }
    .cci-icon-post {
        padding: 0 14px 0 6px; font-size: 13px; color: #9ca3af;
        flex-shrink: 0; pointer-events: none;
    }

    .cci-input {
        flex: 1; border: none; outline: none; padding: 13px 10px;
        font-size: 14px; color: #111827; font-family: inherit;
        background: transparent; min-width: 0; cursor: pointer;
    }
    .cci-input-padded-l { padding-left: 10px; }
    .cci-input::placeholder { color: #9ca3af; }
    .cci-input-no-events { pointer-events: none; }

    .cci-select {
        flex: 1; border: none; outline: none; padding: 13px 10px;
        font-size: 14px; color: #111827; font-family: inherit;
        background: transparent; -webkit-appearance: none;
        appearance: none; cursor: pointer; min-width: 0;
    }
    .cci-select option[value=""] { color: #9ca3af; }
    .cci-field-icon {
        padding: 0 14px 0 6px; font-size: 11px;
        color: #9ca3af; flex-shrink: 0; pointer-events: none;
    }

    .cci-textarea {
        flex: 1; border: none; outline: none; padding: 12px 14px;
        font-size: 14px; font-family: inherit; background: transparent;
        resize: vertical; min-height: 80px; line-height: 1.5;
        color: #111827; width: 100%; cursor: text;
    }

    /* ══════════════════════════════════════════════════════
       FLATPICKR — matching screenshots exactly
       ══════════════════════════════════════════════════════ */

    .flatpickr-calendar {
