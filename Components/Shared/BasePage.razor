    private async Task AdminApprove()
    {
        if (_leaveDetail == null || _activeNotif == null) return;
        _reviewBusy      = true;
        _reviewingAction = "approve";
        _reviewError     = "";
        await InvokeAsync(StateHasChanged);

        var (ok, err) = await NotificationService.ReviewLeaveAsync(
            _leaveDetail.Id, "direct_approve", "TeamLead");

        if (ok)
        {
            _reviewSuccess            = "Leave request approved successfully.";
            _leaveDetail.Status       = "Approved";
            _leaveDetail.ReviewedBy   = SessionService.FullName;
            // Remove that notification from the list so it won't show again
            _persistentNotifications.Remove(_activeNotif);
        }
        else
        {
            _reviewError = err;
        }

        _reviewBusy = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AdminForwardToHR()
    {
        if (_leaveDetail == null || _activeNotif == null) return;
        _reviewBusy      = true;
        _reviewingAction = "forward_to_hr";
        _reviewError     = "";
        await InvokeAsync(StateHasChanged);

        var (ok, err) = await NotificationService.ReviewLeaveAsync(
            _leaveDetail.Id, "forward_to_hr", "TeamLead");

        if (ok)
        {
            _reviewSuccess      = "Request forwarded to HR.";
            _leaveDetail.Status = "Pending_HR";
            // Keep notification open so HR can act on it too
        }
        else
        {
            _reviewError = err;
        }

        _reviewBusy = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AdminApproveAsHR()
    {
        if (_leaveDetail == null || _activeNotif == null) return;
        _reviewBusy      = true;
        _reviewingAction = "hr_approve";
        _reviewError     = "";
        await InvokeAsync(StateHasChanged);

        var (ok, err) = await NotificationService.ReviewLeaveAsync(
            _leaveDetail.Id, "approve", "HR");

        if (ok)
        {
            _reviewSuccess            = "Leave request approved by HR.";
            _leaveDetail.Status       = "Approved";
            _leaveDetail.ReviewedBy   = "HR";
            _persistentNotifications.Remove(_activeNotif);
        }
        else
        {
            _reviewError = err;
        }

        _reviewBusy = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AdminReject()
    {
        if (_leaveDetail == null || _activeNotif == null) return;
        if (string.IsNullOrWhiteSpace(_rejectReason))
        {
            _reviewError = "A rejection reason is required.";
            return;
        }

        _reviewBusy      = true;
        _reviewingAction = "reject";
        _reviewError     = "";
        await InvokeAsync(StateHasChanged);

        // Reject as whoever is the current reviewer
        var reviewer = _leaveDetail.Status == "Pending_HR" ? "HR" : "TeamLead";
        var (ok, err) = await NotificationService.ReviewLeaveAsync(
            _leaveDetail.Id, "reject", reviewer, _rejectReason.Trim());

        if (ok)
        {
            _reviewSuccess            = "Leave request rejected.";
            _leaveDetail.Status       = reviewer == "HR" ? "Rejected_HR" : "Rejected_TeamLead";
            _leaveDetail.ReviewedBy   = reviewer;
            _leaveDetail.RejectReason = _rejectReason.Trim();
            _showRejectInput          = false;
            _persistentNotifications.Remove(_activeNotif);
        }
        else
        {
            _reviewError = err;
        }

        _reviewBusy = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DismissNotification(NotificationVm n)
    {
        await NotificationService.DismissAsync(n.Id);
        _persistentNotifications.Remove(n);
        if (!_persistentNotifications.Any()) _showNotifPanel = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearAllNotifications()
    {
        await NotificationService.ClearAllAsync();
        _persistentNotifications.Clear();
        _showNotifPanel = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _faceClockRef?.Dispose();
        SessionService.OnSessionReady -= LoadAsync;
        NotificationBus.OnNotify -= OnPushReceived;
        _timer?.Dispose();
        _dotNetRef?.Dispose();
    }
