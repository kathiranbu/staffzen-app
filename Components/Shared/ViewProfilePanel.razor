    }
    .vp-mark-complete:hover { color: #6b7280; }

    /* ── Divider ───────────────────────────────────────────────────── */
    .vp-divider { height: 1px; background: #f0f0f0; margin: 8px 0; }

    /* ── Section ───────────────────────────────────────────────────── */
    .vp-section { padding: 20px 0; }
    .vp-section-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 16px;
    }
    .vp-section-title {
        font-size: 12px; font-weight: 700; letter-spacing: .06em;
        color: #374151; text-transform: uppercase;
    }

    /* ── View fields ───────────────────────────────────────────────── */
    .vp-fields-view { display: flex; flex-direction: column; gap: 16px; }
    .vp-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .vp-field-pair { display: flex; flex-direction: column; gap: 4px; }
    .vp-field-label { font-size: 13px; color: #9ca3af; }
    .vp-field-value { font-size: 14px; font-weight: 500; color: #111; }

    /* ── Edit form ─────────────────────────────────────────────────── */
    .vp-edit-form { display: flex; flex-direction: column; gap: 14px; }
    .vp-field { display: flex; flex-direction: column; gap: 5px; }
    .vp-field label { font-size: 12px; font-weight: 600; color: #374151; }
    .vp-input {
        padding: 9px 12px; border: 1px solid #d1d5db;
        border-radius: 8px; font-size: 14px; color: #111;
        outline: none; background: #fff; width: 100%; box-sizing: border-box;
    }
    .vp-input:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.1); }
    .vp-phone-row { display: flex; gap: 8px; }
    .vp-code-select { flex: 0 0 110px; }
    .vp-phone-input { flex: 1; }
    .vp-save-error { font-size: 13px; color: #ef4444; }
    .vp-edit-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 4px; }

    /* ── Buttons ───────────────────────────────────────────────────── */
    .vp-btn-cancel {
        padding: 8px 18px; border: 1px solid #d1d5db;
        border-radius: 8px; background: #fff; font-size: 14px;
        cursor: pointer; color: #374151;
    }
