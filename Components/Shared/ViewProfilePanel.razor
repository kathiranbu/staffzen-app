        font-weight: 600; cursor: pointer;
        display: flex; align-items: center; gap: 6px;
    }
    .vp-btn-save:hover:not(:disabled) { background: #4338ca; }
    .vp-btn-save:disabled { opacity: .65; }
    .vp-archive-btn {
        background: none; border: none; cursor: pointer;
        font-size: 14px; color: #6b7280; font-weight: 500; padding: 0;
    }
    .vp-archive-btn:hover { color: #374151; text-decoration: underline; }
    .vp-remove-btn {
        background: none; border: none; cursor: pointer;
        font-size: 14px; color: #ef4444; font-weight: 500; padding: 0;
    }
    .vp-remove-btn:hover { color: #dc2626; text-decoration: underline; }
    .vp-btn-danger {
        padding: 8px 20px; background: #ef4444; border: none;
        border-radius: 8px; color: #fff; font-size: 14px;
        font-weight: 600; cursor: pointer;
    }
    .vp-btn-danger:hover { background: #dc2626; }

    /* ── Spinner ───────────────────────────────────────────────────── */
    .vp-spinner {
        width: 14px; height: 14px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,.4);
        border-top-color: #fff;
        animation: vp-spin .6s linear infinite; display: inline-block;
    }

    /* ── Archive confirm dialog ────────────────────────────────────── */
    .vp-confirm-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,.5);
        z-index: 1000; display: flex; align-items: center; justify-content: center;
    }
    .vp-confirm-dialog {
        background: #fff; border-radius: 14px; padding: 28px 32px;
        max-width: 400px; width: 90%; box-shadow: 0 8px 40px rgba(0,0,0,.2);
    }
    .vp-confirm-dialog h3 { font-size: 17px; font-weight: 700; margin: 0 0 10px; }
    .vp-confirm-dialog p { font-size: 14px; color: #6b7280; margin: 0 0 20px; line-height: 1.5; }
    .vp-confirm-actions { display: flex; justify-content: flex-end; gap: 10px; }

    /* ── Loading skeleton ──────────────────────────────────────────── */
    .vp-loading { padding: 32px 24px; display: flex; flex-direction: column; gap: 12px; }
    .vp-skel {
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        border-radius: 6px;
        animation: vp-shimmer 1.4s ease infinite;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public int? EmployeeId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnMemberArchived { get; set; }
    [Parameter] public EventCallback OnMemberUpdated { get; set; }
    [Parameter] public List<GroupOption> Groups { get; set; } = new();

    private ProfileVm? _profile;
    private List<GroupOption> _groups = new();
    private bool _animateIn;
    private string _editingSection = "";
    private bool _saving;
    private string _saveError = "";
    private bool _showArchiveConfirm;
    private bool _showRemoveConfirm;

    // Edit buffers
    private string _editName = "";
    private string _editPhone = "";
    private string _editCountryCode = "+91";
    private DateTime? _editDob;
    private string _editRole = "";
    private string _editGroupId = "";

    private string Initials => string.IsNullOrWhiteSpace(_profile?.FullName)
        ? "?"
        : string.Concat(_profile.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => char.ToUpper(w[0])));

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && EmployeeId.HasValue)
        {
            await LoadProfile(EmployeeId.Value);
            _groups = Groups.Any() ? Groups : await LoadGroups();
            // Trigger slide animation on next render cycle
            await Task.Delay(10);
            _animateIn = true;
            StateHasChanged();
        }
        else if (!IsVisible)
        {
            _animateIn = false;
            _profile = null;
            _editingSection = "";
            _saveError = "";
        }
    }

    private async Task LoadProfile(int id)
    {
        try
        {
            var client = ClientFactory.CreateClient("API");
            var emp = await client.GetFromJsonAsync<ProfileVm>($"api/employees/{id}");
            if (emp != null) _profile = emp;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading profile: {ex.Message}");
        }
    }

    private async Task<List<GroupOption>> LoadGroups()
    {
        try
        {
            var client = ClientFactory.CreateClient("API");
            return await client.GetFromJsonAsync<List<GroupOption>>("api/groups") ?? new();
        }
        catch { return new(); }
    }

    private void ToggleSection(string section)
    {
        if (_editingSection == section)
        {
            CancelEdit();
            return;
        }
        _editingSection = section;
        _saveError = "";

        // Pre-fill edit buffers
        if (_profile != null)
        {
            _editName        = _profile.FullName;
            _editPhone       = _profile.MobileNumber ?? "";
            _editCountryCode = _profile.CountryCode ?? "+91";
            _editDob         = _profile.DateOfBirth;
            _editRole        = _profile.Role ?? "Employee";
            _editGroupId     = _profile.GroupId?.ToString() ?? "";
        }
    }

    private void CancelEdit()
    {
        _editingSection = "";
        _saveError = "";
    }

    private async Task SaveContact()
    {
        if (_profile == null) return;
        _saving = true; _saveError = ""; StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("API");
            var resp = await client.PutAsJsonAsync($"api/employees/{_profile.Id}/profile", new
            {
                FullName       = _editName,
                MobileNumber   = _editPhone,
                CountryCode    = _editCountryCode,
                DateOfBirth    = _editDob,
                ProfileImageUrl = _profile.ProfileImageUrl
            });

            if (resp.IsSuccessStatusCode)
            {
                _profile.FullName     = _editName;
                _profile.MobileNumber = _editPhone;
                _profile.CountryCode  = _editCountryCode;
                _profile.DateOfBirth  = _editDob;
                _editingSection = "";
                await OnMemberUpdated.InvokeAsync();
            }
            else
            {
                _saveError = "Failed to save. Please try again.";
            }
        }
        catch { _saveError = "Network error. Please try again."; }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task SaveEmployment()
    {
        if (_profile == null) return;
        _saving = true; _saveError = ""; StateHasChanged();
        try
        {
            var client  = ClientFactory.CreateClient("API");
            int? groupId = int.TryParse(_editGroupId, out var gid) ? gid : null;
            var orgId   = SessionService.ActiveOrganizationId;

            // ── Step 1: update OrgRole via the org-scoped endpoint ──────────
            if (orgId.HasValue)
            {
                var roleRequest = new HttpRequestMessage(HttpMethod.Patch,
                    $"api/organizations/{orgId.Value}/members/{_profile.Id}/role")
                {
                    Content = JsonContent.Create(new { OrgRole = _editRole })
                };
                var roleResp = await client.SendAsync(roleRequest);
                if (!roleResp.IsSuccessStatusCode)
                {
                    _saveError = "Failed to update role. Please try again.";
                    _saving = false; StateHasChanged(); return;
                }
                // Read confirmed role back from server
                var roleResult = await roleResp.Content.ReadFromJsonAsync<RoleUpdateResult>();
                _profile.Role = roleResult?.OrgRole ?? _editRole;
            }

            // ── Step 2: update GroupId via the employment endpoint ──────────
            var empRequest = new HttpRequestMessage(HttpMethod.Patch,
                $"api/employees/{_profile.Id}/employment")
            {
                Content = JsonContent.Create(new { Role = _editRole, GroupId = groupId })
            };
            var empResp = await client.SendAsync(empRequest);

            if (empResp.IsSuccessStatusCode)
            {
                var empResult = await empResp.Content.ReadFromJsonAsync<EmploymentUpdateResult>();
                _profile.GroupId   = empResult?.GroupId ?? groupId;
                _profile.GroupName = empResult?.GroupName
                    ?? _groups.FirstOrDefault(g => g.Id == groupId)?.Name;
                _editingSection = "";
                await OnMemberUpdated.InvokeAsync();
            }
            else
            {
                _saveError = "Failed to save group. Please try again.";
            }
        }
        catch { _saveError = "Network error. Please try again."; }
        finally { _saving = false; StateHasChanged(); }
    }

    // Response shapes from the API
    private class RoleUpdateResult
    {
        public string? OrgRole { get; set; }
    }

    private class EmploymentUpdateResult
    {
        public string?  Role      { get; set; }
        public int?     GroupId   { get; set; }
        public string?  GroupName { get; set; }
    }

    private void ArchiveMember() => _showArchiveConfirm = true;

    private async Task ConfirmArchive()
    {
        if (_profile == null) return;
        _showArchiveConfirm = false;
        try
        {
            var client = ClientFactory.CreateClient("API");
            // Soft-delete: sets IsActive = false, data preserved
            var resp = await client.DeleteAsync($"api/employees/{_profile.Id}/archive");
            if (resp.IsSuccessStatusCode)
            {
                await OnMemberArchived.InvokeAsync();
                await Close();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Archive error: {ex.Message}"); }
    }

    private void RemoveMember() => _showRemoveConfirm = true;

    private async Task ConfirmRemove()
    {
        if (_profile == null) return;
        _showRemoveConfirm = false;
        try
        {
            var client = ClientFactory.CreateClient("API");
            var orgId = SessionService.ActiveOrganizationId;
            if (!orgId.HasValue)
            {
                Console.WriteLine("Remove error: No active organization selected.");
                return;
            }
            // Org-scoped soft-remove: only removes membership from this org
            var resp = await client.DeleteAsync($"api/organizations/{orgId.Value}/members/{_profile.Id}");
            if (resp.IsSuccessStatusCode)
            {
                await OnMemberArchived.InvokeAsync();
                await Close();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Remove error: {ex.Message}"); }
    }

    private async Task Close()
    {
        _animateIn = false;
        StateHasChanged();
        await Task.Delay(300); // wait for close animation
        await OnClose.InvokeAsync();
    }

