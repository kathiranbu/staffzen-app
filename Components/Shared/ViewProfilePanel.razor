@using System.Net.Http.Json
@inject IHttpClientFactory ClientFactory
@inject SessionService SessionService

@if (IsVisible && _profile != null)
{
    <!-- Backdrop -->
    <div class="vp-backdrop" @onclick="Close"></div>

    <!-- Slide-over panel -->
    <div class="vp-panel @(_animateIn ? "vp-panel--open" : "")">

        <!-- Header -->
        <div class="vp-header">
            <h2 class="vp-title">View Profile</h2>
            <button class="vp-close" @onclick="Close"><i class="bi bi-x-lg"></i></button>
        </div>

        <!-- Scrollable body -->
        <div class="vp-body">

            <!-- Identity block -->
            <div class="vp-identity">
                <div class="vp-avatar">
                    @if (!string.IsNullOrEmpty(_profile.ProfileImageUrl))
                    {
                        <img src="@_profile.ProfileImageUrl" alt="@_profile.FullName" />
                    }
                    else
                    {
                        <span>@Initials</span>
                    }
                </div>
                <div class="vp-identity-info">
                    <div class="vp-name">@_profile.FullName</div>
                    <div class="vp-role-row">
                        <span class="vp-role-label">@_profile.Role</span>
                        @if (!_profile.IsActive)
                        {
                            <span class="vp-badge vp-badge--pending">Pending</span>
                        }
                        else
                        {
                            <span class="vp-badge vp-badge--active">Active</span>
                        }
                    </div>
                </div>
                <div class="vp-identity-actions">
                    <button class="vp-icon-btn" title="More options"><i class="bi bi-three-dots"></i></button>
                    <button class="vp-icon-btn" title="Edit profile" @onclick='() => ToggleSection("contact")'><i class="bi bi-pencil"></i></button>
                </div>
            </div>

            @if (!_profile.IsActive)
            {
                <!-- Complete profile prompt -->
                <div class="vp-complete-prompt">
                    <div class="vp-complete-left">
                        <div class="vp-complete-title">Complete this profile</div>
                        <div class="vp-complete-sub">We recommend letting employees fill up their own profile so they can clock in from their own devices and view their timesheets.</div>
                    </div>
                    <button class="vp-mark-complete">Mark as complete <i class="bi bi-check-circle"></i></button>
                </div>
            }

            <div class="vp-divider"></div>

            <!-- CONTACT INFORMATION -->
            <div class="vp-section">
                <div class="vp-section-header">
                    <span class="vp-section-title">CONTACT INFORMATION</span>
                    <button class="vp-icon-btn" @onclick='() => ToggleSection("contact")'><i class="bi bi-pencil"></i></button>
                </div>

                @if (_editingSection == "contact")
                {
                    <div class="vp-edit-form">
                        <div class="vp-field">
                            <label>Full Name</label>
                            <input class="vp-input" @bind="_editName" placeholder="Full name" />
                        </div>
                        <div class="vp-field">
                            <label>Phone Number</label>
                            <div class="vp-phone-row">
                                <select class="vp-input vp-code-select" @bind="_editCountryCode">
                                    <option value="+91">🇮🇳 +91</option>
                                    <option value="+1">🇺🇸 +1</option>
                                    <option value="+44">🇬🇧 +44</option>
                                    <option value="+61">🇦🇺 +61</option>
                                </select>
                                <input class="vp-input vp-phone-input" @bind="_editPhone" placeholder="Phone number" />
                            </div>
                        </div>
                        <div class="vp-field">
                            <label>Date of Birth</label>
                            <input type="date" class="vp-input" @bind="_editDob" />
                        </div>
                        @if (!string.IsNullOrEmpty(_saveError))
                        {
                            <div class="vp-save-error">@_saveError</div>
                        }
                        <div class="vp-edit-actions">
                            <button class="vp-btn-cancel" @onclick="CancelEdit">Cancel</button>
                            <button class="vp-btn-save" @onclick="SaveContact" disabled="@_saving">
                                @if (_saving) { <span class="vp-spinner"></span> }
                                Save
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="vp-fields-view">
                        <div class="vp-field-pair">
                            <div class="vp-field-label">Email</div>
                            <div class="vp-field-value">@_profile.Email</div>
                        </div>
                        <div class="vp-field-pair">
                            <div class="vp-field-label">Phone Number</div>
                            <div class="vp-field-value">@(string.IsNullOrEmpty(_profile.MobileNumber) ? "—" : $"{_profile.CountryCode}{_profile.MobileNumber}")</div>
                        </div>
                        @if (_profile.DateOfBirth.HasValue)
                        {
                            <div class="vp-field-pair">
                                <div class="vp-field-label">Date of Birth</div>
                                <div class="vp-field-value">@_profile.DateOfBirth.Value.ToString("yyyy-MM-dd")</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="vp-divider"></div>

            <!-- EMPLOYMENT INFORMATION -->
            <div class="vp-section">
                <div class="vp-section-header">
                    <span class="vp-section-title">EMPLOYMENT INFORMATION</span>
                    <button class="vp-icon-btn" @onclick='() => ToggleSection("employment")'><i class="bi bi-pencil"></i></button>
                </div>

                @if (_editingSection == "employment")
                {
                    <div class="vp-edit-form">
                        <div class="vp-field">
                            <label>Role</label>
                            <select class="vp-input" @bind="_editRole">
                                <option value="Employee">Employee</option>
                                <option value="Team Lead">Team Lead</option>
                                <option value="HR">HR</option>
                                <option value="Manager">Manager</option>
                                <option value="Admin">Admin</option>
                                <option value="User">User</option>
                            </select>
                        </div>
                        <div class="vp-field">
                            <label>Group</label>
                            <select class="vp-input" @bind="_editGroupId">
                                <option value="">No Group</option>
                                @foreach (var g in _groups)
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            </select>
                        </div>
                        @if (!string.IsNullOrEmpty(_saveError))
                        {
                            <div class="vp-save-error">@_saveError</div>
                        }
                        <div class="vp-edit-actions">
                            <button class="vp-btn-cancel" @onclick="CancelEdit">Cancel</button>
                            <button class="vp-btn-save" @onclick="SaveEmployment" disabled="@_saving">
                                @if (_saving) { <span class="vp-spinner"></span> }
                                Save
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="vp-fields-view">
                        <div class="vp-two-col">
                            <div class="vp-field-pair">
                                <div class="vp-field-label">Role</div>
                                <div class="vp-field-value">@_profile.Role</div>
                            </div>
                            <div class="vp-field-pair">
                                <div class="vp-field-label">Group</div>
                                <div class="vp-field-value">@(_profile.GroupName ?? "—")</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Archive / Remove member -->
                <div style="margin-top: 24px; display: flex; gap: 20px; align-items: center;">
                    <button class="vp-archive-btn" @onclick="ArchiveMember">Archive member</button>
                    <span style="color:#e5e7eb;">|</span>
                    <button class="vp-remove-btn" @onclick="RemoveMember">Remove member</button>
                </div>
            </div>

        </div>
    </div>
}

@if (_showArchiveConfirm)
{
    <div class="vp-confirm-backdrop">
        <div class="vp-confirm-dialog">
            <h3>Archive member?</h3>
            <p><strong>@(_profile?.FullName)</strong> will be moved to Archived Members and will no longer have access. Their data is preserved and they can be restored later.</p>
            <div class="vp-confirm-actions">
                <button class="vp-btn-cancel" @onclick="() => _showArchiveConfirm = false">Cancel</button>
                <button class="vp-btn-save" @onclick="ConfirmArchive">Archive</button>
            </div>
        </div>
    </div>
}

@if (_showRemoveConfirm)
{
    <div class="vp-confirm-backdrop">
        <div class="vp-confirm-dialog">
            <h3>Remove member permanently?</h3>
            <p>This will permanently delete <strong>@(_profile?.FullName)</strong> and all their data — time entries, invites, and settings. <strong>This cannot be undone.</strong></p>
            <div class="vp-confirm-actions">
                <button class="vp-btn-cancel" @onclick="() => _showRemoveConfirm = false">Cancel</button>
                <button class="vp-btn-danger" @onclick="ConfirmRemove">Remove permanently</button>
            </div>
        </div>
    </div>
}

<style>
    /* ── Backdrop ──────────────────────────────────────────────────── */
    .vp-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 900;
    }

    /* ── Panel ─────────────────────────────────────────────────────── */
    .vp-panel {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: 520px; max-width: 100vw;
        background: #fff;
        box-shadow: -4px 0 32px rgba(0,0,0,.15);
        z-index: 901;
        display: flex; flex-direction: column;
        transform: translateX(100%);
        transition: transform .3s cubic-bezier(.4,0,.2,1);
    }
    .vp-panel--open { transform: translateX(0); }

    /* ── Header ────────────────────────────────────────────────────── */
    .vp-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid #f0f0f0;
        flex-shrink: 0;
    }
    .vp-title { font-size: 18px; font-weight: 700; color: #111; margin: 0; }
    .vp-close {
        background: none; border: none; cursor: pointer;
        font-size: 18px; color: #6b7280; padding: 4px;
        border-radius: 6px; line-height: 1;
    }
    .vp-close:hover { background: #f3f4f6; color: #111; }

    /* ── Scrollable body ───────────────────────────────────────────── */
    .vp-body { flex: 1; overflow-y: auto; padding: 0 24px 32px; }

    /* ── Identity ──────────────────────────────────────────────────── */
    .vp-identity {
        display: flex; align-items: center; gap: 16px;
        padding: 24px 0 20px;
    }
    .vp-avatar {
        width: 64px; height: 64px; border-radius: 50%;
        background: #e5e7eb; color: #6b7280;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; font-weight: 700; flex-shrink: 0; overflow: hidden;
    }
    .vp-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .vp-identity-info { flex: 1; min-width: 0; }
    .vp-name { font-size: 20px; font-weight: 700; color: #111; }
    .vp-role-row { display: flex; align-items: center; gap: 8px; margin-top: 4px; }
    .vp-role-label { font-size: 14px; color: #6b7280; }
    .vp-badge {
        font-size: 11px; font-weight: 600; padding: 2px 9px;
        border-radius: 20px;
    }
    .vp-badge--pending { background: #fff3cd; color: #92400e; }
    .vp-badge--active  { background: #d1fae5; color: #065f46; }
    .vp-identity-actions { display: flex; gap: 6px; }

    /* ── Icon button ───────────────────────────────────────────────── */
    .vp-icon-btn {
        background: none; border: 1px solid #e5e7eb;
        border-radius: 8px; padding: 7px 9px;
        cursor: pointer; font-size: 14px; color: #6b7280;
        line-height: 1; transition: all .15s;
    }
    .vp-icon-btn:hover { background: #f3f4f6; color: #111; border-color: #d1d5db; }

    /* ── Complete prompt ───────────────────────────────────────────── */
    .vp-complete-prompt {
        background: #f9fafb; border-radius: 10px;
        padding: 14px 16px; display: flex;
        align-items: flex-start; gap: 16px; margin-bottom: 8px;
    }
    .vp-complete-left { flex: 1; }
    .vp-complete-title { font-size: 14px; font-weight: 600; color: #111; margin-bottom: 4px; }
    .vp-complete-sub { font-size: 13px; color: #6b7280; line-height: 1.5; }
    .vp-mark-complete {
        background: none; border: none; cursor: pointer;
        font-size: 13px; color: #9ca3af; white-space: nowrap;
