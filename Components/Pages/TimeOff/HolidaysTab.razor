@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<!-- ═══ TOAST NOTIFICATION ═══ -->
@if (toastVisible)
{
    <div class="ht-toast @(toastFading ? "ht-toast--fade" : "")">
        <i class="bi bi-check-circle-fill ht-toast-icon"></i>
        <span>@toastMessage</span>
    </div>
}

<!-- ═══ THREE-DOT TOOLTIP ═══ -->
@if (showDotsMenu)
{
    <div style="position:fixed;inset:0;z-index:8000;" @onclick="CloseDotsMenu"></div>
    <div class="ht-dots-menu" style="top:@(dotsMenuTop)px;left:@(dotsMenuLeft)px;">
        <div class="ht-dots-menu-item" @onclick="OpenRefreshModal" @onclick:stopPropagation="true">
            <i class="bi bi-arrow-clockwise"></i>
            <span>Refresh calendar</span>
        </div>
    </div>
}

<!-- ═══ REFRESH MODAL ═══ -->
@if (showRefreshModal)
{
    <div class="ht-modal-back" @onclick="CloseRefreshModal">
        <div class="ht-modal ht-refresh-modal" @onclick:stopPropagation="true">
            <div class="ht-modal-head">
                <span>Refresh @selectedCalendar?.Name calendar</span>
                <button class="ht-modal-close" @onclick="CloseRefreshModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ht-modal-body">
                <p class="ht-refresh-desc">Update imported calendars to include the latest holiday data.</p>
                <div class="ht-refresh-options-label">
                    Refresh options
                    <i class="bi bi-info-circle ht-info-icon" title="Choose which dates to refresh."></i>
                </div>
                <div class="ht-refresh-options">
                    <label class="ht-refresh-opt @(refreshOption == "all" ? "ht-refresh-opt--active" : "")" @onclick='() => refreshOption = "all"'>
                        <div class="ht-refresh-radio @(refreshOption == "all" ? "ht-refresh-radio--checked" : "")">
                            @if (refreshOption == "all") { <i class="bi bi-check-lg"></i> }
                        </div>
                        <span>All dates</span>
                    </label>
                    <label class="ht-refresh-opt @(refreshOption == "future" ? "ht-refresh-opt--active" : "")" @onclick='() => refreshOption = "future"'>
                        <div class="ht-refresh-radio @(refreshOption == "future" ? "ht-refresh-radio--checked" : "")">
                            @if (refreshOption == "future") { <i class="bi bi-check-lg"></i> }
                        </div>
                        <span>Future dates</span>
                    </label>
                    <label class="ht-refresh-opt @(refreshOption == "specific" ? "ht-refresh-opt--active" : "")" @onclick='() => refreshOption = "specific"'>
                        <div class="ht-refresh-radio @(refreshOption == "specific" ? "ht-refresh-radio--checked" : "")">
                            @if (refreshOption == "specific") { <i class="bi bi-check-lg"></i> }
                        </div>
                        <span>From a specific date</span>
                    </label>
                </div>

                @if (refreshOption == "specific")
                {
                    <div class="ht-specific-date-wrap">
                        <label class="ht-specific-date-label">Selected date</label>
                        <div class="ht-specific-date-input-wrap">
                            <input type="date" class="ht-specific-date-input"
                                   @bind="specificRefreshDate" />
                            <i class="bi bi-calendar3 ht-specific-date-icon"></i>
                        </div>
                    </div>
                }
            </div>
            <div class="ht-modal-foot">
                <button class="ht-btn-cancel" @onclick="CloseRefreshModal">Cancel</button>
                <button class="ht-btn-save" @onclick="DoRefreshCalendar" disabled="@isRefreshing">
                    @if (isRefreshing)
                    {
                        <span class="ht-mini-spin"></span><span>Refreshing...</span>
                    }
                    else
                    {
                        <span>Refresh</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<div class="ht-layout">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <div class="ht-sidebar">
        <div class="ht-sidebar-search">
            <i class="bi bi-search ht-search-icon"></i>
            <input type="text" class="ht-search-input" placeholder="Search..."
                   @bind="calSearch" @bind:event="oninput" />
        </div>

        <div class="ht-add-btn" @onclick="OpenAddCalendar">
            <i class="bi bi-plus-lg"></i>
            <span>Add new calendar</span>
        </div>

        @if (!calendars.Any())
        {
            <div class="ht-no-calendars">No calendars added yet</div>
        }
        else
        {
            @foreach (var cal in FilteredCalendars)
            {
                var c = cal;
                <div class='ht-cal-item @(selectedCalendar?.Id == c.Id ? "ht-cal-item--active" : "")'
                     @onclick="() => SelectCalendar(c)">
                    <div class="ht-cal-item-top">
                        <span class="ht-cal-name">@c.Name</span>
                        <i class="bi bi-download ht-cal-dl"></i>
                    </div>
                    @if (c.IsDefault)
                    {
                        <span class="ht-cal-default">DEFAULT</span>
                    }
                </div>
            }
        }
    </div>

    <!-- ═══ MAIN CONTENT ═══ -->
    <div class="ht-main">

        @if (showAddForm)
        {
            <div class="ht-form-card">
                <div class="ht-form-name-preview">@newCalName</div>

                <!-- Calendar name -->
                <div class="ht-form-row">
                    <label class="ht-form-label">Calendar name</label>
                    <input type="text"
                           class='ht-form-input @(calNameErr ? "ht-form-input--err" : "")'
                           placeholder="Calendar name"
                           @bind="newCalName" @bind:event="oninput"
                           @onfocus="() => calNameErr = false" />
                    @if (calNameErr)
                    {
                        <span class="ht-err-msg">Calendar name is required.</span>
                    }
                </div>

                <!-- Make default -->
                <div class="ht-default-row">
                    <input type="checkbox" id="ht-make-default" class="ht-checkbox"
                           @bind="newCalMakeDefault" />
                    <label for="ht-make-default" class="ht-checkbox-label">
                        Make default
                        <span class="ht-tooltip-wrap">
                            <i class="bi bi-info-circle ht-info-icon"></i>
                            <span class="ht-tooltip-box">
                                By making this the default calendar, members or groups that aren't directly assigned will be put to the default calendar.<br/><br/>
                                To switch the default calendar to another, make the other calendar the default instead.
                            </span>
                        </span>
                    </label>
                </div>

                @if (!editMode)
                {
                    <div class="ht-form-row">
                        <label class="ht-form-label">Holidays</label>

                        <!-- Import from a calendar -->
                        <div class='ht-radio-option @(!addManually ? "ht-radio-option--selected" : "")'
                             @onclick="() => { addManually = false; StateHasChanged(); }">
                            <div class='@(!addManually ? "ht-radio-check" : "ht-radio-circle")'>
                                @if (!addManually) { <i class="bi bi-check-lg"></i> }
                            </div>
                            <span>Import from a calendar</span>
                        </div>

                        @if (!addManually)
                        {
                            <div class="ht-country-wrap" @ref="triggerRef">
                                <div class='ht-country-trigger @(countryDropOpen ? "ht-country-trigger--open" : "")'
                                     @onclick="ToggleCountryDropAsync">
                                    <span class='@(selectedCountry == null ? "ht-placeholder" : "")'>
                                        @(selectedCountry ?? "Select country or region")
                                    </span>
                                    <i class='bi bi-chevron-@(countryDropOpen ? "up" : "down")'></i>
                                </div>
                            </div>
                        }

                        <!-- Add manually -->
                        <div class='ht-radio-option @(addManually ? "ht-radio-option--selected" : "")'
                             style="margin-top:12px;"
                             @onclick="() => { addManually = true; selectedCountry = null; countryDropOpen = false; StateHasChanged(); }">
                            <div class='@(addManually ? "ht-radio-check" : "ht-radio-circle")'>
                                @if (addManually) { <i class="bi bi-check-lg"></i> }
                            </div>
                            <span>Add manually</span>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(selectedCountry))
                {
                    <div class="ht-edit-country">Country: @selectedCountry</div>
                }

                <!-- Members -->
                <div class="ht-members-section">
                    <div class="ht-members-title">
                        MEMBERS
                        <span class="ht-tooltip-wrap">
                            <i class="bi bi-info-circle ht-info-icon"></i>
                            <span class="ht-tooltip-box ht-tooltip-box--sm">
                                Members or groups assigned to this calendar will follow its holiday rules.
                            </span>
                        </span>
                    </div>
                    <div class="ht-people-link" style="margin-bottom:0;">
                        <a href="#" class="ht-link">Go to People Settings</a>
                        <span> to view or edit Members and Groups assignment for this calendar</span>
                    </div>
                </div>

                <div class="ht-form-actions">
                    <button class="ht-btn-cancel" @onclick="CancelAdd">Cancel</button>
                    <button class="ht-btn-save" @onclick="SaveCalendar" disabled="@importLoading">
                        @if (importLoading)
                        {
                            <span class="ht-mini-spin"></span><span>Importing from Google Calendar...</span>
                        }
                        else
                        {
                            <span>Save</span>
                        }
                    </button>
                </div>

                @if (importError != null)
                {
                    <div class="ht-import-err">
                        <i class="bi bi-exclamation-triangle"></i> @importError
                    </div>
                }
            </div>
        }
                else if (selectedCalendar != null)
        {
            <div class="ht-cal-detail">

                <div class="ht-cal-header-card">
                    <div class="ht-cal-header-left">
                        <span class="ht-cal-title">@selectedCalendar.Name</span>
                        <div class="ht-tooltip-wrap" style="position:relative;display:inline-flex;">
                        <button class="ht-icon-btn"><i class="bi bi-download"></i></button>
                        <div class="ht-tooltip-box" style="bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);white-space:nowrap;">
                            Imported from Google Calendar
                        </div>
                    </div>
                    </div>
                    <div class="ht-cal-header-right">
                        <button class="ht-icon-btn" title="More" @ref="dotsButtonRef"
                                @onclick="ToggleDotsMenu"><i class="bi bi-three-dots"></i></button>
                        <button class="ht-icon-btn" title="Edit"
                                @onclick="() => OpenEditCalendar(selectedCalendar)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="ht-icon-btn" title="Collapse">
                            <i class="bi bi-chevron-down"></i>
                        </button>
                    </div>
                </div>

                <div class="ht-holidays-panel">
                    <div class="ht-year-bar">
                        <div class="ht-year-tabs">
                            @foreach (var y in new[] { selectedYear - 1, selectedYear, selectedYear + 1 })
                            {
                                var yr = y;
                                <button class='ht-year-tab @(yr == selectedYear ? "ht-year-tab--active" : "")'
                                        @onclick="() => selectedYear = yr">@yr</button>
                            }
                        </div>
                    </div>

                    <div class="ht-table-head">
                        <div class="ht-th ht-th--name">Holiday name</div>
                        <div class="ht-th ht-th--date">Date <i class="bi bi-arrow-up" style="font-size:10px;margin-left:3px;"></i></div>
                        <div class="ht-th ht-th--day">Day</div>
                        <div class="ht-th ht-th--actions">
                            <button class="ht-add-holiday-btn" @onclick="OpenAddHoliday">Add Holiday</button>
                        </div>
                    </div>

                    @{
                        var yearRows = selectedCalendar.Holidays
                            .Where(h => h.Date.Year == selectedYear)
                            .OrderBy(h => h.Date)
                            .ToList();
                    }

                    @if (!yearRows.Any())
                    {
                        <div class="ht-no-holidays">
                            <div class="ht-no-holidays-icon">
                                <i class="bi bi-calendar3-event"></i>
                            </div>
                            <div class="ht-no-holidays-title">No holidays</div>
                            <div class="ht-no-holidays-sub">Remember to take some time off!</div>
                            <button class="ht-add-holiday-btn ht-add-holiday-btn--center" @onclick="OpenAddHoliday">
                                Add Holiday
                            </button>
                        </div>
                    }
                    else
                    {
                        @foreach (var h in yearRows)
                        {
                            var holiday = h;
                            <div class="ht-holiday-row">
                                <div class="ht-td ht-td--name">@holiday.Name</div>
                                <div class="ht-td ht-td--date ht-td--muted">@holiday.DateDisplay</div>
                                <div class="ht-td ht-td--day ht-td--muted">@holiday.DayOfWeek</div>
                                <div class="ht-td ht-td--actions">
                                    <button class="ht-icon-btn ht-icon-btn--sm" title="Edit"
                                            @onclick="() => OpenEditHoliday(holiday)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="ht-icon-btn ht-icon-btn--sm ht-icon-btn--del"
                                            title="Delete"
                                            @onclick="() => AskDeleteHoliday(holiday)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>

            </div>
        }
        else
        {
            <div class="ht-empty-state">
                <div class="ht-empty-icon"><i class="bi bi-calendar3"></i></div>
                <div class="ht-empty-title">No calendar selected</div>
                <div class="ht-empty-sub">Add a new calendar or select one from the list</div>
                <button class="ht-btn-save" style="margin-top:8px;" @onclick="OpenAddCalendar">
                    <i class="bi bi-plus-lg"></i> Add new calendar
                </button>
            </div>
        }

    </div>
</div>

<!-- ── Fixed-position country dropdown (escapes all overflow clipping) ── -->
@if (countryDropOpen)
{
    <!-- Backdrop -->
    <div style="position:fixed;inset:0;z-index:9990;" @onclick="CloseCountryDrop"></div>

    <!-- Dropdown panel, positioned via JS -->
    <div class="ht-fixed-dropdown" style="top:@(dropTop)px;left:@(dropLeft)px;width:@(dropWidth)px;">
        <div class="ht-country-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text"
                   class="ht-country-search"
                   placeholder="Search country..."
                   value="@countrySearch"
                   @oninput="OnCountrySearchInput"
                   @onclick:stopPropagation="true"
                   @ref="searchInputRef" />
        </div>
        <div class="ht-country-list">
            @{
                var shown = string.IsNullOrWhiteSpace(countrySearch)
                    ? AllCountries
                    : AllCountries.Where(x => x.Contains(countrySearch, StringComparison.OrdinalIgnoreCase)).ToList();
            }
            @if (!shown.Any())
            {
                <div class="ht-country-empty">No countries found</div>
            }
            @foreach (var country in shown)
            {
                var cn = country;
                <div class='ht-country-item @(selectedCountry == cn ? "ht-country-item--sel" : "")'
                     @onclick="() => PickCountry(cn)"
                     @onclick:stopPropagation="true">
                    @cn
                </div>
            }
        </div>
    </div>
}

<!-- ═══ ADD HOLIDAY PANEL (Jibble-style right slide-in) ═══ -->
@if (showAddHolidayModal)
{
    <!-- Backdrop -->
    <div class="ah-backdrop" @onclick="CloseAddHolidayPanel"></div>

    <!-- Right panel -->
    <div class="ah-panel" @onclick:stopPropagation="true">

        <!-- Header -->
        <div class="ah-header">
            <span class="ah-title">Add Holiday</span>
            <button class="ah-close" @onclick="CloseAddHolidayPanel"><i class="bi bi-x-lg"></i></button>
        </div>

        <!-- Body -->
        <div class="ah-body">

            <!-- Holiday Name -->
            <div class="ah-section-label">Holiday Name</div>
            <div class="ah-input-wrap @(ahNameErr ? "ah-input-wrap--err" : "")">
                <input class="ah-text-input"
                       placeholder="Holiday Name"
                       @bind="newHolidayName" @bind:event="oninput"
                       @onfocus="() => ahNameErr = false" />
            </div>
            @if (ahNameErr)
            {
                <div class="ah-err-msg">Holiday name is required.</div>
            }

            <!-- Dates -->
            <div class="ah-section-label" style="margin-top:28px;">Dates</div>
            <div class="ah-dates-row">
                <!-- Start date -->
                <div class="ah-date-field @(ahStartDateOpen ? "ah-date-field--active" : "")"
                     @onclick="() => { ahStartDateOpen = !ahStartDateOpen; ahEndDateOpen = false; }">
                    <span class="ah-date-val @(newHolidayStartDate == null ? "ah-date-placeholder" : "")">
                        @(newHolidayStartDate.HasValue ? newHolidayStartDate.Value.ToString("d MMM yyyy") : "Start date")
                    </span>
                    <i class="bi bi-calendar3 ah-date-icon"
                       @onclick="() => { ahCalViewStart = DateTime.Today; ahStartDateOpen = true; ahEndDateOpen = false; StateHasChanged(); }"
                       @onclick:stopPropagation="true"></i>
                </div>
                <!-- End date -->
                <div class="ah-date-field @(ahEndDateOpen ? "ah-date-field--active" : "")"
                     @onclick="() => { ahEndDateOpen = !ahEndDateOpen; ahStartDateOpen = false; }">
                    <span class="ah-date-val @(newHolidayEndDate == null ? "ah-date-placeholder" : "")">
                        @(newHolidayEndDate.HasValue ? newHolidayEndDate.Value.ToString("d MMM yyyy") : "End date (optional)")
                    </span>
                    <i class="bi bi-calendar3 ah-date-icon"
                       @onclick="() => { ahCalViewEnd = DateTime.Today; ahEndDateOpen = true; ahStartDateOpen = false; StateHasChanged(); }"
                       @onclick:stopPropagation="true"></i>
                </div>
            </div>

            <!-- Inline calendars -->
            @if (ahStartDateOpen)
            {
                <div class="ah-cal-wrap" @onclick:stopPropagation="true">
                    @{ var (sv, ss) = AhCalState(true); }
                    <div class="ah-cal-nav">
                        <button class="ah-cal-nav-btn" @onclick="() => AhCalPrev(true)"><i class="bi bi-chevron-left"></i></button>
                        <span class="ah-cal-month">@sv.ToString("MMM yyyy")</span>
                        <button class="ah-cal-nav-btn" @onclick="() => AhCalNext(true)"><i class="bi bi-chevron-right"></i></button>
                    </div>
                    <div class="ah-cal-grid">
                        @foreach (var d in new[]{"Mo","Tu","We","Th","Fr","Sa","Su"})
                        { <div class="ah-cal-dow">@d</div> }
                        @{ int so = ((int)new DateTime(sv.Year,sv.Month,1).DayOfWeek+6)%7; }
                        @for (int b = 0; b < so; b++) { <div class="ah-cal-cell ah-cal-cell--empty"></div> }
                        @for (int d = 1; d <= DateTime.DaysInMonth(sv.Year,sv.Month); d++)
                        {
                            var cd = new DateTime(sv.Year,sv.Month,d);
                            var cls2 = "ah-cal-cell"
                                + (ss.HasValue && ss.Value.Date==cd ? " ah-cal-cell--sel" : "")
                                + (cd.Date==DateTime.Today && !(ss.HasValue && ss.Value.Date==cd) ? " ah-cal-cell--today" : "");
                            var cap2 = cd;
                            <div class="@cls2" @onclick="() => AhCalPick(true, cap2)">@d</div>
                        }
                    </div>
                    <div class="ah-cal-footer">
                        <button class="ah-cal-today-btn" @onclick="() => { ahCalViewStart = DateTime.Today; StateHasChanged(); }">Today</button>
                    </div>
                </div>
            }
            @if (ahEndDateOpen)
            {
                <div class="ah-cal-wrap" @onclick:stopPropagation="true">
                    @{ var (ev, es) = AhCalState(false); }
                    <div class="ah-cal-nav">
                        <button class="ah-cal-nav-btn" @onclick="() => AhCalPrev(false)"><i class="bi bi-chevron-left"></i></button>
                        <span class="ah-cal-month">@ev.ToString("MMM yyyy")</span>
                        <button class="ah-cal-nav-btn" @onclick="() => AhCalNext(false)"><i class="bi bi-chevron-right"></i></button>
                    </div>
                    <div class="ah-cal-grid">
                        @foreach (var d in new[]{"Mo","Tu","We","Th","Fr","Sa","Su"})
                        { <div class="ah-cal-dow">@d</div> }
                        @{ int eo = ((int)new DateTime(ev.Year,ev.Month,1).DayOfWeek+6)%7; }
                        @for (int b = 0; b < eo; b++) { <div class="ah-cal-cell ah-cal-cell--empty"></div> }
                        @for (int d = 1; d <= DateTime.DaysInMonth(ev.Year,ev.Month); d++)
                        {
                            var cd = new DateTime(ev.Year,ev.Month,d);
                            var cls2 = "ah-cal-cell"
                                + (es.HasValue && es.Value.Date==cd ? " ah-cal-cell--sel" : "")
                                + (cd.Date==DateTime.Today && !(es.HasValue && es.Value.Date==cd) ? " ah-cal-cell--today" : "");
                            var cap2 = cd;
                            <div class="@cls2" @onclick="() => AhCalPick(false, cap2)">@d</div>
                        }
                    </div>
                    <div class="ah-cal-footer">
                        <button class="ah-cal-today-btn" @onclick="() => { ahCalViewEnd = DateTime.Today; StateHasChanged(); }">Today</button>
                    </div>
                </div>
            }

            <!-- Shortened day rules -->
            @foreach (var (rule, idx) in ahShortenedRules.Select((r, i) => (r, i)))
            {
                var ci = idx;
                <div class="ah-section-label" style="margin-top:24px;">Shortened day rule</div>

                @* Row: [Property dropdown] [Condition dropdown] [h m time] [clock] [trash] *@
                <div class="ah-rule-row" @ref="ahShortenedRules[ci].RowRef">

                    @* Property dropdown *@
                    <div class="ah-dd @(rule.PropOpen ? "ah-dd--open" : "")"
                         @onclick="() => TogglePropDrop(ci)" @onclick:stopPropagation="true">
                        <span class="@(string.IsNullOrEmpty(rule.Property) ? "ah-dd-ph" : "ah-dd-val")">
                            @(string.IsNullOrEmpty(rule.Property) ? "Select a property" : rule.Property)
                        </span>
                        <i class="bi bi-chevron-down ah-dd-chev"></i>
                        @if (rule.PropOpen)
                        {
                            <div class="ah-dd-menu @(rule.DropUp ? "ah-dd-menu--up" : "")" @onclick:stopPropagation="true">
                                @foreach (var opt in AhPropertyOptions)
                                {
                                    var o = opt;
                                    <div class="ah-dd-item @(rule.Property == o ? "ah-dd-item--sel" : "")"
                                         @onclick="() => PickProperty(ci, o)">@o</div>
                                }
                            </div>
                        }
                    </div>

                    @* Condition dropdown — options depend on property *@
                    @if (!string.IsNullOrEmpty(rule.Property))
                    {
                        <div class="ah-dd ah-dd--cond @(rule.CondOpen ? "ah-dd--open" : "")"
                             @onclick="() => ToggleCondDrop(ci)" @onclick:stopPropagation="true">
                            <span class="@(string.IsNullOrEmpty(rule.Condition) ? "ah-dd-ph" : "ah-dd-val")">
                                @(string.IsNullOrEmpty(rule.Condition) ? "Select" : rule.Condition)
                            </span>
                            <i class="bi bi-chevron-@(rule.CondOpen ? "up" : "down") ah-dd-chev"></i>
                            @if (rule.CondOpen)
                            {
                                <div class="ah-dd-menu @(rule.DropUp ? "ah-dd-menu--up" : "")" @onclick:stopPropagation="true">
                                    @foreach (var co in GetConditionOptions(rule.Property))
                                    {
                                        var cv = co;
                                        <div class="ah-dd-item @(rule.Condition == cv ? "ah-dd-item--sel" : "")"
                                             @onclick="() => PickCondition(ci, cv)">@cv</div>
                                    }
                                </div>
                            }
                        </div>

                        @* Time input: clock (HH:mm am/pm) or duration (h m) based on condition *@
                        @if (UseClockTime(rule.Condition))
                        {
                            @* Clock time picker: shows e.g. 12:00 pm *@
                            <div class="ah-rule-time">
                                <input class="ah-time-seg ah-time-seg--clock" type="text" inputmode="numeric" maxlength="2"
                                       placeholder="12"
                                       value="@(rule.TimeH == 0 ? 12 : (rule.TimeH > 12 ? rule.TimeH - 12 : rule.TimeH))"
                                       @onchange='@(e => { var raw = int.TryParse(e.Value?.ToString(), out var v) ? Math.Clamp(v,1,12) : 12; ahShortenedRules[ci].TimeH = (ahShortenedRules[ci].TimeH >= 12) ? raw + 12 : raw; if(ahShortenedRules[ci].TimeH==24) ahShortenedRules[ci].TimeH=12; StateHasChanged(); })' />
                                <span class="ah-time-sep">:</span>
                                <input class="ah-time-seg ah-time-seg--clock" type="text" inputmode="numeric" maxlength="2"
                                       placeholder="00"
                                       value="@rule.TimeM.ToString("D2")"
                                       @onchange='@(e => { ahShortenedRules[ci].TimeM = int.TryParse(e.Value?.ToString(), out var v) ? Math.Clamp(v,0,59) : 0; StateHasChanged(); })' />
                                <button class="ah-time-ampm" @onclick='() => { ahShortenedRules[ci].TimeH = ahShortenedRules[ci].TimeH >= 12 ? ahShortenedRules[ci].TimeH - 12 : ahShortenedRules[ci].TimeH + 12; StateHasChanged(); }'>
