    private static readonly List<string> AllCountries = new(GoogleCalendarIds.Keys.OrderBy(k => k).ToList());

    // ── Fetch and parse iCal from Google Calendar ────────────────────────────
    private async Task<List<HolidayEntry>> FetchGoogleCalendarHolidays(string country)
    {
        if (!GoogleCalendarIds.TryGetValue(country, out var calId))
            return new();

        try
        {
            var url  = $"https://calendar.google.com/calendar/ical/{calId}/public/basic.ics";
            using var http = HttpClientFactory.CreateClient("GoogleCalendar");
            var ics  = await http.GetStringAsync(url);
            return ParseIcal(ics);
        }
        catch (Exception ex)
        {
            importError = $"Could not import from Google Calendar: {ex.Message}";
            return new();
        }
    }

    // ── iCal parser: extracts VEVENT blocks ──────────────────────────────────
    private static List<HolidayEntry> ParseIcal(string ics)
    {
        var result  = new List<HolidayEntry>();
        var lines   = ics.Replace("\r\n", "\n").Replace("\r", "\n").Split('\n');

        // Unfold continued lines (lines starting with space/tab are continuations)
        var unfolded = new List<string>();
        foreach (var line in lines)
        {
            if ((line.StartsWith(" ") || line.StartsWith("\t")) && unfolded.Count > 0)
                unfolded[^1] += line.TrimStart();
            else
                unfolded.Add(line);
        }

        string? summary = null;
        DateTime? dtStart = null;
        bool inEvent = false;

        foreach (var line in unfolded)
        {
            var trimmed = line.Trim();

            if (trimmed == "BEGIN:VEVENT")  { inEvent = true; summary = null; dtStart = null; continue; }
            if (trimmed == "END:VEVENT")
            {
                if (inEvent && summary != null && dtStart.HasValue)
                {
                    result.Add(new HolidayEntry
                    {
                        Name        = summary,
                        Date        = dtStart.Value,
                        DateDisplay = dtStart.Value.ToString("MMM, dd yyyy"),
                        DayOfWeek   = dtStart.Value.ToString("dddd")
                    });
                }
                inEvent = false; continue;
            }

            if (!inEvent) continue;

            if (trimmed.StartsWith("SUMMARY:"))
                summary = trimmed["SUMMARY:".Length..].Trim();
            else if (trimmed.StartsWith("DTSTART"))
            {
                // Handles: DTSTART;VALUE=DATE:20260126  OR  DTSTART:20260126
                var val = trimmed.Contains(':') ? trimmed[(trimmed.LastIndexOf(':') + 1)..].Trim() : "";
                if (val.Length >= 8 &&
                    int.TryParse(val[..4],  out var yr) &&
                    int.TryParse(val[4..6], out var mo) &&
                    int.TryParse(val[6..8], out var dy))
                {
                    try { dtStart = new DateTime(yr, mo, dy); } catch { }
                }
            }
        }

        return result.OrderBy(h => h.Date).ToList();
    }


