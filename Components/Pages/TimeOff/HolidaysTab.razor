    private async Task SaveCalendar()
    {
        calNameErr = string.IsNullOrWhiteSpace(newCalName);
        if (calNameErr) return;

        if (!addManually && selectedCountry == null && !editMode)
        {
            importError = "Please select a country to import holidays from.";
            return;
        }

        importLoading = true;
        importError   = null;
        StateHasChanged();

        if (editMode)
        {
            var existing = calendars.FirstOrDefault(c => c.Id == editCalId);
            if (existing != null)
            {
                existing.Name = newCalName.Trim();
                if (newCalMakeDefault)
                {
                    foreach (var c in calendars) c.IsDefault = false;
                    existing.IsDefault = true;
                }
                selectedCalendar = existing;
            }
        }
        else
        {
            if (newCalMakeDefault)
                foreach (var c in calendars) c.IsDefault = false;

            var holidays = addManually
                ? new List<HolidayEntry>()
                : await FetchGoogleCalendarHolidays(selectedCountry!);

            var cal = new HolidayCalendar
            {
                Id        = nextId++,
                Name      = newCalName.Trim(),
                Country   = addManually ? "" : selectedCountry!,
                IsDefault = newCalMakeDefault || !calendars.Any(),
                Holidays  = holidays
            };
            calendars.Add(cal);
            selectedCalendar = cal;
        }

        importLoading   = false;
        showAddForm     = false;
        countryDropOpen = false;
        countrySearch   = "";
        SyncPublicState();
        StateHasChanged();

        await ShowToast("Calendar saved");
    }

    private void DeleteHoliday(HolidayCalendar cal, HolidayEntry entry)
    {
        cal.Holidays.Remove(entry);
        StateHasChanged();
    }

    // ── Edit Holiday ──────────────────────────────────────────────────────────
    private void OpenEditHoliday(HolidayEntry entry)
    {
        editingHoliday      = entry;
        editHolidayName     = entry.Name;
        editHolidayDate     = entry.Date;
        ehCalView           = entry.Date;
        ehNameErr           = false;
        ehCalOpen           = false;
        showEditHolidayModal = true;
    }

    private void CloseEditHolidayPanel()
    {
        showEditHolidayModal = false;
        ehCalOpen            = false;
    }

    private async Task ConfirmEditHoliday()
    {
        ehNameErr = string.IsNullOrWhiteSpace(editHolidayName);
        if (ehNameErr) return;
        if (editingHoliday == null) return;

        editingHoliday.Name        = editHolidayName.Trim();
        editingHoliday.Date        = editHolidayDate ?? editingHoliday.Date;
        editingHoliday.DateDisplay = editingHoliday.Date.ToString("MMM, dd yyyy");
        editingHoliday.DayOfWeek   = editingHoliday.Date.ToString("dddd");

        showEditHolidayModal = false;
        StateHasChanged();
        await ShowToast("Holiday updated");
    }

    // ── Delete Holiday confirm ────────────────────────────────────────────────
    private void AskDeleteHoliday(HolidayEntry entry)
    {
        deleteTargetHoliday = entry;
        deleteConfirmText   = "";
        showDeleteConfirm   = true;
    }

    private void CancelDeleteHoliday()
    {
        showDeleteConfirm   = false;
        deleteTargetHoliday = null;
        deleteConfirmText   = "";
    }

    private async Task ConfirmDeleteHoliday()
    {
        if (deleteConfirmText != "DELETE" || deleteTargetHoliday == null || selectedCalendar == null) return;
        selectedCalendar.Holidays.Remove(deleteTargetHoliday);
        CancelDeleteHoliday();
        StateHasChanged();
        await ShowToast("Holiday deleted");
    }

    private void OpenAddHoliday()
    {
        newHolidayName      = "";
        ahNameErr           = false;
        newHolidayStartDate = null;
        newHolidayEndDate   = null;
        ahStartDateOpen     = false;
        ahEndDateOpen       = false;
        ahCalViewStart      = DateTime.Today;
        ahCalViewEnd        = DateTime.Today;
        ahShortenedRules    = new();
        ahError             = "";
        showAddHolidayModal = true;
    }

    private void CloseAddHolidayPanel()
    {
        showAddHolidayModal = false;
        ahStartDateOpen     = false;
        ahEndDateOpen       = false;
        foreach (var r in ahShortenedRules) { r.PropOpen = false; r.CondOpen = false; r.SchedulesOpen = false; }
    }

    private async Task ConfirmAddHoliday()
    {
        ahNameErr = string.IsNullOrWhiteSpace(newHolidayName);
        if (ahNameErr) { ahError = ""; return; }
        if (newHolidayStartDate == null) { ahError = "Please select a start date."; return; }
        if (selectedCalendar == null) return;

        var dt   = newHolidayStartDate.Value;
        var name = newHolidayName.Trim();
        selectedCalendar.Holidays.Add(new HolidayEntry
        {
            Name        = name,
            Date        = dt,
            DateDisplay = dt.ToString("MMM, dd yyyy"),
            DayOfWeek   = dt.ToString("dddd")
        });

        // Switch the year tab so the new holiday is immediately visible
        selectedYear = dt.Year;

        CloseAddHolidayPanel();
        SyncPublicState();
        StateHasChanged();
        await ShowToast($"\"{name}\" added successfully.");
    }

    // ── Sync to public static state (for Timesheets page) ───────────────────
    private static void SyncPublicState()
    {
        HolidaysTabState.SharedCalendars = _sharedCalendars.Select(c => new HolidayCalendarPublic
        {
            Id        = c.Id,
            Name      = c.Name,
            IsDefault = c.IsDefault,
            Holidays  = c.Holidays.Select(h => new HolidayEntryPublic { Name = h.Name, Date = h.Date }).ToList()
        }).ToList();
    }

    // ── Shortened day rule — data model ──────────────────────────────────────
    private class ShortenedRule
    {
        public string  Property         { get; set; } = "";
        public bool    PropOpen         { get; set; } = false;
        public string  Condition        { get; set; } = "";
        public bool    CondOpen         { get; set; } = false;
        public int     TimeH            { get; set; } = 0;
        public int     TimeM            { get; set; } = 0;
        public bool    ApplyAll         { get; set; } = true;
        public bool    SchedulesOpen    { get; set; } = false;
        public string? SelectedSchedule { get; set; } = null;
        public string  ScheduleSearch   { get; set; } = "";
        public bool    DropUp           { get; set; } = false;
        public ElementReference RowRef  { get; set; }
    }

    private static readonly List<string> AhPropertyOptions = new()
    {
        "Expected work hours",
        "Daily overtime",
        "Daily double overtime",
        "All (work and overtime hours)"
    };

    private static List<string> GetConditionOptions(string property) => property switch
    {
        "Expected work hours"           => new() { "are", "are until", "reduced by" },
        "Daily overtime"                => new() { "starts after", "starts at", "reduced by" },
        "Daily double overtime"         => new() { "starts after", "starts at", "reduced by" },
        "All (work and overtime hours)" => new() { "reduced by" },
        _                               => new() { "reduced by" }
    };

    private static bool UseClockTime(string condition) =>
        condition is "are until" or "starts at";

    private bool HasAllWorkHoursRule() =>
        ahShortenedRules.Any(r => r.Property == "All (work and overtime hours)");

    // ── Shortened day rule helpers ────────────────────────────────────────────
    private void AddShortenedRule()
    {
        ahShortenedRules.Add(new ShortenedRule());
        StateHasChanged();
    }
    private void RemoveRule(int idx)
    {
        if (idx >= 0 && idx < ahShortenedRules.Count)
            ahShortenedRules.RemoveAt(idx);
        StateHasChanged();
    }
    private async Task TogglePropDrop(int idx)
    {
        bool wasOpen = ahShortenedRules[idx].PropOpen;
        for (int i = 0; i < ahShortenedRules.Count; i++)
        {
            ahShortenedRules[i].PropOpen = false;
            ahShortenedRules[i].CondOpen = false;
        }
        ahStartDateOpen = false; ahEndDateOpen = false;
        if (!wasOpen)
        {
            ahShortenedRules[idx].DropUp = await IsNearBottom(ahShortenedRules[idx].RowRef);
            ahShortenedRules[idx].PropOpen = true;
        }
        StateHasChanged();
    }
    private async Task ToggleCondDrop(int idx)
    {
        bool wasOpen = ahShortenedRules[idx].CondOpen;
        for (int i = 0; i < ahShortenedRules.Count; i++)
        {
            ahShortenedRules[i].CondOpen = false;
            ahShortenedRules[i].PropOpen = false;
        }
        if (!wasOpen)
        {
            ahShortenedRules[idx].DropUp = await IsNearBottom(ahShortenedRules[idx].RowRef);
            ahShortenedRules[idx].CondOpen = true;
        }
        StateHasChanged();
    }
    private async Task<bool> IsNearBottom(ElementReference el)
    {
        try
        {
            var result = await JS.InvokeAsync<double>(
                "eval",
                $"(()=>{{ try {{ var r=document.activeElement?.closest('.ah-rule-row')?.getBoundingClientRect(); return r ? r.bottom : 0; }} catch{{return 0;}} }})()");
            var vh = await JS.InvokeAsync<double>("eval", "window.innerHeight");
            return vh > 0 && result > vh * 0.6;
        }
        catch { return false; }
    }

    private void PickProperty(int idx, string opt)
    {
        ahShortenedRules[idx].Property  = opt;
        ahShortenedRules[idx].PropOpen  = false;
        var opts = GetConditionOptions(opt);
        ahShortenedRules[idx].Condition = opts.Count > 0 ? opts[0] : "";
        ahShortenedRules[idx].TimeH = 0;
        ahShortenedRules[idx].TimeM = 0;
        StateHasChanged();
    }

    private void PickCondition(int idx, string cond)
    {
        ahShortenedRules[idx].Condition = cond;
        ahShortenedRules[idx].CondOpen  = false;
        ahShortenedRules[idx].TimeH = 0;
        ahShortenedRules[idx].TimeM = 0;
        StateHasChanged();
    }

    // ── FIX: extracted methods to avoid nested double-quotes in Razor attributes ──
    private void PickSchedule(int idx, string schedule)
    {
        ahShortenedRules[idx].SelectedSchedule = schedule;
        ahShortenedRules[idx].SchedulesOpen    = false;
        StateHasChanged();
    }

    private void ClearSchedule(int idx)
    {
        ahShortenedRules[idx].SelectedSchedule = null;
        ahShortenedRules[idx].SchedulesOpen    = false;
        StateHasChanged();
    }

    // ── Calendar helpers ──────────────────────────────────────────────────────
    private void AhCalPrev(bool isStart)
    {
        if (isStart) ahCalViewStart = ahCalViewStart.AddMonths(-1);
        else         ahCalViewEnd   = ahCalViewEnd.AddMonths(-1);
    }
    private void AhCalNext(bool isStart)
    {
        if (isStart) ahCalViewStart = ahCalViewStart.AddMonths(1);
        else         ahCalViewEnd   = ahCalViewEnd.AddMonths(1);
    }
    private void AhCalPick(bool isStart, DateTime date)
    {
        if (isStart) { newHolidayStartDate = date; ahStartDateOpen = false; }
        else         { newHolidayEndDate   = date; ahEndDateOpen   = false; }
        StateHasChanged();
    }
    private (DateTime view, DateTime? sel) AhCalState(bool isStart)
        => isStart ? (ahCalViewStart, newHolidayStartDate)
                   : (ahCalViewEnd,   newHolidayEndDate);

    // ── Toast ─────────────────────────────────────────────────────────────────
    private async Task ShowToast(string message)
    {
        toastCts?.Cancel();
        toastCts = new System.Threading.CancellationTokenSource();
        var token = toastCts.Token;

        toastMessage = message;
        toastFading  = false;
        toastVisible = true;
        StateHasChanged();

        try
        {
            await Task.Delay(2500, token);
            if (!token.IsCancellationRequested)
            {
                toastFading = true;
                StateHasChanged();
                await Task.Delay(400, token);
                if (!token.IsCancellationRequested)
                {
                    toastVisible = false;
                    StateHasChanged();
                }
            }
        }
        catch (TaskCanceledException) { }
    }

    // ── Three-dot menu ─────────────────────────────────────────────────────────
    private async Task ToggleDotsMenu()
    {
        if (showDotsMenu) { CloseDotsMenu(); return; }

        try
        {
            var rect = await JS.InvokeAsync<BoundingRect>(
                "eval",
                "(()=>{ var el=document.querySelector('.ht-cal-header-right .ht-icon-btn'); var r=el.getBoundingClientRect(); return {top:r.bottom+window.scrollY+4,left:r.right+window.scrollX-160,width:r.width}; })()"
            );
            dotsMenuTop  = rect.Top;
            dotsMenuLeft = rect.Left;
        }
        catch
        {
            dotsMenuTop  = 200;
            dotsMenuLeft = 300;
        }

        showDotsMenu = true;
        StateHasChanged();
    }

    private void CloseDotsMenu() { showDotsMenu = false; StateHasChanged(); }

    private void OpenRefreshModal()
    {
        showDotsMenu     = false;
        refreshOption    = "all";
        specificRefreshDate = DateTime.Today;
        showRefreshModal = true;
        StateHasChanged();
    }

    private void CloseRefreshModal() { showRefreshModal = false; StateHasChanged(); }

    private async Task DoRefreshCalendar()
    {
        if (selectedCalendar == null) return;
        isRefreshing = true;
        StateHasChanged();

        await Task.CompletedTask; // real fetch handles its own async

        if (!string.IsNullOrEmpty(selectedCalendar.Country))
        {
            var refreshed = await FetchGoogleCalendarHolidays(selectedCalendar.Country);
            if (refreshOption == "future")
                refreshed = refreshed.Where(h => h.Date >= DateTime.Today).ToList();
            else if (refreshOption == "specific")
                refreshed = refreshed.Where(h => h.Date >= specificRefreshDate).ToList();

            if (refreshed.Any())
                selectedCalendar.Holidays = refreshed;
            else
                importError = "Could not fetch holidays from Google Calendar. Check your internet connection.";
        }

        isRefreshing     = false;
        showRefreshModal = false;
        StateHasChanged();

        await ShowToast($"Calendar '{selectedCalendar.Name}' has been refreshed.");
    }

    public void Refresh() => StateHasChanged();

    // JS interop helper
    private class BoundingRect
    {
        public double Top   { get; set; }
        public double Left  { get; set; }
        public double Width { get; set; }
    }
}

