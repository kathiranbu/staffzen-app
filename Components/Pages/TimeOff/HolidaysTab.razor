                                @if (!rule.ApplyAll) { <i class="bi bi-check-lg"></i> }
                            </div>
                            <span>Apply only to selected schedules</span>
                        </label>
                    </div>

                    @* Select schedules dropdown — shown when ApplyAll = false *@
