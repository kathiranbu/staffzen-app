        try
        {
            var rect = await JS.InvokeAsync<BoundingRect>(
                "eval",
                $"(()=>{{ var r=document.querySelector('.ht-country-wrap').getBoundingClientRect(); return {{top:r.bottom+window.scrollY,left:r.left+window.scrollX,width:r.width}}; }})()"
            );
            dropTop   = rect.Top + 4;
            dropLeft  = rect.Left;
            dropWidth = rect.Width;
        }
        catch { dropTop = 300; dropLeft = 300; dropWidth = 300; }
        countryDropOpen = true;
        StateHasChanged();
        try { await JS.InvokeVoidAsync("eval", "setTimeout(()=>document.querySelector('.ht-country-search')?.focus(),50)"); } catch { }
