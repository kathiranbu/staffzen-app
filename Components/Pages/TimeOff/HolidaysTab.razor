        width: 30px; height: 30px; border: 1.5px solid #e8eaed;
        border-radius: 7px; background: #fff; cursor: pointer; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 13px; color: #6b7280;
        transition: border-color .15s, color .15s, background .15s;
    }
    .ht-icon-btn:hover      { border-color: #ff7a00; color: #ff7a00; background: #fff7ed; }
    .ht-icon-btn--del:hover { border-color: #ef4444; color: #ef4444; background: #fef2f2; }
    .ht-icon-btn--sm        { width: 26px; height: 26px; font-size: 11px; }

    .ht-holidays-panel {
        background: #fff; border: 1.5px solid #e8eaed;
        border-radius: 10px; overflow: hidden; width: 100%;
    }
    .ht-year-bar {
        display: flex; align-items: center;
        padding: 12px 20px 12px 0; border-bottom: none;
    }
    .ht-year-tabs { display: flex; gap: 2px; }
    .ht-year-tab {
        padding: 5px 14px; border: 1.5px solid #e8eaed; border-radius: 6px;
        background: #fff; font-size: 13px; font-weight: 500; color: #6b7280;
        cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .ht-year-tab:hover     { border-color: #ff7a00; color: #ff7a00; }
    .ht-year-tab--active   { border-color: #ff7a00; color: #ff7a00; background: #fff7ed; font-weight: 700; }

    .ht-add-holiday-btn {
        padding: 8px 20px; background: #ff7a00; color: #fff; border: none;
        border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; font-family: inherit; transition: background .15s;
        white-space: nowrap;
    }
    .ht-add-holiday-btn:hover { background: #e66c00; }

    .ht-table-head {
        display: grid; grid-template-columns: 1fr 180px 160px 160px;
        padding: 10px 20px; background: #fafafa;
        border-top: 1px solid #f0f0f0; border-bottom: 1px solid #f0f0f0;
        align-items: center;
    }
    .ht-th {
        font-size: 12px; font-weight: 700; color: #6b7280;
        letter-spacing: .3px;
    }
    .ht-th--actions { display: flex; justify-content: flex-end; }
    .ht-holiday-row {
        display: grid; grid-template-columns: 1fr 180px 160px 160px;
        padding: 16px 20px; border-bottom: 1px solid #f5f5f5;
        align-items: center; transition: background .1s;
    }
    .ht-holiday-row:last-child   { border-bottom: none; }
    .ht-holiday-row:hover        { background: #fafafa; }
    .ht-holiday-row:hover .ht-td--actions { opacity: 1; }

    .ht-td           { font-size: 14px; color: #111827; }
    .ht-td--muted    { color: #374151; }
    .ht-td--actions  {
        display: flex; align-items: center; gap: 6px;
        justify-content: flex-end; opacity: 0; transition: opacity .15s;
    }

    .ht-no-holidays {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; gap: 10px; padding: 60px 20px; text-align: center;
    }
    .ht-no-holidays-icon {
        font-size: 52px; color: #d1d5db; margin-bottom: 4px;
        position: relative;
    }
    .ht-no-holidays-icon i { font-size: 52px; color: #c0bfbf; }
    .ht-no-holidays-title { font-size: 16px; font-weight: 700; color: #111827; }
    .ht-no-holidays-sub   { font-size: 14px; color: #6b7280; margin-bottom: 6px; }
    .ht-add-holiday-btn--center { margin-top: 4px; }

    /* ── Empty state ── */
    .ht-empty-state {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; min-height: 300px; gap: 10px; text-align: center;
    }
    .ht-empty-icon  { font-size: 48px; color: #d1d5db; }
    .ht-empty-title { font-size: 18px; font-weight: 700; color: #374151; }
    .ht-empty-sub   { font-size: 14px; color: #9ca3af; }

    /* ── Modal ── */
    .ht-modal-back {
        position: fixed; inset: 0; z-index: 1100;
        background: rgba(0,0,0,.45);
        display: flex; align-items: center; justify-content: center;
    }
    .ht-modal {
        background: #fff; border-radius: 12px; padding: 28px;
        width: 420px; max-width: calc(100vw - 32px);
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        animation: ht-modal-in .18s ease;
    }
    @@keyframes ht-modal-in {
        from { opacity: 0; transform: scale(.95); }
        to   { opacity: 1; transform: scale(1); }
    }
    .ht-modal-head {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 20px; font-size: 18px; font-weight: 700; color: #111827;
    }
    .ht-modal-close {
        width: 32px; height: 32px; border: none; background: #f3f4f6;
        border-radius: 7px; cursor: pointer; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 14px; color: #6b7280; transition: background .15s;
    }
    .ht-modal-close:hover { background: #e5e7eb; }
    .ht-modal-body        { margin-bottom: 4px; }
    .ht-modal-foot {
        display: flex; justify-content: flex-end; gap: 12px; margin-top: 20px;
    }

    /* ── Toast ── */
    .ht-toast {
        position: fixed; top: 20px; right: 24px; z-index: 99999;
        display: flex; align-items: center; gap: 10px;
        background: #111827; color: #fff;
        padding: 12px 20px; border-radius: 10px;
        font-size: 14px; font-weight: 500;
        box-shadow: 0 8px 32px rgba(0,0,0,.22);
        animation: ht-toast-in .25s ease;
        transition: opacity .4s ease;
    }
    .ht-toast--fade { opacity: 0; }
    .ht-toast-icon  { color: #22c55e; font-size: 16px; flex-shrink: 0; }
    @@keyframes ht-toast-in {
        from { opacity: 0; transform: translateY(-12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Three-dot menu ── */
    .ht-dots-menu {
        position: fixed; z-index: 9000;
        background: #fff; border: 1.5px solid #e0e0e0;
        border-radius: 8px; box-shadow: 0 8px 28px rgba(0,0,0,.16);
        min-width: 180px;
        animation: ht-dd-in .13s ease;
    }
    .ht-dots-menu-item {
        display: flex; align-items: center; gap: 10px;
        padding: 11px 16px; font-size: 14px; color: #374151;
        cursor: pointer; transition: background .1s;
        border-radius: 6px;
    }
    .ht-dots-menu-item:hover { background: #f3f4f6; color: #ff7a00; }
    .ht-dots-menu-item i     { font-size: 14px; }

    /* ── Refresh modal specifics ── */
    .ht-refresh-modal { width: 460px; }
    .ht-refresh-desc  { font-size: 14px; color: #6b7280; margin-bottom: 16px; margin-top: 0; }
    .ht-refresh-options-label {
        display: flex; align-items: center; gap: 6px;
        font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 12px;
    }
    .ht-refresh-options { display: flex; gap: 20px; flex-wrap: wrap; }
    .ht-refresh-opt {
        display: flex; align-items: center; gap: 8px;
        font-size: 14px; color: #374151; cursor: pointer; user-select: none;
    }
    .ht-refresh-radio {
        width: 18px; height: 18px; border-radius: 50%;
        border: 2px solid #d1d5db; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; color: #fff; transition: all .15s;
    }
    .ht-refresh-radio--checked { background: #22c55e; border-color: #22c55e; }

    /* ── Form name preview ── */
    .ht-form-name-preview {
        font-size: 20px; font-weight: 700; color: #111827;
        margin-bottom: 24px; min-height: 28px;
        transition: color .15s;
    }

    /* ── Edit mode country display ── */
    .ht-edit-country {
        font-size: 14px; color: #374151; margin-bottom: 20px;
        padding: 10px 14px; background: #f9fafb;
        border-radius: 8px; border: 1px solid #e5e7eb;
    }

    /* ── Specific date picker ── */
    .ht-specific-date-wrap {
        margin-top: 18px;
        animation: ht-dd-in .15s ease;
    }
    .ht-specific-date-label {
        display: block; font-size: 13px; font-weight: 600;
        color: #374151; margin-bottom: 8px;
    }
    .ht-specific-date-input-wrap {
        position: relative; display: flex; align-items: center;
    }
    .ht-specific-date-input {
        width: 100%; padding: 11px 40px 11px 14px;
        border: 1.5px solid #d1d5db; border-radius: 8px;
        font-size: 14px; font-weight: 600; color: #111827;
        font-family: inherit; outline: none; background: #fff;
        box-sizing: border-box; cursor: pointer;
        transition: border-color .15s;
        appearance: none; -webkit-appearance: none;
    }
    .ht-specific-date-input:focus { border-color: #ff7a00; }
    .ht-specific-date-icon {
        position: absolute; right: 13px;
        font-size: 15px; color: #9ca3af; pointer-events: none;
    }

    /* ── Members section ── */
    .ht-members-section { margin: 20px 0 8px; }
    .ht-members-title {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 700; color: #374151;
        letter-spacing: .5px; margin-bottom: 6px;
    }

    /* ════════════════════════════════════════
       SHORTENED RULE ROW
       ════════════════════════════════════════ */

    .ah-rule-row {
        display: flex; align-items: center; gap: 10px;
        flex-wrap: nowrap;
    }

    .ah-dd {
        position: relative; display: flex; align-items: center;
        justify-content: space-between; gap: 8px;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        padding: 13px 15px; cursor: pointer; background: #fff;
        user-select: none; transition: border-color .15s;
        min-width: 0;
    }
    .ah-dd:hover      { border-color: #d1d5db; }
    .ah-dd--open      { border-color: #ff7a00; }
    .ah-dd:not(.ah-dd--cond) { flex: 1 1 200px; }
    .ah-dd--cond      { flex: 0 0 130px; min-width: 115px; }

    .ah-dd-ph   { font-size: 14px; color: #9ca3af; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ah-dd-val  { font-size: 14px; color: #111827; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ah-dd-chev { font-size: 12px; color: #6b7280; flex-shrink: 0; }

    .ah-dd-menu {
        position: absolute; top: calc(100% + 4px); left: 0;
        min-width: 100%; z-index: 400;
        background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,.13); overflow: hidden;
        animation: ah-slide-in .12s ease;
    }
    .ah-dd-menu--up {
        top: auto;
        bottom: calc(100% + 4px);
    }
    .ah-dd-item {
        padding: 13px 16px; font-size: 14px; color: #374151;
        cursor: pointer; transition: background .1s;
        border-bottom: 1px solid #f5f5f5; white-space: nowrap;
    }
    .ah-dd-item:last-child { border-bottom: none; }
    .ah-dd-item:hover      { background: #f9fafb; color: #111827; }
    .ah-dd-item--sel       { background: #fff7ed; color: #ff7a00; font-weight: 600; }

    .ah-rule-time {
        display: flex; align-items: center; gap: 4px; flex-shrink: 0;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        padding: 13px 14px; background: #fff;
    }
    .ah-time-seg {
        width: 26px; text-align: center; border: none; outline: none;
        font-size: 14px; font-weight: 600; color: #111827;
        font-family: inherit; background: transparent;
        -moz-appearance: textfield; appearance: textfield;
    }
    .ah-time-seg--clock { width: 26px; }
    .ah-time-seg::-webkit-inner-spin-button,
    .ah-time-seg::-webkit-outer-spin-button { -webkit-appearance: none; }
    .ah-time-sep { font-size: 14px; color: #374151; font-weight: 500; }
    .ah-time-ampm {
        padding: 2px 6px; border: 1px solid #e5e7eb; border-radius: 5px;
        background: #f9fafb; font-size: 12px; font-weight: 700; color: #374151;
        cursor: pointer; font-family: inherit; margin-left: 2px;
        transition: background .15s, color .15s;
    }
    .ah-time-ampm:hover { background: #fff7ed; color: #ff7a00; border-color: #ff7a00; }
    .ah-time-clock {
        width: 24px; height: 24px; border: none; background: transparent;
        cursor: pointer; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 14px; color: #9ca3af; margin-left: 2px;
        transition: color .15s;
    }
    .ah-time-clock:hover { color: #ff7a00; }

    .ah-apply-row {
        display: flex; align-items: center; gap: 24px;
        margin-top: 12px; margin-bottom: 4px;
    }
    .ah-apply-opt {
        display: flex; align-items: center; gap: 8px;
        cursor: pointer; user-select: none; font-size: 14px; color: #374151;
    }
    .ah-apply-radio {
        width: 22px; height: 22px; border-radius: 50%;
        border: 2px solid #d1d5db; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; color: #fff; transition: all .15s;
    }
    .ah-apply-radio--on { background: #22c55e; border-color: #22c55e; }

    .ah-sched-wrap { margin-top: 10px; position: relative; }
    .ah-sched-trigger {
        display: flex; align-items: center; justify-content: space-between;
        border: 1.5px solid #e5e7eb; border-radius: 8px;
        padding: 11px 14px; cursor: pointer; background: #fff;
        user-select: none; transition: border-color .15s;
    }
    .ah-sched-trigger:hover   { border-color: #d1d5db; }
    .ah-sched-trigger--open   { border-color: #ff7a00; }
    .ah-sched-drop {
        position: absolute; top: calc(100% + 2px); left: 0; right: 0; z-index: 400;
        background: #fff; border: 1.5px solid #e5e7eb; border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,.13);
        overflow: hidden; animation: ah-slide-in .12s ease;
    }
    .ah-sched-search-row {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px; border-bottom: 1px solid #f0f0f0;
        background: #fafafa;
    }
    .ah-sched-search-row i { font-size: 13px; color: #9ca3af; flex-shrink: 0; }
    .ah-sched-search {
        border: none; outline: none; font-size: 13px; color: #374151;
        font-family: inherit; width: 100%; background: transparent;
    }
    .ah-sched-search::placeholder { color: #9ca3af; }
    .ah-sched-item {
        padding: 12px 14px; font-size: 13px; color: #374151;
        cursor: pointer; transition: background .1s;
        border-bottom: 1px solid #f5f5f5;
    }
    .ah-sched-item:hover { background: #f9fafb; color: #111827; }
    .ah-sched-clear {
        padding: 10px 14px; font-size: 13px; color: #9ca3af;
        cursor: pointer; transition: color .1s;
    }
    .ah-sched-clear:hover { color: #ef4444; }

    /* ════════════════════════════════════════════════
       ADD HOLIDAY PANEL — Jibble-style right slide-in
       ════════════════════════════════════════════════ */

    .ah-backdrop {
        position: fixed; inset: 0; z-index: 1200;
        background: rgba(0,0,0,.35);
    }
    .ah-panel {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: 680px; max-width: 100vw; z-index: 1201;
        background: #fff;
        display: flex; flex-direction: column;
        box-shadow: -8px 0 40px rgba(0,0,0,.16);
        animation: ah-slide-in .22s ease;
    }
    @@keyframes ah-slide-in {
        from { transform: translateX(60px); opacity: 0; }
        to   { transform: translateX(0);    opacity: 1; }
    }

    .ah-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 26px 32px 22px; border-bottom: 1.5px solid #f0f0f0;
        flex-shrink: 0;
    }
    .ah-title { font-size: 22px; font-weight: 700; color: #111827; }
    .ah-close {
        width: 36px; height: 36px; border: none; background: transparent;
        cursor: pointer; border-radius: 8px; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 18px; color: #6b7280; transition: background .15s;
    }
    .ah-close:hover { background: #f3f4f6; color: #111827; }

    .ah-body { flex: 1; overflow-y: auto; padding: 32px 32px 20px; }

    .ah-section-label {
        font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 12px;
    }

    .ah-input-wrap {
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        padding: 15px 18px; background: #fff; transition: border-color .15s;
    }
    .ah-input-wrap:focus-within { border-color: #ff7a00; }
    .ah-input-wrap--err { border-color: #ef4444 !important; }
    .ah-text-input {
        width: 100%; border: none; outline: none; background: transparent;
        font-size: 15px; color: #111827; font-family: inherit;
    }
    .ah-text-input::placeholder { color: #9ca3af; }
    .ah-err-msg { font-size: 12px; color: #ef4444; margin-top: 5px; }

    .ah-dates-row {
        display: flex; gap: 14px;
    }
    .ah-date-field {
        flex: 1; display: flex; align-items: center; justify-content: space-between;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        padding: 15px 16px; cursor: pointer; transition: border-color .15s;
        background: #fff; user-select: none;
    }
    .ah-date-field:hover { border-color: #d1d5db; }
    .ah-date-field--active { border-color: #ff7a00; }
    .ah-date-val { font-size: 15px; color: #111827; font-weight: 500; }
    .ah-date-placeholder { color: #9ca3af !important; font-weight: 400 !important; }
    .ah-date-icon { font-size: 16px; color: #9ca3af; flex-shrink: 0; cursor: pointer; transition: color .15s; }
    .ah-date-icon:hover { color: #ff7a00; }

    .ah-cal-wrap {
        margin-top: 6px; margin-bottom: 4px;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        background: #fff; padding: 10px 12px 8px;
        box-shadow: 0 4px 16px rgba(0,0,0,.07);
        animation: ah-slide-in .15s ease;
        max-width: 280px;
    }
    .ah-cal-nav {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 8px;
    }
    .ah-cal-nav-btn {
        width: 24px; height: 24px; border: 1.5px solid #e8eaed; border-radius: 5px;
        background: #fff; cursor: pointer; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 10px; color: #6b7280; transition: all .15s;
    }
    .ah-cal-nav-btn:hover { border-color: #ff7a00; color: #ff7a00; }
    .ah-cal-month { font-size: 13px; font-weight: 700; color: #111827; }
    .ah-cal-grid {
        display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px;
    }
    .ah-cal-dow {
        text-align: center; font-size: 10px; font-weight: 600;
        color: #9ca3af; padding: 2px 0 5px;
    }
    .ah-cal-cell {
        aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
        border-radius: 50%; font-size: 11px; font-weight: 500; color: #111827;
        cursor: pointer; transition: background .12s;
    }
    .ah-cal-cell:hover { background: #f3f4f6; }
    .ah-cal-cell--today {
        color: #ff7a00; font-weight: 700;
        border: 2px solid #ff7a00; border-radius: 50%;
    }
    .ah-cal-cell--sel { background: #ff7a00 !important; color: #fff !important; font-weight: 700; }
    .ah-cal-cell--future { color: #d1d5db; cursor: default; }
    .ah-cal-cell--future:hover { background: transparent; }
    .ah-cal-cell--empty { cursor: default; }
    .ah-cal-footer {
        display: flex; justify-content: flex-end;
        border-top: 1px solid #f0f0f0; margin-top: 6px; padding-top: 6px;
    }
    .ah-cal-today-btn {
        border: none; background: transparent; font-size: 12px;
        font-weight: 600; color: #ff7a00; cursor: pointer;
        font-family: inherit; padding: 2px 6px; border-radius: 5px;
        transition: background .15s;
    }
    .ah-cal-today-btn:hover { background: #fff7ed; }

    .ah-shortened-row {
        display: flex; align-items: center; gap: 10px; margin-bottom: 4px;
    }
    .ah-select-wrap {
        flex: 1; position: relative;
        display: flex; align-items: center; justify-content: space-between;
        border: 1.5px solid #e5e7eb; border-radius: 8px;
        padding: 12px 14px; cursor: pointer; background: #fff;
        transition: border-color .15s; user-select: none;
    }
    .ah-select-wrap:hover { border-color: #d1d5db; }
    .ah-select-wrap--open { border-color: #ff7a00; }
    .ah-select-placeholder { font-size: 14px; color: #9ca3af; }
    .ah-select-val { font-size: 14px; color: #111827; font-weight: 500; }
    .ah-select-chevron { font-size: 12px; color: #6b7280; flex-shrink: 0; }
    .ah-select-dropdown {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 300;
        background: #fff; border: 1.5px solid #e5e7eb; border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        overflow: hidden;
        animation: ah-slide-in .13s ease;
    }
    .ah-select-option {
        padding: 12px 16px; font-size: 14px; color: #374151;
        cursor: pointer; transition: background .1s;
        border-bottom: 1px solid #f5f5f5;
    }
    .ah-select-option:last-child { border-bottom: none; }
    .ah-select-option:hover { background: #f9fafb; color: #111827; }
    .ah-select-option--sel { background: #fff7ed; color: #ff7a00; font-weight: 600; }
    .ah-rule-del {
        width: 32px; height: 32px; flex-shrink: 0;
