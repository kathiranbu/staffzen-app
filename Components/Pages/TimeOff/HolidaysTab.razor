                                <button class="ah-time-clock"><i class="bi bi-clock"></i></button>
                            </div>
                        }
                        else
                        {
                            @* Duration picker: shows e.g. 0 h 0 m *@
                            <div class="ah-rule-time">
                                <input class="ah-time-seg" type="text" inputmode="numeric" maxlength="2"
                                       value="@rule.TimeH"
                                       @onchange='@(e => { ahShortenedRules[ci].TimeH = int.TryParse(e.Value?.ToString(), out var v) ? Math.Clamp(v,0,23) : 0; StateHasChanged(); })' />
                                <span class="ah-time-sep">h</span>
                                <input class="ah-time-seg" type="text" inputmode="numeric" maxlength="2"
                                       value="@rule.TimeM"
