<!-- ═══ EDIT HOLIDAY PANEL ═══ -->
@if (showEditHolidayModal)
{
    <div class="ah-backdrop" @onclick="CloseEditHolidayPanel"></div>
    <div class="ah-panel" @onclick:stopPropagation="true">
        <div class="ah-header">
            <span class="ah-title">Edit Holiday</span>
            <button class="ah-close" @onclick="CloseEditHolidayPanel"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="ah-body">
            <!-- Holiday Name -->
            <div class="ah-section-label">Holiday Name</div>
            <div class="ah-input-wrap @(ehNameErr ? "ah-input-wrap--err" : "")">
                <input class="ah-text-input"
                       placeholder="Holiday Name"
                       @bind="editHolidayName" @bind:event="oninput"
                       @onfocus="() => ehNameErr = false" />
            </div>
            @if (ehNameErr)
            {
                <div class="ah-err-msg">Holiday name is required.</div>
            }

            <!-- Date -->
            <div class="ah-section-label" style="margin-top:28px;">Date</div>
            <div class="ah-date-field @(ehCalOpen ? "ah-date-field--active" : "")" style="max-width:300px;"
                 @onclick="() => { ehCalOpen = !ehCalOpen; }">
                <span class="ah-date-val @(editHolidayDate == null ? "ah-date-placeholder" : "")">
                    @(editHolidayDate.HasValue ? editHolidayDate.Value.ToString("yyyy-MM-dd") : "Select date")
                </span>
                <i class="bi bi-calendar3 ah-date-icon"
                   @onclick="() => { ehCalView = editHolidayDate ?? DateTime.Today; ehCalOpen = true; StateHasChanged(); }"
                   @onclick:stopPropagation="true"></i>
            </div>

            @if (ehCalOpen)
            {
                <div class="ah-cal-wrap" @onclick:stopPropagation="true">
                    <div class="ah-cal-nav">
                        <button class="ah-cal-nav-btn" @onclick="() => ehCalView = ehCalView.AddMonths(-1)"><i class="bi bi-chevron-left"></i></button>
                        <span class="ah-cal-month">@ehCalView.ToString("MMM yyyy")</span>
                        <button class="ah-cal-nav-btn" @onclick="() => ehCalView = ehCalView.AddMonths(1)"><i class="bi bi-chevron-right"></i></button>
                    </div>
                    <div class="ah-cal-grid">
                        @foreach (var d in new[]{"Mo","Tu","We","Th","Fr","Sa","Su"})
                        { <div class="ah-cal-dow">@d</div> }
                        @{ int eho = ((int)new DateTime(ehCalView.Year, ehCalView.Month, 1).DayOfWeek + 6) % 7; }
                        @for (int b = 0; b < eho; b++) { <div class="ah-cal-cell ah-cal-cell--empty"></div> }
                        @for (int d = 1; d <= DateTime.DaysInMonth(ehCalView.Year, ehCalView.Month); d++)
                        {
                            var cd = new DateTime(ehCalView.Year, ehCalView.Month, d);
                            var cls2 = "ah-cal-cell"
                                + (editHolidayDate.HasValue && editHolidayDate.Value.Date == cd ? " ah-cal-cell--sel" : "")
                                + (cd.Date == DateTime.Today && !(editHolidayDate.HasValue && editHolidayDate.Value.Date == cd) ? " ah-cal-cell--today" : "");
                            var cap2 = cd;
                            <div class="@cls2" @onclick="() => { editHolidayDate = cap2; ehCalOpen = false; StateHasChanged(); }">@d</div>
                        }
                    </div>
                    <div class="ah-cal-footer">
                        <button class="ah-cal-today-btn" @onclick="() => { ehCalView = DateTime.Today; StateHasChanged(); }">Today</button>
                    </div>
                </div>
            }

            <!-- Shortened day rules (read-only display) -->
            <div style="margin-top:28px;">
                <button class="ah-add-rule-btn" @onclick="() => { }">+ Add shortened day rule</button>
            </div>
        </div>
        <div class="ah-footer">
            <button class="ah-footer-cancel" @onclick="CloseEditHolidayPanel">Cancel</button>
            <button class="ah-footer-save" @onclick="ConfirmEditHoliday">Save</button>
        </div>
    </div>
}

<!-- ═══ DELETE HOLIDAY CONFIRM ═══ -->
