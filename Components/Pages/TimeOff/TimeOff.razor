    .to-preset-row--active { color:#f07820; font-weight:700; }
    .to-preset-row--active:hover { background:#fff7ed; }
    .to-preset-check { color:#f07820; font-size:.9rem; font-weight:700; }
    /* Calendar popup */
    .to-datepicker-popup { position:absolute; top:calc(100% + 8px); left:0; z-index:700; background:#fff; border:1.5px solid #e5e7eb; border-radius:12px; box-shadow:0 10px 36px rgba(0,0,0,.14); padding:18px; width:300px; animation:to-fade-in .12s ease; }
    .to-cal-header { display:flex; align-items:center; gap:4px; margin-bottom:14px; justify-content:center; }
    .to-cal-nav { background:none; border:none; cursor:pointer; font-size:1.1rem; color:#6b7280; padding:4px 7px; border-radius:5px; transition:background .1s; }
    .to-cal-nav:hover { background:#f3f4f6; color:#111; }
    .to-cal-month-label { font-weight:700; font-size:.95rem; color:#111827; padding:0 5px; }
    .to-cal-year-label  { font-weight:600; font-size:.875rem; color:#6b7280; padding:0 4px; }
    .to-cal-pick-hint { font-size:.75rem; color:#f07820; font-weight:600; text-align:center; margin-bottom:10px; letter-spacing:.3px; }
    .to-cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:3px; }
    .to-cal-dayname { font-size:.72rem; font-weight:700; color:#9ca3af; text-align:center; padding:4px 0; text-transform:uppercase; letter-spacing:.3px; }
    .to-cal-day { text-align:center; padding:7px 3px; font-size:.85rem; color:#374151; border-radius:7px; cursor:pointer; transition:background .1s, color .1s; }
    .to-cal-day:hover { background:#fff7ed; color:#f07820; }
    .to-cal-day--today { font-weight:700; border:1.5px solid #f07820; color:#f07820; }
    .to-cal-day--sel   { background:#f07820 !important; color:#fff !important; font-weight:700; border-radius:7px; }
    .to-cal-day--range { background:#fff3e8; color:#c05010; }
    .to-search-bar { display:flex; align-items:center; background:#fff; border:1.5px solid #e5e7eb; border-radius:10px; padding:0 14px; margin-top:18px; flex-wrap:wrap; box-shadow:0 1px 4px rgba(0,0,0,.05); }
    .to-search-input-wrap { display:flex; align-items:center; gap:9px; padding:11px 0; min-width:220px; }
    .to-search-icon { color:#9ca3af; font-size:1rem; }
    .to-search-input { border:none; outline:none; font-size:.9rem; color:#111827; background:transparent; width:200px; font-family:inherit; }
    .to-search-input::placeholder { color:#d1d5db; }
    .to-filter-divider { width:1px; height:30px; background:#e5e7eb; margin:0 14px; }
    .to-filter-group { display:flex; align-items:center; gap:2px; flex-wrap:wrap; padding:8px 0; }
    .to-filter-btn { background:none; border:none; font-size:.875rem; color:#374151; font-weight:500; cursor:pointer; padding:7px 12px; border-radius:7px; display:flex; align-items:center; gap:5px; font-family:inherit; white-space:nowrap; transition:background .12s, color .12s; }
    .to-filter-btn:hover { background:#f3f4f6; color:#111827; }
    .to-filter-btn--active { color:#f07820; font-weight:700; background:#fff7ed; }
    .to-filter-btn--active:hover { background:#feecd8; }
    .to-reset-btn { background:none; border:none; font-size:.875rem; color:#9ca3af; cursor:pointer; padding:7px 10px; font-family:inherit; font-weight:500; transition:color .12s; }
    .to-reset-btn:hover { color:#f07820; }
    /* Filter dropdowns */
    .to-filter-dd-wrap { position:relative; }
    .to-filter-popup { position:absolute; top:calc(100% + 6px); left:0; z-index:600; background:#fff; border:1.5px solid #e5e7eb; border-radius:10px; box-shadow:0 8px 28px rgba(0,0,0,.13); min-width:200px; overflow:hidden; }
    .to-filter-popup-search { display:flex; align-items:center; gap:8px; padding:10px 14px; border-bottom:1px solid #f3f4f6; }
    .to-filter-popup-input { border:none; outline:none; font-size:.875rem; color:#111; font-family:inherit; background:transparent; flex:1; }
    .to-filter-popup-row { display:flex; align-items:center; justify-content:space-between; padding:11px 16px; font-size:.875rem; color:#374151; cursor:pointer; border-bottom:1px solid #f9fafb; }
    .to-filter-popup-row:last-child { border-bottom:none; }
    .to-filter-popup-row:hover { background:#f9fafb; }
    .to-filter-popup-empty { padding:14px 16px; font-size:.875rem; color:#9ca3af; text-align:center; }
    .to-filter-popup-clear { padding:11px 16px; font-size:.875rem; color:#f07820; font-weight:600; cursor:pointer; border-top:1px solid #f3f4f6; }
    .to-filter-popup-clear:hover { background:#fff7ed; }
    /* Bulk bar */
    .to-bulk-bar { display:flex; align-items:center; gap:10px; padding:10px 16px; background:#fff; border:1.5px solid #e0e0e0; border-radius:8px; margin-top:12px; }
    .to-bulk-count { font-size:.875rem; font-weight:600; color:#374151; margin-right:4px; }
    .to-bulk-btn { padding:7px 20px; border:none; border-radius:6px; font-size:.875rem; font-weight:600; cursor:pointer; font-family:inherit; }
    .to-bulk-cancel-req { background:#374151; color:#fff; }
    .to-bulk-cancel-req:hover { background:#1f2937; }
    .to-bulk-cancel  { background:none; border:none; font-size:.875rem; color:#888; cursor:pointer; padding:7px 10px; font-family:inherit; }
    .to-bulk-cancel:hover { color:#374151; }
    /* Unselectable rows */
    .to-row-unselectable { opacity:.75; }
    .to-row-unselectable:hover { background:#fafafa !important; }
    /* Loading */
    .to-loading { display:flex; justify-content:center; padding:80px 0; }
    .to-spinner { width:36px; height:36px; border-radius:50%; border:3px solid #f0e0d0; border-top-color:#f07820; animation:spin .7s linear infinite; }
    @@keyframes spin { to { transform:rotate(360deg); } }
    /* Empty */
    .to-empty-state { display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:60px 20px 40px; }
    .to-empty-illustration { margin-bottom:16px; }
    .to-empty-title { font-size:1.1rem; font-weight:700; color:#1a1a1a; margin-bottom:8px; }
    .to-empty-sub { font-size:.9rem; color:#888; max-width:440px; margin-bottom:24px; }
    /* Table */
    .to-table-wrap { margin-top:16px; background:#fff; border-radius:8px; border:1px solid #e5e7eb; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,.04); }
    .to-table { width:100%; border-collapse:collapse; font-size:.9rem; }
    .to-table thead tr { border-bottom:1px solid #f0f0f0; background:#fafafa; }
    .to-table thead th { padding:11px 18px; text-align:left; font-size:.75rem; font-weight:600; color:#9ca3af; text-transform:uppercase; letter-spacing:.5px; white-space:nowrap; }
    .to-table thead th:first-child { width:44px; padding-right:0; }
    .to-table tbody tr { border-bottom:1px solid #f3f4f6; transition:background .1s; }
    .to-table tbody tr:last-child { border-bottom:none; }
    .to-table tbody tr:hover { background:#fafafa; }
    .to-table tbody tr.to-row-selected { background:#fff8f2; }
    .to-table tbody td { padding:14px 18px; color:#374151; vertical-align:middle; }
    /* Member cell — avatar + name like Jibble */
    .to-member-cell { display:flex; align-items:center; gap:10px; }
    .to-member-avatar { width:32px; height:32px; border-radius:50%; background:#c7d2e8; color:#3b4f78; font-size:.8rem; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .to-member-name { font-weight:500; color:#111827; font-size:.88rem; }
    /* Status badges — pill style matching Jibble */
    .to-status-badge { display:inline-flex; align-items:center; gap:6px; font-size:.82rem; font-weight:600; padding:4px 10px; border-radius:16px; }
    .to-status-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
    .to-status-pending   { background:#fff7ed; color:#ea6d10; } .to-status-pending   .to-status-dot { background:#f07820; }
    .to-status-approved  { background:#f0fdf4; color:#16a34a; } .to-status-approved  .to-status-dot { background:#16a34a; }
    .to-status-rejected  { background:#fef2f2; color:#dc2626; } .to-status-rejected  .to-status-dot { background:#dc2626; }
    .to-status-cancelled { background:#f3f4f6; color:#6b7280; } .to-status-cancelled .to-status-dot { background:#9ca3af; }
    /* Row actions */
    .to-row-actions { display:flex; align-items:center; gap:4px; opacity:0; transition:opacity .15s; justify-content:flex-end; }
    .to-table tbody tr:hover .to-row-actions { opacity:1; }
    .to-action-btn { width:30px; height:30px; border:none; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.85rem; transition:background .12s, transform .1s; }
    .to-action-btn:hover { transform:scale(1.08); }
    .to-action-edit    { background:#f3f4f6; color:#6b7280; } .to-action-edit:hover    { background:#e5e7eb; }
    .to-action-delete  { background:#fef2f2; color:#dc2626; } .to-action-delete:hover  { background:#fee2e2; }
    .to-action-approve { background:#f0fdf4; color:#16a34a; } .to-action-approve:hover { background:#dcfce7; }
    .to-action-reject  { background:#fef2f2; color:#dc2626; } .to-action-reject:hover  { background:#fee2e2; }
    .to-action-cancel-req { background:#f3f4f6; color:#6b7280; } .to-action-cancel-req:hover { background:#e5e7eb; }
    /* Confirm modals */
    .to-modal-overlay { position:fixed; inset:0; z-index:1060; background:rgba(0,0,0,.45); }
    .to-modal { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); z-index:1061; background:#fff; border-radius:12px; width:480px; max-width:calc(100vw - 32px); box-shadow:0 20px 60px rgba(0,0,0,.2); }
    .to-modal-head { display:flex; align-items:center; justify-content:space-between; padding:22px 24px 16px; }
    .to-modal-title { font-size:1.1rem; font-weight:700; color:#111827; }
    .to-modal-body { padding:0 24px 20px; }
    .to-modal-body p { font-size:.95rem; color:#374151; line-height:1.6; }
    .to-modal-footer { display:flex; align-items:center; justify-content:flex-end; gap:12px; padding:16px 24px; border-top:1px solid #f0f0f0; }
    .to-modal-btn-cancel { background:none; border:none; font-size:.9rem; font-weight:500; color:#374151; cursor:pointer; padding:10px 20px; border-radius:7px; font-family:inherit; }
    .to-modal-btn-cancel:hover { background:#f3f4f6; }
    .to-modal-btn-confirm { padding:10px 28px; border:none; border-radius:7px; font-size:.9rem; font-weight:600; cursor:pointer; font-family:inherit; color:#fff; }
    .to-modal-btn-green { background:#16a34a; } .to-modal-btn-green:hover { background:#15803d; }
    .to-modal-btn-red   { background:#dc2626; } .to-modal-btn-red:hover   { background:#b91c1c; }
    .to-leave-balance { margin-top:30px; padding:20px; background:#fff; border-radius:8px; border:1px solid #e5e5e5; text-align:center; }
    /* Drawer */
    .to-overlay { position:fixed; inset:0; z-index:1050; background:rgba(0,0,0,.45); backdrop-filter:blur(1px); }
    .ato-panel { position:fixed; top:0; right:0; bottom:0; width:580px; z-index:1051; background:#fff; box-shadow:-8px 0 48px rgba(0,0,0,.18); display:flex; flex-direction:column; animation:ato-slide-in .22s cubic-bezier(.4,0,.2,1); }
    @@keyframes ato-slide-in { from { transform:translateX(100%); } to { transform:translateX(0); } }
    .ato-head { display:flex; align-items:center; justify-content:space-between; padding:22px 28px 18px; border-bottom:1px solid #f0f0f0; flex-shrink:0; }
    .ato-title { font-size:1.25rem; font-weight:700; color:#111827; }
