@page "/time-off"
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory ClientFactory
@inject TimeOffPolicyService PolicyService
@inject SessionService SessionService
@inject LeaveRequestService LeaveRequestService

<div class="timeoff-container">

    <!-- Page Header -->
    <div class="to-page-header">
        <h2 class="to-title">@(IsUserRole && activeTab == "leaveRequests" ? "Leave Requests" : "Overview")</h2>
        <div class="to-header-actions">
            @if (IsUserRole)
            {
                <button class="to-btn-add to-btn-new-request" @onclick="OpenLrForm">
                    <i class="bi bi-plus"></i> New Request
                </button>
            }
            else
            {
                <button class="to-btn-export" @onclick="OpenExport">
                    <i class="bi bi-download"></i> Export
                </button>
                <button class="to-btn-add" @onclick="OpenAddTimeOff">
                    Add Time Off
                </button>
            }
        </div>
    </div>

    <!-- Tabs -->
    <div class="to-tabs">
        <span class="to-tab @(activeTab == "overview" ? "to-tab-active" : "")"
              @onclick='() => activeTab = "overview"'>Overview</span>
        <span class="to-tab @(activeTab == "leave" ? "to-tab-active" : "")"
              @onclick='() => activeTab = "leave"'>Leave Balance</span>
        @if (IsUserRole)
        {
            <span class="to-tab @(activeTab == "leaveRequests" ? "to-tab-active" : "")"
                  @onclick='() => activeTab = "leaveRequests"'>Leave Requests</span>
        }
    </div>

    @if (activeTab == "overview")
    {
        @* ════════════════════════════════════════════════════════
           USER LEAVE DASHBOARD — Zoho-style overview for logged-in user
           Shown only when IsUserRole; admin sees the standard overview below
           ════════════════════════════════════════════════════════ *@
        @if (IsUserRole)
        {
            @* ── Summary Cards ── *@
            <div class="lov-cards-row">
                @{
                    var approvedRequests  = myLeaveRequests.Where(r => r.Status == "Approved").ToList();
                    var pendingRequests   = myLeaveRequests.Where(r => r.Status.StartsWith("Pending")).ToList();
                    var thisMonthTaken    = approvedRequests.Where(r => r.StartDate.Month == DateTime.Today.Month && r.StartDate.Year == DateTime.Today.Year).ToList();
                    var upcomingLeaves    = approvedRequests.Where(r => r.StartDate.Date > DateTime.Today).OrderBy(r => r.StartDate).ToList();
                    int thisMonthDays     = thisMonthTaken.Sum(r => { var e = r.EndDate ?? r.StartDate; return (e.Date - r.StartDate.Date).Days + 1; });
                    int totalPolicyDays   = (int)policies.Sum(p => p.AnnualEntitlement);
                    int usedDays          = approvedRequests.Sum(r => { var e = r.EndDate ?? r.StartDate; return (e.Date - r.StartDate.Date).Days + 1; });
                    int availableDays     = Math.Max(0, totalPolicyDays - usedDays);
                }
                <div class="lov-card lov-card--available">
                    <div class="lov-card-icon"><i class="bi bi-calendar-check"></i></div>
                    <div class="lov-card-body">
                        <span class="lov-card-value">@availableDays</span>
                        <span class="lov-card-label">Available Leaves</span>
                    </div>
                </div>
                <div class="lov-card lov-card--taken">
                    <div class="lov-card-icon"><i class="bi bi-calendar-x"></i></div>
                    <div class="lov-card-body">
                        <span class="lov-card-value">@thisMonthDays</span>
                        <span class="lov-card-label">Taken This Month</span>
                    </div>
                </div>
                <div class="lov-card lov-card--pending">
                    <div class="lov-card-icon"><i class="bi bi-hourglass-split"></i></div>
                    <div class="lov-card-body">
                        <span class="lov-card-value">@pendingRequests.Count</span>
                        <span class="lov-card-label">Pending Requests</span>
                    </div>
                </div>
                <div class="lov-card lov-card--upcoming">
                    <div class="lov-card-icon"><i class="bi bi-calendar2-week"></i></div>
                    <div class="lov-card-body">
                        <span class="lov-card-value">@upcomingLeaves.Count</span>
                        <span class="lov-card-label">Upcoming Leaves</span>
                    </div>
                </div>
            </div>

            @* ── Middle Row: Balance Bars + Mini Calendar ── *@
            <div class="lov-mid-row">
                @* LEFT: Leave Balance Bars *@
                <div class="lov-balance-card">
                    <div class="lov-section-header">
                        <span class="lov-section-title">Leave Balance</span>
                        <span class="lov-section-sub">@DateTime.Today.Year</span>
                    </div>
                    @if (!policies.Any())
                    {
                        <div class="lov-empty-small">No leave policies configured.</div>
                    }
                    else
                    {
                        @foreach (var pol in policies)
                        {
                            int polUsed  = approvedRequests.Sum(rr => { var e = rr.EndDate ?? rr.StartDate; return (e.Date - rr.StartDate.Date).Days + 1; });
                            int polTotal = pol.AnnualEntitlement > 0 ? (int)pol.AnnualEntitlement : 1;
                            int polAvail = Math.Max(0, polTotal - polUsed);
                            double pct   = Math.Min(100, (polUsed * 100.0) / polTotal);
                            <div class="lov-bal-row">
                                <div class="lov-bal-header">
                                    <span class="lov-bal-name">@pol.Name</span>
                                    <span class="lov-bal-counts"><b>@polAvail</b> / @polTotal days left</span>
                                </div>
                                <div class="lov-bal-track">
                                    <div class="lov-bal-fill" style="width:@(pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                </div>
                                <div class="lov-bal-footer">
                                    <span class="lov-bal-used">@polUsed used</span>
                                    <span class="lov-bal-avail">@polAvail remaining</span>
                                </div>
                            </div>
                        }
                    }
                </div>

                @* RIGHT: Mini Calendar with leave highlights *@
                <div class="lov-cal-card">
                    <div class="lov-section-header">
                        <button class="lov-cal-nav" @onclick="() => lovCalMonth = lovCalMonth.AddMonths(-1)">&#8249;</button>
                        <span class="lov-section-title">@lovCalMonth.ToString("MMMM yyyy")</span>
                        <button class="lov-cal-nav" @onclick="() => lovCalMonth = lovCalMonth.AddMonths(1)">&#8250;</button>
                    </div>
                    <div class="lov-cal-legend">
                        <span class="lov-leg-dot lov-leg-dot--approved"></span><span>Approved</span>
                        <span class="lov-leg-dot lov-leg-dot--pending" style="margin-left:12px;"></span><span>Pending</span>
                    </div>
                    <div class="lov-mini-cal-grid">
                        @foreach (var dn in new[]{"Mo","Tu","We","Th","Fr","Sa","Su"})
                        { <div class="lov-cal-dn">@dn</div> }
                        @{
                            var first = new DateTime(lovCalMonth.Year, lovCalMonth.Month, 1).DayOfWeek;
                            int blanks = first == DayOfWeek.Sunday ? 6 : (int)first - 1;
                        }
                        @for (int b = 0; b < blanks; b++) { <div></div> }
                        @for (int d = 1; d <= DateTime.DaysInMonth(lovCalMonth.Year, lovCalMonth.Month); d++)
                        {
                            var day = d;
                            var td  = new DateTime(lovCalMonth.Year, lovCalMonth.Month, day);
                            var isToday = td.Date == DateTime.Today;

                            // Check if this date falls in any leave request
                            var matchApproved = myLeaveRequests.FirstOrDefault(r =>
                                r.Status == "Approved" &&
                                td.Date >= r.StartDate.Date &&
                                td.Date <= (r.EndDate ?? r.StartDate).Date);
                            var matchPending = myLeaveRequests.FirstOrDefault(r =>
                                r.Status.StartsWith("Pending") &&
                                td.Date >= r.StartDate.Date &&
                                td.Date <= (r.EndDate ?? r.StartDate).Date);

                            string calCss = isToday ? "lov-cal-today" : "";
                            if (matchApproved != null) calCss += " lov-cal-approved";
                            else if (matchPending != null) calCss += " lov-cal-pending";

                            <div class="lov-mini-cal-day @calCss" title="@(matchApproved != null ? "Approved Leave" : matchPending != null ? "Pending Leave" : "")">@day</div>
                        }
                    </div>
                </div>
            </div>

            @* ── Trend Chart + Right Panel Row ── *@
            <div class="lov-bottom-row">
                @* Trend Chart *@
                <div class="lov-trend-card">
                    <div class="lov-section-header">
                        <span class="lov-section-title">Monthly Leave Usage</span>
                        <span class="lov-section-sub">Last 6 months</span>
                    </div>
                    @{
                        var months = Enumerable.Range(0, 6)
                            .Select(i => DateTime.Today.AddMonths(-5 + i))
                            .ToList();
                        var monthlyData = months.Select(m => new {
                            Label = m.ToString("MMM"),
                            Days  = approvedRequests
                                .Where(r => r.StartDate.Month == m.Month && r.StartDate.Year == m.Year)
                                .Sum(r => { var e = r.EndDate ?? r.StartDate; return (e.Date - r.StartDate.Date).Days + 1; })
                        }).ToList();
                        int maxDays = monthlyData.Max(x => x.Days);
                        if (maxDays == 0) maxDays = 1;
                    }
                    <div class="lov-chart-wrap">
                        @foreach (var md in monthlyData)
                        {
                            double barPct = (md.Days * 100.0) / maxDays;
                            <div class="lov-chart-col">
                                <span class="lov-chart-val">@(md.Days > 0 ? md.Days.ToString() : "")</span>
                                <div class="lov-chart-bar-wrap">
                                    <div class="lov-chart-bar" style="height:@(barPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                </div>
                                <span class="lov-chart-label">@md.Label</span>
                            </div>
                        }
                    </div>
                </div>

                @* Right: Upcoming + Recent Activity *@
                <div class="lov-right-panel">
                    @* Upcoming Leaves *@
                    <div class="lov-upcoming-card">
                        <div class="lov-section-header">
                            <span class="lov-section-title">Upcoming Leaves</span>
                            @if (upcomingLeaves.Any())
                            {
                                <span class="lov-badge-count">@upcomingLeaves.Count</span>
                            }
                        </div>
                        @if (!upcomingLeaves.Any())
                        {
                            <div class="lov-empty-small">No upcoming leaves scheduled.</div>
                        }
                        else
                        {
                            @foreach (var ul in upcomingLeaves.Take(4))
                            {
                                var uEnd   = ul.EndDate ?? ul.StartDate;
                                var uDays  = (uEnd.Date - ul.StartDate.Date).Days + 1;
                                <div class="lov-upcoming-row">
                                    <div class="lov-upcoming-dot lov-upcoming-dot--approved"></div>
                                    <div class="lov-upcoming-info">
                                        <span class="lov-upcoming-dates">@ul.StartDate.ToString("MMM dd") @(ul.EndDate.HasValue && ul.EndDate.Value.Date != ul.StartDate.Date ? $"– {ul.EndDate.Value:MMM dd}" : "")</span>
                                        <span class="lov-upcoming-meta">@uDays day@(uDays != 1 ? "s" : "") · Approved</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @* Recent Activity *@
                    <div class="lov-activity-card">
                        <div class="lov-section-header">
                            <span class="lov-section-title">Recent Activity</span>
                        </div>
                        @{
                            var recentActivity = myLeaveRequests
                                .OrderByDescending(r => r.CreatedAt)
                                .Take(5)
                                .ToList();
                        }
                        @if (!recentActivity.Any())
                        {
                            <div class="lov-empty-small">No recent activity.</div>
                        }
                        else
                        {
                            @foreach (var act in recentActivity)
                            {
                                string actIcon  = act.Status == "Approved" ? "bi-check-circle-fill" :
                                                  act.Status.StartsWith("Rejected") ? "bi-x-circle-fill" : "bi-clock-fill";
                                string actClass = act.Status == "Approved" ? "lov-act--approved" :
                                                  act.Status.StartsWith("Rejected") ? "lov-act--rejected" : "lov-act--pending";
                                string actLabel = act.DisplayStatus;
                                <div class="lov-act-row">
                                    <i class="bi @actIcon lov-act-icon @actClass"></i>
                                    <div class="lov-act-info">
                                        <span class="lov-act-title">Leave @actLabel</span>
                                        <span class="lov-act-date">@act.StartDate.ToString("MMM dd, yyyy")@(act.EndDate.HasValue && act.EndDate.Value.Date != act.StartDate.Date ? $" – {act.EndDate.Value:MMM dd}" : "")</span>
                                    </div>
                                    <span class="lov-act-time">@act.CreatedAt.ToString("MMM dd")</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }

        @* ════ Admin Overview content below (hidden for user role) ════ *@
        @if (!IsUserRole)
        {

        <!-- Date Range Filter Row -->
        <div class="to-filter-row">
            <div class="to-date-selector" style="position:relative;">

                @* ── Preset label button ── *@
                <div class="to-range-btn @(presetOpen ? "to-range-btn--open" : "")" @onclick="() => { presetOpen = !presetOpen; datePickerOpen = false; }">
                    <span class="to-range-label">@selectedPreset</span>
                    <i class="bi @(presetOpen ? "bi-chevron-up" : "bi-chevron-down") to-range-caret"></i>
                </div>

                @* ── Preset dropdown ── *@
                @if (presetOpen)
                {
                    <div class="to-preset-popup" @onclick:stopPropagation>
                        @foreach (var preset in new[]{"Today","Yesterday","Last 7 days","Last week","This week","This month","This year","Last month","Custom"})
                        {
                            var ps = preset;
                            <div class="to-preset-row @(selectedPreset == ps ? "to-preset-row--active" : "")"
                                 @onclick="() => ApplyPreset(ps)">
                                <span>@ps</span>
                                @if (selectedPreset == ps) { <i class="bi bi-check2 to-preset-check"></i> }
                            </div>
                        }
                    </div>
                    <div style="position:fixed;inset:0;z-index:498;" @onclick="() => presetOpen=false"></div>
                }

                @* ── Date range display + calendar icon ── *@
                <div class="to-range-display-wrap" @onclick='() => { if(selectedPreset=="Custom") { datePickerOpen=!datePickerOpen; presetOpen=false; } }'>
                    <span class="to-range-display">
                        @filterStart.ToString("MMM, dd yyyy") &ndash; @filterEnd.ToString("MMM, dd yyyy")
                    </span>
                    <i class="bi bi-calendar3 to-range-cal-icon" @onclick='() => { selectedPreset="Custom"; datePickerOpen=!datePickerOpen; presetOpen=false; }' @onclick:stopPropagation></i>
                </div>

                @* ── Custom date picker calendar ── *@
                @if (datePickerOpen)
                {
                    <div class="to-datepicker-popup" @onclick:stopPropagation>
                        <div class="to-cal-header">
                            <button class="to-cal-nav" @onclick="FilterCalPrev">&#8249;</button>
                            <span class="to-cal-month-label">@filterCalDate.ToString("MMMM")</span>
                            <button class="to-cal-nav" @onclick="FilterCalNext">&#8250;</button>
                            <button class="to-cal-nav" @onclick="FilterCalPrevYear">&#8249;</button>
                            <span class="to-cal-year-label">@filterCalDate.Year</span>
                            <button class="to-cal-nav" @onclick="FilterCalNextYear">&#8250;</button>
                        </div>
                        <div class="to-cal-pick-hint">@(pickingStart ? "Select start date" : "Select end date")</div>
                        <div class="to-cal-grid">
                            @foreach (var dn in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"})
                            {
                                <div class="to-cal-dayname">@dn</div>
                            }
                            @for (int blank = 0; blank < FilterCalStartBlank(); blank++)
                            {
                                <div></div>
                            }
                            @for (int d = 1; d <= DateTime.DaysInMonth(filterCalDate.Year, filterCalDate.Month); d++)
                            {
                                var day = d;
                                var thisDate = new DateTime(filterCalDate.Year, filterCalDate.Month, day);
                                var isSel    = thisDate.Date == filterStart.Date || thisDate.Date == filterEnd.Date;
                                var inRange  = thisDate.Date > filterStart.Date && thisDate.Date < filterEnd.Date;
                                var isToday  = thisDate.Date == DateTime.Today;
                                <div class="to-cal-day @(isSel ? "to-cal-day--sel" : "") @(inRange ? "to-cal-day--range" : "") @(isToday && !isSel ? "to-cal-day--today" : "")"
                                     @onclick="() => PickFilterDate(day)">@day</div>
                            }
                        </div>
                    </div>
                    <div style="position:fixed;inset:0;z-index:498;" @onclick="() => { datePickerOpen=false; pickingStart=true; }"></div>
                }
            </div>
        </div>

        <!-- Search & Filter Bar -->
        <div class="to-search-bar" @onclick="CloseAllFilterDropdowns">
            <div class="to-search-input-wrap">
                <i class="bi bi-search to-search-icon"></i>
                <input class="to-search-input" placeholder="Search members..." @bind="searchText" @bind:event="oninput" @onclick:stopPropagation />
            </div>
            <div class="to-filter-divider"></div>
            <div class="to-filter-group">

                @* ── Policies dropdown ── *@
                <div class="to-filter-dd-wrap" @onclick:stopPropagation>
                    <button class="to-filter-btn @(filterPolicyIds.Any() ? "to-filter-btn--active" : "")"
                            @onclick="() => { filterPoliciesOpen = !filterPoliciesOpen; filterStatusesOpen = false; }">
                        @if (filterPolicyIds.Any())
                        {
                            <span>Policies: <strong>@string.Join(", ", policies.Where(p => filterPolicyIds.Contains(p.Id)).Select(p => p.Name))</strong></span>
                        }
                        else
                        {
                            <span>Policies</span>
                        }
                        <i class="bi @(filterPoliciesOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                    @if (filterPoliciesOpen)
                    {
                        <div class="to-filter-popup" @onclick:stopPropagation>
                            <div class="to-filter-popup-search">
                                <i class="bi bi-search" style="color:#aaa;font-size:.8rem;"></i>
                                <input class="to-filter-popup-input" placeholder="Search policies" @bind="filterPoliciesSearch" @bind:event="oninput" />
                            </div>
                            @{ var filtPolicies = string.IsNullOrWhiteSpace(filterPoliciesSearch) ? policies : policies.Where(p => p.Name.Contains(filterPoliciesSearch, StringComparison.OrdinalIgnoreCase)).ToList(); }
                            @foreach (var pol in filtPolicies)
                            {
                                var p = pol;
                                var isChecked = filterPolicyIds.Contains(p.Id);
                                <div class="to-filter-popup-row" @onclick="() => { if(!filterPolicyIds.Remove(p.Id)) filterPolicyIds.Add(p.Id); }">
                                    <span>@p.Name</span>
                                    @if (isChecked) { <i class="bi bi-check2" style="color:#f07820;font-weight:700;"></i> }
                                </div>
                            }
                            @if (!filtPolicies.Any()) { <div class="to-filter-popup-empty">No policies found</div> }
                            @if (filterPolicyIds.Any())
                            {
                                <div class="to-filter-popup-clear" @onclick='() => { filterPolicyIds = new(); filterPoliciesSearch = string.Empty; }'>Clear selection</div>
                            }
                        </div>
                        <div style="position:fixed;inset:0;z-index:498;" @onclick="() => filterPoliciesOpen=false"></div>
                    }
                </div>

                @* ── Positions (static, no data) ── *@
                <button class="to-filter-btn">Positions <i class="bi bi-chevron-down"></i></button>

                @* ── Employment types (static, no data) ── *@
                <button class="to-filter-btn">Employment types <i class="bi bi-chevron-down"></i></button>

                @* ── Statuses dropdown ── *@
                <div class="to-filter-dd-wrap" @onclick:stopPropagation>
                    <button class="to-filter-btn @(filterStatuses.Any() ? "to-filter-btn--active" : "")"
                            @onclick="() => { filterStatusesOpen = !filterStatusesOpen; filterPoliciesOpen = false; }">
                        @if (filterStatuses.Any())
                        {
                            <span>Statuses: <strong>@string.Join(", ", filterStatuses)</strong></span>
                        }
                        else
                        {
                            <span>Statuses</span>
                        }
                        <i class="bi @(filterStatusesOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                    @if (filterStatusesOpen)
                    {
                        <div class="to-filter-popup" @onclick:stopPropagation>
                            @foreach (var st in new[]{"Pending","Approved","Rejected","Cancelled"})
                            {
                                var s = st;
                                var isChecked = filterStatuses.Contains(s);
                                <div class="to-filter-popup-row" @onclick="() => { if(!filterStatuses.Remove(s)) filterStatuses.Add(s); }">
                                    <span>@s</span>
                                    @if (isChecked) { <i class="bi bi-check2" style="color:#f07820;font-weight:700;"></i> }
                                </div>
                            }
                            @if (filterStatuses.Any())
                            {
                                <div class="to-filter-popup-clear" @onclick="() => filterStatuses = new()">Clear selection</div>
                            }
                        </div>
                        <div style="position:fixed;inset:0;z-index:498;" @onclick="() => filterStatusesOpen=false"></div>
                    }
                </div>

                <div class="to-filter-divider"></div>
                <button class="to-reset-btn" @onclick="ResetFilters">Reset</button>
            </div>
        </div>

        @* Bulk action bar - shown when rows are selected *@
        @if (selectedIds.Any())
        {
            <div class="to-bulk-bar">
                <span class="to-bulk-count">@selectedIds.Count selected</span>
                <button class="to-bulk-cancel" @onclick="ClearSelection">Cancel</button>
                <div style="flex:1;"></div>
                <button class="to-bulk-btn to-bulk-cancel-req" @onclick="BulkCancelRequest">Cancel request</button>
            </div>
        }

        @if (isLoading)
        {
            <div class="to-loading"><div class="to-spinner"></div></div>
        }
        else if (!filteredRequests.Any())
        {
            <div class="to-empty-state">
                <div class="to-empty-illustration">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="280" height="210">
                        <ellipse cx="200" cy="265" rx="130" ry="22" fill="#e0e0e0" opacity="0.6"/>
                        <ellipse cx="140" cy="200" rx="95" ry="75" fill="#e8e8e8" opacity="0.7"/>
                        <rect x="130" y="185" width="90" height="75" rx="8" fill="#4a7fd4"/>
                        <rect x="135" y="190" width="80" height="65" rx="6" fill="#5585dc"/>
                        <rect x="157" y="175" width="36" height="15" rx="7" fill="none" stroke="#3a6fc4" stroke-width="4"/>
                        <rect x="165" y="218" width="20" height="14" rx="3" fill="#ffa040"/>
                        <rect x="195" y="165" width="55" height="70" rx="10" fill="#f07820"/>
                        <circle cx="222" cy="150" r="22" fill="#8B5E3C"/>
                        <rect x="198" y="225" width="22" height="50" rx="6" fill="#4a90d9"/>
                        <rect x="225" y="225" width="22" height="50" rx="6" fill="#3a80c9"/>
                        <path d="M195 185 Q165 205 155 220" stroke="#f07820" stroke-width="14" stroke-linecap="round" fill="none"/>
                        <path d="M250 185 Q265 195 268 185" stroke="#f07820" stroke-width="14" stroke-linecap="round" fill="none"/>
                        <line x1="310" y1="205" x2="310" y2="150" stroke="#a0c878" stroke-width="3"/>
                        <ellipse cx="310" cy="160" rx="22" ry="12" fill="#a0c878" transform="rotate(-30 310 160)"/>
                        <ellipse cx="310" cy="150" rx="22" ry="12" fill="#b0d888" transform="rotate(30 310 150)"/>
                    </svg>
                </div>
                <h4 class="to-empty-title">No time off</h4>
                <p class="to-empty-sub">Record time off for your team members to have them reflected in timesheets and reports.</p>
                <button class="to-btn-add" @onclick="OpenAddTimeOff">Add Time Off</button>
            </div>
        }
        else
        {
            <div class="to-table-wrap">
                <table class="to-table">
                    <thead>
                        <tr>
                            <th>
                                <input type="checkbox"
                                       checked="@(selectedIds.Count == filteredRequests.Count && filteredRequests.Any())"
                                       @onchange="ToggleSelectAll" />
                            </th>
                            <th>@filteredRequests.Count of @filteredRequests.Count time off</th>
                            <th>Dates</th>
                            <th>Duration <i class="bi bi-info-circle" style="font-size:.75rem;color:#aaa;"></i></th>
                            <th>Time Off Policy</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in filteredRequests)
                        {
                            var r = req;
                            var selectable = IsSelectableRow(r);
                            var isChecked  = selectedIds.Contains(r.Id);
                            <tr class="@(isChecked ? "to-row-selected" : "") @(!selectable ? "to-row-unselectable" : "")">
                                <td>
                                    @if (selectable)
                                    {
                                        <input type="checkbox" checked="@isChecked"
                                               @onchange="() => ToggleRowSelect(r.Id)" />
                                    }
                                    else
                                    {
                                        <input type="checkbox" disabled style="opacity:0.3;cursor:not-allowed;" />
                                    }
                                </td>
                                <td>
                                    <div class="to-member-cell">
                                        <div class="to-member-avatar">@(r.EmployeeName.Length > 0 ? r.EmployeeName[0].ToString().ToUpper() : "?")</div>
                                        <span class="to-member-name">@r.EmployeeName</span>
                                    </div>
                                </td>
                                <td class="to-dates-cell">@FormatDates(r)</td>
                                <td class="to-duration-cell">@FormatDuration(r)</td>
                                <td class="to-policy-cell">@r.PolicyName</td>
                                <td>
                                    <span class="to-status-badge to-status-@r.Status.ToLower()">
                                        <span class="to-status-dot"></span>@r.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="to-row-actions">
                                        @if (r.Status == "Pending")
                                        {
                                            <button class="to-action-btn to-action-edit"    title="Edit"           @onclick="() => OpenEditRequest(r)"><i class="bi bi-pencil"></i></button>
                                            <button class="to-action-btn to-action-delete"  title="Cancel request" @onclick='() => ConfirmDelete(r.Id)'><i class="bi bi-x-lg"></i></button>
                                            <button class="to-action-btn to-action-approve" title="Approve"        @onclick='() => ConfirmApprove(r.Id)'><i class="bi bi-check-lg"></i></button>
                                            <button class="to-action-btn to-action-reject"  title="Reject"         @onclick='() => ConfirmReject(r.Id)'><i class="bi bi-x-circle"></i></button>
                                        }
                                        else if (r.Status == "Approved")
                                        {
                                            <button class="to-action-btn to-action-cancel-req" title="Cancel request" @onclick='() => ConfirmCancel(r.Id)'><i class="bi bi-x-circle"></i></button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        } @* end !IsUserRole admin overview *@
    }
    else if (activeTab == "leaveRequests" && IsUserRole)
    {
        @* ════════════════════════════════════════════════════════
           MY LEAVE REQUESTS — wired to api/leave-requests
           ════════════════════════════════════════════════════════ *@
        <div class="lr-section-card">
            <div class="lr-section-header">
                <span class="lr-section-title">My Leave Requests</span>
                @if (!lrFormOpen)
                {
                    <button class="to-btn-add lr-apply-btn" @onclick="OpenLrForm">
                        <i class="bi bi-plus"></i> Apply Leave
                    </button>
                }
            </div>

            @* ── Inline New Request Form ── *@
            @if (lrFormOpen)
            {
                <div class="lr-form-card">
                    <div class="lr-form-header">
                        <span class="lr-form-title">New Leave Request</span>
                        <button class="lr-form-close" @onclick="CloseLrForm"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="lr-form-body">
                        @* Date row *@
                        <div class="lr-date-row">
                            @* Start Date *@
                            <div class="lr-field" style="position:relative;flex:1;">
                                <label class="lr-label">Start Date</label>
                                <div class="lr-date-box @(lrStartCalOpen ? "lr-date-box--open" : "") @(lrStartErr ? "lr-date-box--err" : "")"
                                     @onclick="() => { lrStartCalOpen = !lrStartCalOpen; lrEndCalOpen = false; }">
                                    <i class="bi bi-calendar3 lr-field-icon"></i>
                                    <span class="@(lrStartDate.HasValue ? "lr-selected" : "lr-placeholder")">
                                        @(lrStartDate.HasValue ? lrStartDate.Value.ToString("MMM dd, yyyy") : "Start date")
                                    </span>
                                </div>
                                @if (lrStartErr) { <small class="lr-err">Start date is required.</small> }
                                @if (lrStartCalOpen)
                                {
                                    <div class="lr-calendar" @onclick:stopPropagation>
                                        <div class="lr-cal-head">
                                            <button class="lr-cal-nav" @onclick="() => lrCalDate = lrCalDate.AddMonths(-1)">&#8249;</button>
                                            <span class="lr-cal-label">@lrCalDate.ToString("MMMM yyyy")</span>
                                            <button class="lr-cal-nav" @onclick="() => lrCalDate = lrCalDate.AddMonths(1)">&#8250;</button>
                                        </div>
                                        <div class="lr-cal-grid">
                                            @foreach (var dn in new[]{"Mo","Tu","We","Th","Fr","Sa","Su"})
                                            { <div class="lr-cal-dn">@dn</div> }
                                            @{ int sb = LrCalBlank(); }
                                            @for (int b = 0; b < sb; b++) { <div></div> }
                                            @for (int d = 1; d <= DateTime.DaysInMonth(lrCalDate.Year, lrCalDate.Month); d++)
                                            {
                                                var day = d;
                                                var td  = new DateTime(lrCalDate.Year, lrCalDate.Month, day);
                                                var isSel   = lrStartDate.HasValue && td.Date == lrStartDate.Value.Date;
                                                var inRange = lrStartDate.HasValue && lrEndDate.HasValue && td > lrStartDate.Value && td < lrEndDate.Value;
                                                <div class="lr-cal-day @(isSel?"lr-cal-day--sel":"") @(inRange?"lr-cal-day--range":"") @(td.Date==DateTime.Today&&!isSel?"lr-cal-day--today":"")"
                                                     @onclick="() => { lrStartDate = new DateTime(lrCalDate.Year, lrCalDate.Month, day); if(lrEndDate.HasValue && lrStartDate > lrEndDate) lrEndDate=null; lrStartCalOpen=false; lrStartErr=false; }">@day</div>
                                            }
                                        </div>
                                    </div>
                                    <div style="position:fixed;inset:0;z-index:498;" @onclick="() => lrStartCalOpen=false"></div>
                                }
                            </div>

                            <div class="lr-date-sep"><i class="bi bi-arrow-right" style="color:#9ca3af;"></i></div>

                            @* End Date *@
                            <div class="lr-field" style="position:relative;flex:1;">
                                <label class="lr-label">End Date <span style="color:#9ca3af;font-weight:400;">(optional)</span></label>
                                <div class="lr-date-box @(lrEndCalOpen ? "lr-date-box--open" : "")"
                                     @onclick="() => { lrEndCalOpen = !lrEndCalOpen; lrStartCalOpen = false; }">
                                    <i class="bi bi-calendar3 lr-field-icon"></i>
                                    <span class="@(lrEndDate.HasValue ? "lr-selected" : "lr-placeholder")">
                                        @(lrEndDate.HasValue ? lrEndDate.Value.ToString("MMM dd, yyyy") : "End date (optional)")
                                    </span>
                                </div>
                                @if (lrEndCalOpen)
                                {
                                    <div class="lr-calendar" @onclick:stopPropagation>
                                        <div class="lr-cal-head">
                                            <button class="lr-cal-nav" @onclick="() => lrCalDate = lrCalDate.AddMonths(-1)">&#8249;</button>
                                            <span class="lr-cal-label">@lrCalDate.ToString("MMMM yyyy")</span>
                                            <button class="lr-cal-nav" @onclick="() => lrCalDate = lrCalDate.AddMonths(1)">&#8250;</button>
                                        </div>
                                        <div class="lr-cal-grid">
                                            @foreach (var dn in new[]{"Mo","Tu","We","Th","Fr","Sa","Su"})
                                            { <div class="lr-cal-dn">@dn</div> }
                                            @{ int sb2 = LrCalBlank(); }
                                            @for (int b = 0; b < sb2; b++) { <div></div> }
                                            @for (int d = 1; d <= DateTime.DaysInMonth(lrCalDate.Year, lrCalDate.Month); d++)
                                            {
                                                var day = d;
                                                var td  = new DateTime(lrCalDate.Year, lrCalDate.Month, day);
                                                var isSel   = lrEndDate.HasValue && td.Date == lrEndDate.Value.Date;
                                                var inRange = lrStartDate.HasValue && lrEndDate.HasValue && td > lrStartDate.Value && td < lrEndDate.Value;
                                                <div class="lr-cal-day @(isSel?"lr-cal-day--sel":"") @(inRange?"lr-cal-day--range":"") @(td.Date==DateTime.Today&&!isSel?"lr-cal-day--today":"")"
                                                     @onclick="() => { lrEndDate = new DateTime(lrCalDate.Year, lrCalDate.Month, day); lrEndCalOpen=false; }">@day</div>
                                            }
                                        </div>
                                    </div>
                                    <div style="position:fixed;inset:0;z-index:498;" @onclick="() => lrEndCalOpen=false"></div>
                                }
                            </div>
                        </div>

                        @* Type of Leave *@
                        <div class="lr-field" style="position:relative;">
                            <label class="lr-label">Type of Leave <span style="color:#ef4444;">*</span></label>
                            <div class="lr-policy-box @(lrPolicyOpen ? "lr-policy-box--open" : "") @(lrPolicyErr ? "lr-date-box--err" : "")"
                                 @onclick="() => { lrPolicyOpen = !lrPolicyOpen; lrStartCalOpen = false; lrEndCalOpen = false; }" @onclick:stopPropagation>
                                <i class="bi bi-tag lr-field-icon"></i>
                                <span class="@(lrSelectedPolicy != null ? "lr-selected" : "lr-placeholder")">
                                    @(lrSelectedPolicy != null ? lrSelectedPolicy.Name : "Select leave type")
                                </span>
                                <i class="bi @(lrPolicyOpen ? "bi-chevron-up" : "bi-chevron-down") lr-policy-caret"></i>
                            </div>
                            @if (lrPolicyErr) { <small class="lr-err">Please select a leave type.</small> }
                            @if (lrPolicyOpen)
                            {
                                <div class="lr-policy-dropdown" @onclick:stopPropagation>
                                    <div class="lr-policy-search-wrap">
                                        <i class="bi bi-search" style="color:#aaa;font-size:.8rem;"></i>
                                        <input class="lr-policy-search-input" placeholder="Search leave types…"
                                               @bind="lrPolicySearch" @bind:event="oninput" />
                                    </div>
                                    @{
                                        var visiblePolicies = string.IsNullOrWhiteSpace(lrPolicySearch)
                                            ? policies
                                            : policies.Where(p => p.Name.Contains(lrPolicySearch, StringComparison.OrdinalIgnoreCase)).ToList();
                                    }
                                    @if (!visiblePolicies.Any())
                                    {
                                        <div class="lr-policy-empty">No leave types found</div>
                                    }
                                    else
                                    {
                                        @foreach (var pol in visiblePolicies)
                                        {
                                            var p = pol;
                                            var isActive = lrSelectedPolicy?.Id == p.Id;
                                            <div class="lr-policy-option @(isActive ? "lr-policy-option--active" : "")"
                                                 @onclick='() => { lrSelectedPolicy = p; lrPolicyOpen = false; lrPolicySearch = ""; lrPolicyErr = false; }'>
                                                <span class="lr-policy-name">@p.Name</span>
                                                <span class="lr-policy-days">@p.AnnualEntitlement days/yr</span>
                                                @if (isActive) { <i class="bi bi-check2 lr-policy-check"></i> }
                                            </div>
                                        }
                                    }
                                </div>
                                <div style="position:fixed;inset:0;z-index:498;" @onclick="() => lrPolicyOpen=false"></div>
                            }
                        </div>

                        @* Reason *@
                        <div class="lr-field">
                            <label class="lr-label">Reason <span style="color:#9ca3af;font-weight:400;">(optional)</span></label>
                            <div class="lr-textarea-wrap">
                                <textarea class="lr-textarea" rows="4" placeholder="Add a reason or note for your leave..." @bind="lrReason"></textarea>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(lrSaveError))
                        {
                            <div class="lr-error-msg"><i class="bi bi-exclamation-circle"></i> @lrSaveError</div>
                        }
                    </div>
                    <div class="lr-form-footer">
                        <button class="lr-btn-cancel" @onclick="CloseLrForm">Cancel</button>
                        <button class="lr-btn-submit" @onclick="SubmitLeaveRequest" disabled="@lrSaving">
                            @if (lrSaving) { <span class="lr-mini-spin"></span> <span>Submitting...</span> }
                            else { <span>Submit Request</span> }
                        </button>
                    </div>
                </div>
            }

            @* ── Loading ── *@
            @if (isLoadingLeaveRequests)
            {
                <div class="to-loading" style="padding:60px 0;"><div class="to-spinner"></div></div>
            }
            @* ── Empty state ── *@
            else if (!myLeaveRequests.Any() && !lrFormOpen)
            {
                <div class="lr-empty-state">
                    <div class="lr-empty-illustration">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 180" width="180" height="160">
                            <ellipse cx="100" cy="168" rx="70" ry="10" fill="#e0e0e0" opacity="0.5"/>
                            <rect x="30" y="20" width="120" height="140" rx="10" fill="#fff" stroke="#e8e8e8" stroke-width="1.5"/>
                            <rect x="30" y="20" width="120" height="28" rx="10" fill="#fde8d8"/>
                            <rect x="30" y="36" width="120" height="12" fill="#fde8d8"/>
                            <rect x="46" y="66" width="88" height="8" rx="4" fill="#ebebeb"/>
                            <rect x="46" y="82" width="70" height="8" rx="4" fill="#ebebeb"/>
                            <rect x="46" y="98" width="80" height="8" rx="4" fill="#ebebeb"/>
                            <rect x="46" y="114" width="55" height="8" rx="4" fill="#ebebeb"/>
                            <circle cx="138" cy="132" r="18" fill="#f07820"/>
                            <line x1="138" y1="123" x2="138" y2="141" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                            <line x1="129" y1="132" x2="147" y2="132" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h4 class="lr-empty-title">No leave requests found</h4>
                    <p class="lr-empty-sub">You haven't submitted any leave requests yet. Apply for your first leave now.</p>
                    <button class="to-btn-add lr-apply-btn" @onclick="OpenLrForm">
                        <i class="bi bi-plus"></i> Apply Your First Leave
                    </button>
                </div>
            }
            @* ── Data table ── *@
            else if (myLeaveRequests.Any())
            {
                <div class="lr-table-wrap">
                    <table class="lr-table">
                        <thead>
                            <tr>
                                <th class="lr-th">Date Range</th>
                                <th class="lr-th">Leave Type</th>
                                <th class="lr-th">Reason</th>
                                <th class="lr-th">Status</th>
                                <th class="lr-th">Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in myLeaveRequests)
                            {
                                var r = req;
                                <tr class="lr-tr">
                                    @* Date Range *@
                                    <td class="lr-td">
                                        <div class="lr-date-range">
                                            <i class="bi bi-calendar3 lr-date-icon"></i>
                                            <span>@r.DateRangeLabel</span>
                                        </div>
                                    </td>
                                    @* Leave Type *@
                                    <td class="lr-td">
                                        @if (!string.IsNullOrWhiteSpace(r.LeaveTypeName))
                                        {
                                            <span class="lr-leave-type-badge">@r.LeaveTypeName</span>
                                        }
                                        else
                                        {
                                            <span class="lr-td--muted">—</span>
                                        }
                                    </td>
                                    @* Reason *@
                                    <td class="lr-td lr-td--reason">
                                        @if (!string.IsNullOrWhiteSpace(r.Reason))
                                        {
                                            @r.Reason
                                        }
                                        else
                                        {
                                            <span class="lr-td--muted">—</span>
                                        }
                                    </td>
                                    @* Status badge *@
                                    <td class="lr-td">
                                        <span class="lr-badge @r.BadgeCss">
                                            <span class="lr-badge-dot"></span>
                                            @r.DisplayStatus
                                        </span>
                                    </td>
                                    @* Remarks / Reject reason *@
                                    <td class="lr-td lr-td--remarks">
                                        @if (r.Status == "Rejected" && !string.IsNullOrWhiteSpace(r.RejectReason))
                                        {
                                            <span class="lr-reject-note">
                                                <i class="bi bi-chat-left-text" style="margin-right:5px;color:#dc2626;"></i>@r.RejectReason
                                            </span>
                                        }
                                        else if (r.Status == "Approved")
                                        {
                                            <span class="lr-approved-note">
                                                <i class="bi bi-check-circle" style="margin-right:5px;color:#16a34a;"></i>Approved by @(r.ReviewedBy ?? "HR")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="lr-td--muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
    else if (activeTab == "leave")
    {
        @* ════════════════════════════════════════════════════════
           LEAVE BALANCE TAB — Zoho-style detailed leave overview
           ════════════════════════════════════════════════════════ *@

        <div class="lb-page">
            @* ── TOP BAR: title + Apply Leave button ── *@
            <div class="lb-top-bar">
                <div class="lb-top-bar-left">
                    <span class="lb-page-title">Leave Balance</span>
                    <span class="lb-page-sub">@DateTime.Today.Year · @(policies.Count) leave @(policies.Count == 1 ? "type" : "types")</span>
                </div>
                <button class="lb-apply-btn" @onclick="OpenLrForm">
                    <i class="bi bi-plus-circle-fill"></i>
                    Apply Leave
                </button>
            </div>

            @if (isLoadingLeaveRequests)
            {
                <div class="to-loading" style="padding:60px 0;"><div class="to-spinner"></div></div>
            }
            else if (!policies.Any())
            {
                <div class="lb-empty-state">
                    <i class="bi bi-calendar2-x lb-empty-icon"></i>
                    <p class="lb-empty-title">No leave policies configured</p>
                    <p class="lb-empty-sub">Contact your HR administrator to set up leave types for your account.</p>
                </div>
            }
            else
            {
                @* ── SECTION 1: Policy Cards Grid ── *@
                <div class="lb-cards-grid">
                    @for (int ci = 0; ci < policies.Count; ci++)
                    {
                        var pol      = policies[ci];
                        var color    = LbColor(ci);
                        var used     = LbUsed(pol.Id);
                        var total    = pol.AnnualEntitlement;
                        var remain   = Math.Max(0, total - used);
                        var pct      = total > 0 ? Math.Min(100, (used / total) * 100) : 0;
                        var carryFwd = pol.AllowCarryForward
                            ? (pol.CarryForwardLimit.HasValue ? $"Up to {pol.CarryForwardLimit} days" : "Unlimited")
                            : "Not allowed";

                        <div class="lb-card" style="--lb-card-color:@color;">
                            <div class="lb-card-header">
                                <div class="lb-card-icon-wrap" style="background:@(color)18;">
                                    <i class="bi bi-calendar2-check" style="color:@color;"></i>
                                </div>
                                <div class="lb-card-title-wrap">
                                    <span class="lb-card-name">@pol.Name</span>
                                    <span class="lb-card-type lb-card-type--@(pol.CompensationType.ToLower())">@pol.CompensationType</span>
                                </div>
                            </div>
                            <div class="lb-card-stats">
                                <div class="lb-card-stat">
                                    <span class="lb-stat-val">@total</span>
                                    <span class="lb-stat-lbl">Total</span>
                                </div>
                                <div class="lb-card-stat-divider"></div>
                                <div class="lb-card-stat">
                                    <span class="lb-stat-val lb-stat-used">@used</span>
                                    <span class="lb-stat-lbl">Used</span>
                                </div>
                                <div class="lb-card-stat-divider"></div>
                                <div class="lb-card-stat">
                                    <span class="lb-stat-val lb-stat-remain" style="color:@color;">@remain</span>
                                    <span class="lb-stat-lbl">Remaining</span>
                                </div>
                            </div>
                            <div class="lb-card-progress-wrap">
                                <div class="lb-card-progress-bar">
                                    <div class="lb-card-progress-fill" style="width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:@color;"></div>
                                </div>
                                <span class="lb-card-pct">@pct.ToString("F0")% used</span>
                            </div>
                            @if (pol.AllowCarryForward)
                            {
                                <div class="lb-card-carry">
                                    <i class="bi bi-arrow-repeat" style="color:@color;font-size:.72rem;"></i>
                                    <span>Carry forward: @carryFwd</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* ── SECTION 2+3: Table + Donut side by side ── *@
                <div class="lb-mid-row">

                    @* ── Left: Detailed Table ── *@
                    <div class="lb-table-card">
                        <div class="lb-section-header">
                            <span class="lb-section-title">Leave Summary</span>
                            <span class="lb-section-badge">@DateTime.Today.Year</span>
                        </div>
                        <div class="lb-table-wrap">
                            <table class="lb-table">
                                <thead>
                                    <tr>
                                        <th class="lb-th">Leave Type</th>
                                        <th class="lb-th lb-th--num">Total</th>
                                        <th class="lb-th lb-th--num">Used</th>
                                        <th class="lb-th lb-th--num">Remaining</th>
                                        <th class="lb-th lb-th--num">Carry Fwd</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int ti = 0; ti < policies.Count; ti++)
                                    {
                                        var pol    = policies[ti];
                                        var color  = LbColor(ti);
                                        var used   = LbUsed(pol.Id);
                                        var total  = pol.AnnualEntitlement;
                                        var remain = Math.Max(0, total - used);
                                        var cfVal  = pol.AllowCarryForward
                                            ? (pol.CarryForwardLimit.HasValue ? pol.CarryForwardLimit.Value.ToString() : "∞")
                                            : "—";

                                        <tr class="lb-tr">
                                            <td class="lb-td">
                                                <div class="lb-td-type">
                                                    <span class="lb-type-dot" style="background:@color;"></span>
                                                    <span class="lb-type-name">@pol.Name</span>
                                                    @if (pol.CompensationType == "Unpaid")
                                                    {
                                                        <span class="lb-unpaid-tag">Unpaid</span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="lb-td lb-td--num">@total</td>
                                            <td class="lb-td lb-td--num">
                                                <span class="@(used > 0 ? "lb-used-val" : "")">@used</span>
                                            </td>
                                            <td class="lb-td lb-td--num">
                                                <span class="lb-remain-pill" style="background:@(color)18;color:@color;">@remain</span>
                                            </td>
                                            <td class="lb-td lb-td--num lb-td--cf">@cfVal</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="lb-tfoot-row">
                                        <td class="lb-td lb-tfoot-label">Total</td>
                                        <td class="lb-td lb-td--num lb-tfoot-val">@LbTotalEntitlement</td>
                                        <td class="lb-td lb-td--num lb-tfoot-val">@LbTotalUsed</td>
                                        <td class="lb-td lb-td--num lb-tfoot-val">@LbTotalRemaining</td>
                                        <td class="lb-td lb-td--num lb-tfoot-val">—</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    @* ── Right: Donut Chart ── *@
                    <div class="lb-donut-card">
                        <div class="lb-section-header">
                            <span class="lb-section-title">Overall Usage</span>
                        </div>
                        <div class="lb-donut-wrap">
                            <svg class="lb-donut-svg" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="90" cy="90" r="70" fill="none" stroke="#f3f4f6" stroke-width="18" />
                                @if (LbRemainPct > 0)
                                {
                                    <circle cx="90" cy="90" r="70" fill="none" stroke="#10b981"
                                            stroke-width="18"
                                            stroke-dasharray="@LbRemainDashStr @LbCircStr"
                                            stroke-dashoffset="@LbRemainOffsetStr"
                                            stroke-linecap="round"
                                            transform="rotate(-90 90 90)" />
                                }
                                @if (LbUsedPct > 0)
                                {
                                    <circle cx="90" cy="90" r="70" fill="none" stroke="#f07820"
                                            stroke-width="18"
                                            stroke-dasharray="@LbUsedDashStr @LbCircStr"
                                            stroke-dashoffset="0"
                                            stroke-linecap="round"
                                            transform="rotate(-90 90 90)" />
                                }
                                <text x="90" y="84" text-anchor="middle" font-size="26" font-weight="700" fill="#111827">@LbTotalRemaining.ToString("F0")</text>
                                <text x="90" y="102" text-anchor="middle" font-size="11" fill="#6b7280">days left</text>
                            </svg>

                            <div class="lb-donut-legend">
                                <div class="lb-legend-item">
                                    <span class="lb-legend-dot" style="background:#10b981;"></span>
                                    <span class="lb-legend-label">Remaining</span>
                                    <span class="lb-legend-val">@LbTotalRemaining days (@LbRemainPct.ToString("F0")%)</span>
                                </div>
                                <div class="lb-legend-item">
                                    <span class="lb-legend-dot" style="background:#f07820;"></span>
                                    <span class="lb-legend-label">Used</span>
                                    <span class="lb-legend-val">@LbTotalUsed days (@LbUsedPct.ToString("F0")%)</span>
                                </div>
                                <div class="lb-legend-item lb-legend-item--total">
                                    <span class="lb-legend-dot" style="background:#e5e7eb;"></span>
                                    <span class="lb-legend-label">Total Entitlement</span>
                                    <span class="lb-legend-val">@LbTotalEntitlement days</span>
                                </div>
                            </div>
                        </div>

                        @* Per-policy mini bars *@
                        <div class="lb-donut-policy-bars">
                            @for (int pi = 0; pi < Math.Min(policies.Count, 5); pi++)
                            {
                                var pol   = policies[pi];
                                var color = LbColor(pi);
                                var used  = LbUsed(pol.Id);
                                var tot   = pol.AnnualEntitlement;
                                var p2    = tot > 0 ? Math.Min(100, (used / tot) * 100) : 0;

                                <div class="lb-mini-bar-row">
                                    <span class="lb-mini-bar-name">@pol.Name</span>
                                    <div class="lb-mini-bar-track">
                                        <div class="lb-mini-bar-fill" style="width:@p2.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:@color;"></div>
                                    </div>
                                    <span class="lb-mini-bar-num">@used/@tot</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* ── SECTION 4: Collapsible Leave Policy Details ── *@
                <div class="lb-policy-section">
                    <button class="lb-policy-toggle" @onclick="LbTogglePolicy">
                        <span class="lb-policy-toggle-left">
                            <i class="bi bi-shield-check lb-policy-toggle-icon"></i>
                            <span>Leave Policy Details</span>
                            <span class="lb-policy-count">@policies.Count @(policies.Count == 1 ? "policy" : "policies")</span>
                        </span>
                        <i class="bi @(lbPolicyOpen ? "bi-chevron-up" : "bi-chevron-down") lb-policy-caret"></i>
                    </button>

                    @if (lbPolicyOpen)
                    {
                        <div class="lb-policy-body">
                            @for (int pi2 = 0; pi2 < policies.Count; pi2++)
                            {
                                var pol   = policies[pi2];
                                var color = LbColor(pi2);

                                <div class="lb-policy-item">
                                    <div class="lb-policy-item-header">
                                        <div class="lb-policy-dot" style="background:@color;"></div>
                                        <span class="lb-policy-item-name">@pol.Name</span>
                                        <span class="lb-policy-comp lb-policy-comp--@(pol.CompensationType.ToLower())">@pol.CompensationType</span>
                                    </div>
                                    <div class="lb-policy-rules">
                                        <div class="lb-rule">
                                            <i class="bi bi-calendar3 lb-rule-icon"></i>
                                            <span class="lb-rule-lbl">Annual Limit</span>
                                            <span class="lb-rule-val">@pol.AnnualEntitlement @pol.Unit.ToLower()</span>
                                        </div>
                                        <div class="lb-rule">
                                            <i class="bi bi-graph-up lb-rule-icon"></i>
                                            <span class="lb-rule-lbl">Accrual</span>
                                            <span class="lb-rule-val">@(pol.AccrualType == "None" ? "Instant (full entitlement)" : pol.AccrualType)</span>
                                        </div>
                                        <div class="lb-rule">
                                            <i class="bi bi-arrow-repeat lb-rule-icon"></i>
                                            <span class="lb-rule-lbl">Carry Forward</span>
                                            <span class="lb-rule-val">
                                                @if (!pol.AllowCarryForward)
                                                {
                                                    <span class="lb-rule-no">Not allowed</span>
                                                }
                                                else if (pol.CarryForwardLimit.HasValue)
                                                {
                                                    @($"Up to {pol.CarryForwardLimit} days")
                                                    @if (pol.CarryForwardExpiryMonths.HasValue)
                                                    {
                                                        <span class="lb-rule-exp"> · Expires in @pol.CarryForwardExpiryMonths months</span>
                                                    }
                                                }
                                                else
                                                {
                                                    @("Unlimited")
                                                    @if (pol.CarryForwardExpiryMonths.HasValue)
                                                    {
                                                        <span class="lb-rule-exp"> · Expires in @pol.CarryForwardExpiryMonths months</span>
                                                    }
                                                }
                                            </span>
                                        </div>
                                        <div class="lb-rule">
                                            <i class="bi bi-flag lb-rule-icon"></i>
                                            <span class="lb-rule-lbl">Public Holidays</span>
                                            <span class="lb-rule-val">@(pol.ExcludePublicHolidays ? "Excluded from leave count" : "Counted as leave days")</span>
                                        </div>
                                        <div class="lb-rule">
                                            <i class="bi bi-moon lb-rule-icon"></i>
                                            <span class="lb-rule-lbl">Non-working Days</span>
                                            <span class="lb-rule-val">@(pol.ExcludeNonWorkingDays ? "Excluded from leave count" : "Counted as leave days")</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

</div>

@* ── Add / Edit drawer ───────────────────────────────────────────── *@
@if (addDrawerOpen)
{
    <div class="to-overlay" @onclick="CloseAddTimeOff"></div>
    <div class="ato-panel" @onclick:stopPropagation>
        <div class="ato-head">
            <span class="ato-title">@(editingId.HasValue ? "Edit Time Off" : "Add Time Off")</span>
            <button class="ato-close" @onclick="CloseAddTimeOff"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="ato-body">
            <!-- Member -->
            <div class="ato-field" style="position:relative;">
                <label class="ato-label">Member</label>
                @if (editingId.HasValue)
                {
                    @* Read-only in edit mode *@
                    <div class="ato-select-box ato-select-box--readonly">
                        <div class="ato-avatar" style="width:26px;height:26px;font-size:.75rem;">@(selectedMember?.FullName?.Length > 0 ? selectedMember.FullName[0].ToString().ToUpper() : "?")</div>
                        <span class="ato-selected-val">@(selectedMember?.FullName ?? "")</span>
                        <i class="bi bi-chevron-down ato-caret" style="opacity:.3;"></i>
                    </div>
                }
                else
                {
                    <div class="ato-select-box @(memberOpen ? "ato-select-box--open" : "") @(addMemberErr ? "ato-select-box--err" : "")"
                         @onclick="() => { memberOpen = !memberOpen; policyOpen = false; calOpen = null; }">
                        <i class="bi bi-person ato-field-icon"></i>
                        <span class="@(selectedMember != null ? "ato-selected-val" : "ato-placeholder")">@(selectedMember?.FullName ?? "Select a member")</span>
                        <i class="bi @(memberOpen ? "bi-chevron-up" : "bi-chevron-down") ato-caret"></i>
                    </div>
                    @if (addMemberErr) { <small class="ato-err-msg">Please select a member.</small> }
                    @if (memberOpen)
                    {
                        <div class="ato-dropdown" @onclick:stopPropagation>
                            <div class="ato-dropdown-search">
                                <i class="bi bi-search ato-dd-search-icon"></i>
                                <input type="text" class="ato-dd-search-input" placeholder="Search members..." @bind="memberSearch" @bind:event="oninput" />
                            </div>
                            @{ var filtMembers = string.IsNullOrWhiteSpace(memberSearch) ? members : members.Where(m => m.FullName.Contains(memberSearch, StringComparison.OrdinalIgnoreCase)).ToList(); }
                            @if (!filtMembers.Any()) { <div class="ato-dd-empty">No members found</div> }
                            else
                            {
                                @foreach (var m in filtMembers)
                                {
                                    var cap = m;
                                    <div class="ato-dd-row" @onclick="() => SelectMember(cap)">
                                        <div class="ato-avatar">@(cap.FullName.Length > 0 ? cap.FullName[0].ToString().ToUpper() : "?")</div>
                                        <span>@cap.FullName</span>
                                    </div>
                                }
                            }
                        </div>
                        <div style="position:fixed;inset:0;z-index:498;" @onclick="() => { memberOpen=false; memberSearch=string.Empty; }"></div>
                    }
                }
            </div>

            <!-- Policy -->
            <div class="ato-field" style="position:relative; margin-top:12px;">
                @if (editingId.HasValue)
                {
                    @* Read-only in edit mode *@
                    <div class="ato-select-box ato-select-box--readonly">
                        <i class="bi bi-briefcase ato-field-icon" style="opacity:.5;"></i>
                        <span class="ato-selected-val">@(selectedPolicy?.Name ?? "")</span>
                        <i class="bi bi-chevron-down ato-caret" style="opacity:.3;"></i>
                    </div>
                }
                else
                {
                    <div class="ato-select-box @(policyOpen ? "ato-select-box--open" : "") @(addPolicyErr ? "ato-select-box--err" : "")"
                         @onclick="() => { policyOpen = !policyOpen; memberOpen = false; calOpen = null; }">
                        <i class="bi bi-briefcase ato-field-icon"></i>
                        <span class="@(selectedPolicy != null ? "ato-selected-val" : "ato-placeholder")">@(selectedPolicy?.Name ?? "Select a policy")</span>
                        <i class="bi @(policyOpen ? "bi-chevron-up" : "bi-chevron-down") ato-caret"></i>
                    </div>
                    @if (addPolicyErr) { <small class="ato-err-msg">What type of time off are they taking?</small> }
                    @if (policyOpen)
                    {
                        <div class="ato-dropdown" @onclick:stopPropagation>
                            @if (!policies.Any()) { <div class="ato-dd-empty">No policies available.</div> }
                            else
                            {
                                @foreach (var p in policies)
                                {
                                    var cap = p;
                                    <div class="ato-dd-row" @onclick="() => SelectPolicy(cap)">@cap.Name</div>
                                }
                            }
                        </div>
                        <div style="position:fixed;inset:0;z-index:498;" @onclick="() => policyOpen=false"></div>
                    }
                }
            </div>

            <!-- Days -->
            <div class="ato-field" style="margin-top:20px;">
                <div class="ato-days-header">
                    <i class="bi bi-calendar3 ato-days-icon"></i>
                    <span class="ato-days-label">Days</span>
                </div>
                <div class="ato-date-row">
                    <div style="flex:1;position:relative;">
                        <div class="ato-date-box @(addStartErr ? "ato-date-box--err" : "") @(calOpen == "start" ? "ato-date-box--open" : "")" @onclick="ToggleStartCal">
                            <span class="@(startDate.HasValue ? "ato-selected-val" : "ato-placeholder")">@(startDate.HasValue ? startDate.Value.ToString("MMM dd, yyyy") : "Start date")</span>
                            <i class="bi bi-calendar3 ato-date-icon"></i>
                        </div>
                        @if (addStartErr) { <small class="ato-err-msg">Start date is required.</small> }
                        @if (calOpen == "start")
                        {
                            <div class="ato-calendar" @onclick:stopPropagation>
                                <div class="ato-cal-header">
                                    <button class="ato-cal-nav" @onclick="CalPrevMonth">&#8249;</button>
                                    <span class="ato-cal-month">@calDate.ToString("MMMM")</span>
                                    <button class="ato-cal-nav" @onclick="CalNextMonth">&#8250;</button>
                                    <button class="ato-cal-nav" @onclick="CalPrevYear">&#8249;</button>
                                    <span class="ato-cal-year">@calDate.Year</span>
                                    <button class="ato-cal-nav" @onclick="CalNextYear">&#8250;</button>
                                </div>
                                <div class="ato-cal-grid">
                                    @foreach (var dn in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"}) { <div class="ato-cal-dayname">@dn</div> }
                                    @for (int blank = 0; blank < CalStartBlank(); blank++) { <div></div> }
                                    @for (int d = 1; d <= DateTime.DaysInMonth(calDate.Year, calDate.Month); d++)
                                    {
                                        var day = d;
                                        var td = new DateTime(calDate.Year, calDate.Month, day);
                                        var isSel = startDate.HasValue && td.Date == startDate.Value.Date;
                                        var inRange = startDate.HasValue && endDate.HasValue && td > startDate.Value && td < endDate.Value;
                                        <div class="ato-cal-day @(td.Date==DateTime.Today?"ato-cal-day--today":"") @(isSel?"ato-cal-day--selected":"") @(inRange?"ato-cal-day--range":"")" @onclick="() => PickStartDate(day)">@day</div>
                                    }
                                </div>
                            </div>
                            <div style="position:fixed;inset:0;z-index:498;" @onclick="() => calOpen=null"></div>
                        }
                    </div>
                    <div style="flex:1;position:relative;">
                        <div class="ato-date-box @(calOpen == "end" ? "ato-date-box--open" : "")" @onclick="ToggleEndCal">
                            <span class="@(endDate.HasValue ? "ato-selected-val" : "ato-placeholder")">@(endDate.HasValue ? endDate.Value.ToString("MMM dd, yyyy") : "End date (optional)")</span>
                            <i class="bi bi-calendar3 ato-date-icon"></i>
                        </div>
                        @if (calOpen == "end")
                        {
                            <div class="ato-calendar" @onclick:stopPropagation>
                                <div class="ato-cal-header">
                                    <button class="ato-cal-nav" @onclick="CalPrevMonth">&#8249;</button>
                                    <span class="ato-cal-month">@calDate.ToString("MMMM")</span>
                                    <button class="ato-cal-nav" @onclick="CalNextMonth">&#8250;</button>
                                    <button class="ato-cal-nav" @onclick="CalPrevYear">&#8249;</button>
                                    <span class="ato-cal-year">@calDate.Year</span>
                                    <button class="ato-cal-nav" @onclick="CalNextYear">&#8250;</button>
                                </div>
                                <div class="ato-cal-grid">
                                    @foreach (var dn in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"}) { <div class="ato-cal-dayname">@dn</div> }
                                    @for (int blank = 0; blank < CalStartBlank(); blank++) { <div></div> }
                                    @for (int d = 1; d <= DateTime.DaysInMonth(calDate.Year, calDate.Month); d++)
                                    {
                                        var day = d;
                                        var td = new DateTime(calDate.Year, calDate.Month, day);
                                        var isSel = endDate.HasValue && td.Date == endDate.Value.Date;
                                        var inRange = startDate.HasValue && endDate.HasValue && td > startDate.Value && td < endDate.Value;
                                        <div class="ato-cal-day @(td.Date==DateTime.Today?"ato-cal-day--today":"") @(isSel?"ato-cal-day--selected":"") @(inRange?"ato-cal-day--range":"")" @onclick="() => PickEndDate(day)">@day</div>
                                    }
                                </div>
                            </div>
                            <div style="position:fixed;inset:0;z-index:498;" @onclick="() => calOpen=null"></div>
                        }
                    </div>
                </div>
                <div class="ato-halfday-row">
                    <label class="ato-checkbox-label"><input type="checkbox" @bind="halfDay" /><span>Half day</span></label>
                    @if (halfDay)
                    {
                        <div style="position:relative;flex:1;min-width:200px;">
                            <div class="ato-halfday-select @(halfDayOpen ? "ato-select-box--open" : "")" @onclick="() => halfDayOpen = !halfDayOpen" @onclick:stopPropagation>
                                <span class="@(halfDayOption != null ? "ato-selected-val" : "ato-placeholder")">@(halfDayOption ?? "Select time range (optional)")</span>
                                <i class="bi @(halfDayOpen ? "bi-chevron-up" : "bi-chevron-down") ato-caret"></i>
                            </div>
                            @if (halfDayOpen)
                            {
                                <div class="ato-dropdown" @onclick:stopPropagation>
                                    @foreach (var opt in new[]{"Beginning of the workday","Middle of the workday","End of the workday"})
                                    { var o = opt; <div class="ato-dd-row" @onclick="() => { halfDayOption = o; halfDayOpen = false; }">@o</div> }
                                </div>
                                <div style="position:fixed;inset:0;z-index:498;" @onclick="() => halfDayOpen=false"></div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Reason -->
            <div class="ato-field" style="margin-top:16px;">
                <div class="ato-reason-wrap">
                    <i class="bi bi-justify ato-reason-icon"></i>
                    <textarea class="ato-reason-input" placeholder="Add a reason or note" rows="4" @bind="addReason"></textarea>
                </div>
            </div>
        </div>
        <div class="ato-footer">
            @if (!string.IsNullOrEmpty(saveError)) { <span class="ato-save-error">@saveError</span> }
            <button class="ato-btn-cancel" @onclick="CloseAddTimeOff">Cancel</button>
            <button class="ato-btn-save" @onclick="SaveTimeOff" disabled="@addSaving">
                @if (addSaving) { <span class="ato-mini-spin"></span> } else { <span>Save</span> }
            </button>
        </div>
    </div>
}

@* ── Confirm: Approve ───────────────────────────────────────────── *@
@if (confirmApproveId.HasValue)
{
    <div class="to-modal-overlay" @onclick="() => confirmApproveId = null"></div>
