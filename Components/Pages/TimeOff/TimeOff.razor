    /// <summary>Days used per policy, computed from approved leave requests.</summary>
    private double LbUsed(int policyId)
    {
        double total = 0;
        foreach (var r in myLeaveRequests)
        {
            if (r.Status != "Approved") continue;
            bool match = (r.LeaveTypeId.HasValue && r.LeaveTypeId.Value == policyId)
                      || (!r.LeaveTypeId.HasValue && policies.Any(p =>
                              p.Id == policyId &&
                              string.Equals(p.Name, r.LeaveTypeName, StringComparison.OrdinalIgnoreCase)));
            if (!match) continue;
            var end = r.EndDate ?? r.StartDate;
            total += (end.Date - r.StartDate.Date).Days + 1;
        }
        return total;
    }

    private double LbTotalEntitlement => policies.Sum(p => p.AnnualEntitlement);
    private double LbTotalUsed        => policies.Sum(p => LbUsed(p.Id));
    private double LbTotalRemaining   => Math.Max(0, LbTotalEntitlement - LbTotalUsed);

    // ── Donut chart SVG values ─────────────────────────────────────
    private double LbUsedPct    => LbTotalEntitlement > 0 ? Math.Min(100, (LbTotalUsed / LbTotalEntitlement) * 100) : 0;
    private double LbRemainPct  => 100 - LbUsedPct;
    private double LbCirc       => 2 * Math.PI * 70;
    private string LbCircStr    => LbCirc.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private string LbUsedDashStr   => ((LbUsedPct / 100) * LbCirc).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private string LbRemainDashStr => ((LbRemainPct / 100) * LbCirc).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private string LbRemainOffsetStr => (-(LbUsedPct / 100) * LbCirc).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

