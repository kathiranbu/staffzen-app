    .to-range-btn { display:inline-flex; align-items:center; gap:7px; background:#fff; border:1.5px solid #d1d5db; border-radius:8px; padding:8px 14px; font-size:.9rem; font-weight:600; color:#111827; cursor:pointer; white-space:nowrap; transition:border-color .15s, box-shadow .15s; }
