    // ── Selection ──────────────────────────────────────────────────
    private HashSet<int> selectedIds = new();

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var selectableIds = filteredRequests.Where(r => IsSelectableRow(r)).Select(r => r.Id).ToHashSet();
        if ((bool?)e.Value == true) selectedIds = selectableIds;
        else selectedIds.Clear();
    }

    private void ToggleRowSelect(int id)
    {
        var req = requests.FirstOrDefault(r => r.Id == id);
        if (req != null && !IsSelectableRow(req)) return;
        if (!selectedIds.Remove(id)) selectedIds.Add(id);
    }

    private void ClearSelection() => selectedIds.Clear();

    private async Task BulkCancelRequest()
    {
        foreach (var id in selectedIds.ToList())
        {
            var req = requests.FirstOrDefault(r => r.Id == id);
            if (req != null && (req.Status == "Pending" || req.Status == "Approved"))
                await UpdateStatus(id, "Cancelled");
        }
        ClearSelection();
    }

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        filterStart   = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        filterEnd     = new DateTime(DateTime.Today.Year, DateTime.Today.Month,
                            DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
        filterCalDate = DateTime.Today;
        await LoadData();
        if (IsUserRole)
        {
            activeTab = "overview"; // Show the Zoho-style dashboard on Overview tab
            await LoadMyLeaveRequestsAsync();
        }
    }

    private async Task LoadData()
    {
        try { policies = await PolicyService.GetAllAsync(); } catch { policies = new(); }
        try
        {
            var client = ClientFactory.CreateClient("API");
            var res    = await client.GetAsync($"api/employees?organizationId={SessionService.ActiveOrganizationId}");
            if (res.IsSuccessStatusCode)
            {
                var json = await res.Content.ReadAsStringAsync();
                var arr  = JsonSerializer.Deserialize<JsonElement[]>(json, new JsonSerializerOptions(JsonSerializerDefaults.Web));
                members  = arr?.Select(e => new MemberVm {
                    Id       = e.GetProperty("id").GetInt32(),
                    FullName = e.GetProperty("fullName").GetString() ?? "",
                    Email    = e.TryGetProperty("email", out var em) ? em.GetString() ?? "" : ""
                }).ToList() ?? new();
            }
        }
        catch { members = new(); }
        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        isLoading = true; StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("API");
            var url    = $"api/time-off-requests?start={filterStart:yyyy-MM-dd}&end={filterEnd:yyyy-MM-dd}";
            var res    = await client.GetAsync(url);
            if (res.IsSuccessStatusCode)
            {
                var opts = new JsonSerializerOptions(JsonSerializerDefaults.Web);
                var arr  = JsonSerializer.Deserialize<JsonElement[]>(await res.Content.ReadAsStringAsync(), opts);
                requests = arr?.Select(e => new TimeOffRequestVm
                {
                    Id           = e.GetProperty("id").GetInt32(),
                    EmployeeId   = e.GetProperty("employeeId").GetInt32(),
                    EmployeeName = e.GetProperty("employeeName").GetString() ?? "",
                    PolicyId     = e.GetProperty("policyId").GetInt32(),
                    PolicyName   = e.GetProperty("policyName").GetString() ?? "",
                    StartDate    = DateTime.Parse(e.GetProperty("startDate").GetString() ?? DateTime.Today.ToString("yyyy-MM-dd")),
                    EndDate      = e.TryGetProperty("endDate", out var ed) && ed.ValueKind != JsonValueKind.Null ? DateTime.Parse(ed.GetString()!) : null,
                    IsHalfDay    = e.TryGetProperty("isHalfDay", out var hd) && hd.GetBoolean(),
                    Status       = e.GetProperty("status").GetString() ?? "Pending"
                }).ToList() ?? new();
            }
            else requests = new();
        }
        catch { requests = new(); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private void ResetFilters()
    {
        searchText           = "";
        filterPolicyIds      = new();
        filterStatuses       = new();
        filterPoliciesSearch = "";
        selectedPreset       = "This month";
        CloseAllFilterDropdowns();
        filterStart = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        filterEnd   = new DateTime(DateTime.Today.Year, DateTime.Today.Month,
                          DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
        _ = LoadRequests();
    }

    private string FormatDates(TimeOffRequestVm r)
    {
        if (!r.EndDate.HasValue || r.EndDate.Value.Date == r.StartDate.Date)
            return r.StartDate.ToString("ddd, dd MMM");
        return $"{r.StartDate:ddd, dd MMM} - {r.EndDate:ddd, dd MMM}";
    }

    private string FormatDuration(TimeOffRequestVm r)
    {
        if (r.IsHalfDay) return "0.5 day";
        var end  = r.EndDate ?? r.StartDate;
        var days = (end.Date - r.StartDate.Date).Days + 1;
        return days == 1 ? "1 day" : $"{days} days";
    }

