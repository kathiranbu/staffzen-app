    private void PickStartDate(int day) { startDate = new DateTime(calDate.Year, calDate.Month, day); if (endDate.HasValue && startDate > endDate) endDate = null; addStartErr = false; calOpen = null; }
    private void PickEndDate(int day)   { endDate = new DateTime(calDate.Year, calDate.Month, day); calOpen = null; }
    private void CalPrevMonth()  => calDate = calDate.AddMonths(-1);
    private void CalNextMonth()  => calDate = calDate.AddMonths(1);
    private void CalPrevYear()   => calDate = calDate.AddYears(-1);
    private void CalNextYear()   => calDate = calDate.AddYears(1);
    private void ToggleStartCal() { calOpen = calOpen == "start" ? null : "start"; memberOpen = false; policyOpen = false; }
    private void ToggleEndCal()   { calOpen = calOpen == "end"   ? null : "end";   memberOpen = false; policyOpen = false; }
    private int CalStartBlank()   { var first = new DateTime(calDate.Year, calDate.Month, 1).DayOfWeek; return first == DayOfWeek.Sunday ? 6 : (int)first - 1; }

    private async Task SaveTimeOff()
    {
        addMemberErr = selectedMember == null; addPolicyErr = selectedPolicy == null; addStartErr = !startDate.HasValue;
        if (addMemberErr || addPolicyErr || addStartErr) return;
        addSaving = true; saveError = "";
        try
        {
            var client  = ClientFactory.CreateClient("API");
            var payload = new {
                employeeId  = selectedMember!.Id,
                policyId    = selectedPolicy!.Id,
                startDate   = startDate!.Value.ToString("yyyy-MM-dd"),
                endDate     = endDate?.ToString("yyyy-MM-dd"),
                isHalfDay   = halfDay,
                halfDayPart = halfDayOption,
                reason      = addReason
            };
            var res = editingId.HasValue
                ? await client.PutAsJsonAsync($"api/time-off-requests/{editingId.Value}", payload)
                : await client.PostAsJsonAsync("api/time-off-requests", payload);
            if (res.IsSuccessStatusCode) { CloseAddTimeOff(); await LoadRequests(); }
            else
            {
                try
                {
                    var doc = JsonDocument.Parse(await res.Content.ReadAsStringAsync());
                    saveError = doc.RootElement.TryGetProperty("message", out var msg) ? msg.GetString() ?? "Error." : "Error.";
                }
                catch { saveError = "An error occurred while saving."; }
            }
        }
        catch { saveError = "An error occurred while saving."; }
        addSaving = false;
    }

    // ── Confirm modals ─────────────────────────────────────────────
    private int?   confirmApproveId = null;
    private int?   confirmRejectId  = null;
    private int?   confirmDeleteId  = null;
    private int?   confirmCancelId  = null;
    private string rejectTargetName = "";
    private int    confirmBulkCount = 1;

    private void ConfirmApprove(int id) { confirmApproveId = id; confirmBulkCount = 1; }
    private void ConfirmReject(int id)
    {
        confirmRejectId  = id;
        rejectTargetName = requests.FirstOrDefault(r => r.Id == id)?.EmployeeName ?? "this member";
    }
    private void ConfirmDelete(int id) => confirmDeleteId = id;
    private void ConfirmCancel(int id) => confirmCancelId = id;

    private void BulkApprove()
    {
        if (!selectedIds.Any()) return;
        confirmBulkCount  = selectedIds.Count;
        confirmApproveId  = -1; // sentinel for bulk
    }
    private void BulkReject()
    {
        if (!selectedIds.Any()) return;
        confirmBulkCount  = selectedIds.Count;
        rejectTargetName  = $"{confirmBulkCount} members";
        confirmRejectId   = -1; // sentinel for bulk
    }

    private async Task ExecuteApprove()
    {
        if (confirmApproveId == -1)
        {
            foreach (var id in selectedIds.ToList())
                await UpdateStatus(id, "Approved");
            ClearSelection();
        }
        else if (confirmApproveId.HasValue)
            await UpdateStatus(confirmApproveId.Value, "Approved");
        confirmApproveId = null;
    }

    private async Task ExecuteReject()
    {
        if (confirmRejectId == -1)
        {
            foreach (var id in selectedIds.ToList())
                await UpdateStatus(id, "Rejected");
            ClearSelection();
        }
        else if (confirmRejectId.HasValue)
            await UpdateStatus(confirmRejectId.Value, "Rejected");
        confirmRejectId = null;
    }

    private async Task ExecuteDelete()
    {
        if (confirmDeleteId.HasValue)
            await UpdateStatus(confirmDeleteId.Value, "Cancelled");
        confirmDeleteId = null;
    }

    private async Task ExecuteCancel()
    {
        if (confirmCancelId.HasValue)
            await UpdateStatus(confirmCancelId.Value, "Cancelled");
        confirmCancelId = null;
    }

    private async Task UpdateStatus(int id, string status)
    {
        try
        {
            var client = ClientFactory.CreateClient("API");
            await client.PatchAsJsonAsync($"api/time-off-requests/{id}/status", new { status });
            await LoadRequests();
        }
        catch { }
    }

    private async Task DeleteRequest(int id)
    {
        try
        {
            var client = ClientFactory.CreateClient("API");
            await client.DeleteAsync($"api/time-off-requests/{id}");
            await LoadRequests();
        }
        catch { }
    }

