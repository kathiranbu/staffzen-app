    /// <summary>
    /// Submits a leave request via LeaveRequestService → POST api/leave-requests.
    /// LeaveType (policy) is required.
    /// </summary>
    private async Task SubmitLeaveRequest()
    {
        lrStartErr  = !lrStartDate.HasValue;
        lrPolicyErr = lrSelectedPolicy == null;
        if (lrStartErr || lrPolicyErr) return;

        lrSaving = true; lrSaveError = ""; StateHasChanged();

        var (ok, error) = await LeaveRequestService.SubmitAsync(
            startDate:     lrStartDate!.Value.ToString("yyyy-MM-dd"),
            endDate:       lrEndDate?.ToString("yyyy-MM-dd") ?? lrStartDate!.Value.ToString("yyyy-MM-dd"),
            reason:        string.IsNullOrWhiteSpace(lrReason) ? null : lrReason.Trim(),
            leaveTypeId:   lrSelectedPolicy!.Id,
            leaveTypeName: lrSelectedPolicy!.Name
        );

        if (ok)
        {
            CloseLrForm();
            await LoadMyLeaveRequestsAsync();
        }
        else
        {
            lrSaveError = string.IsNullOrWhiteSpace(error)
                ? "An error occurred while submitting." : error;
        }

        lrSaving = false;
    }

    // ── Filter date range — default to current month ──────────────
    private DateTime filterStart   = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime filterEnd     = new DateTime(DateTime.Today.Year, DateTime.Today.Month,
                                         DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
    private DateTime filterCalDate = DateTime.Today;
    private bool     datePickerOpen = false;
    private bool     pickingStart   = true;

    private string selectedPreset = "This month";
    private bool   presetOpen     = false;

    private void ToggleDatePicker() => datePickerOpen = !datePickerOpen;

    private void ApplyPreset(string preset)
    {
        selectedPreset = preset;
        presetOpen     = false;
        var today      = DateTime.Today;
        switch (preset)
        {
            case "Today":
                filterStart = today; filterEnd = today; break;
            case "Yesterday":
                filterStart = today.AddDays(-1); filterEnd = today.AddDays(-1); break;
            case "Last 7 days":
                filterStart = today.AddDays(-6); filterEnd = today; break;
            case "Last week":
                int dow = (int)today.DayOfWeek; dow = dow == 0 ? 7 : dow;
                filterStart = today.AddDays(-(dow - 1) - 7);
                filterEnd   = filterStart.AddDays(6); break;
            case "This week":
                int dow2 = (int)today.DayOfWeek; dow2 = dow2 == 0 ? 7 : dow2;
                filterStart = today.AddDays(-(dow2 - 1));
                filterEnd   = filterStart.AddDays(6); break;
            case "This month":
                filterStart = new DateTime(today.Year, today.Month, 1);
                filterEnd   = new DateTime(today.Year, today.Month, DateTime.DaysInMonth(today.Year, today.Month)); break;
            case "This year":
                filterStart = new DateTime(today.Year, 1, 1);
                filterEnd   = new DateTime(today.Year, 12, 31); break;
            case "Last month":
                var lm = today.AddMonths(-1);
                filterStart = new DateTime(lm.Year, lm.Month, 1);
                filterEnd   = new DateTime(lm.Year, lm.Month, DateTime.DaysInMonth(lm.Year, lm.Month)); break;
            case "Custom":
                datePickerOpen = true;
                filterCalDate  = filterStart;
                pickingStart   = true;
                return; // don't reload yet
        }
        datePickerOpen = false;
        pickingStart   = true;
        _ = LoadRequests();
    }

    private void PickFilterDate(int day)
    {
        var picked = new DateTime(filterCalDate.Year, filterCalDate.Month, day);
        if (pickingStart) { filterStart = picked; filterEnd = picked; pickingStart = false; }
        else
        {
            if (picked < filterStart) { filterEnd = filterStart; filterStart = picked; }
            else filterEnd = picked;
            datePickerOpen = false; pickingStart = true;
            _ = LoadRequests();
        }
    }

    private void FilterCalPrev()     => filterCalDate = filterCalDate.AddMonths(-1);
    private void FilterCalNext()     => filterCalDate = filterCalDate.AddMonths(1);
    private void FilterCalPrevYear() => filterCalDate = filterCalDate.AddYears(-1);
    private void FilterCalNextYear() => filterCalDate = filterCalDate.AddYears(1);

