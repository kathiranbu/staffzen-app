@if (confirmCancelId.HasValue)
{
    <div class="to-modal-overlay" @onclick="() => confirmCancelId = null"></div>
    <div class="to-modal" @onclick:stopPropagation>
        <div class="to-modal-head">
            <span class="to-modal-title">Cancel Time Off Request</span>
            <button class="ato-close" @onclick="() => confirmCancelId = null"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="to-modal-body">
            <p>Are you sure you want to cancel this time off request?</p>
        </div>
        <div class="to-modal-footer">
            <button class="to-modal-btn-cancel" @onclick="() => confirmCancelId = null">No, thanks</button>
            <button class="to-modal-btn-confirm to-modal-btn-red" @onclick="ExecuteCancel">Confirm</button>
        </div>
    </div>
}

@* ── Export panel ───────────────────────────────────────────────── *@
@if (exportOpen)
{
    <div class="to-overlay" @onclick="() => exportOpen = false"></div>
    <div class="ato-panel" style="width:420px;" @onclick:stopPropagation>
        <div class="ato-head">
            <span class="ato-title">Export Time Off Report</span>
            <button class="ato-close" @onclick="() => exportOpen=false"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="ato-body">
            <div class="ato-field">
                <label class="ato-label">File Format</label>
                <div class="tp-toggle-row"><button class="tp-toggle-btn tp-toggle-btn--sel">XLS</button></div>
            </div>
            <div class="ato-field" style="margin-top:16px;">
                <label class="ato-label">Options</label>
                <label class="ato-checkbox-label"><input type="checkbox" @bind="exportPerMember" /> Time off requests per member in individual tabs</label>
            </div>
            <div class="ato-field" style="margin-top:16px;">
                <label class="ato-label">Date Range</label>
                @foreach (var rv in new[]{"Day","Week","Month","Custom"})
                {
                    var rvv = rv;
                    <label class="ato-checkbox-label" style="margin-top:8px;">
                        <input type="radio" name="exportRange" value="@rvv.ToLower()" checked="@(exportRange == rvv.ToLower())" @onchange="() => exportRange = rvv.ToLower()" /> @rvv
                    </label>
                }
            </div>
        </div>
        <div class="ato-footer">
            <button class="ato-btn-cancel" @onclick="() => exportOpen=false">Cancel</button>
            <button class="ato-btn-save">Export</button>
        </div>
    </div>
}

@code {
