    .ato-err-msg { display:block; font-size:.8rem; color:#ef4444; margin-top:5px; }
    .ato-dropdown { position:absolute; left:0; right:0; top:calc(100% + 4px); z-index:500; background:#fff; border:1.5px solid #e5e7eb; border-radius:9px; box-shadow:0 8px 28px rgba(0,0,0,.12); max-height:240px; overflow-y:auto; scrollbar-width:thin; }
    .ato-dropdown-search { display:flex; align-items:center; gap:8px; padding:10px 14px; border-bottom:1px solid #f3f4f6; position:sticky; top:0; background:#fff; }
    .ato-dd-search-icon { color:#9ca3af; font-size:.9rem; flex-shrink:0; }
    .ato-dd-search-input { border:none; outline:none; font-size:.875rem; color:#111827; font-family:inherit; background:transparent; flex:1; }
    .ato-dd-row { display:flex; align-items:center; gap:10px; padding:11px 14px; cursor:pointer; font-size:.875rem; color:#374151; border-bottom:1px solid #f9fafb; }
    .ato-dd-row:last-child { border-bottom:none; }
    .ato-dd-row:hover { background:#f9fafb; }
    .ato-dd-empty { padding:16px; text-align:center; font-size:.875rem; color:#9ca3af; }
    .ato-avatar { width:30px; height:30px; border-radius:50%; background:#e5e7eb; color:#374151; font-size:.8rem; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .ato-days-header { display:flex; align-items:center; gap:8px; margin-bottom:10px; }
    .ato-days-icon { color:#9ca3af; }
    .ato-days-label { font-size:.85rem; font-weight:600; color:#374151; }
    .ato-date-row { display:flex; gap:12px; }
    .ato-date-box { display:flex; align-items:center; justify-content:space-between; border:1.5px solid #e5e7eb; border-radius:8px; padding:11px 14px; cursor:pointer; background:#fff; }
    .ato-date-box:hover, .ato-date-box--open { border-color:#f07820; }
    .ato-date-box--err { border-color:#ef4444; }
    .ato-date-icon { color:#9ca3af; font-size:.9rem; flex-shrink:0; }
    .ato-calendar { position:absolute; left:0; top:calc(100% + 6px); z-index:600; background:#fff; border:1.5px solid #e5e7eb; border-radius:10px; box-shadow:0 8px 28px rgba(0,0,0,.12); padding:16px; width:280px; }
    .ato-cal-header { display:flex; align-items:center; gap:4px; margin-bottom:12px; justify-content:center; }
    .ato-cal-nav { background:none; border:none; cursor:pointer; font-size:1.1rem; color:#6b7280; padding:2px 5px; border-radius:4px; }
    .ato-cal-nav:hover { background:#f3f4f6; }
    .ato-cal-month { font-weight:700; font-size:.9rem; color:#111; }
    .ato-cal-year  { font-weight:600; font-size:.875rem; color:#4b5563; }
    .ato-cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:2px; }
    .ato-cal-dayname { font-size:.7rem; font-weight:600; color:#9ca3af; text-align:center; padding:4px 0; }
    .ato-cal-day { text-align:center; padding:6px 2px; font-size:.8rem; color:#374151; border-radius:6px; cursor:pointer; }
    .ato-cal-day:hover { background:#fff7ed; color:#f07820; }
    .ato-cal-day--today    { font-weight:700; border:1.5px solid #f07820; color:#f07820; }
    .ato-cal-day--selected { background:#f07820 !important; color:#fff !important; font-weight:700; }
