@* ── Confirm: Cancel request (pending row) ───────────────────────── *@
@if (confirmDeleteId.HasValue)
{
    <div class="to-modal-overlay" @onclick="() => confirmDeleteId = null"></div>
    <div class="to-modal" @onclick:stopPropagation>
        <div class="to-modal-head">
            <span class="to-modal-title">Cancel Time Off Request</span>
            <button class="ato-close" @onclick="() => confirmDeleteId = null"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="to-modal-body">
            <p>Are you sure you want to cancel this time off request?</p>
        </div>
        <div class="to-modal-footer">
            <button class="to-modal-btn-cancel" @onclick="() => confirmDeleteId = null">No, thanks</button>
