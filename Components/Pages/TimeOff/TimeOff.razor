    .to-range-caret { font-size:.75rem; color:#9ca3af; }
    /* Date range display */
    .to-range-display-wrap { display:flex; align-items:center; gap:8px; cursor:default; }
    .to-range-display { font-size:.9rem; color:#374151; font-weight:500; white-space:nowrap; }
    .to-range-cal-icon { color:#9ca3af; font-size:.95rem; cursor:pointer; padding:4px; border-radius:5px; transition:color .15s, background .15s; }
    .to-range-cal-icon:hover { color:#f07820; background:#fff7ed; }
    /* Preset dropdown popup */
    .to-preset-popup { position:absolute; top:calc(100% + 6px); left:0; z-index:700; background:#fff; border:1.5px solid #e5e7eb; border-radius:10px; box-shadow:0 10px 36px rgba(0,0,0,.14); min-width:190px; overflow:hidden; animation:to-fade-in .12s ease; }
    @@keyframes to-fade-in { from { opacity:0; transform:translateY(-4px); } to { opacity:1; transform:translateY(0); } }
    .to-preset-row { display:flex; align-items:center; justify-content:space-between; padding:11px 18px; font-size:.9rem; color:#374151; cursor:pointer; font-weight:500; transition:background .1s; }
