@page "/settings/time-off-holidays"
@using System.Net.Http.Json
@using System.Text.Json
@inject TimeOffPolicyService PolicyService
@inject IHttpClientFactory ClientFactory
@inject SessionService SessionService

<BasePage Title="Time Off &amp; Holidays">

<div class="tp-page">

    <!-- ── Tabs ── -->
    <div class="tp-tabs-row">
        <div class="tp-tabs">
            <span class='tp-tab @(activeTab == "policies" ? "tp-tab--active" : "")'
                  @onclick='() => activeTab = "policies"'>Time Off Policies</span>
            <span class='tp-tab @(activeTab == "holidays" ? "tp-tab--active" : "")'
                  @onclick='() => activeTab = "holidays"'>Holidays</span>
        </div>
        <div class="tp-tabs-actions" style='@(activeTab == "policies" ? "" : "display:none")'>
            <button class="tp-approval-btn">
                <i class="bi bi-gear-fill"></i> Approval Settings
            </button>
            <button class="tp-add-btn" @onclick="OpenAdd">
                Add Time Off Policy
            </button>
        </div>
        <div class="tp-tabs-actions" style='@(activeTab == "holidays" ? "" : "display:none")'>
            <button class="tp-approval-btn" @onclick="RefreshCalendars">
                <i class="bi bi-arrow-clockwise"></i> Refresh calendars
            </button>
        </div>
    </div>

    <div id="tp-policies-section" style='@(activeTab == "policies" ? "" : "display:none")'>
    <!-- ── Toolbar ── -->
    <div class="tp-toolbar">
        <div class="tp-toolbar-left">
            <div class="tp-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search..." @bind="searchText" @bind:event="oninput" />
            </div>

            <!-- Compensation dropdown -->
            <div class="tp-dd-wrap" @onclick:stopPropagation>
                <button class="tp-dd-btn @(compOpen ? "tp-dd-btn--open" : "")"
                        @onclick="() => { compOpen = !compOpen; unitOpen = false; }">
                    Compensation
                    <i class="bi @(compOpen ? "bi-chevron-up" : "bi-chevron-down") tp-dd-chevron"></i>
                </button>
                @if (compOpen)
                {
                    <div class="tp-dd-menu">
                        <div class="tp-dd-item @(filterComp=="Paid"?"tp-dd-item--sel":"")"
                             @onclick='() => { filterComp = filterComp=="Paid"?"":"Paid"; compOpen=false; }'>
                            Paid
                        </div>
                        <div class="tp-dd-item @(filterComp=="Unpaid"?"tp-dd-item--sel":"")"
                             @onclick='() => { filterComp = filterComp=="Unpaid"?"":"Unpaid"; compOpen=false; }'>
                            Unpaid
                        </div>
                        <div class="tp-dd-sep"></div>
                        <div class="tp-dd-item tp-dd-item--clear"
                             @onclick='() => { filterComp = ""; compOpen=false; }'>
                            Clear selection
                        </div>
                    </div>
                }
            </div>

            <!-- Units dropdown -->
            <div class="tp-dd-wrap" @onclick:stopPropagation>
                <button class="tp-dd-btn @(unitOpen ? "tp-dd-btn--open" : "")"
                        @onclick="() => { unitOpen = !unitOpen; compOpen = false; }">
                    Units
                    <i class="bi @(unitOpen ? "bi-chevron-up" : "bi-chevron-down") tp-dd-chevron"></i>
                </button>
                @if (unitOpen)
                {
                    <div class="tp-dd-menu">
                        <div class="tp-dd-item @(filterUnit=="Hours"?"tp-dd-item--sel":"")"
                             @onclick='() => { filterUnit = filterUnit=="Hours"?"":"Hours"; unitOpen=false; }'>
                            Hours
                        </div>
                        <div class="tp-dd-item @(filterUnit=="Days"?"tp-dd-item--sel":"")"
                             @onclick='() => { filterUnit = filterUnit=="Days"?"":"Days"; unitOpen=false; }'>
                            Days
                        </div>
                        <div class="tp-dd-sep"></div>
                        <div class="tp-dd-item tp-dd-item--clear"
                             @onclick='() => { filterUnit = ""; unitOpen=false; }'>
                            Clear selection
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="tp-toolbar-right">
        </div>
    </div>

    @if (compOpen || unitOpen)
    {
        <div style="position:fixed;inset:0;z-index:98;" @onclick="() => { compOpen=false; unitOpen=false; }"></div>
    }

    <!-- ── Table ── -->
    @if (isLoading)
    {
        <div class="tp-loading"><div class="tp-spinner"></div><span>Loading...</span></div>
    }
    else if (errorMsg != null)
    {
        <div class="tp-error"><i class="bi bi-exclamation-circle"></i> @errorMsg <button @onclick="Load">Retry</button></div>
    }
    else
    {
        <div class="tp-table-wrap">
            <table class="tp-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Compensation</th>
                        <th>Units</th>
                        <th>Accrual</th>
                        <th>Assignees</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (!Filtered.Any())
                {
                    <tr>
                        <td colspan="6" class="tp-nodata">
                            @if (policies.Any())
                            {
                                <span>No policies match your search.</span>
                            }
                            else
                            {
                                <span>No data available</span>
                            }
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var p in Filtered)
                    {
                        var cp = p;
                        <tr class="tp-row" @onclick="() => OpenEdit(cp)">
                            <td>
                                <div class="tp-name-cell">
                                    <div class="tp-name-icon"><i class="bi bi-briefcase"></i></div>
                                    <span>@p.Name</span>
                                </div>
                            </td>
                            <td>
                                <span class="tp-badge tp-badge--@p.CompensationType.ToLower()">@p.CompensationType</span>
                            </td>
                            <td class="tp-muted">@p.Unit</td>
                            <td class="tp-muted">@p.AccrualType</td>
                            <td class="tp-muted">@p.AssigneeSummary</td>
                            <td class="tp-actions" @onclick:stopPropagation="true">
                                <button class="tp-icon-btn" title="Edit" @onclick="() => OpenEdit(cp)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="tp-icon-btn tp-icon-btn--del" title="Delete" @onclick="() => PromptDelete(cp)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        @* Empty state hero card (Jibble-style) *@
        @if (!policies.Any() && !heroDismissed)
        {
            <div class="tp-hero">
                <div class="tp-hero-text">
                    <h3>Manage time off for accurate attendance</h3>
                    <p>Configure time off policies to track entitlements, manage attendance, and ensure accurate payroll records.</p>
                    <a href="#" class="tp-hero-link">Learn more about Time Off <i class="bi bi-box-arrow-up-right"></i></a>
                    <button class="tp-hero-dismiss" @onclick="() => heroDismissed = true">Dismiss</button>
                </div>
                <div class="tp-hero-img">
                    <!-- Travel / time-off illustration -->
                    <svg viewBox="0 0 240 200" xmlns="http://www.w3.org/2000/svg" fill="none">
                        <!-- Ground blob -->
                        <ellipse cx="120" cy="178" rx="95" ry="18" fill="#e8eaed" opacity=".6"/>
                        <!-- Luggage body -->
                        <rect x="72" y="100" width="62" height="72" rx="8" fill="#4285f4"/>
                        <rect x="82" y="108" width="42" height="56" rx="5" fill="#5a9bf5"/>
                        <!-- Luggage handle -->
                        <rect x="93" y="86" width="20" height="20" rx="5" stroke="#4285f4" stroke-width="4" fill="none"/>
                        <!-- Luggage wheels -->
                        <circle cx="85" cy="175" r="6" fill="#2563eb"/>
                        <circle cx="121" cy="175" r="6" fill="#2563eb"/>
                        <!-- Luggage strap -->
                        <rect x="99" y="100" width="8" height="72" rx="3" fill="#3b82f6" opacity=".5"/>
                        <!-- Luggage latch -->
                        <rect x="97" y="133" width="12" height="8" rx="3" fill="#1d4ed8"/>
                        <!-- Person legs -->
                        <rect x="148" y="138" width="14" height="38" rx="7" fill="#1e40af"/>
                        <rect x="165" y="138" width="14" height="38" rx="7" fill="#1e40af"/>
                        <!-- Person shoes -->
                        <ellipse cx="155" cy="176" rx="10" ry="5" fill="#111827"/>
                        <ellipse cx="172" cy="176" rx="10" ry="5" fill="#111827"/>
                        <!-- Person body -->
                        <rect x="142" y="90" width="42" height="52" rx="14" fill="#f97316"/>
                        <!-- Person arm (reaching for luggage) -->
                        <rect x="124" y="108" width="22" height="10" rx="5" fill="#f97316"/>
                        <!-- Person arm (other side) -->
                        <rect x="182" y="108" width="20" height="10" rx="5" fill="#f97316"/>
                        <!-- Person head -->
                        <circle cx="163" cy="72" r="22" fill="#92400e"/>
                        <!-- Hair -->
                        <ellipse cx="163" cy="55" rx="22" ry="12" fill="#111827"/>
                        <ellipse cx="148" cy="68" rx="8" ry="14" fill="#111827"/>
                        <!-- Plant pot -->
                        <rect x="196" y="142" width="30" height="28" rx="4" fill="#d1d5db"/>
                        <rect x="199" y="138" width="24" height="8" rx="3" fill="#9ca3af"/>
                        <!-- Plant leaves -->
                        <ellipse cx="211" cy="128" rx="8" ry="14" fill="#4ade80" transform="rotate(-20 211 128)"/>
                        <ellipse cx="218" cy="122" rx="7" ry="12" fill="#22c55e" transform="rotate(15 218 122)"/>
                        <ellipse cx="204" cy="124" rx="7" ry="12" fill="#4ade80" transform="rotate(-35 204 124)"/>
                        <!-- Sparkles -->
                        <circle cx="46" cy="88" r="4" fill="#fbbf24" opacity=".8"/>
                        <circle cx="58" cy="70" r="3" fill="#f97316" opacity=".6"/>
                        <circle cx="38" cy="110" r="3" fill="#a78bfa" opacity=".7"/>
                    </svg>
                </div>
            </div>
        }
    }

</div>

    </div><!-- /tp-policies-section -->

    <div id="tp-holidays-section" style='@(activeTab == "holidays" ? "" : "display:none")'>
        <HolidaysTab />
    </div>

<!-- Archived policies footer -->
<div class="tp-archived-footer">
    <i class="bi bi-archive"></i>
    <a href="#">Archived policies</a>
</div>

<!-- ════════════════════════════════════════════
     ADD / EDIT SLIDE PANEL
════════════════════════════════════════════ -->
@if (panelOpen)
{
    <div class="tp-overlay" @onclick="ClosePanel"></div>
    <div class="tp-panel" @onclick:stopPropagation>

        <div class="tp-panel-head">
            <span class="tp-panel-title">@(editId.HasValue ? "Edit Policy" : "Add Time Off Policy")</span>
            <button class="tp-panel-x" @onclick="ClosePanel"><i class="bi bi-x-lg"></i></button>
        </div>

        <div class="tp-panel-body">

            <!-- POLICY DETAILS -->
            <div class="tp-section-label">POLICY DETAILS</div>

            <!-- Name -->
            <div class="tp-pfield">
                <label class="tp-plabel">Name</label>
                <input class="tp-pinput @(nameErr ? "tp-pinput--err" : "")"
                       type="text" placeholder="Name of the policy (required)"
                       @bind="fName" @bind:event="oninput"
                       @onfocus="() => nameErr = false" />
                @if (nameErr) { <span class="tp-ferr">Policy name is required.</span> }
            </div>

            <!-- Members -->
            <div class="tp-pfield">
                <label class="tp-plabel">
                    Members
                    <i class="bi bi-info-circle tp-info-icon" title="Assign specific members or groups, or leave it as default to apply to everyone."></i>
                </label>
                @if (selEmps.Any())
                {
                    <div class="tp-chips-wrap">
                        @foreach (var mid in selEmps)
                        {
                            var m = members.FirstOrDefault(x => x.Id == mid);
                            if (m != null)
                            {
                                var capturedId = mid;
                                <span class="tp-chip">
                                    @m.FullName
                                    <button class="tp-chip-x" @onclick="() => TogEmp(capturedId)" @onclick:stopPropagation>x</button>
                                </span>
                            }
                        }
                    </div>
                }
                <div class="tp-member-box @(membersOpen ? "tp-member-box--open" : "")" @onclick:stopPropagation>
                    <input class="tp-member-search-input"
                           type="text"
                           placeholder="Select members"
                           @bind="memberSearch"
                           @bind:event="oninput"
                           @onfocus="() => membersOpen = true" />
                </div>
                @if (membersOpen)
                {
                    <div class="tp-member-dropdown" @onclick:stopPropagation>
                        @{
                            var filtered = string.IsNullOrWhiteSpace(memberSearch)
                                ? members
                                : members.Where(m => m.FullName.Contains(memberSearch, StringComparison.OrdinalIgnoreCase)
                                                  || m.Email.Contains(memberSearch, StringComparison.OrdinalIgnoreCase)).ToList();
                        }
                        @if (!filtered.Any())
                        {
                            <div class="tp-member-empty">No members found</div>
                        }
                        else
                        {
                            @foreach (var m in filtered)
                            {
                                var mid2 = m.Id;
                                bool isSel = selEmps.Contains(mid2);
                                <div class="tp-member-row @(isSel ? "tp-member-row--sel" : "")"
                                     @onclick="() => SelectMember(mid2)">
                                    <div class="tp-member-av">@(m.FullName.Length > 0 ? m.FullName[0].ToString().ToUpper() : "?")</div>
                                    <div class="tp-member-info">
                                        <span class="tp-member-name">@m.FullName</span>
                                        <span class="tp-member-email">@m.Email</span>
                                    </div>
                                    @if (isSel) { <i class="bi bi-check2 tp-member-check"></i> }
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            @if (membersOpen)
            {
                <div style="position:fixed;inset:0;z-index:498;" @onclick="CloseMembersDropdown"></div>
            }

            <!-- Compensation -->
            <div class="tp-pfield">
                <label class="tp-plabel">
                    Compensation
                    <i class="bi bi-info-circle tp-info-icon" title="Paid leaves count towards payroll. Unpaid leaves deduct from salary."></i>
                </label>
                <div class="tp-toggle-row">
                    <button class="tp-toggle-btn @(fComp=="Paid"?"tp-toggle-btn--sel":"")"
                            @onclick='() => { fComp = "Paid"; }'>Paid</button>
                    <button class="tp-toggle-btn @(fComp=="Unpaid"?"tp-toggle-btn--sel":"")"
                            @onclick='() => { fComp = "Unpaid"; fAccrual = "None"; }'>Unpaid</button>
                </div>
            </div>

            <!-- Units — always visible -->
            <div class="tp-pfield">
                <label class="tp-plabel">Units</label>
                <div class="tp-toggle-row">
                    <button class="tp-toggle-btn @(fUnit=="Days"?"tp-toggle-btn--sel":"")"
                            @onclick='() => fUnit="Days"'>Days</button>
                    <button class="tp-toggle-btn @(fUnit=="Hours"?"tp-toggle-btn--sel":"")"
                            @onclick='() => fUnit="Hours"'>Hours</button>
                </div>
            </div>

            @if (fComp == "Paid")
            {
                <!-- ACCRUAL SETTINGS — Paid only -->
                <div class="tp-section-label">ACCRUAL SETTINGS</div>

                <div class="tp-pfield">
                    <label class="tp-plabel">Schedule of Accrual</label>
                    <div class="tp-select-wrap">
                        <select class="tp-pselect" @bind="fAccrual">
                            <option value="None">None</option>
                            <option value="Annual">Annual – earned yearly</option>
                            <option value="Monthly">Monthly – earned each month</option>
                        </select>
                    </div>
                </div>

                <div class="tp-pfield">
                    <label class="tp-plabel">Entitled</label>
                    <div class="tp-entitled-row">
                        <input class="tp-pinput tp-entitled-num" type="number" min="0" step="0.5"
                               placeholder="0" @bind="fEntitlement" />
                        <div class="tp-select-wrap tp-entitled-unit">
                            <select class="tp-pselect" @bind="fUnit">
                                <option value="Days">Days</option>
                                <option value="Hours">Hours</option>
                            </select>
                        </div>
                    </div>
                </div>
            }

            <!-- Exclude checkboxes — always visible -->
            <label class="tp-pchk-row">
                <input type="checkbox" @bind="fExcludePH" />
                <span>Exclude public holidays</span>
                <i class="bi bi-info-circle tp-info-icon" title="Public holidays won't be counted as leave days"></i>
            </label>
            <label class="tp-pchk-row">
                <input type="checkbox" @bind="fExcludeNW" />
                <span>Exclude non-working days</span>
                <i class="bi bi-info-circle tp-info-icon" title="Weekends and non-working days won't be counted"></i>
            </label>

            @if (fComp == "Paid")
            {
                <!-- BALANCE RULES — Paid only -->
                <div class="tp-section-label" style="margin-top:8px;">
                    BALANCE RULES
                    <i class="bi bi-info-circle tp-info-icon" title="Configure how unused leave balances are handled"></i>
                </div>

                <label class="tp-pchk-row">
                    <input type="checkbox" @bind="fCarry" />
                    <span>Leave balances can be carried forward to the next cycle.</span>
                </label>

                @if (fCarry)
                {
                    <div class="tp-carry-box">
                        <div class="tp-pfield">
                            <label class="tp-plabel">Max @fUnit to carry forward</label>
                            <input class="tp-pinput" type="number" min="0" step="0.5"
                                   placeholder="e.g. 5" @bind="fCarryLimit" />
                        </div>
                        <div class="tp-pfield">
                            <label class="tp-plabel">Expires after (months into new cycle)</label>
                            <input class="tp-pinput" type="number" min="1" max="12"
                                   placeholder="e.g. 3" @bind="fCarryExpiry" />
                            <span class="tp-hint">Leave blank for no expiry.</span>
                        </div>
                    </div>
                }
            }

            @if (saveErr != null)
            {
                <div class="tp-save-err"><i class="bi bi-exclamation-triangle"></i> @saveErr</div>
            }

        </div>
        <div class="tp-panel-foot">
            <button class="tp-btn-cancel" @onclick="ClosePanel">Cancel</button>
            <button class="tp-btn-save" @onclick="Save" disabled="@saving">
                @if (saving) { <span class="tp-mini-spin"></span> }
                else { <span>Save</span> }
            </button>
        </div>

    </div>
}

<!-- ════════════════════════════════════════════
     DELETE MODAL
════════════════════════════════════════════ -->
@if (deleteTarget != null)
{
    <div class="tp-modal-back">
        <div class="tp-modal">
            <div class="tp-modal-head">
                <span>Delete Policy</span>
                <button class="tp-panel-x" @onclick="() => deleteTarget = null"><i class="bi bi-x-lg"></i></button>
            </div>
            <p class="tp-modal-body">
                Are you sure you want to delete <strong>@deleteTarget.Name</strong>? This action cannot be undone.
            </p>
            @if (delErr != null)
            {
                <div class="tp-save-err"><i class="bi bi-exclamation-triangle"></i> @delErr</div>
            }
            <div class="tp-modal-foot">
                <button class="tp-btn-cancel" @onclick="() => { deleteTarget = null; delErr = null; }">Cancel</button>
                <button class="tp-btn-del" @onclick="ConfirmDelete" disabled="@deleting">
                    @if (deleting) { <span class="tp-mini-spin"></span> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

</BasePage>

@code {
    // ── Data ──────────────────────────────────────────────────────────────────
    private List<TimeOffPolicyVm> policies = new();
    private List<MiniEmployee>    members  = new();
    private List<MiniGroup>       groups   = new();

    // ── Tab ──────────────────────────────────────────────────────────────────
    private string  activeTab = "policies";

    // ── State ─────────────────────────────────────────────────────────────────
    private bool    isLoading = true;
    private string? errorMsg;
    private string  searchText   = "";
    private string  filterComp   = "";
    private string  filterUnit   = "";
    private bool    compOpen     = false;
    private bool    unitOpen     = false;
    private bool    heroDismissed = false;

    // ── Panel ─────────────────────────────────────────────────────────────────
    private bool    panelOpen = false;
    private int?    editId    = null;
    private bool    saving    = false;
    private string? saveErr;
    private bool    nameErr   = false;
    private string  memberSearch = "";
    private bool    membersOpen  = false;

    // Form fields
    private string  fName        = "";
    private string  fComp        = "Paid";
    private string  fUnit        = "Days";
    private string  fAccrual     = "None";
    private double  fEntitlement = 0;
    private bool    fExcludePH   = false;
    private bool    fExcludeNW   = false;
    private bool    fCarry       = false;
    private double? fCarryLimit;
    private int?    fCarryExpiry;
    private HashSet<int> selGroups = new();
    private HashSet<int> selEmps   = new();

    // ── Delete ────────────────────────────────────────────────────────────────
    private TimeOffPolicyVm? deleteTarget;
    private bool    deleting = false;
    private string? delErr;

    // ── Computed ──────────────────────────────────────────────────────────────
    private IEnumerable<TimeOffPolicyVm> Filtered => policies
        .Where(p =>
            (string.IsNullOrWhiteSpace(searchText) || p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filterComp) || p.CompensationType == filterComp) &&
            (string.IsNullOrWhiteSpace(filterUnit) || p.Unit == filterUnit));

    private IEnumerable<MiniEmployee> MembersFiltered => string.IsNullOrWhiteSpace(memberSearch)
        ? members
        : members.Where(m => m.FullName.Contains(memberSearch, StringComparison.OrdinalIgnoreCase)
                          || m.Email.Contains(memberSearch, StringComparison.OrdinalIgnoreCase));

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
        => await Task.WhenAll(Load(), LoadMembersGroups());

    private async Task Load()
    {
        isLoading = true; errorMsg = null; StateHasChanged();
        try   { policies = await PolicyService.GetAllAsync(); }
        catch (Exception ex) { errorMsg = ex.Message; }
        isLoading = false; StateHasChanged();
    }

    private async Task LoadMembersGroups()
    {
        try
        {
            var client = ClientFactory.CreateClient("API");
            var eRes   = await client.GetAsync($"api/employees?organizationId={SessionService.ActiveOrganizationId}");
            var gRes   = await client.GetAsync("api/groups");

            if (eRes.IsSuccessStatusCode)
            {
                var arr = JsonSerializer.Deserialize<JsonElement[]>(
                    await eRes.Content.ReadAsStringAsync(),
                    new JsonSerializerOptions(JsonSerializerDefaults.Web));
                members = arr?.Select(e => new MiniEmployee
                {
                    Id       = e.GetProperty("id").GetInt32(),
                    FullName = e.GetProperty("fullName").GetString() ?? "",
                    Email    = e.GetProperty("email").GetString() ?? ""
                }).ToList() ?? new();
            }

            if (gRes.IsSuccessStatusCode)
            {
                var arr = JsonSerializer.Deserialize<JsonElement[]>(
                    await gRes.Content.ReadAsStringAsync(),
                    new JsonSerializerOptions(JsonSerializerDefaults.Web));
                groups = arr?.Select(g => new MiniGroup
                {
                    Id   = g.GetProperty("id").GetInt32(),
                    Name = g.GetProperty("name").GetString() ?? ""
                }).ToList() ?? new();
            }
        }
        catch { /* non-critical */ }
    }

    // ── Panel open/close ──────────────────────────────────────────────────────
    private void OpenAdd()
    {
        editId = null;
        ResetForm();
        panelOpen = true;
    }

    private void OpenEdit(TimeOffPolicyVm p)
    {
        editId       = p.Id;
        fName        = p.Name;
        fComp        = p.CompensationType;
        fUnit        = p.Unit;
        fAccrual     = p.AccrualType;
        fEntitlement = p.AnnualEntitlement;
        fExcludePH   = p.ExcludePublicHolidays;
        fExcludeNW   = p.ExcludeNonWorkingDays;
        fCarry       = p.AllowCarryForward;
        fCarryLimit  = p.CarryForwardLimit;
        fCarryExpiry = p.CarryForwardExpiryMonths;
        selGroups    = new HashSet<int>(p.AssignedGroupIds);
        selEmps      = new HashSet<int>(p.AssignedEmployeeIds);
        saveErr      = null; nameErr = false; memberSearch = "";
        panelOpen    = true;
    }

    private void ClosePanel() { panelOpen = false; saveErr = null; membersOpen = false; memberSearch = ""; }

    private void ResetForm()
    {
        fName = ""; fComp = "Paid"; fUnit = "Days"; fAccrual = "None";
        fEntitlement = 0; fExcludePH = false; fExcludeNW = false;
        fCarry = false; fCarryLimit = null; fCarryExpiry = null;
        selGroups = new(); selEmps = new(); saveErr = null; nameErr = false; memberSearch = "";
    }

    // ── Assign toggles ────────────────────────────────────────────────────────
    private void TogGrp(int id) { if (!selGroups.Remove(id)) selGroups.Add(id); }
    private void TogEmp(int id) { if (!selEmps.Remove(id))   selEmps.Add(id); }

    private void SelectMember(int id)
    {
        TogEmp(id);
        memberSearch = "";
    }

    private void CloseMembersDropdown()
    {
        membersOpen = false;
        memberSearch = "";
    }

    // ── Save ──────────────────────────────────────────────────────────────────
    private async Task Save()
    {
        nameErr = string.IsNullOrWhiteSpace(fName);
        if (nameErr) return;

        saving = true; saveErr = null;

        var req = new SaveTimeOffPolicyRequest
        {
            Name                     = fName.Trim(),
            CompensationType         = fComp,
            Unit                     = fUnit,
            AccrualType              = fComp == "Unpaid" ? "None" : fAccrual,
            AnnualEntitlement        = fEntitlement,
            ExcludePublicHolidays    = fExcludePH,
            ExcludeNonWorkingDays    = fExcludeNW,
            AllowCarryForward        = fCarry,
            CarryForwardLimit        = fCarry ? fCarryLimit : null,
            CarryForwardExpiryMonths = fCarry ? fCarryExpiry : null,
            AssignedGroupIds         = selGroups.ToList(),
            AssignedEmployeeIds      = selEmps.ToList()
        };

        var (ok, err) = editId.HasValue
            ? await PolicyService.UpdateAsync(editId.Value, req)
            : await PolicyService.CreateAsync(req);

        if (ok) { panelOpen = false; await Load(); }
        else    { saveErr = err ?? "Failed to save."; }

        saving = false;
    }

    // ── Delete ────────────────────────────────────────────────────────────────
    private void PromptDelete(TimeOffPolicyVm p) { deleteTarget = p; delErr = null; }

    private async Task ConfirmDelete()
    {
        if (deleteTarget == null) return;
        deleting = true; delErr = null;

        var (ok, err) = await PolicyService.DeleteAsync(deleteTarget.Id);
        if (ok) { deleteTarget = null; await Load(); }
        else    { delErr = err ?? "Delete failed."; }

        deleting = false;
    }

    // ── Holidays ─────────────────────────────────────────────────────────────
    private void RefreshCalendars() { StateHasChanged(); }

    // ── Local helper models ───────────────────────────────────────────────────
    private record MiniEmployee(int Id, string FullName, string Email)
    {
        public MiniEmployee() : this(0, "", "") { }
        public int    Id       { get; init; } = Id;
        public string FullName { get; init; } = FullName;
        public string Email    { get; init; } = Email;
    }
    private record MiniGroup(int Id, string Name)
    {
        public MiniGroup() : this(0, "") { }
        public int    Id   { get; init; } = Id;
        public string Name { get; init; } = Name;
    }
}

