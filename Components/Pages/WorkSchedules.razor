    /* ═══ Main ═══════════════════════════════════════════════════════════════ */
    .ws-main { flex:1; overflow-y:auto; scrollbar-width:thin; }
    .ws-top-hint { font-size:13px; color:#374151; padding:12px 24px; background:#fff; border-bottom:1px solid #e8eaed; }
    .ws-upgrade-banner { display:flex; align-items:flex-start; gap:14px; margin:20px 24px 0; padding:16px 20px; background:#fff; border:1px solid #e8eaed; border-radius:10px; }
    .ws-banner-icon { color:#ef4444; font-size:16px; flex-shrink:0; margin-top:2px; }
    .ws-banner-body { flex:1; }
    .ws-banner-title { font-size:14px; font-weight:700; color:#111827; margin-bottom:4px; }
    .ws-banner-desc { font-size:13px; color:#6b7280; line-height:1.5; }
    .ws-upgrade-cta { flex-shrink:0; padding:8px 16px; border-radius:8px; background:#ff7a00; color:#fff; border:none; font-size:13px; font-weight:600; cursor:pointer; font-family:inherit; white-space:nowrap; align-self:center; transition:background .15s; }
    .ws-upgrade-cta:hover { background:#e66c00; }
    .ws-banner-dismiss { flex-shrink:0; background:none; border:none; color:#9ca3af; font-size:13px; cursor:pointer; font-family:inherit; align-self:center; padding:4px; }

    /* ═══ Sections ═══════════════════════════════════════════════════════════ */
    .ws-section { padding:24px 24px 0; }
    .ws-section-header { font-size:12px; font-weight:800; color:#374151; letter-spacing:1px; text-transform:uppercase; display:flex; align-items:center; gap:7px; margin-bottom:20px; }
    .ws-section-desc { font-size:13px; color:#6b7280; line-height:1.6; margin-bottom:14px; margin-top:-10px; }
    .ws-info-icon { font-size:13px; color:#9ca3af; cursor:help; flex-shrink:0; }
    .ws-divider { height:1px; background:#e8eaed; margin:24px 0 0; }
    .ws-field-row { display:flex; align-items:center; gap:20px; margin-bottom:24px; flex-wrap:wrap; }
    .ws-field-label { font-size:14px; font-weight:500; color:#374151; min-width:160px; flex-shrink:0; }
    .ws-input { flex:1; max-width:580px; padding:10px 14px; border:1.5px solid #e5e7eb; border-radius:8px; font-size:14px; color:#111827; font-family:inherit; background:#fff; transition:border-color .15s; box-sizing:border-box; min-width:200px; }
    .ws-input:focus { outline:none; border-color:#ff7a00; }
    .ws-empty-label { font-size:13px; color:#9ca3af; margin-bottom:12px; font-style:italic; }

    /* ═══ Arrangement tabs ═══════════════════════════════════════════════════ */
    .ws-arrangement-tabs { display:flex; border:1.5px solid #e5e7eb; border-radius:8px; overflow:hidden; background:#fff; }
    .ws-arr-tab { padding:10px 28px; border:none; background:transparent; font-size:14px; font-weight:500; color:#374151; cursor:pointer; font-family:inherit; border-right:1.5px solid #e5e7eb; transition:background .15s, color .15s; }
    .ws-arr-tab:last-child { border-right:none; }
    .ws-arr-tab:hover:not(.ws-arr-tab--active) { background:#f9fafb; }
    .ws-arr-tab--active { background:#fff7ed; color:#ff7a00; font-weight:700; }

    /* ═══ Day buttons ════════════════════════════════════════════════════════ */
    .ws-days-row { display:flex; gap:6px; flex-wrap:wrap; }
    .ws-day-btn { width:36px; height:36px; border-radius:50%; border:1.5px solid #e5e7eb; background:#fff; font-size:13px; font-weight:600; color:#374151; cursor:pointer; font-family:inherit; display:flex; align-items:center; justify-content:center; transition:border-color .15s, background .15s, color .15s; }
    .ws-day-btn:hover { border-color:#ff7a00; color:#ff7a00; }
    .ws-day-btn--sel { background:#ff7a00; border-color:#ff7a00; color:#fff; }

    /* ═══ Per-day rows (Fixed / Flexible) ═══════════════════════════════════ */
    .ws-day-schedule-list { display:flex; flex-direction:column; margin-bottom:8px; }
    .ws-flex-day-row { display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid #f3f4f6; font-size:14px; color:#374151; }
    .ws-flex-day-label { min-width:180px; flex-shrink:0; font-size:14px; font-weight:500; color:#374151; text-align:right; padding-right:8px; }
    .ws-rest-label { color:#9ca3af; font-size:13px; font-style:italic; }
    .ws-time-arrow { font-size:13px; color:#374151; font-weight:400; }

    /* Time box — plain until focused */
    .ws-time-box { display:flex; align-items:center; gap:6px; border:1.5px solid #e5e7eb; border-radius:8px; background:#fff; padding:9px 14px; transition:border-color .15s; }
    .ws-time-box--active { border-color:#e5e7eb; }
    .ws-time-box--active:focus-within,
    .ws-time-box:focus-within { border-color:#ff7a00; }
    .ws-time-box--disabled-range { background:#f9fafb; border-color:#e5e7eb; opacity:0.6; }
    .ws-time-native { border:none; outline:none; font-size:14px; color:#374151; font-weight:500; font-family:inherit; background:transparent; cursor:pointer; min-width:100px; }
    .ws-time-native:disabled { color:#9ca3af; cursor:not-allowed; }
    .ws-time-clock { font-size:13px; color:#9ca3af; flex-shrink:0; }
    .ws-time-clock--clickable { cursor:pointer; }
    .ws-time-clock--clickable:hover { color:#ff7a00; }

    /* H/M box — plain (no border) vs focused (with border) */
    .ws-hm-box { display:flex; align-items:center; gap:4px; border-radius:8px; background:#fff; padding:9px 14px; transition:border-color .15s; }
    .ws-hm-box--plain { border:1.5px solid transparent; }
    .ws-hm-box--focused { border:1.5px solid #e5e7eb; }
    .ws-hm-box--focused:focus-within { border-color:#ff7a00; }
    .ws-hm-box--sm { padding:9px 12px; }
    .ws-hm-break { padding:9px 14px; }
    .ws-hm-input { width:36px; border:none; outline:none; font-size:14px; font-weight:700; color:#111827; font-family:inherit; background:transparent; text-align:center; }
    .ws-hm-input--no-arrows::-webkit-inner-spin-button, .ws-hm-input--no-arrows::-webkit-outer-spin-button { -webkit-appearance:none; margin:0; }
    .ws-hm-input--no-arrows { -moz-appearance:textfield; }
    .ws-hm-sep { font-size:13px; color:#6b7280; margin:0 2px; font-weight:500; }
    .ws-hm-clock-sm { font-size:13px; color:#9ca3af; margin-left:6px; flex-shrink:0; }

    /* Copy to all button */
    .ws-copy-all-btn { display:inline-flex; align-items:center; gap:5px; background:none; border:none; cursor:pointer; font-family:inherit; font-size:13px; font-weight:600; color:#ff7a00; padding:0 4px; white-space:nowrap; transition:color .15s; }
    .ws-copy-all-btn:hover { color:#c05a00; }
    .ws-copy-all-btn i { font-size:13px; }

    /* ═══ Split timesheets ═══════════════════════════════════════════════════ */
    .ws-split-row { display:flex; align-items:center; gap:10px; padding:20px 0 18px; border-top:1px solid #f3f4f6; flex-wrap:wrap; }
    /* Disabled state — grey, light text */
    .ws-split-box--disabled { display:flex; align-items:center; gap:8px; border:1.5px solid #e5e7eb; border-radius:8px; background:#f9fafb; padding:8px 14px; }
    .ws-split-time-text { font-size:14px; color:#9ca3af; min-width:82px; }
    /* Edit state */
    .ws-split-box--edit { display:flex; align-items:center; gap:8px; border:1.5px solid #e5e7eb; border-radius:8px; background:#fff; padding:8px 14px; transition:border-color .15s; }
    .ws-split-box--edit:focus-within { border-color:#ff7a00; }
    .ws-split-time-input { border:none; outline:none; font-size:14px; color:#374151; font-weight:500; font-family:inherit; background:transparent; cursor:pointer; min-width:82px; }
    .ws-split-clock { font-size:13px; color:#9ca3af; flex-shrink:0; }
    .ws-split-edit-btn { background:#f3f4f6; border:1.5px solid #e5e7eb; border-radius:8px; padding:7px 10px; color:#6b7280; cursor:pointer; font-size:14px; transition:background .15s, color .15s; }
    .ws-split-edit-btn:hover { background:#e5e7eb; color:#374151; }
    .ws-split-cancel-text { background:none; border:none; cursor:pointer; font-family:inherit; font-size:14px; font-weight:600; color:#ff7a00; padding:0 4px; transition:color .15s; }
    .ws-split-cancel-text:hover { color:#c05a00; }
    .ws-split-hint { font-size:12px; color:#9ca3af; flex-basis:100%; margin-top:0; padding-left:196px; }
    .ws-split-warning { display:flex; align-items:flex-start; gap:10px; flex-basis:100%; margin-top:6px; background:#fffbeb; border:1px solid #fde68a; border-radius:8px; padding:12px 16px; font-size:13px; color:#374151; line-height:1.5; }
    .ws-split-warn-icon { color:#f59e0b; font-size:15px; flex-shrink:0; margin-top:1px; }

    /* ═══ Breaks section — Image 1 layout ═══════════════════════════════════ */
    .ws-break-row-outer { margin-bottom:16px; }
    .ws-break-main-row { display:flex; align-items:center; gap:10px; flex-wrap:nowrap; }
    .ws-break-name-input { flex:1; min-width:140px; max-width:280px; padding:9px 12px; border:1.5px solid #e5e7eb; border-radius:8px; font-size:14px; color:#374151; font-family:inherit; background:#fff; transition:border-color .15s; }
    .ws-break-name-input:focus { outline:none; border-color:#ff7a00; }
    .ws-break-name-input::placeholder { color:#9ca3af; }
    .ws-break-time-row { display:flex; align-items:center; gap:10px; margin-top:10px; flex-wrap:wrap; padding-left:2px; }
    .ws-row-del { background:none; border:none; cursor:pointer; color:#9ca3af; font-size:15px; padding:4px 6px; transition:color .15s; flex-shrink:0; }
    .ws-row-del:hover { color:#ef4444; }
    /* Unpaid/Paid pill tabs for breaks */
    .ws-pill-tabs--break { margin-left:auto; }

    /* Pill tabs */
    .ws-pill-tabs { display:flex; border:1.5px solid #e5e7eb; border-radius:8px; overflow:hidden; background:#fff; }
    .ws-pill-tabs--ot { margin-left:auto; }
    .ws-pill-tab { padding:7px 18px; border:none; background:transparent; font-size:13px; font-weight:500; color:#374151; cursor:pointer; font-family:inherit; border-right:1.5px solid #e5e7eb; transition:background .15s, color .15s; }
    .ws-pill-tab:last-child { border-right:none; }
    .ws-pill-tab--active { background:#fff7ed; color:#ff7a00; font-weight:700; }
    .ws-pill-tab:hover:not(.ws-pill-tab--active) { background:#f9fafb; }

    .ws-add-link { display:inline-flex; align-items:center; gap:6px; background:none; border:none; cursor:pointer; font-family:inherit; font-size:14px; font-weight:600; color:#ff7a00; padding:8px 0; transition:color .15s; }
    .ws-add-link:hover { color:#c05a00; }

    /* ═══ Auto deductions ════════════════════════════════════════════════════ */
    .ws-deduction-row { display:flex; align-items:center; gap:12px; padding:10px 14px; border:1px solid #e8eaed; border-radius:8px; margin-bottom:8px; background:#fff; }
    .ws-break-name { flex:1; font-size:14px; color:#374151; font-weight:500; }

    /* ═══ Overtime — Image 4 layout ═════════════════════════════════════════ */
    .ws-ot-group { padding:16px 0; }
    .ws-ot-group--simple { display:flex; align-items:center; gap:14px; padding:16px 0; }
    .ws-ot-header-row { display:flex; align-items:center; }
    .ws-ot-left { display:flex; align-items:center; gap:14px; flex:1; }
    .ws-ot-label { font-size:14px; color:#374151; font-weight:500; }
    .ws-ot-divider { height:1px; background:#f3f4f6; }
    .ws-ot-detail { margin-top:16px; padding-left:0; display:flex; flex-direction:column; gap:14px; }
    .ws-ot-detail-row { display:flex; align-items:center; gap:12px; padding-left:54px; }
    .ws-ot-detail-label { font-size:14px; color:#374151; min-width:160px; }
    .ws-ot-x { font-size:14px; color:#6b7280; }
    /* Global Hours/Time pill floated to top-right of section */
    .ws-ot-global-pill-row { display:flex; justify-content:flex-end; margin-bottom:4px; }
    .ws-multiplier-input { width:130px; padding:10px 14px; border:1.5px solid #e5e7eb; border-radius:8px; font-size:14px; color:#9ca3af; font-family:inherit; background:#fff; }
    .ws-multiplier-input:focus { outline:none; border-color:#ff7a00; }

    /* Toggle switch */
    .ws-toggle { width:44px; height:24px; border-radius:12px; background:#d1d5db; position:relative; cursor:pointer; transition:background .2s; flex-shrink:0; }
    .ws-toggle--on { background:#22c55e; }
    .ws-toggle-knob { position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; box-shadow:0 1px 4px rgba(0,0,0,.2); transition:left .2s; }
    .ws-toggle--on .ws-toggle-knob { left:23px; }
    .ws-toggle--disabled { opacity:0.4; cursor:not-allowed; pointer-events:none; }
    .ws-toggle-wrap--disabled { cursor:not-allowed; }
    .ws-toggle-wrap--disabled .ws-toggle { pointer-events:none; }
    .ws-ot-label--disabled { opacity:0.45; color:#9ca3af; }
    .ws-green-check { accent-color:#22c55e; width:17px; height:17px; cursor:pointer; }
    .ws-checkbox-row { display:flex; align-items:center; gap:10px; font-size:13px; color:#374151; cursor:pointer; }

    /* ═══ Locations ══════════════════════════════════════════════════════════ */
    .ws-locations-row { display:flex; align-items:center; gap:20px; margin-bottom:16px; }
    .ws-locations-input-wrap { flex:1; max-width:480px; display:flex; align-items:center; border:1.5px solid #e5e7eb; border-radius:8px; background:#fff; padding:10px 14px; gap:8px; transition:border-color .15s; }
    .ws-locations-input-wrap:focus-within { border-color:#ff7a00; }
    .ws-locations-input { flex:1; border:none; outline:none; font-size:14px; color:#9ca3af; font-family:inherit; background:transparent; }
    .ws-loc-search { font-size:14px; color:#9ca3af; }

    /* ═══ Members ════════════════════════════════════════════════════════════ */
    .ws-premium-badge { font-size:10px; font-weight:700; padding:2px 8px; background:#eff6ff; color:#3b82f6; border-radius:20px; border:1px solid #bfdbfe; }
    .ws-members-notice { display:flex; align-items:center; gap:10px; padding:13px 16px; background:#fffbeb; border:1px solid #fde68a; border-radius:8px; margin-bottom:14px; font-size:13px; color:#92400e; font-weight:500; }
    .ws-notice-icon { color:#f59e0b; font-size:15px; flex-shrink:0; }
    .ws-members-link-row { font-size:13px; color:#6b7280; }
    .ws-go-people-link { color:#ff7a00; font-weight:600; text-decoration:none; }
    .ws-go-people-link:hover { text-decoration:underline; }
    .ws-members-link-text { color:#6b7280; }

    /* ═══ Footer ═════════════════════════════════════════════════════════════ */
    .ws-footer { flex-shrink:0; display:flex; align-items:center; justify-content:flex-end; gap:12px; padding:14px 24px; background:#fff; border-top:1px solid #e8eaed; z-index:20; }
    .ws-cancel-btn { padding:10px 28px; border-radius:8px; border:none; background:none; font-size:14px; font-weight:600; color:#ff7a00; cursor:pointer; font-family:inherit; transition:background .15s; }
    .ws-cancel-btn:hover { background:#fff7ed; }
    .ws-save-btn { padding:10px 36px; border-radius:8px; border:none; background:#ff7a00; color:#fff; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; display:flex; align-items:center; gap:8px; transition:background .15s; }
    .ws-save-btn:hover { background:#e66c00; }
    .ws-save-btn:disabled { background:#fbd5a7; cursor:not-allowed; }
    .ws-mini-spin { width:14px; height:14px; border-radius:50%; border:2px solid rgba(255,255,255,.4); border-top-color:#fff; animation:ws-spin .6s linear infinite; display:inline-block; }
    @@keyframes ws-spin { to { transform:rotate(360deg); } }

    /* ═══ Modal (Image 2) ════════════════════════════════════════════════════ */
    .ws-modal-backdrop { position:fixed; inset:0; background:rgba(0,0,0,0.35); z-index:1000; display:flex; align-items:center; justify-content:center; }
    .ws-modal { background:#fff; border-radius:16px; width:560px; max-width:90vw; padding:36px 40px; box-shadow:0 20px 60px rgba(0,0,0,0.15); }
    .ws-modal-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:20px; }
    .ws-modal-title { font-size:24px; font-weight:700; color:#111827; margin:0; }
    .ws-modal-close { background:none; border:none; font-size:20px; color:#6b7280; cursor:pointer; padding:4px; line-height:1; }
    .ws-modal-close:hover { color:#111827; }
    .ws-modal-body { font-size:14px; color:#374151; line-height:1.65; }
    .ws-modal-body p { margin:0 0 12px; }
    .ws-modal-link { color:#ff7a00; font-size:14px; font-weight:600; text-decoration:none; }
    .ws-modal-link:hover { text-decoration:underline; }
    .ws-modal-footer { display:flex; align-items:center; justify-content:flex-end; gap:12px; margin-top:28px; }
    .ws-modal-cancel { padding:10px 24px; border-radius:8px; border:none; background:none; font-size:14px; font-weight:600; color:#374151; cursor:pointer; font-family:inherit; transition:background .15s; }
    .ws-modal-cancel:hover { background:#f3f4f6; }
    .ws-modal-confirm { padding:10px 28px; border-radius:8px; border:none; background:#dc2626; color:#fff; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; transition:background .15s; }
    .ws-save-error { font-size:12px; color:#dc2626; font-weight:500; margin-left:8px; }
    .ws-modal-confirm:hover { background:#b91c1c; }

    /* ═══ Landing page ═══════════════════════════════════════════════════════ */
    .ws-landing { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:40px 24px; text-align:center; }
    .ws-landing-illustration { width:100%; max-width:420px; margin-bottom:28px; }
    .ws-landing-svg { width:100%; height:auto; }
    .ws-landing-title { font-size:22px; font-weight:800; color:#111827; margin:0 0 12px; }
    .ws-landing-desc { font-size:14px; color:#6b7280; line-height:1.65; margin:0 0 28px; max-width:420px; }
    .ws-landing-cta { padding:13px 36px; border-radius:8px; border:none; background:#ff7a00; color:#fff; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; transition:background .15s; margin-bottom:16px; }
    .ws-landing-cta:hover { background:#e66c00; }
    .ws-landing-learn { font-size:13px; font-weight:600; color:#ff7a00; text-decoration:none; }
    .ws-landing-learn:hover { text-decoration:underline; }

    /* ═══ View mode — matches Jibble screenshot exactly ═══════════════════════ */
    .ws-view-panel { background:#fff; border:1px solid #e8eaed; border-radius:10px; margin:20px 20px 20px; overflow:hidden; }

    /* Section */
    .ws-vs-section { padding:24px 32px; }
    .ws-vs-section--last { padding-bottom:32px; }

    /* Section header row (SCHEDULE with pencil icon) */
    .ws-vs-section-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
    .ws-vs-section-title { font-size:12px; font-weight:800; color:#374151; letter-spacing:1px; text-transform:uppercase; display:flex; align-items:center; gap:6px; }
    .ws-vs-section-title-plain { font-size:12px; font-weight:800; color:#374151; letter-spacing:1px; text-transform:uppercase; display:flex; align-items:center; gap:6px; margin-bottom:6px; }

    /* Pencil edit button */
    .ws-vs-edit-btn { background:none; border:none; cursor:pointer; color:#9ca3af; font-size:16px; padding:4px 6px; border-radius:6px; transition:color .15s; line-height:1; }
    .ws-vs-edit-btn:hover { color:#ff7a00; }

    /* Schedule name heading */
    .ws-vs-name { font-size:24px; font-weight:800; color:#111827; margin:0 0 20px; display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
    .ws-vs-default-badge { font-size:11px; font-weight:600; padding:3px 10px; background:#e5e7eb; color:#6b7280; border-radius:4px; }

    /* Label-value rows — right-aligned label, bold value — matching screenshot */
    .ws-vs-row { display:flex; align-items:baseline; padding:9px 0; border-bottom:1px solid #f3f4f6; font-size:14px; }
    .ws-vs-row:last-child { border-bottom:none; }
    .ws-vs-label { min-width:180px; text-align:right; padding-right:20px; color:#6b7280; font-size:14px; flex-shrink:0; }
    .ws-vs-value { font-weight:700; color:#111827; font-size:14px; }
    .ws-vs-value--muted { font-weight:400; color:#9ca3af; }

    /* Inner divider (between days and split timesheets) */
    .ws-vs-inner-divider { height:1px; background:#e8eaed; margin:12px 0; }

    /* Section divider */
    .ws-vs-divider { height:1px; background:#e8eaed; margin:0; }

    /* Description text under section header */
    .ws-vs-desc { font-size:13px; color:#6b7280; line-height:1.6; margin-bottom:10px; }

    /* Empty italic text */
    .ws-vs-empty { font-size:13px; color:#9ca3af; font-style:italic; padding:4px 0 8px; }

    /* ── Schedule Saved Toast ─────────────────────────────────────────────── */
    .ws-toast {
        position:fixed; top:24px; right:28px; z-index:9999;
        display:flex; align-items:center; gap:10px;
        background:#111827; color:#fff;
        font-size:14px; font-weight:500;
        padding:12px 20px; border-radius:10px;
        box-shadow:0 8px 24px rgba(0,0,0,.18);
        animation: ws-toast-in .25s ease, ws-toast-out .35s ease 2.65s forwards;
        pointer-events:none;
    }
    .ws-toast-icon { color:#22c55e; font-size:16px; }
