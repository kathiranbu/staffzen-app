    // ── Sync to WorkScheduleState (called after every mutation that needs to persist) ──
    private void PersistState()
    {
        APM.StaffZen.Blazor.Services.WorkScheduleState.Schedules        = schedules.Select(VmToPersisted).ToList();
        APM.StaffZen.Blazor.Services.WorkScheduleState.NextId           = nextId;
        APM.StaffZen.Blazor.Services.WorkScheduleState.ActiveScheduleId = activeScheduleId;
    }

    private void SelectSchedule(int id)
    {
        activeScheduleId = id;
        activeSchedule   = schedules.FirstOrDefault(s => s.Id == id);
        splitEditMode    = false;
        isEditing        = false; // always open in view mode when selecting saved
        PersistState();
    }

    private void AddNewSchedule()
    {
        // If no schedule is currently marked as default, make this new one the default.
        // This ensures the timesheet calculation always has a schedule to load.
        bool noDefaultExists = !schedules.Any(s => s.IsDefault);
        var s = new ScheduleVm { Id = nextId++, IsSaved = false, IsDefault = noDefaultExists };
        schedules.Add(s);
        activeScheduleId = s.Id;
        activeSchedule   = s;
        splitEditMode    = false;
        isEditing        = true; // new schedules go straight to edit mode
        PersistState();
    }

    private void SetArrangement(string arr) { if (activeSchedule != null) activeSchedule.Arrangement = arr; }

    private void ToggleDay(string day)
    {
        if (activeSchedule == null) return;
        if (!activeSchedule.WorkingDays.Remove(day)) activeSchedule.WorkingDays.Add(day);
    }

    private void SetDayStart(string day, string val)
    {
        if (activeSchedule == null) return;
        if (!activeSchedule.DaySlots.ContainsKey(day)) activeSchedule.DaySlots[day] = new DaySlot();
        activeSchedule.DaySlots[day].Start = val;
    }

    private void SetDayEnd(string day, string val)
    {
        if (activeSchedule == null) return;
        if (!activeSchedule.DaySlots.ContainsKey(day)) activeSchedule.DaySlots[day] = new DaySlot();
        activeSchedule.DaySlots[day].End = val;
    }

    private void CopyTimeToAll(string fromDay)
    {
        if (activeSchedule == null) return;
        if (!activeSchedule.DaySlots.ContainsKey(fromDay)) return;
        var src = activeSchedule.DaySlots[fromDay];
        foreach (var d in DayKeys.Where(k => activeSchedule.WorkingDays.Contains(k) && k != fromDay))
        {
            if (!activeSchedule.DaySlots.ContainsKey(d)) activeSchedule.DaySlots[d] = new DaySlot();
            activeSchedule.DaySlots[d].Start = src.Start;
            activeSchedule.DaySlots[d].End   = src.End;
        }
    }

    private void SetDailyHoursFromHM(string day, int h, int m)
    {
        if (activeSchedule == null) return;
        if (!activeSchedule.DaySlots.ContainsKey(day)) activeSchedule.DaySlots[day] = new DaySlot();
        activeSchedule.DaySlots[day].DailyHours = h + m / 60.0;
    }

    private int GetSlotHours(string day)
    {
        if (activeSchedule == null || !activeSchedule.DaySlots.ContainsKey(day)) return 0;
        return (int)activeSchedule.DaySlots[day].DailyHours;
    }

    private int GetSlotMins(string day)
    {
        if (activeSchedule == null || !activeSchedule.DaySlots.ContainsKey(day)) return 0;
        var h = activeSchedule.DaySlots[day].DailyHours;
        return (int)((h - (int)h) * 60);
    }

    private void CopyFlexToAll(string fromDay)
    {
        if (activeSchedule == null || !activeSchedule.DaySlots.ContainsKey(fromDay)) return;
        double hrs = activeSchedule.DaySlots[fromDay].DailyHours;
        foreach (var d in DayKeys.Where(k => activeSchedule.WorkingDays.Contains(k) && k != fromDay))
        {
            if (!activeSchedule.DaySlots.ContainsKey(d)) activeSchedule.DaySlots[d] = new DaySlot();
            activeSchedule.DaySlots[d].DailyHours = hrs;
        }
    }

