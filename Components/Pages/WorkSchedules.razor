    [Microsoft.AspNetCore.Components.Inject]
    private Microsoft.JSInterop.IJSRuntime JS { get; set; } = default!;

    private async Task OpenTimePicker_OtDaily()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('ot-daily-time-input')?.showPicker()");
    }

    private async Task OpenTimePicker_OtDailyDouble()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('ot-daily-double-time-input')?.showPicker()");
    }

    private void ToggleDailyOvertime()
    {
        if (activeSchedule == null) return;
        activeSchedule.DailyOvertime = !activeSchedule.DailyOvertime;
        if (activeSchedule.DailyOvertime)
        {
            // Daily ON → Weekly turns OFF
            activeSchedule.WeeklyOvertime = false;
        }
        else
        {
            // Daily OFF → Daily Double must also turn OFF
            activeSchedule.DailyDoubleOvertime = false;
        }
    }

    private void ToggleDailyDoubleOvertime()
    {
        if (activeSchedule == null) return;
        // Can only be toggled when Daily Overtime is enabled
        if (!activeSchedule.DailyOvertime) return;
        activeSchedule.DailyDoubleOvertime = !activeSchedule.DailyDoubleOvertime;
    }

    private void ToggleWeeklyOvertime()
    {
        if (activeSchedule == null) return;
        activeSchedule.WeeklyOvertime = !activeSchedule.WeeklyOvertime;
        // Weekly ON → Daily, Daily Double, Rest Day, Public Holiday all turn OFF
        if (activeSchedule.WeeklyOvertime)
        {
            activeSchedule.DailyOvertime = false;
            activeSchedule.DailyDoubleOvertime = false;
            activeSchedule.RestDayOvertime = false;
            activeSchedule.PublicHolidayOvertime = false;
        }
    }

    private void CancelChanges()
    {
        if (activeSchedule != null && !activeSchedule.IsSaved)
        {
            schedules.Remove(activeSchedule);
            activeSchedule   = null;
            activeScheduleId = 0;
            isEditing        = false;
        }
        else if (activeScheduleId > 0)
        {
            SelectSchedule(activeScheduleId); // reverts to view mode
        }
        PersistState();
    }

    private void RequestSave() => showSaveConfirm = true;

    private async Task SaveSchedule()
    {
        if (activeSchedule == null) return;
        showSaveConfirm = false;
        saving = true; saveError = ""; StateHasChanged();

        // ── Persist to database ──────────────────────────────────────────────
        // isNew = true  → POST  (schedule never saved to DB)
        // isNew = false → PUT/{id} (schedule already has a real DB id)
        // IMPORTANT: Only set IsSaved = true AFTER a confirmed successful API
        // response. If we set it on failure the next save will use the wrong
        // PUT/{tempId} route and silently fail every time.
        try
        {
            bool isNew = !activeSchedule.IsSaved || activeSchedule.Id <= 0;
            var dto    = VmToDto(activeSchedule);
            dto.OrganizationId = SessionService.OrganizationId; // stamp current org so AutoClockOut can find this schedule
            var saved  = await WorkScheduleService.SaveAsync(dto, isNew);
            if (saved != null)
            {
                // Replace local temp Id with the real DB-assigned Id
                var oldId = activeSchedule.Id;
                activeSchedule.Id = saved.Id;
                activeSchedule.IsSaved = true; // ← only mark saved on SUCCESS

                // Keep local schedule list Id in sync
                var listEntry = schedules.FirstOrDefault(s => s.Id == oldId);
                if (listEntry != null) listEntry.Id = saved.Id;
                activeScheduleId = saved.Id;

                // Re-sync nextId so local counter stays above all DB ids
                if (nextId <= saved.Id) nextId = saved.Id + 1;
            }
            else
            {
                // API call failed — surface the error so user knows
                saveError = "Failed to save schedule. Please try again.";
            }
        }
        catch (Exception ex)
        {
            saveError = $"Error saving schedule: {ex.Message}";
        }

        saving    = false;
        isEditing = activeSchedule.IsSaved ? false : true; // stay in edit if save failed
        PersistState();

        if (string.IsNullOrEmpty(saveError))
        {
            showToast = true; StateHasChanged();
            await Task.Delay(3000);
            showToast = false; StateHasChanged();
        }
        else
        {
            StateHasChanged();
        }
    }
