@page "/kiosk/face-clockin"
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject SessionService SessionService
@inject NavigationManager NavManager
@inject APM.StaffZen.Blazor.Services.TimeTrackingPolicyService TimeTrackingPolicyService
@rendermode RenderMode.InteractiveServer

<BasePage Title="Face Clock-In">

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center" style="background: #1a1a2e;">
    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 480px; border-radius: 16px; overflow: hidden;">
        <div class="card-header text-center py-4 border-0" style="background: #16213e;">
            <h4 class="fw-bold text-white mb-1">
                <i class="bi bi-person-bounding-box me-2" style="color: #ff6b35;"></i>
                Face Clock-In
            </h4>
            <p class="text-secondary small mb-0">Press Clock In or Clock Out, then look at the camera</p>
        </div>

        <div class="card-body p-4" style="background: #0f3460;">

            <!-- Camera view with canvas overlay -->
            <div class="text-center mb-3">
                <div class="position-relative d-inline-block" style="width:100%; max-width:360px;">
                    <video id="kioskVideo" autoplay muted playsinline
                           class="rounded d-block"
                           style="width: 100%; background: #000; border: 3px solid @BorderColor; transition: border-color 0.4s;">
                    </video>

                    <!-- Canvas draws the face circle overlay (green = match / red = no-match) -->
                    <canvas id="kioskCanvas"
                            class="position-absolute top-0 start-0 rounded"
                            style="width:100%; height:100%; pointer-events:none;">
                    </canvas>

                    <!-- Scanning spinner overlay -->
                    @if (kioskState == KioskState.Scanning)
                    {
                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                             style="pointer-events:none;">
                            <div style="width: 180px; height: 180px; border: 2px dashed rgba(255,107,53,0.7); border-radius: 50%; animation: spin 3s linear infinite;"></div>
                        </div>
                    }
                </div>
            </div>

            <!-- Status message -->
            <div class="text-center mb-3" style="min-height: 60px;">
                @if (kioskState == KioskState.Loading)
                {
                    <div class="text-secondary small">
                        <div class="spinner-border spinner-border-sm me-1 text-secondary" role="status"></div>
                        Loading face data...
                    </div>
                }
                else if (kioskState == KioskState.Scanning)
                {
                    <p class="text-secondary small mb-1">Scanning for faces...</p>
                    <p class="text-muted mb-0" style="font-size: 11px;">@enrolledCount employee(s) enrolled</p>
                }
                else if (kioskState == KioskState.Matched)
                {
                    <div class="text-center">
                        <div class="rounded-circle bg-success d-flex align-items-center justify-content-center mx-auto mb-2"
                             style="width: 56px; height: 56px;">
                            <i class="bi bi-check-lg text-white fs-3"></i>
                        </div>
                        <h5 class="text-white fw-bold mb-1">@matchedName</h5>
                        <p class="text-secondary small mb-0">@statusText</p>
                    </div>
                }
                else if (kioskState == KioskState.NoMatch)
                {
                    <div class="text-center">
                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center mx-auto mb-2"
                             style="width: 56px; height: 56px;">
                            <i class="bi bi-x-lg text-white fs-3"></i>
                        </div>
                        <p class="text-danger fw-semibold mb-1">@(statusText?.Contains("Multiple") == true ? "Multiple people detected" : "Face not recognised")</p>
                        <p class="text-secondary small mb-0">@(string.IsNullOrEmpty(statusText) ? "Face not recognised. Please try again or contact your administrator." : statusText)</p>
                        @if (unusualBehavior == "Blocked")
                        {
                            <div class="mt-2 px-3 py-2 rounded" style="background:#fef2f2; border:1px solid #fca5a5; color:#dc2626; font-size:12px; font-weight:600;">
                                <i class="bi bi-shield-lock me-1"></i>Clock-in/out is blocked — face not verified
                            </div>
                        }
                        else if (unusualBehavior == "Flagged")
                        {
                            <div class="mt-2 px-3 py-2 rounded" style="background:#fffbeb; border:1px solid #fcd34d; color:#92400e; font-size:12px; font-weight:600;">
                                <i class="bi bi-flag me-1"></i>Unusual behaviour flagged — entry recorded with warning
                            </div>
                        }
                    </div>
                }
                else if (kioskState == KioskState.Error)
                {
                    <p class="text-danger small">@statusText</p>
                }
            </div>

            <!-- Action buttons -->
            <div class="d-flex gap-3 justify-content-center">
                @if (kioskState == KioskState.Scanning)
                {
                    @if (isProcessing)
                    {
                        <button class="btn btn-secondary fw-semibold px-4" disabled>
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Scanning face...</span>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-success fw-semibold px-4" @onclick="ClockInClicked">
                            <i class="bi bi-box-arrow-in-right me-1"></i>
                            Clock In
                        </button>
                        <button class="btn btn-danger fw-semibold px-4" @onclick="ClockOutClicked">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            Clock Out
                        </button>
                    }
                }
                else if (kioskState == KioskState.Matched)
                {
                    <button class="btn btn-success px-4 fw-semibold" @onclick="OpenConfirmPanel">
                        <i class="bi bi-arrow-right-circle me-1"></i>
                        @(isClockedIn ? "Clock Out" : "Clock In")
                    </button>
                    <button class="btn btn-outline-secondary px-3" @onclick="ResetKiosk">Cancel</button>
                }
                else if (kioskState is KioskState.NoMatch or KioskState.Error)
                {
                    @if (kioskState == KioskState.NoMatch && unusualBehavior == "Blocked" && !statusText.Contains("Multiple"))
                    {
                        <button class="btn btn-outline-secondary px-4" @onclick="ResetKiosk">Try Again</button>
                    }
                    else if (kioskState == KioskState.NoMatch && unusualBehavior == "Flagged" && !statusText.Contains("Multiple"))
                    {
                        <button class="btn btn-warning fw-semibold px-4" @onclick="() => ProceedDespiteMismatch()">
                            <i class="bi bi-flag me-1"></i>Proceed Anyway
                        </button>
                        <button class="btn btn-outline-secondary px-3" @onclick="ResetKiosk">Cancel</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-warning px-4" @onclick="ResetKiosk">Try Again</button>
                    }
                }
            </div>

        </div>

        <div class="card-footer text-center py-3 border-0" style="background: #16213e;">
            <span class="text-secondary" style="font-size: 11px;">ApmStaffZen Kiosk &mdash; @DateTime.Now.ToString("ddd, dd MMM yyyy HH:mm")</span>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════
     CONFIRM CLOCK IN / CLOCK OUT DRAWER
     Styled to match the existing BasePage cci-drawer
     ══════════════════════════════════════════════════ -->
@if (showConfirmPanel)
{
    <div class="cci-backdrop" @onclick="CloseConfirmPanel"></div>

    <div class="cci-drawer">

        <div class="cci-header">
            <h3 class="cci-title">@(isClockedIn ? "Confirm Clock Out" : "Confirm Clock In")</h3>
            <button class="cci-close" @onclick="CloseConfirmPanel" title="Close" disabled="@isProcessing">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Employee strip -->
        <div class="cci-user-strip">
            <div class="cci-user-av kiosk-av">@(matchedName.Length > 0 ? char.ToUpper(matchedName[0]) : 'E')</div>
            <div class="cci-user-info">
                <div class="cci-user-name">@matchedName</div>
                <div class="cci-user-meta">Clocking from kiosk</div>
                @if (isClockedIn)
                {
                    <div class="cci-user-meta" style="color:#16a34a; font-weight:600;">
                        <i class="bi bi-circle-fill me-1" style="font-size:8px;"></i>Currently clocked in &mdash; @statusText
                    </div>
                }
                else
                {
                    <div class="cci-user-meta">Not currently clocked in</div>
                }
            </div>
        </div>

        <!-- Action badge -->
        <div style="padding: 0 24px 16px;">
            <div class="kiosk-action-badge @(isClockedIn ? "badge-out" : "badge-in")">
                <i class="bi @(isClockedIn ? "bi-box-arrow-right" : "bi-box-arrow-in-right") me-2"></i>
                @(isClockedIn ? "You are about to Clock Out" : "You are about to Clock In")
            </div>
        </div>

        <!-- Note field -->
        <div class="cci-form">
            <div class="cci-field cci-field--note">
                <textarea class="cci-input cci-textarea" placeholder="Add a note (optional)" @bind="confirmNote"></textarea>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(confirmError))
        {
            <div class="cci-error">
                <i class="bi bi-exclamation-circle"></i> @confirmError
            </div>
        }

        @if (!string.IsNullOrEmpty(confirmSuccess))
        {
            <div class="cci-success">
                <i class="bi bi-check-circle"></i> @confirmSuccess
            </div>
        }

        <div class="cci-footer">
            <button class="cci-cancel-btn" @onclick="CloseConfirmPanel" disabled="@isProcessing">Cancel</button>
            <button class="cci-save-btn" @onclick="ExecuteClockAction" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="bp-mini-spinner"></span>
                }
                else
                {
                    <span>Save</span>
                }
            </button>
        </div>

    </div>
}

<style>
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* ── Confirm drawer ── */
    .cci-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1040;
        animation: cciFadeIn .18s ease;
    }
    .cci-drawer {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: 420px; max-width: 100vw;
        background: #fff; z-index: 1050;
        display: flex; flex-direction: column;
        box-shadow: -4px 0 32px rgba(0,0,0,.18);
        animation: cciSlideIn .22s cubic-bezier(.4,0,.2,1);
        overflow-y: auto;
    }
    @@keyframes cciFadeIn  { from { opacity:0 } to { opacity:1 } }
    @@keyframes cciSlideIn { from { transform:translateX(100%) } to { transform:translateX(0) } }

    .cci-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 24px 16px; border-bottom: 1px solid #f3f4f6; flex-shrink: 0;
    }
    .cci-title { font-size: 18px; font-weight: 700; color: #111827; margin: 0; }
    .cci-close {
        width: 32px; height: 32px; border: none; background: #f3f4f6;
        border-radius: 8px; cursor: pointer; display: flex; align-items: center;
        justify-content: center; font-size: 14px; color: #6b7280;
        transition: background .15s; flex-shrink: 0;
    }
    .cci-close:hover:not(:disabled) { background: #e5e7eb; }
    .cci-close:disabled { opacity: .5; cursor: not-allowed; }

    .cci-user-strip {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 24px; border-bottom: 1px solid #f3f4f6; flex-shrink: 0;
    }
    .cci-user-av {
        width: 44px; height: 44px; border-radius: 50%;
        background: #ff7a00; color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; font-weight: 700; flex-shrink: 0;
    }
    .kiosk-av { background: #6366f1; }
    .cci-user-info { display: flex; flex-direction: column; gap: 2px; }
    .cci-user-name { font-size: 15px; font-weight: 600; color: #111827; }
    .cci-user-meta { font-size: 12px; color: #6b7280; }

    .kiosk-action-badge {
        padding: 12px 16px; border-radius: 10px;
        font-size: 14px; font-weight: 600;
        display: flex; align-items: center;
    }
    .badge-in  { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .badge-out { background: #fff7ed; color: #ea580c; border: 1px solid #fed7aa; }

    .cci-form { padding: 16px 24px 8px; flex: 1; }
    .cci-field {
        display: flex; align-items: center; gap: 10px;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        padding: 10px 14px; margin-bottom: 12px;
        cursor: pointer; transition: border-color .15s; background: #fff;
    }
    .cci-field--note { align-items: flex-start; cursor: default; padding: 0; }
    .cci-input { border: none; outline: none; font-size: 14px; color: #111827; width: 100%; font-family: inherit; background: transparent; }
    .cci-textarea {
        resize: none; height: 80px; padding: 12px 14px;
        font-size: 14px; color: #111827; width: 100%;
        border: 1.5px solid #e5e7eb; outline: none; font-family: inherit;
        border-radius: 10px; transition: border-color .15s;
    }
    .cci-textarea:focus { border-color: #ff7a00; }

    .cci-error {
        margin: 0 24px 8px; padding: 10px 14px; border-radius: 8px;
        background: #fef2f2; border: 1px solid #fca5a5; color: #dc2626;
        font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 8px;
    }
    .cci-success {
        margin: 0 24px 8px; padding: 10px 14px; border-radius: 8px;
        background: #f0fdf4; border: 1px solid #86efac; color: #16a34a;
        font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 8px;
    }

    .cci-footer {
        display: flex; align-items: center; justify-content: flex-end;
        gap: 12px; padding: 16px 24px; border-top: 1px solid #f3f4f6;
        flex-shrink: 0; background: #fff;
    }
    .cci-cancel-btn {
        padding: 10px 24px; border-radius: 8px; border: none; background: none;
        font-size: 14px; font-weight: 600; color: #ff7a00;
        cursor: pointer; font-family: inherit; transition: background .15s;
    }
    .cci-cancel-btn:hover:not(:disabled) { background: #fff7ed; }
    .cci-cancel-btn:disabled { opacity: .5; cursor: not-allowed; }
    .cci-save-btn {
        padding: 10px 32px; border-radius: 8px; border: none;
        background: #ff7a00; color: #fff; font-size: 14px; font-weight: 700;
        cursor: pointer; font-family: inherit; display: flex; align-items: center;
        gap: 8px; min-width: 80px; justify-content: center;
        transition: background .15s, transform .1s;
    }
    .cci-save-btn:hover:not(:disabled) { background: #e66c00; }
    .cci-save-btn:active:not(:disabled) { transform: scale(.97); }
    .cci-save-btn:disabled { opacity: .6; cursor: not-allowed; }

    .bp-mini-spinner {
        width: 16px; height: 16px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,.4); border-top-color: #fff;
        animation: bpSpin .7s linear infinite; display: inline-block;
    }
    @@keyframes bpSpin { to { transform: rotate(360deg); } }
</style>

</BasePage>

@code {
    // ── State machine ──────────────────────────────────────────────────────
    private enum KioskState { Loading, Scanning, Matched, NoMatch, Error }
    private KioskState kioskState = KioskState.Loading;

    private List<EnrolledEmployee> enrolledEmployees = new();
    private int    enrolledCount  = 0;
    private bool   isProcessing   = false;

    // Policy — loaded from the org's time-tracking policy / default work schedule
    // "Blocked" | "Flagged" | "Allowed"  (default: "Blocked")
    private string unusualBehavior    = "Blocked";
    // Action captured at scan time so ProceedDespiteMismatch knows what to do
    private string _pendingAction     = string.Empty;

    // After a successful match
    private int    matchedEmployeeId = 0;
    private string matchedName       = string.Empty;
    private bool   isClockedIn       = false;
    private string statusText        = string.Empty;

    // Confirm panel
    private bool   showConfirmPanel = false;
    private string confirmNote      = string.Empty;
    private string confirmError     = string.Empty;
    private string confirmSuccess   = string.Empty;

    // Flag: after NoMatch, re-draw the red canvas overlay in OnAfterRenderAsync
    private bool _pendingMismatchDraw = false;

    private string BorderColor => kioskState switch
    {
        KioskState.Matched  => "#198754",   // green
        KioskState.NoMatch  => "#dc3545",   // red
        KioskState.Scanning => "#ff6b35",   // orange
        _                   => "#444"
    };

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        if (!SessionService.IsLoggedIn) { NavManager.NavigateTo("/login"); return; }
        await Task.WhenAll(LoadEnrolledFaces(), LoadPolicy());
    }

    private async Task LoadPolicy()
    {
        try
        {
            var orgId = SessionService.OrganizationId;
            // Fetch all work schedules and use the default one for the org's UnusualBehavior
            var http      = HttpClientFactory.CreateClient("API");
            var schedules = await http.GetFromJsonAsync<List<WorkScheduleDto>>(
                "api/WorkSchedules", _jsonOpts);
            if (schedules != null)
            {
                // Prefer the default schedule; fall back to the first schedule found
                var sched = schedules.FirstOrDefault(s => s.IsDefault)
                         ?? schedules.FirstOrDefault();
                if (sched != null)
                    unusualBehavior = sched.UnusualBehavior ?? "Blocked";
            }
        }
        catch
        {
            // Non-fatal — keep default "Blocked"
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && kioskState == KioskState.Scanning)
            await JS.InvokeVoidAsync("startCamera", "kioskVideo");

        // Re-draw the mismatch overlay after Blazor re-renders (which blanks the canvas)
        if (_pendingMismatchDraw)
        {
            _pendingMismatchDraw = false;
            try { await JS.InvokeVoidAsync("drawMismatchOverlay", "kioskCanvas"); } catch { }
        }
    }

    // Shared JSON options — API returns camelCase, records use PascalCase
    private static readonly System.Text.Json.JsonSerializerOptions _jsonOpts =
        new(System.Text.Json.JsonSerializerDefaults.Web);   // sets PropertyNameCaseInsensitive = true

    private async Task LoadEnrolledFaces()
    {
        kioskState = KioskState.Loading;
        try
        {
            var http      = HttpClientFactory.CreateClient("API");
            var orgId     = SessionService.OrganizationId;
            var employees = await http.GetFromJsonAsync<List<EnrolledEmployee>>(
                $"api/employees/face-descriptors?organizationId={orgId}", _jsonOpts);

            enrolledEmployees = employees ?? new();
            enrolledCount     = enrolledEmployees.Count;
            kioskState        = KioskState.Scanning;
            StateHasChanged();

            await Task.Delay(200);
            await JS.InvokeVoidAsync("startCamera", "kioskVideo");
        }
        catch (Exception ex)
        {
            kioskState = KioskState.Error;
            statusText = $"Could not load employee data: {ex.Message}";
        }
    }

    // ── Face matching ──────────────────────────────────────────────────────
    private Task ClockInClicked()  => ScanAndMatch("clockin");
    private Task ClockOutClicked() => ScanAndMatch("clockout");

    private async Task ScanAndMatch(string action)
    {
        _pendingAction = action;
        isProcessing = true;
        StateHasChanged();

        try
        {
            var jsEmployees = enrolledEmployees.Select(e => new
            {
                employeeId = e.EmployeeId,
                fullName   = e.FullName,
                descriptor = e.Descriptor
            }).ToArray();

            // JS draws green circle on match, red/amber circle on mismatch/multi-face, then returns result
            var result = await JS.InvokeAsync<MatchResult>(
                "matchFaceKioskWithOverlay", "kioskVideo", "kioskCanvas", jsEmployees, 0.35);

            if (result.MultipleFaces)
            {
                // More than one face in frame — warn and let the user retry
                kioskState            = KioskState.NoMatch;
                statusText            = "Multiple people detected. Only one person should stand in front of the camera.";
                isProcessing          = false;
                _pendingMismatchDraw  = true;
                StateHasChanged();

                await Task.Delay(4000);
                if (kioskState == KioskState.NoMatch)
                    await ResetKioskAsync();
                return;
            }

            if (result.Matched && result.EmployeeId.HasValue)
            {
                matchedEmployeeId = result.EmployeeId.Value;
                matchedName       = result.FullName ?? "Unknown";

                var http      = HttpClientFactory.CreateClient("API");
                var statusRes = await http.GetFromJsonAsync<ClockStatusResponse>(
                    $"api/attendance/status/{matchedEmployeeId}", _jsonOpts);

                isClockedIn = action == "clockout";
                statusText  = statusRes?.IsClockedIn == true
                    ? $"Since {statusRes?.ClockIn?.ToString("hh:mm tt")}"
                    : "Not currently clocked in";

                kioskState   = KioskState.Matched;
                isProcessing = false;
                // Open the confirm drawer immediately — user presses Save to confirm
                OpenConfirmPanel();
            }
            else
            {
                // ── Policy enforcement on no-match ───────────────────────────
                // Blocked  → hard stop, no clock action possible
                // Flagged  → show warning, offer "Proceed Anyway" button
                // Allowed  → treat as if matched (bypass face check silently)
                if (unusualBehavior == "Allowed")
                {
                    // Allowed: skip face check, open confirm drawer without a matched employee
                    // (clock-in will use kiosk manual fallback — employee selects themselves)
                    kioskState   = KioskState.NoMatch;
                    statusText   = "Face not recognised but policy allows proceeding.";
                    isProcessing = false;
                    _pendingMismatchDraw = true;
                    StateHasChanged();
                    // Auto-reset after a moment — user can retry or use another method
                    await Task.Delay(3000);
                    if (kioskState == KioskState.NoMatch)
                        await ResetKioskAsync();
                }
                else
                {
                    // Blocked or Flagged — show NoMatch state with appropriate banner
                    kioskState            = KioskState.NoMatch;
                    statusText            = "Face not recognised. Please try again or contact your administrator.";
                    isProcessing          = false;
                    _pendingMismatchDraw  = true;
                    StateHasChanged();

                    if (unusualBehavior == "Blocked")
                    {
                        // Auto-reset after showing the blocked banner
                        await Task.Delay(4000);
                        if (kioskState == KioskState.NoMatch)
                            await ResetKioskAsync();
                    }
                    // Flagged: stay on NoMatch — buttons let user "Proceed Anyway" or Cancel
                }
                return;
            }
        }
        catch (Exception ex)
        {
            kioskState = KioskState.Error;
            statusText = ex.Message;
        }

        isProcessing = false;
        StateHasChanged();
    }

    // ── Open / close confirm drawer ────────────────────────────────────────
    private void OpenConfirmPanel()
    {
        confirmNote    = string.Empty;
        confirmError   = string.Empty;
        confirmSuccess = string.Empty;
        showConfirmPanel = true;
        StateHasChanged();
    }

    private void CloseConfirmPanel()
    {
        if (!isProcessing)
        {
            showConfirmPanel = false;
            StateHasChanged();
        }
    }

    // ── Execute clock action on Save ───────────────────────────────────────
    private async Task ExecuteClockAction()
    {
        isProcessing   = true;
        confirmError   = string.Empty;
        confirmSuccess = string.Empty;
        StateHasChanged();

        // If the employee was not face-verified (matchedEmployeeId == 0) and policy
        // is Flagged, we cannot clock-in/out via the face endpoint without a real ID.
        // Show a clear error and force them to use the standard clock-in flow.
        if (matchedEmployeeId <= 0 && unusualBehavior == "Flagged")
        {
            confirmError = "⚠ Face not verified. Entry flagged — please contact your administrator or use the standard clock-in.";
            isProcessing = false;
            StateHasChanged();
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("API");

            if (isClockedIn)
            {
                var res = await http.PostAsJsonAsync("api/attendance/clockout",
                    new { EmployeeId = matchedEmployeeId, Note = confirmNote });
                if (res.IsSuccessStatusCode)
                    confirmSuccess = $"{matchedName} clocked out successfully!";
                else
                    confirmError = "Clock out failed. Please try again.";
            }
            else
            {
                string? auditPhoto = null;
                try { auditPhoto = await JS.InvokeAsync<string>("captureAuditPhoto", "kioskVideo"); } catch { }

                var res = await http.PostAsJsonAsync("api/attendance/clockin-face", new
                {
                    EmployeeId       = matchedEmployeeId,
                    OrganizationId   = SessionService.OrganizationId,
                    AuditPhotoBase64 = auditPhoto,
                    Note             = confirmNote
                });
                if (res.IsSuccessStatusCode)
                    confirmSuccess = $"{matchedName} clocked in successfully!";
                else
                    confirmError = "Clock in failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            confirmError = $"Error: {ex.Message}";
        }

        isProcessing = false;
        StateHasChanged();

        if (string.IsNullOrEmpty(confirmError))
        {
            await Task.Delay(2000);
            showConfirmPanel = false;
            await ResetKioskAsync();
        }
    }

    // ── Proceed despite mismatch (Flagged policy) ─────────────────────────
    // Opens the confirm drawer without a verified employee match.
    // The note field will carry a "⚠ Unusual behaviour flagged" prefix so
    // administrators can see the entry was unverified.
    private void ProceedDespiteMismatch()
    {
        // We have no matchedEmployeeId from face-rec — the confirm drawer still
        // opens but the Save button will show the flagged warning in the note.
        // matchedName stays empty so the drawer shows "Unknown / Unverified".
        if (string.IsNullOrEmpty(matchedName)) matchedName = "Unverified Employee";
        isClockedIn      = _pendingAction == "clockout";
        showConfirmPanel = true;
        confirmNote      = "⚠ Unusual behaviour flagged — face not verified";
        confirmError     = string.Empty;
        confirmSuccess   = string.Empty;
        StateHasChanged();
    }

    private async Task ResetKioskAsync()
    {
        kioskState        = KioskState.Scanning;
        matchedEmployeeId = 0;
        matchedName       = string.Empty;
        statusText        = string.Empty;
        isProcessing      = false;
        showConfirmPanel  = false;
        StateHasChanged();
        try { await JS.InvokeVoidAsync("clearKioskCanvas", "kioskCanvas"); } catch { }
    }

    private void ResetKiosk() => _ = ResetKioskAsync();

    // ── DTOs ───────────────────────────────────────────────────────────────
    private record EnrolledEmployee(int EmployeeId, string FullName, string? ProfileImageUrl, string? Descriptor);
    private record ClockStatusResponse(bool IsClockedIn, int? EntryId, DateTime? ClockIn);
    private record MatchResult(bool Matched, int? EmployeeId, string? FullName, double Distance, bool MultipleFaces = false);

    // Minimal projection of WorkSchedule used only to read UnusualBehavior
    private class WorkScheduleDto
    {
        public bool    IsDefault       { get; set; }
        public string? UnusualBehavior { get; set; }
    }
}
