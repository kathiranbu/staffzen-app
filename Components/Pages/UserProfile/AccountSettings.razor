    private async Task SaveSecurity()
    {
        isSaving = true;
        var req = new UpdateProfileRequest { FullName = profile?.FullName ?? string.Empty, MobileNumber = editPhone, DateOfBirth = profile?.DateOfBirth, ProfileImageUrl = profile?.ProfileImageUrl };
        var result = await ProfileService.UpdateProfileAsync(SessionService.Id, req);
        if (result != null) { profile = result; editSection = string.Empty; }
        isSaving = false;
