    private async Task SaveSubscriptions()
    {
        notifSaveError = string.Empty;        StateHasChanged();
        var (ok, err) = await NotifService.SaveAsync(SessionService.Id, editNotif);
        if (ok)
        {
            liveNotif = editNotif.Clone();
            editSection = string.Empty;
            await Task.Delay(2000);
        }
        else { notifSaveError = err ?? "Save failed. Please try again."; }
        StateHasChanged();
