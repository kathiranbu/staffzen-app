    // Change Password
    private bool   showChangePasswordModal = false;
#pragma warning disable CS0414
    private bool   showSuccessToast        = false;
    private bool   toastFading             = false;
#pragma warning restore CS0414
    private string cpCurrentPassword = string.Empty;
    private string cpNewPassword     = string.Empty;
    private string cpConfirmPassword = string.Empty;
    private string cpCurrentType = "password";
    private string cpNewType     = "password";
    private string cpConfirmType = "password";
    private string cpError           = string.Empty;
    private bool   cpPasswordChanged = false;
    private string cpSuccess         = string.Empty;
    private bool   cpSaving          = false;

    private bool cpCurrentFilled => !string.IsNullOrWhiteSpace(cpCurrentPassword);
    private bool cpMismatch => !string.IsNullOrEmpty(cpConfirmPassword) && cpNewPassword != cpConfirmPassword;
    private bool cpMatch    => !string.IsNullOrEmpty(cpConfirmPassword) && cpNewPassword == cpConfirmPassword && cpNewPassword.Length >= 6;
    private bool cpCanSubmit => !string.IsNullOrWhiteSpace(cpCurrentPassword) && !string.IsNullOrWhiteSpace(cpNewPassword)
                             && !string.IsNullOrWhiteSpace(cpConfirmPassword) && cpNewPassword == cpConfirmPassword && cpNewPassword.Length >= 6;

    private void OpenChangePasswordModal()
    {
        cpCurrentPassword = cpNewPassword = cpConfirmPassword = string.Empty;
        cpCurrentType = cpNewType = cpConfirmType = "password";
        cpError = cpSuccess = string.Empty;
        cpPasswordChanged = false; cpSaving = false;
        showChangePasswordModal = true;
    }
    private void CloseChangePasswordModal() => showChangePasswordModal = false;

    private async Task HandleChangePassword()
    {
        cpError = cpSuccess = string.Empty; cpPasswordChanged = false;
        if (cpNewPassword.Length < 6)          { cpError = "New password must be at least 6 characters."; return; }
        if (cpNewPassword != cpConfirmPassword) { cpError = "Passwords do not match."; return; }
        cpSaving = true; StateHasChanged();
        var email = profile?.Email ?? SessionService.Email ?? string.Empty;
        var (success, error) = await AuthService.ChangePasswordAsync(email, cpCurrentPassword, cpNewPassword);
        cpSaving = false;
        if (success)
        {
            cpPasswordChanged = true; cpError = string.Empty; StateHasChanged();
            await Task.Delay(1800);
            CloseChangePasswordModal();
            showSuccessToast = true; toastFading = false; StateHasChanged();
            await Task.Delay(3000); toastFading = true; StateHasChanged();
            await Task.Delay(400); showSuccessToast = false;
        }
        else { cpError = error ?? "Failed to change password. Please try again."; }
        StateHasChanged();
    }

    private void ToggleReportsEmail()   { if (editSection == "notifications") editNotif.ReportsChannelEmail   = !editNotif.ReportsChannelEmail; }
    private void ToggleRemindersEmail() { if (editSection == "notifications") editNotif.RemindersChannelEmail = !editNotif.RemindersChannelEmail; }
    private void ToggleReportsPush()    { if (editSection == "notifications") editNotif.ReportsChannelPush    = !editNotif.ReportsChannelPush; }
    private void ToggleRemindersPush()  { if (editSection == "notifications") editNotif.RemindersChannelPush  = !editNotif.RemindersChannelPush; }

    private void ToggleReportsWhatsApp()
    {
        if (editSection != "notifications") return;
        if (!editNotif.ReportsChannelWhatsApp && string.IsNullOrWhiteSpace(profile?.MobileNumber)) editNotif.ReportsChannelWhatsApp = true;
        else editNotif.ReportsChannelWhatsApp = !editNotif.ReportsChannelWhatsApp;
    }
    private void ToggleReportsSms()
    {
        if (editSection != "notifications") return;
        if (!editNotif.ReportsChannelSms && string.IsNullOrWhiteSpace(profile?.MobileNumber)) editNotif.ReportsChannelSms = true;
        else editNotif.ReportsChannelSms = !editNotif.ReportsChannelSms;
    }
    private void ToggleRemindersWhatsApp()
    {
        if (editSection != "notifications") return;
        if (!editNotif.RemindersChannelWhatsApp && string.IsNullOrWhiteSpace(profile?.MobileNumber)) editNotif.RemindersChannelWhatsApp = true;
        else editNotif.RemindersChannelWhatsApp = !editNotif.RemindersChannelWhatsApp;
    }
    private void ToggleRemindersSms()
    {
        if (editSection != "notifications") return;
        if (!editNotif.RemindersChannelSms && string.IsNullOrWhiteSpace(profile?.MobileNumber)) editNotif.RemindersChannelSms = true;
        else editNotif.RemindersChannelSms = !editNotif.RemindersChannelSms;
    }

    private void ToggleCpCurrent() => cpCurrentType = cpCurrentType == "password" ? "text" : "password";
    private void ToggleCpNew()     => cpNewType     = cpNewType     == "password" ? "text" : "password";
    private void ToggleCpConfirm() => cpConfirmType = cpConfirmType == "password" ? "text" : "password";

    private static string NcBtnOn(bool active)       => active ? "nc-channel-btn--on" : string.Empty;
    private static string NsItemActive(bool active)  => active ? "ns-item--active"    : string.Empty;
    private bool IsNotEditingNotifications()          => editSection != "notifications";
    private bool IsNotEditingSubscriptions()          => editSection != "subscriptions";
    private static string CpEyeIcon(string inputType)=> inputType == "password" ? "bi bi-eye" : "bi bi-eye-slash";
    private string CpInputLockedClass()               => !cpCurrentFilled ? "cp-input cp-input-locked" : "cp-input";
    private string CpConfirmInputClass()
    {
        if (!cpCurrentFilled) return "cp-input cp-input-locked";
        if (cpMismatch)       return "cp-input cp-input-error";
        if (cpMatch)          return "cp-input cp-input-success";
        return "cp-input";
    }
    private string CpConfirmBtnClass() => cpCanSubmit ? "cp-btn cp-btn-confirm" : "cp-btn cp-btn-confirm cp-btn-disabled";

    private async Task DismissToast()
    {
        toastFading = true; StateHasChanged();
        await Task.Delay(400); showSuccessToast = false; StateHasChanged();
    }

    // Push notification (Firebase)
    private string pushStatusMsg        = string.Empty;
    private DotNetObjectReference<AccountSettings>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("FirebasePush.init", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnFcmTokenReceived(string token)
    {
        if (SessionService.Id <= 0) return;
        try
        {
            var http    = HttpClientFactory.CreateClient("API");
            var body    = System.Text.Json.JsonSerializer.Serialize(new { token });
            var content = new System.Net.Http.StringContent(body, System.Text.Encoding.UTF8, "application/json");
            var response = await http.PutAsync($"api/employees/{SessionService.Id}/fcm-token", content);
            if (response.IsSuccessStatusCode)
            {
                pushStatusMsg = "Push notifications enabled on this device! ✅";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* silently ignore token save failures */ }
    }

    [JSInvokable] public Task OnPushPermissionDenied() { return InvokeAsync(StateHasChanged); }
    [JSInvokable] public Task OnPushReceived(string title, string body) => Task.CompletedTask;

    public void Dispose() => _dotNetRef?.Dispose();
}

<style>
    /* ── Face enrolled card ── */
    /* ═══════════════════════════════════════════════════════════════
       FACE ENROLLMENT UI  — Professional redesign
       ═══════════════════════════════════════════════════════════════ */

    /* ── Enrolled status card ── */
    .face-enrolled-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border: 1.5px solid #86efac;
        border-radius: 14px;
        padding: 16px;
        display: flex; flex-direction: column; gap: 10px;
    }

    /* ── Face photo lightbox ── */
    .face-lightbox-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.78);
        z-index: 9999;
        display: flex; align-items: center; justify-content: center;
        animation: fl-in .15s ease;
    }
    @@keyframes fl-in { from { opacity: 0; } to { opacity: 1; } }
    .face-lightbox {
        background: #fff; border-radius: 18px;
        width: 90%; max-width: 460px;
        box-shadow: 0 28px 60px rgba(0,0,0,0.38);
        overflow: hidden;
        animation: fl-slide .18s ease;
    }
    @@keyframes fl-slide {
        from { transform: translateY(18px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
    .face-lightbox-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 18px; border-bottom: 1px solid #f3f4f6; font-size: 15px;
        font-weight: 600;
    }
    .face-lightbox-body {
        padding: 20px; text-align: center; background: #111;
    }
    .face-lightbox-footer {
        padding: 12px 18px; border-top: 1px solid #f3f4f6; text-align: center;
        font-size: 12px; color: #9ca3af;
    }

    /* ═══════════════════════════════════════════════════════════════
       FACE ENROLLMENT CAMERA UI  — polished
       ═══════════════════════════════════════════════════════════════ */
    .face-enroll-wrap {
        max-width: 380px;
        margin: 0 auto;
    }

    /* ── Status chip above video ── */
    .face-status-chip {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 5px 14px; border-radius: 20px;
        font-size: 12px; font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: .2px;
