@page "/approval"
@rendermode RenderMode.InteractiveServer
@inject SessionService SessionService
@inject IHttpClientFactory ClientFactory

<BasePage Title="Approval">

    <div class="appr-page">

        @* ── Top tab bar (matches Timesheets dtl-topbar style) ── *@
        <div class="appr-topbar">
            <div class="appr-tabs">
                @if (IsTeamLead && IsHR)
                {
                    <button class='appr-tab @(activePanel == "teamlead" ? "appr-tab--active" : "")'
                            @onclick='() => SwitchPanel("teamlead")'>
                        <i class="bi bi-person-check"></i> Team Lead
                    </button>
                    <button class='appr-tab @(activePanel == "hr" ? "appr-tab--active" : "")'
                            @onclick='() => SwitchPanel("hr")'>
                        <i class="bi bi-shield-check"></i> HR
                    </button>
                }
                else if (IsTeamLead)
                {
                    <button class="appr-tab appr-tab--active">
                        <i class="bi bi-person-check"></i> Team Lead
                    </button>
                }
                else if (IsHR)
                {
                    <button class="appr-tab appr-tab--active">
                        <i class="bi bi-shield-check"></i> HR
                    </button>
                }
            </div>
        </div>

        @* ── Filter / search bar ── *@
        <div class="appr-filterbar">
            <div class="appr-search-wrap">
                <i class="bi bi-search appr-search-icon"></i>
                <input class="appr-search-input" type="text" placeholder="Search by employee name"
                       @bind="searchQuery" @bind:event="oninput" />
            </div>
            @if (activePanel == "teamlead")
            {
                <select class="appr-filter-select" @bind="statusFilter">
                    <option value="All">All</option>
                    <option value="Pending_TeamLead">Pending with Team Lead</option>
                    <option value="Rejected_TeamLead">Rejected by Team Lead</option>
                </select>
            }
            else
            {
                <select class="appr-filter-select" @bind="statusFilter">
                    <option value="All">All</option>
                    <option value="Pending_HR">Pending with HR</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected_HR">Rejected by HR</option>
                </select>
            }
        </div>

        @* ── Table area ── *@
        <div class="appr-table-wrap">
            @if (isLoading)
            {
                <div class="appr-loading">
                    <div class="appr-loader-ring"></div>
                    <span>Loading requests…</span>
                </div>
            }
            else
            {
                var filtered = leaveRequests
                    .Where(r =>
                        (string.IsNullOrWhiteSpace(searchQuery) ||
                         r.EmployeeName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
                        (statusFilter == "All" || r.Status == statusFilter))
                    .ToList();

                if (!filtered.Any())
                {
                    <div class="appr-empty-state">
                        <div class="appr-empty-icon">
                            @if (activePanel == "teamlead") { <i class="bi bi-person-check"></i> }
                            else { <i class="bi bi-shield-check"></i> }
                        </div>
                        <div class="appr-empty-title">No requests here</div>
                        <div class="appr-empty-sub">
                            @if (activePanel == "teamlead")
                            { <span>Leave requests pending your review will appear here.</span> }
                            else
                            { <span>Requests forwarded to HR will appear here for final review.</span> }
                        </div>
                    </div>
                }
                else
                {
                    <table class="appr-table">
                        <thead>
                            <tr class="appr-thead-row">
                                <th class="appr-th appr-th--name">Employee</th>
                                <th class="appr-th">Date Range</th>
                                <th class="appr-th">Reason</th>
                                <th class="appr-th">Status</th>
                                <th class="appr-th appr-th--actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in filtered)
                            {
                                <tr class="appr-row">

                                    @* Employee *@
                                    <td class="appr-td appr-td--name">
                                        <div class="appr-name-cell">
                                            <div class="appr-av">@GetInitials(req.EmployeeName)</div>
                                            <div>
                                                <div class="appr-name">@req.EmployeeName</div>
                                                <div class="appr-sub">Submitted @req.CreatedAt.ToString("MMM dd, yyyy")</div>
                                            </div>
                                        </div>
                                    </td>

                                    @* Dates *@
                                    <td class="appr-td">
                                        <div class="appr-date-cell">
                                            <i class="bi bi-calendar3 appr-cal-icon"></i>
                                            <span>
                                                @req.StartDate.ToString("MMM dd, yyyy")
                                                @if ((req.EndDate ?? req.StartDate).Date != req.StartDate.Date)
                                                {
                                                    <span class="appr-date-arrow"> → </span>@((req.EndDate ?? req.StartDate).ToString("MMM dd, yyyy"))
                                                }
                                            </span>
                                        </div>
                                    </td>

                                    @* Reason *@
                                    <td class="appr-td">
                                        <span class="appr-reason">
                                            @(string.IsNullOrWhiteSpace(req.Reason) ? "—" : req.Reason)
                                        </span>
                                    </td>

                                    @* Status *@
                                    <td class="appr-td appr-td--status">
                                        @{ var (badgeCls, badgeLabel) = GetBadge(req.Status); }
                                        <span class="appr-status-pill @badgeCls">
                                            <span class="appr-status-dot"></span>
                                            @badgeLabel
                                        </span>
                                        @if ((req.Status == "Rejected_TeamLead" || req.Status == "Rejected_HR")
                                             && !string.IsNullOrWhiteSpace(req.RejectReason))
                                        {
                                            <div class="appr-reject-note">
                                                <i class="bi bi-chat-left-text"></i> @req.RejectReason
                                            </div>
                                        }
                                    </td>

                                    @* Actions *@
                                    <td class="appr-td appr-td--actions">
                                        @if (activePanel == "teamlead" && req.Status == "Pending_TeamLead")
                                        {
                                            <div class="appr-action-btns">
                                                <button class="appr-act-btn appr-act-btn--approve"
                                                        @onclick="() => OpenTLApproveModal(req)" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button class="appr-act-btn appr-act-btn--reject"
                                                        @onclick='() => OpenRejectModal(req, "TeamLead")' title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        }
                                        else if (activePanel == "hr" && req.Status == "Pending_HR")
                                        {
                                            <div class="appr-action-btns">
                                                <button class="appr-act-btn appr-act-btn--approve"
                                                        @onclick="() => OpenHRApproveModal(req)" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button class="appr-act-btn appr-act-btn--reject"
                                                        @onclick='() => OpenRejectModal(req, "HR")' title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="appr-no-action">—</span>
                                        }
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>

    </div>

    @* ════════════════════════════════════════════
       TEAM LEAD APPROVE MODAL
       Choose: Forward to HR  /  Direct Approval
       ════════════════════════════════════════════ *@
    @if (showTLApproveModal && selectedRequest != null)
    {
        <div class="appr-overlay" @onclick="CloseModals">
            <div class="appr-modal appr-modal--choice" @onclick:stopPropagation="true">

                <div class="appr-modal-header">
                    <span class="appr-modal-title">Approve Leave Request</span>
                    <button class="appr-modal-close" @onclick="CloseModals">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="appr-modal-info-row">
                    <div class="appr-av appr-avatar--lg">
                        @GetInitials(selectedRequest.EmployeeName)
                    </div>
                    <div>
                        <div class="appr-modal-emp-name">@selectedRequest.EmployeeName</div>
                        <div class="appr-modal-emp-dates">
                            @selectedRequest.StartDate.ToString("MMM dd") – @(selectedRequest.EndDate ?? selectedRequest.StartDate).ToString("MMM dd, yyyy")
                        </div>
                        @if (!string.IsNullOrWhiteSpace(selectedRequest.Reason))
                        {
                            <div class="appr-modal-emp-reason">"@selectedRequest.Reason"</div>
                        }
                    </div>
                </div>

                <p class="appr-modal-choice-label">How would you like to proceed?</p>

                <div class="appr-choice-cards">

                    @* Forward to HR *@
                    <div class="appr-choice-card @(tlApproveChoice == "forward_to_hr" ? "appr-choice-card--selected" : "")"
                         @onclick='() => { tlApproveChoice = "forward_to_hr"; choiceErr = false; }'>
                        <div class="appr-choice-card-icon appr-choice-card-icon--forward">
                            <i class="bi bi-diagram-3"></i>
                        </div>
                        <div class="appr-choice-card-body">
                            <div class="appr-choice-card-title">Forward to HR</div>
                            <div class="appr-choice-card-desc">
                                Request moves to HR for final approval.
                                Status becomes <strong>Pending with HR</strong>.
                            </div>
                        </div>
                        <div class="appr-choice-radio">
                            <div class="appr-radio-outer">
                                @if (tlApproveChoice == "forward_to_hr") { <div class="appr-radio-inner"></div> }
                            </div>
                        </div>
                    </div>

                    @* Direct Approval *@
                    <div class="appr-choice-card @(tlApproveChoice == "direct_approve" ? "appr-choice-card--selected" : "")"
                         @onclick='() => { tlApproveChoice = "direct_approve"; choiceErr = false; }'>
                        <div class="appr-choice-card-icon appr-choice-card-icon--direct">
                            <i class="bi bi-check2-circle"></i>
                        </div>
                        <div class="appr-choice-card-body">
                            <div class="appr-choice-card-title">Direct Approval</div>
                            <div class="appr-choice-card-desc">
                                Approve immediately without HR involvement.
                                Status becomes <strong>Approved</strong>.
                            </div>
                        </div>
                        <div class="appr-choice-radio">
                            <div class="appr-radio-outer">
                                @if (tlApproveChoice == "direct_approve") { <div class="appr-radio-inner"></div> }
                            </div>
                        </div>
                    </div>
                </div>

                @if (choiceErr)
                {
                    <p class="appr-modal-err appr-modal-err--inline">
                        <i class="bi bi-exclamation-circle"></i> Please select an option.
                    </p>
                }

                <div class="appr-modal-actions">
                    <button class="appr-modal-btn appr-modal-btn--cancel" @onclick="CloseModals">Cancel</button>
                    <button class="appr-modal-btn appr-modal-btn--approve"
                            @onclick="SubmitTLApprove" disabled="@isSaving">
                        @if (isSaving) { <span class="appr-mini-spin"></span> }
                        else { <span>Confirm</span> }
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(actionError))
                {
                    <p class="appr-modal-err appr-modal-err--inline">@actionError</p>
                }
            </div>
        </div>
    }

    @* ════════════════════════════════════════════
       HR FINAL APPROVE CONFIRM MODAL
       ════════════════════════════════════════════ *@
    @if (showHRApproveModal && selectedRequest != null)
    {
        <div class="appr-overlay" @onclick="CloseModals">
            <div class="appr-modal appr-modal--confirm" @onclick:stopPropagation="true">
                <div class="appr-confirm-icon appr-confirm-icon--hr">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div class="appr-confirm-title">Final Approval</div>
                <p class="appr-confirm-sub">
                    You are about to <strong>finally approve</strong> the leave request for
                    <strong>@selectedRequest.EmployeeName</strong>
                    (@selectedRequest.StartDate.ToString("MMM dd") – @(selectedRequest.EndDate ?? selectedRequest.StartDate).ToString("MMM dd, yyyy")).
                    This action cannot be undone.
                </p>
                <div class="appr-modal-actions appr-modal-actions--centered">
                    <button class="appr-modal-btn appr-modal-btn--cancel" @onclick="CloseModals">Cancel</button>
                    <button class="appr-modal-btn appr-modal-btn--approve"
                            @onclick="SubmitHRApprove" disabled="@isSaving">
                        @if (isSaving) { <span class="appr-mini-spin"></span> } else { <span>Approve</span> }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(actionError))
                {
                    <p class="appr-modal-err" style="text-align:center;margin:0 24px 16px">@actionError</p>
                }
            </div>
        </div>
    }

    @* ════════════════════════════════════════════
       REJECT MODAL — shared by Team Lead and HR
       ════════════════════════════════════════════ *@
    @if (showRejectModal && selectedRequest != null)
    {
        <div class="appr-overlay" @onclick="CloseModals">
            <div class="appr-modal" @onclick:stopPropagation="true">

                <div class="appr-modal-header">
                    <span class="appr-modal-title">Reject Leave Request</span>
                    <button class="appr-modal-close" @onclick="CloseModals">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="appr-modal-info-row">
                    <div class="appr-av appr-avatar--lg">
                        @GetInitials(selectedRequest.EmployeeName)
                    </div>
                    <div>
                        <div class="appr-modal-emp-name">@selectedRequest.EmployeeName</div>
                        <div class="appr-modal-emp-dates">
                            @selectedRequest.StartDate.ToString("MMM dd") – @(selectedRequest.EndDate ?? selectedRequest.StartDate).ToString("MMM dd, yyyy")
                        </div>
                    </div>
                </div>

                <div class="appr-modal-field">
                    <label class="appr-modal-label">
                        Reason for rejection <span class="appr-required">*</span>
                    </label>
                    <textarea class="appr-modal-textarea @(rejectErr ? "appr-modal-textarea--err" : "")"
                              placeholder="Provide a clear reason so the employee understands the decision…"
                              @bind="rejectReason" rows="4"></textarea>
                    @if (rejectErr)
                    {
                        <p class="appr-modal-err appr-modal-err--inline">
                            <i class="bi bi-exclamation-circle"></i> A rejection reason is required.
                        </p>
                    }
                </div>

                <div class="appr-modal-actions">
                    <button class="appr-modal-btn appr-modal-btn--cancel" @onclick="CloseModals">Cancel</button>
                    <button class="appr-modal-btn appr-modal-btn--reject"
                            @onclick="SubmitReject" disabled="@isSaving">
                        @if (isSaving) { <span class="appr-mini-spin"></span> } else { <span>Reject Request</span> }
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(actionError))
                {
                    <p class="appr-modal-err appr-modal-err--inline">@actionError</p>
                }
            </div>
        </div>
    }

</BasePage>

@code {

    // ── State ──────────────────────────────────────────────────────
    private string  searchQuery  = string.Empty;
    private string  statusFilter = "All";
    private bool    isLoading    = true;
    private bool    isSaving     = false;
    private string  actionError  = string.Empty;
    private string  activePanel  = "teamlead";       // "teamlead" | "hr"

    // Modal visibility
    private bool    showTLApproveModal = false;
    private bool    showHRApproveModal = false;
    private bool    showRejectModal    = false;

    // Modal state
    private bool    rejectErr         = false;
    private bool    choiceErr         = false;
    private string  rejectReason      = string.Empty;
    private string  pendingReviewedBy = string.Empty; // "TeamLead" | "HR"
    private string  tlApproveChoice   = string.Empty; // "forward_to_hr" | "direct_approve"

    private LeaveRequestVm?      selectedRequest = null;
    private List<LeaveRequestVm> leaveRequests   = new();

    // ── Role helpers ───────────────────────────────────────────────
    private bool IsTeamLead =>
        string.Equals(SessionService.ActiveOrgRole, "Team Lead", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(SessionService.ActiveOrgRole, "TeamLead",  StringComparison.OrdinalIgnoreCase) ||
        string.Equals(SessionService.ActiveOrgRole, "Admin",     StringComparison.OrdinalIgnoreCase) ||
        string.Equals(SessionService.ActiveOrgRole, "Manager",   StringComparison.OrdinalIgnoreCase);

    private bool IsHR =>
        string.Equals(SessionService.ActiveOrgRole, "HR",      StringComparison.OrdinalIgnoreCase) ||
        string.Equals(SessionService.ActiveOrgRole, "Admin",   StringComparison.OrdinalIgnoreCase) ||
        string.Equals(SessionService.ActiveOrgRole, "Manager", StringComparison.OrdinalIgnoreCase);

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        activePanel = (!IsTeamLead && IsHR) ? "hr" : "teamlead";
        await LoadAsync();
    }

    private async Task SwitchPanel(string panel)
    {
        activePanel  = panel;
        statusFilter = "All";
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true; StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("API");
            var res    = await client.GetAsync($"api/leave-requests?panel={activePanel}");
            if (res.IsSuccessStatusCode)
            {
                var json = await res.Content.ReadAsStringAsync();
                var opts = new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web);
                var arr  = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement[]>(json, opts);
                leaveRequests = arr?.Select(Map).ToList() ?? new();
            }
            else leaveRequests = new();
        }
        catch { leaveRequests = new(); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private static LeaveRequestVm Map(System.Text.Json.JsonElement e) => new()
    {
        Id           = e.GetProperty("id").GetInt32(),
        EmployeeId   = e.GetProperty("employeeId").GetInt32(),
        EmployeeName = e.GetProperty("employeeName").GetString() ?? "",
        StartDate    = DateTime.Parse(e.GetProperty("startDate").GetString()!),
        EndDate      = e.TryGetProperty("endDate", out var ed2) && ed2.ValueKind != System.Text.Json.JsonValueKind.Null ? DateTime.Parse(ed2.GetString()!) : (DateTime?)null,
        Reason       = e.TryGetProperty("reason",       out var r)  && r.ValueKind  != System.Text.Json.JsonValueKind.Null ? r.GetString()  : "",
        Status       = e.GetProperty("status").GetString() ?? "Pending_TeamLead",
        ReviewedBy   = e.TryGetProperty("reviewedBy",   out var rb) && rb.ValueKind != System.Text.Json.JsonValueKind.Null ? rb.GetString() : null,
        RejectReason = e.TryGetProperty("rejectReason", out var rr) && rr.ValueKind != System.Text.Json.JsonValueKind.Null ? rr.GetString() : null,
        CreatedAt    = e.TryGetProperty("createdAt",    out var ca) && ca.ValueKind != System.Text.Json.JsonValueKind.Null
                           ? DateTime.Parse(ca.GetString()!) : DateTime.MinValue,
    };

    // ── Modal openers ──────────────────────────────────────────────
    private void OpenTLApproveModal(LeaveRequestVm req)
    {
        selectedRequest    = req;
        tlApproveChoice    = string.Empty;
        choiceErr          = false;
        actionError        = string.Empty;
        showTLApproveModal = true;
    }

    private void OpenHRApproveModal(LeaveRequestVm req)
    {
        selectedRequest    = req;
        pendingReviewedBy  = "HR";
        actionError        = string.Empty;
        showHRApproveModal = true;
    }

    private void OpenRejectModal(LeaveRequestVm req, string reviewedBy)
    {
        selectedRequest   = req;
        pendingReviewedBy = reviewedBy;
        rejectReason      = string.Empty;
        rejectErr         = false;
        actionError       = string.Empty;
        showRejectModal   = true;
    }

    private void CloseModals()
    {
        showTLApproveModal = false;
        showHRApproveModal = false;
        showRejectModal    = false;
        selectedRequest    = null;
        rejectReason       = string.Empty;
        tlApproveChoice    = string.Empty;
        rejectErr          = false;
        choiceErr          = false;
        actionError        = string.Empty;
        isSaving           = false;
    }

    // ── Submit: Team Lead (Forward to HR or Direct Approve) ────────
    private async Task SubmitTLApprove()
    {
        if (string.IsNullOrEmpty(tlApproveChoice)) { choiceErr = true; return; }
        if (selectedRequest == null) return;
        isSaving = true; actionError = string.Empty; StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("API");
            var body   = new { action = tlApproveChoice, reviewedBy = "TeamLead" };
            var res    = await client.PatchAsJsonAsync($"api/leave-requests/{selectedRequest.Id}/review", body);
            if (res.IsSuccessStatusCode) { CloseModals(); await LoadAsync(); }
            else actionError = await ParseError(res);
        }
        catch { actionError = "An error occurred. Please try again."; }
        finally { isSaving = false; StateHasChanged(); }
    }

    // ── Submit: HR final approval ──────────────────────────────────
    private async Task SubmitHRApprove()
    {
        if (selectedRequest == null) return;
        isSaving = true; actionError = string.Empty; StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("API");
            var body   = new { action = "approve", reviewedBy = "HR" };
            var res    = await client.PatchAsJsonAsync($"api/leave-requests/{selectedRequest.Id}/review", body);
            if (res.IsSuccessStatusCode) { CloseModals(); await LoadAsync(); }
            else actionError = await ParseError(res);
        }
        catch { actionError = "An error occurred. Please try again."; }
        finally { isSaving = false; StateHasChanged(); }
    }

    // ── Submit: Reject (Team Lead or HR) ──────────────────────────
    private async Task SubmitReject()
    {
        rejectErr = string.IsNullOrWhiteSpace(rejectReason);
        if (rejectErr || selectedRequest == null) return;
        isSaving = true; actionError = string.Empty; StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("API");
            var body   = new { action = "reject", reviewedBy = pendingReviewedBy, rejectReason = rejectReason.Trim() };
            var res    = await client.PatchAsJsonAsync($"api/leave-requests/{selectedRequest.Id}/review", body);
            if (res.IsSuccessStatusCode) { CloseModals(); await LoadAsync(); }
            else actionError = await ParseError(res);
        }
        catch { actionError = "An error occurred. Please try again."; }
        finally { isSaving = false; StateHasChanged(); }
    }

    private static async Task<string> ParseError(HttpResponseMessage res)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(await res.Content.ReadAsStringAsync());
            return doc.RootElement.TryGetProperty("message", out var m) ? m.GetString() ?? "Error." : "Error.";
        }
        catch { return "An error occurred."; }
    }

    // ── Display helpers ────────────────────────────────────────────
    private static (string cls, string label) GetBadge(string status) => status switch
    {
        "Pending_TeamLead"  => ("appr-pill--pending-tl", "Pending with Team Lead"),
        "Pending_HR"        => ("appr-pill--pending-hr", "Pending with HR"),
        "Approved"          => ("appr-pill--approved",   "Approved"),
        "Rejected_TeamLead" => ("appr-pill--rejected",   "Rejected by Team Lead"),
        "Rejected_HR"       => ("appr-pill--rejected",   "Rejected by HR"),
        _                   => ("appr-pill--pending-tl", status)
    };

    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length > 0 ? name[0].ToString().ToUpper() : "?";
    }

    private static string GetAvatarColor(string name)
    {
        var colors = new[] { "blue", "green", "amber", "pink", "teal" };
        var hash   = name.Aggregate(0, (acc, c) => acc + c);
        return colors[hash % colors.Length];
    }

}


<style>
    /* ══ PAGE SHELL ══ */
    .appr-page { display:flex;flex-direction:column;width:100%;height:calc(100vh - 60px);background:#f8f9fb;overflow:hidden;position:relative;font-family:inherit; }

    /* ══ TOP TAB BAR — matches dtl-topbar ══ */
    .appr-topbar { display:flex;align-items:center;padding:0 32px;background:#fff;border-bottom:1px solid #eaedf0;flex-shrink:0;height:52px; }
    .appr-tabs   { display:flex;height:100%;gap:4px; }
    .appr-tab {
        padding:0 20px;border:none;background:transparent;
