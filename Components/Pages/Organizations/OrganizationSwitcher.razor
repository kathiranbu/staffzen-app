@page "/organization/switcher"
@layout EmptyLayout
@rendermode RenderMode.InteractiveServer

@using APM.StaffZen.Blazor.Components.Layout
@using APM.StaffZen.Blazor.Services
@using APM.StaffZen.Blazor.ViewModels
@inject SessionService SessionService
@inject OrgService OrgService
@inject NavigationManager Nav
@inject IHttpClientFactory ClientFactory

<div class="so-shell" @onclick="CloseMenuIfOpen">

    <!-- Topbar -->
    <nav class="so-topbar">
        <div class="so-topbar-logo">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
                <rect width="32" height="32" rx="8" fill="#FF6B00"/>
                <path d="M8 10h16M8 16h10M8 22h13" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <span class="so-brand">StaffZen</span>
        </div>
        <div class="so-topbar-user" @onclick:stopPropagation="true" @onclick="ToggleMenu">
            <span class="so-user-name">@SessionService.FullName</span>
            <i class="bi bi-chevron-down so-chevron @(_showMenu ? "open" : "")"></i>
            @if (_showMenu)
            {
                <div class="so-dropdown">
                    <button class="so-dropdown-item so-logout" @onclick="Logout">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </div>
            }
        </div>
    </nav>

    <!-- Two-column layout -->
    <div class="so-layout">

        <!-- Left illustration -->
        <div class="so-left-panel">
            <svg viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" class="so-illus-svg">
                <circle cx="210" cy="210" r="160" fill="#f0f4ff" opacity="0.6"/>
                <circle cx="100" cy="320" r="50" fill="#e8f0fe" opacity="0.5"/>
                <circle cx="340" cy="90"  r="35" fill="#fce8d5" opacity="0.5"/>
                <rect x="80"  y="290" width="260" height="14" rx="7" fill="#d1d5db"/>
                <rect x="110" y="304" width="14"  height="40" rx="4" fill="#d1d5db"/>
                <rect x="296" y="304" width="14"  height="40" rx="4" fill="#d1d5db"/>
                <rect x="145" y="170" width="160" height="110" rx="10" fill="#1e293b"/>
                <rect x="153" y="178" width="144" height="90"  rx="6"  fill="#0f172a"/>
                <rect x="163" y="188" width="60"  height="7"   rx="3"  fill="#FF6B00" opacity="0.9"/>
                <rect x="163" y="201" width="124" height="5"   rx="2"  fill="#334155" opacity="0.7"/>
                <rect x="163" y="212" width="100" height="5"   rx="2"  fill="#334155" opacity="0.5"/>
                <rect x="163" y="223" width="114" height="5"   rx="2"  fill="#334155" opacity="0.5"/>
                <rect x="163" y="234" width="80"  height="5"   rx="2"  fill="#334155" opacity="0.4"/>
                <rect x="163" y="246" width="44"  height="14"  rx="4"  fill="#FF6B00"/>
                <rect x="213" y="246" width="44"  height="14"  rx="4"  fill="none" stroke="#FF6B00" stroke-width="1.5"/>
                <rect x="216" y="280" width="18"  height="14"  rx="2"  fill="#94a3b8"/>
                <rect x="200" y="292" width="50"  height="6"   rx="3"  fill="#94a3b8"/>
                <ellipse cx="118" cy="346" rx="28" ry="8" fill="#fcd9b9" opacity="0.5"/>
                <path d="M108 306 Q104 328 100 344" stroke="#FF8C42" stroke-width="7" stroke-linecap="round" fill="none"/>
                <path d="M118 308 Q120 330 124 344" stroke="#FF8C42" stroke-width="7" stroke-linecap="round" fill="none"/>
                <rect x="100" y="262" width="36" height="48" rx="14" fill="#FF6B00"/>
                <circle cx="118" cy="248" r="20" fill="#fdbcb4"/>
                <path d="M100 242 Q102 222 118 220 Q136 220 138 240 Q130 228 118 230 Q106 230 100 242Z" fill="#2d1b0e"/>
                <path d="M136 278 Q158 272 174 268" stroke="#fdbcb4" stroke-width="6" stroke-linecap="round" fill="none"/>
                <rect x="168" y="288" width="54" height="10" rx="3" fill="#e2e8f0"/>
                <rect x="170" y="290" width="8"  height="6" rx="1" fill="#94a3b8"/>
                <rect x="181" y="290" width="8"  height="6" rx="1" fill="#94a3b8"/>
                <rect x="192" y="290" width="8"  height="6" rx="1" fill="#94a3b8"/>
                <rect x="203" y="290" width="8"  height="6" rx="1" fill="#94a3b8"/>
                <rect x="214" y="290" width="6"  height="6" rx="1" fill="#94a3b8"/>
                <circle cx="80"  cy="160" r="6" fill="#FF6B00" opacity="0.25"/>
                <circle cx="355" cy="230" r="5" fill="#FF6B00" opacity="0.2"/>
                <circle cx="60"  cy="260" r="4" fill="#0ea5e9" opacity="0.25"/>
                <circle cx="370" cy="310" r="7" fill="#10b981" opacity="0.18"/>
            </svg>
        </div>

        <!-- Right content -->
        <div class="so-right-panel">
            <div class="so-content-box">

                <h1 class="so-greeting">Hi @(SessionService.FullName?.Split(' ').FirstOrDefault() ?? "there")</h1>
                <p class="so-tagline">Join an organization to put in your best hours at work.</p>

                @if (_loading)
                {
                    <div class="so-spinner-wrap"><div class="so-spinner"></div></div>
                }
                else
                {
                    <!-- ── Pending invitations (IsActive = false) ── -->
                    @if (_pendingInvites.Any())
                    {
                        <div class="so-section">
                            <p class="so-section-label">
                                You have <strong>@_pendingInvites.Count</strong>
                                pending invitation@(_pendingInvites.Count > 1 ? "s" : "")
                            </p>
                            <div class="so-card">
                                @foreach (var inv in _pendingInvites)
                                {
                                    <div class="so-invite-row">
                                        <div class="so-avatar" style="background:@AvatarColor(inv.OrganizationName)">
                                            @inv.OrganizationName[0].ToString().ToUpper()
                                        </div>
                                        <span class="so-row-name">@inv.OrganizationName</span>
                                        <div class="so-invite-btns">
                                            @if (_actingOn == inv.OrganizationId)
                                            {
                                                <div class="so-mini-spin"></div>
                                            }
                                            else
                                            {
                                                <button class="so-btn-accept"
                                                        @onclick="() => AcceptInvite(inv)"
                                                        disabled="@(_actingOn.HasValue)">
                                                    Accept
                                                </button>
                                                <button class="so-btn-decline"
                                                        @onclick="() => DeclineInvite(inv)"
                                                        disabled="@(_actingOn.HasValue)">
                                                    Decline
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- ── Accepted orgs (IsActive = true) — click to switch ── -->
                    @if (_orgs.Any())
                    {
                        <div class="so-section">
                            <p class="so-section-label">
                                Your organizations
                                <span class="so-count">(@_orgs.Count)</span>
                            </p>
                            <div class="so-card">
                                @foreach (var org in _orgs)
                                {
                                    var isCurrent = org.OrganizationId == SessionService.ActiveOrganizationId;
                                    <div class="so-org-row @(isCurrent ? "so-row-current" : "") @(_selecting == org.OrganizationId ? "so-row-busy" : "")"
                                         @onclick="() => SelectOrg(org)">
                                        <div class="so-avatar" style="background:@AvatarColor(org.OrganizationName)">
                                            @org.OrganizationName[0].ToString().ToUpper()
                                        </div>
                                        <div class="so-org-meta">
                                            <span class="so-row-name">@org.OrganizationName</span>
                                            @if (!string.IsNullOrEmpty(org.OrgRole))
                                            {
                                                <span class="so-role-pill">@org.OrgRole</span>
                                            }
                                        </div>
                                        <div class="so-org-end">
                                            @if (_selecting == org.OrganizationId)
                                            {
                                                <div class="so-mini-spin"></div>
                                            }
                                            else if (isCurrent)
                                            {
                                                <i class="bi bi-check-circle-fill so-check-icon"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-right so-arrow-icon"></i>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (!_pendingInvites.Any())
                    {
                        <div class="so-empty">
                            <i class="bi bi-building so-empty-icon"></i>
                            <p>You are not part of any organization yet.</p>
                        </div>
                    }

                    <!-- ── Create new org CTA ── -->
                    <div class="so-cta-card">
                        <div class="so-cta-body">
                            <p class="so-cta-title">Want to manage your own team's time tracking?</p>
                            <button class="so-cta-btn" @onclick='() => { _showCreate = true; }'>
                                Create a new organization
                            </button>
                        </div>
                        <svg viewBox="0 0 110 100" fill="none" width="96" class="so-cta-svg">
                            <circle cx="55" cy="50" r="44" fill="#FFE8D6"/>
                            <circle cx="55" cy="35" r="13" fill="#FDBCB4"/>
                            <path d="M39 68 Q55 55 71 68" stroke="#FF8C42" stroke-width="5" fill="none" stroke-linecap="round"/>
                            <path d="M55 48 L55 72"  stroke="#FF8C42" stroke-width="5" stroke-linecap="round"/>
                            <path d="M55 60 L43 71"  stroke="#FF8C42" stroke-width="5" stroke-linecap="round"/>
                            <path d="M55 60 L67 71"  stroke="#FF8C42" stroke-width="5" stroke-linecap="round"/>
                            <rect x="72" y="18" width="26" height="26" rx="6" fill="#FF6B00" opacity="0.15"/>
                            <path d="M85 25 L85 37 M79 31 L91 31" stroke="#FF6B00" stroke-width="2.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Create Org Modal -->
@if (_showCreate)
{
    <div class="so-backdrop" @onclick='() => { _showCreate = false; }'>
        <div class="so-modal" @onclick:stopPropagation="true">
            <div class="so-modal-hdr">
                <h2>Create Organization</h2>
                <button class="so-modal-x" @onclick='() => { _showCreate = false; }'>
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="so-modal-body">
                <div class="so-field">
                    <label>Organization Name <span class="req">*</span></label>
                    <input class="so-input" @bind="_newOrgName" placeholder="e.g. Acme Corp"/>
                </div>
                <div class="so-field">
                    <label>Industry</label>
                    <select class="so-input" @bind="_newOrgIndustry">
                        <option value="">Select industry</option>
                        <option>Technology</option><option>Healthcare</option><option>Finance</option>
                        <option>Retail</option><option>Education</option><option>Manufacturing</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="so-field">
                    <label>Organization Size</label>
                    <select class="so-input" @bind="_newOrgSize">
                        <option value="">Select size</option>
                        <option>1-10</option><option>11-50</option><option>51-200</option>
                        <option>201-500</option><option>500+</option>
                    </select>
                </div>
                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div class="so-error-box">@_createError</div>
                }
            </div>
            <div class="so-modal-ftr">
                <button class="so-btn-cancel" @onclick='() => { _showCreate = false; }'>Cancel</button>
                <button class="so-btn-create" @onclick="CreateOrg" disabled="@_creating">
                    @if (_creating) { <span class="so-mini-spin"></span> }
                    Create Organization
                </button>
            </div>
        </div>
    </div>
}

<!-- Toast -->
@if (!string.IsNullOrEmpty(_toast))
{
    <div class="so-toast @(_toastError ? "so-toast--err" : "so-toast--ok")">
        <i class="bi @(_toastError ? "bi-exclamation-circle" : "bi-check-circle")"></i>
        @_toast
    </div>
}

<style>
/* Shell */
.so-shell { min-height:100vh; background:#f5f6f8; display:flex; flex-direction:column; font-family:'Segoe UI',system-ui,sans-serif; }

/* Topbar */
.so-topbar { display:flex; align-items:center; justify-content:space-between; padding:0 32px; height:60px; background:#fff; border-bottom:1px solid #e5e7eb; position:sticky; top:0; z-index:200; }
.so-topbar-logo { display:flex; align-items:center; gap:10px; }
.so-brand { font-size:17px; font-weight:700; color:#111; letter-spacing:-.3px; }
.so-topbar-user { display:flex; align-items:center; gap:6px; cursor:pointer; position:relative; padding:6px 12px; border-radius:8px; font-size:14px; color:#374151; transition:background .15s; user-select:none; }
.so-topbar-user:hover { background:#f3f4f6; }
.so-user-name { font-weight:600; }
.so-chevron { font-size:11px; color:#9ca3af; transition:transform .2s; }
.so-chevron.open { transform:rotate(180deg); }
.so-dropdown { position:absolute; top:calc(100% + 4px); right:0; background:#fff; border:1px solid #e5e7eb; border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,.1); min-width:160px; z-index:500; overflow:hidden; }
.so-dropdown-item { display:flex; align-items:center; gap:8px; padding:11px 16px; width:100%; border:none; background:none; font-size:14px; cursor:pointer; color:#374151; transition:background .15s; text-align:left; }
.so-dropdown-item:hover { background:#f3f4f6; }
.so-logout { color:#ef4444; }
.so-logout:hover { background:#fff5f5; }

/* Layout */
.so-layout { flex:1; display:flex; max-width:1100px; margin:0 auto; width:100%; padding:0 24px; }
.so-left-panel { flex:0 0 400px; display:flex; align-items:center; justify-content:center; padding:40px 24px; }
.so-illus-svg { width:100%; max-width:360px; }
.so-right-panel { flex:1; display:flex; align-items:flex-start; padding:56px 0 48px 24px; }
.so-content-box { width:100%; max-width:520px; }

/* Heading */
.so-greeting { font-size:30px; font-weight:700; color:#111; margin:0 0 6px; letter-spacing:-.5px; }
.so-tagline { font-size:14px; color:#6b7280; margin:0 0 32px; }

/* Sections */
.so-section { margin-bottom:28px; }
.so-section-label { font-size:13px; font-weight:600; color:#374151; margin:0 0 10px; }
.so-count { color:#9ca3af; font-weight:500; }

/* Card */
.so-card { background:#fff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.05); }

/* Avatar */
.so-avatar { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:700; color:#fff; flex-shrink:0; }

/* ── Pending invite rows ── */
.so-invite-row { display:flex; align-items:center; gap:14px; padding:14px 18px; border-bottom:1px solid #f3f4f6; }
.so-invite-row:last-child { border-bottom:none; }
.so-invite-btns { display:flex; gap:8px; flex-shrink:0; margin-left:auto; }
.so-btn-accept  { padding:7px 20px; background:#FF6B00; color:#fff; border:none; border-radius:7px; font-size:13px; font-weight:600; cursor:pointer; transition:background .15s; white-space:nowrap; }
.so-btn-accept:hover:not(:disabled) { background:#e05f00; }
.so-btn-accept:disabled { opacity:.55; cursor:not-allowed; }
.so-btn-decline { padding:7px 18px; background:transparent; color:#FF6B00; border:1.5px solid #FF6B00; border-radius:7px; font-size:13px; font-weight:600; cursor:pointer; transition:all .15s; white-space:nowrap; }
.so-btn-decline:hover:not(:disabled) { background:#fff5ee; }
.so-btn-decline:disabled { opacity:.55; cursor:not-allowed; }

/* ── Accepted org rows (clickable to switch) ── */
.so-org-row { display:flex; align-items:center; gap:14px; padding:14px 18px; border-bottom:1px solid #f3f4f6; cursor:pointer; transition:background .15s; }
.so-org-row:last-child { border-bottom:none; }
.so-org-row:hover:not(.so-row-busy) { background:#fafafa; }
.so-row-current { background:#fff8f4; }
.so-row-current:hover { background:#fff3ec !important; }
.so-row-busy { opacity:.55; pointer-events:none; }
.so-org-meta { flex:1; display:flex; align-items:center; gap:10px; min-width:0; overflow:hidden; }
.so-row-name { font-size:14px; font-weight:600; color:#111; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.so-role-pill { font-size:11px; font-weight:600; color:#FF6B00; background:#fff0e6; padding:2px 9px; border-radius:20px; white-space:nowrap; flex-shrink:0; }
.so-org-end { flex-shrink:0; display:flex; align-items:center; }
.so-check-icon { color:#10b981; font-size:17px; }
.so-arrow-icon { color:#c4c9d4; font-size:15px; }

/* Create CTA */
.so-cta-card { border:1px solid #ffe0c2; background:#fff9f5; border-radius:14px; padding:20px 20px 20px 24px; display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
.so-cta-body { flex:1; min-width:180px; }
.so-cta-title { font-size:14px; font-weight:600; color:#374151; margin:0 0 14px; }
.so-cta-btn { padding:11px 24px; background:#FF6B00; color:#fff; border:none; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer; transition:background .15s; white-space:nowrap; }
.so-cta-btn:hover { background:#e05f00; }
.so-cta-svg { flex-shrink:0; }

/* Loading / spinners */
.so-spinner-wrap { padding:56px 0; display:flex; justify-content:center; }
.so-spinner { width:38px; height:38px; border:3px solid #f3f4f6; border-top-color:#FF6B00; border-radius:50%; animation:so-spin .8s linear infinite; }
.so-mini-spin { display:inline-block; width:16px; height:16px; border:2px solid rgba(255,107,0,.2); border-top-color:#FF6B00; border-radius:50%; animation:so-spin .7s linear infinite; }
@@keyframes so-spin { to { transform:rotate(360deg); } }

/* Empty */
.so-empty { text-align:center; padding:48px 0; color:#9ca3af; }
.so-empty-icon { font-size:42px; display:block; margin-bottom:12px; }

/* Modal */
.so-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.4); display:flex; align-items:center; justify-content:center; z-index:1000; backdrop-filter:blur(2px); }
.so-modal { background:#fff; border-radius:16px; width:100%; max-width:460px; box-shadow:0 16px 56px rgba(0,0,0,.18); animation:so-in .2s ease-out; }
@@keyframes so-in { from { opacity:0; transform:scale(.96) translateY(10px); } to { opacity:1; transform:none; } }
.so-modal-hdr { display:flex; align-items:center; justify-content:space-between; padding:20px 24px; border-bottom:1px solid #f3f4f6; }
.so-modal-hdr h2 { font-size:17px; font-weight:700; margin:0; color:#111; }
.so-modal-x { background:none; border:none; cursor:pointer; font-size:17px; color:#9ca3af; width:34px; height:34px; display:flex; align-items:center; justify-content:center; border-radius:7px; transition:background .15s; }
.so-modal-x:hover { background:#f3f4f6; }
.so-modal-body { padding:22px 24px; }
.so-modal-ftr { padding:16px 24px; border-top:1px solid #f3f4f6; display:flex; justify-content:flex-end; gap:10px; }
.so-field { margin-bottom:16px; }
.so-field label { display:block; font-size:13px; font-weight:600; color:#374151; margin-bottom:6px; }
.req { color:#ef4444; }
.so-input { width:100%; padding:9px 12px; border:1.5px solid #e5e7eb; border-radius:8px; font-size:14px; outline:none; color:#111; background:#fff; box-sizing:border-box; transition:border-color .15s, box-shadow .15s; }
.so-input:focus { border-color:#FF6B00; box-shadow:0 0 0 3px rgba(255,107,0,.1); }
.so-error-box { background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; border-radius:8px; padding:10px 14px; font-size:13px; margin-top:4px; }
.so-btn-cancel { padding:9px 18px; border:1.5px solid #e5e7eb; border-radius:8px; background:#fff; font-size:14px; cursor:pointer; color:#374151; transition:background .15s; }
.so-btn-cancel:hover { background:#f3f4f6; }
.so-btn-create { display:inline-flex; align-items:center; gap:8px; padding:9px 22px; background:#FF6B00; border:none; border-radius:8px; color:#fff; font-size:14px; font-weight:600; cursor:pointer; transition:background .2s; }
.so-btn-create:hover:not(:disabled) { background:#e05f00; }
.so-btn-create:disabled { opacity:.65; cursor:not-allowed; }

/* Toast */
.so-toast { position:fixed; bottom:28px; right:28px; padding:13px 20px; border-radius:10px; font-size:14px; font-weight:500; display:flex; align-items:center; gap:10px; box-shadow:0 4px 20px rgba(0,0,0,.15); z-index:3000; animation:so-toast-in .2s ease; }
.so-toast--ok  { background:#10b981; color:#fff; }
.so-toast--err { background:#ef4444; color:#fff; }
@@keyframes so-toast-in { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }

/* Responsive */
@@media (max-width:820px) {
    .so-left-panel { display:none; }
    .so-right-panel { padding:32px 16px; }
    .so-layout { padding:0; }
    .so-content-box { max-width:100%; }
}
@@media (max-width:480px) {
    .so-invite-row { flex-wrap:wrap; }
    .so-invite-btns { width:100%; justify-content:flex-end; }
}
</style>

@code {
    // IsActive=true  → already a member → show in org list (click to switch)
    // IsActive=false → pending invite   → show Accept / Decline buttons
    private List<UserOrgMembership> _orgs           = new();
    private List<UserOrgMembership> _pendingInvites = new();

    private bool   _loading    = true;
    private bool   _showMenu   = false;
    private bool   _showCreate = false;
    private bool   _creating   = false;
    private int?   _selecting  = null;   // org being switched into
    private int?   _actingOn   = null;   // invite being accepted/declined

    private string _createError    = "";
    private string _newOrgName     = "";
    private string _newOrgIndustry = "";
    private string _newOrgSize     = "";
    private string _toast          = "";
    private bool   _toastError     = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!SessionService.IsLoggedIn)
        {
            var ok = await SessionService.TryRestoreAsync();
            if (!ok) { Nav.NavigateTo("/login"); return; }
        }
        await LoadOrgs();
        StateHasChanged();
    }

    private async Task LoadOrgs()
    {
        _loading = true; StateHasChanged();
        if (SessionService.Id > 0)
        {
            var all = await OrgService.GetMyOrgsAsync(SessionService.Id);
            // IsActive=false → pending invite; IsActive=true → member
            _pendingInvites = all.Where(o => !o.IsActive).ToList();
            _orgs           = all.Where(o =>  o.IsActive).ToList();
        }
        _loading = false;
    }

    // User clicks an accepted org → switch into it
    private async Task SelectOrg(UserOrgMembership org)
    {
        if (_selecting.HasValue || _actingOn.HasValue) return;
        _selecting = org.OrganizationId; StateHasChanged();
        await SessionService.SwitchOrganizationAsync(org.OrganizationId, org.OrganizationName, org.OrgRole);
        Nav.NavigateTo(SessionService.CanManageActiveOrg ? "/admin" : "/dashboard", forceLoad: true);
    }

    // User accepts a pending invite → accept via API then switch in
    private async Task AcceptInvite(UserOrgMembership org)
    {
        if (_actingOn.HasValue) return;
        _actingOn = org.OrganizationId; StateHasChanged();
        var (success, error) = await OrgService.AcceptInviteAsync(org.OrganizationId, SessionService.Id);
        if (success)
        {
            await SessionService.SwitchOrganizationAsync(org.OrganizationId, org.OrganizationName, org.OrgRole);
            Nav.NavigateTo(SessionService.CanManageActiveOrg ? "/admin" : "/dashboard", forceLoad: true);
        }
        else
        {
            ShowToast(error ?? "Failed to accept invitation.", true);
            _actingOn = null; StateHasChanged();
        }
    }

    // User declines a pending invite → remove from list
    private async Task DeclineInvite(UserOrgMembership org)
    {
        if (_actingOn.HasValue) return;
        _actingOn = org.OrganizationId; StateHasChanged();
        await OrgService.DeclineInviteAsync(org.OrganizationId, SessionService.Id);
        _pendingInvites.Remove(org);
        ShowToast("Invitation declined.", false);
        _actingOn = null; StateHasChanged();
    }

    private async Task CreateOrg()
    {
        if (string.IsNullOrWhiteSpace(_newOrgName)) { _createError = "Organization name is required."; return; }
        _creating = true; _createError = ""; StateHasChanged();
        var (org, error) = await OrgService.CreateOrgAsync(new CreateOrgRequest
        {
            Name             = _newOrgName.Trim(),
            EmployeeId       = SessionService.Id,
            Industry         = _newOrgIndustry,
            OrganizationSize = _newOrgSize
        });
        if (org != null)
        {
            await SessionService.SwitchOrganizationAsync(org.Id, org.Name, "Admin");
            _showCreate = false;
            _newOrgName = _newOrgIndustry = _newOrgSize = "";
            ShowToast($"Organization \"{org.Name}\" created!", false);
            await LoadOrgs();
        }
        else
        {
            _createError = error ?? "Failed to create organization.";
        }
        _creating = false; StateHasChanged();
    }

    private void ShowToast(string msg, bool err)
    {
        _toast = msg; _toastError = err; StateHasChanged();
        _ = Task.Run(async () =>
        {
            await Task.Delay(3500);
            _toast = "";
            await InvokeAsync(StateHasChanged);
        });
    }

    private void ToggleMenu() => _showMenu = !_showMenu;
    private void CloseMenuIfOpen() { if (_showMenu) { _showMenu = false; StateHasChanged(); } }
    private async Task Logout() { await SessionService.ClearSessionAsync(); Nav.NavigateTo("/login"); }

    private static string AvatarColor(string name)
    {
        var c = new[] { "#FF6B00","#0ea5e9","#10b981","#8b5cf6","#f59e0b","#ec4899","#14b8a6","#ef4444" };
        return c[string.IsNullOrEmpty(name) ? 0 : Math.Abs(name.GetHashCode()) % c.Length];
    }
}
