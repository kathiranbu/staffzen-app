@page "/timesheets"
@rendermode RenderMode.InteractiveServer
@inject AttendanceService AttendanceService
@inject SessionService SessionService
@inject PayPeriodService PayPeriodService
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject WorkScheduleService WorkScheduleService
@inject IHttpClientFactory HttpClientFactory

<BasePage @ref="basePage" Title="Timesheets" OnClockAction="OnClockActionFired">

    <div class="ts-wrapper">

        @if (!isLoaded)
        {
            <div class="ts-init-loading">
                <div class="ts-spinner"></div>
                <span>Loading timesheets…</span>
            </div>
        }
        else if (currentView == "list")
        {
            @* ══ TIMESHEETS LIST VIEW (Daily / Weekly / Monthly) ══ *@
            <div class="dtl-page">

                @* ── Top bar with tabs ── *@
                <div class="dtl-topbar">
                    <div class="dtl-tabs">
                        <button class='dtl-tab @(activeTab == "timesheets" ? "dtl-tab--active" : "")'
                                @onclick='() => { activeTab = "timesheets"; }'>Timesheets</button>
                        <button class='dtl-tab @(activeTab == "approvals" ? "dtl-tab--active" : "")'
                                @onclick='async () => {
                                    activeTab = "approvals";
                                    apvCalPickerOpen = false;
                                    // Load pay period setting if not yet loaded
                                    if (_payPeriod == null)
                                    {
                                        _payPeriod = await PayPeriodService.GetAsync(SessionService.ActiveOrganizationId ?? 0);
                                        if (_payPeriod != null)
                                        {
                                            apvWeekStart = GetPeriodStartFor(DateTime.Today);
                                        }
                                    }
                                    apvCalYear  = apvWeekStart.Year;
                                    apvCalMonth = apvWeekStart.Month;
                                    await ApvLoadData();
                                }'>Pay Period</button>
                    </div>
                    <div class="dtl-topbar-right">
                        <span class="dtl-view-toggle">
                            <button class="dtl-vtbtn @(orgView ? "dtl-vtbtn--active" : "")" @onclick="() => orgView = true">Organization</button>
                            <button class="dtl-vtbtn @(!orgView ? "dtl-vtbtn--active" : "")" @onclick="() => orgView = false">Managed by me</button>
                        </span>
                    </div>
                </div>

                @* ══ APPROVALS TAB CONTENT ══ *@
                @if (activeTab == "approvals")
                {
                    <div class="apv-page" @onclick="() => { apvCalPickerOpen = false; apvStatusOpen = false; apvAddFilterOpen = false; }">

                        @* ── Controls bar: date range nav + filters ── *@
                        <div class="apv-controls">
                            <div class="apv-controls-left">
                                <button class="apv-nav-btn" @onclick:stopPropagation="true" @onclick="ApvNavPrev">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <button class="apv-nav-btn" @onclick:stopPropagation="true" @onclick="ApvNavNext">
                                    <i class="bi bi-chevron-right"></i>
                                </button>

                                @* Date range label + calendar picker *@
                                <div class="apv-cal-wrap" @onclick:stopPropagation="true">
                                    <button class='apv-date-label @(apvCalPickerOpen ? "apv-date-label--open" : "")'
                                            @onclick="() => apvCalPickerOpen = !apvCalPickerOpen">
                                        @apvWeekStart.ToString("MMM d") - @apvWeekEnd.ToString("MMM d, yyyy")
                                        <i class="bi bi-calendar3 apv-cal-icon"></i>
                                    </button>

                                    @if (apvCalPickerOpen)
                                    {
                                        <div class="apv-cal-backdrop" @onclick="() => apvCalPickerOpen = false"></div>
                                        <div class="apv-cal-picker">
                                            @* Month nav row *@
                                            <div class="apv-cal-nav">
                                                <button class="apv-cal-nav-btn" @onclick="ApvCalPrevMonth"><i class="bi bi-chevron-left"></i></button>
                                                <span class="apv-cal-month-lbl">@(new DateTime(apvCalYear, apvCalMonth, 1).ToString("MMMM"))</span>
                                                <button class="apv-cal-nav-btn" @onclick="ApvCalNextMonth"><i class="bi bi-chevron-right"></i></button>
                                                <button class="apv-cal-nav-btn" @onclick="() => apvCalYear--"><i class="bi bi-chevron-left"></i></button>
                                                <span class="apv-cal-year-lbl">@apvCalYear</span>
                                                <button class="apv-cal-nav-btn" @onclick="() => apvCalYear++"><i class="bi bi-chevron-right"></i></button>
                                            </div>
                                            @* Day-of-week headers *@
                                            <div class="apv-cal-dow-row">
                                                @foreach (var d in ApvCalDowHeaders())
                                                { <span class="apv-cal-dow">@d</span> }
                                            </div>
                                            @* Day grid — highlight entire pay-period range *@
                                            <div class="apv-cal-grid">
                                                @{
                                                    var apvFirst   = new DateTime(apvCalYear, apvCalMonth, 1);
                                                    int apvStartDow = _payPeriod?.Frequency?.ToLowerInvariant() == "weekly"
                                                                      ? _payPeriod.StartDow : 1;
                                                    int apvOffset  = ((int)apvFirst.DayOfWeek - apvStartDow + 7) % 7;
                                                    int apvDays    = DateTime.DaysInMonth(apvCalYear, apvCalMonth);
                                                    var apvSelFrom = apvWeekStart;
                                                    var apvSelTo   = apvWeekEnd;
                                                    for (int bi2 = 0; bi2 < apvOffset; bi2++) { <span class="apv-cal-blank"></span> }
                                                    for (int di2 = 1; di2 <= apvDays; di2++)
                                                    {
                                                        var cd = new DateTime(apvCalYear, apvCalMonth, di2);
                                                        bool apvToday = cd.Date == DateTime.Today;
                                                        bool apvSel   = cd.Date == apvSelFrom.Date || cd.Date == apvSelTo.Date;
                                                        bool apvRange = cd.Date > apvSelFrom.Date && cd.Date < apvSelTo.Date;
                                                        var capCd = cd;
                                                        <span class='apv-cal-day @(apvSel ? "apv-cal-day--sel" : "") @(apvRange ? "apv-cal-day--range" : "") @(apvToday && !apvSel ? "apv-cal-day--today" : "")'
                                                              @onclick="() => ApvCalSelectDay(capCd)">@di2</span>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* ── Setup Pay Period button — after date picker, in controls bar ── *@
                            @if (SessionService.CanManageActiveOrg)
                            {
                                <button class="pp-setup-btn pp-setup-btn--inline" @onclick:stopPropagation="true" @onclick="PpOpenCard">
                                    <i class="bi bi-gear-fill pp-setup-btn-icon"></i>
                                    Setup Pay Period
                                </button>
                            }

                            @* ── Right: filter chips (admin/manager only) ── *@
                            @if (SessionService.CanManageActiveOrg)
                            {
                            <div class="apv-controls-right" @onclick:stopPropagation="true">
                                <button class="apv-filter-chip">Groups <i class="bi bi-chevron-down apv-chip-chevron"></i></button>
                                <button class="apv-filter-chip">Members <i class="bi bi-chevron-down apv-chip-chevron"></i></button>
                                <button class="apv-filter-chip">Schedules <i class="bi bi-chevron-down apv-chip-chevron"></i></button>

                                @* Statuses dropdown *@
                                <div class="apv-dd-wrap">
                                    <button class='apv-filter-chip @(apvSelectedStatuses.Any() ? "apv-chip--active" : "")'
                                            @onclick="() => { apvStatusOpen = !apvStatusOpen; apvAddFilterOpen = false; }">
                                        Statuses <i class='bi bi-chevron-@(apvStatusOpen ? "up" : "down") apv-chip-chevron'></i>
                                    </button>
                                    @if (apvStatusOpen)
                                    {
                                        <div class="apv-dd-popup">
                                            @foreach (var s in new[]{"Open","In progress","Approved","Reopened"})
                                            {
                                                var cap = s;
                                                bool sel = apvSelectedStatuses.Contains(cap);
                                                <div class='apv-dd-item @(sel ? "apv-dd-item--sel" : "")'
                                                     @onclick="() => { if (sel) apvSelectedStatuses.Remove(cap); else apvSelectedStatuses.Add(cap); }">
                                                    @cap
                                                    @if (sel) { <i class="bi bi-check apv-dd-check"></i> }
                                                </div>
                                            }
                                            <div class="apv-dd-clear" @onclick="() => apvSelectedStatuses.Clear()">Clear selection</div>
                                        </div>
                                    }
                                </div>

                                @* Add filter dropdown *@
                                <div class="apv-dd-wrap">
                                    <button class="apv-add-filter-btn"
                                            @onclick="() => { apvAddFilterOpen = !apvAddFilterOpen; apvStatusOpen = false; }">
                                        <i class="bi bi-plus-lg"></i> Add filter
                                    </button>
                                    @if (apvAddFilterOpen)
                                    {
                                        <div class="apv-dd-popup apv-dd-popup--right">
                                            @foreach (var (fLabel, fActive) in new[]{
                                                ("Groups",           true),
                                                ("Members",          true),
                                                ("Schedules",        true),
                                                ("Tracked hours",    false),
                                                ("Member codes",     false),
                                                ("Positions",        false),
                                                ("Employment types", false),
                                                ("Statuses",         true) })
                                            {
                                                <div class="apv-dd-item apv-dd-item--af">
                                                    <span>@fLabel</span>
                                                    @if (fActive) { <i class="bi bi-check apv-dd-check" style="color:#22c55e;"></i> }
                                                </div>
                                            }
                                            <div class="apv-dd-clear" @onclick="() => apvAddFilterOpen = false">Clear selection</div>
                                        </div>
                                    }
                                </div>
                            </div>
                            } @* end CanManageActiveOrg filter chips *@
                        </div>

                        @* ── Pay Period Setup Card Modal ── *@
                        @if (SessionService.CanManageActiveOrg)
                        {
                        @if (ppCardOpen)
                        {
                            <div class="pp-modal-backdrop" @onclick="() => { ppCardOpen = false; ppCycleDropOpen = false; ppSemiDay1Open = false; ppSemiDay2Open = false; }">
                                <div class="pp-card" @onclick:stopPropagation="true">
                                    <div class="pp-card-header">
                                        <div class="pp-card-title-row">
                                            <span class="pp-card-title">PAY PERIOD</span>
                                            <i class="bi bi-info-circle pp-card-info-icon"></i>
                                        </div>
                                    </div>

                                    <div class="pp-card-body">
                                        @* Name field *@
                                        <div class="pp-field-row">
                                            <label class="pp-field-label">Name</label>
                                            <div class="pp-field-input-wrap">
                                                <input class="pp-field-input" type="text"
                                                       @bind="ppName" placeholder="Enter pay period name" />
                                                <i class="bi bi-info-circle pp-field-info"></i>
                                            </div>
                                        </div>

                                        @* Cycle dropdown *@
                                        <div class="pp-field-row">
                                            <label class="pp-field-label">Cycle</label>
                                            <div class="pp-field-input-wrap" style="position:relative;">
                                                <div class="pp-cycle-select @(ppCycleDropOpen ? "pp-cycle-select--open" : "")"
                                                     @onclick:stopPropagation="true"
                                                     @onclick="() => { ppCycleDropOpen = !ppCycleDropOpen; ppSemiDay1Open = false; ppSemiDay2Open = false; }">
                                                    <span class="pp-cycle-value">@ppCycle</span>
                                                    <i class="bi bi-chevron-@(ppCycleDropOpen ? "up" : "down") pp-cycle-chevron"></i>
                                                </div>
                                                @if (ppCycleDropOpen)
                                                {
                                                    <div class="pp-cycle-dropdown" @onclick:stopPropagation="true">
                                                        @foreach (var opt in new[] { "Weekly", "Every two weeks", "Twice a month", "Monthly" })
                                                        {
                                                            var capOpt = opt;
                                                            <div class="pp-cycle-option @(ppCycle == capOpt ? "pp-cycle-option--active" : "")"
                                                                 @onclick="() => PpChangeCycle(capOpt)">
                                                                @opt
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                <i class="bi bi-info-circle pp-field-info"></i>
                                            </div>
                                        </div>

                                        @* Helper: periods per year *@
                                        <div class="pp-periods-hint">@PpPeriodsLabel</div>

                                        @* ── Weekly / Every two weeks: weekday selector + From dates ── *@
                                        @if (ppCycle == "Weekly" || ppCycle == "Every two weeks")
                                        {
                                            @* Weekday selector *@
                                            <div class="pp-field-row">
                                                <label class="pp-field-label">Pay periods start on</label>
                                                <div class="pp-dow-wrap">
                                                    @{
                                                        var dowLabels = new[] { "M", "T", "W", "T", "F", "S", "S" };
                                                    }
                                                    @for (int di = 0; di < 7; di++)
                                                    {
                                                        var capDi = di;
                                                        <button class="pp-dow-btn @(ppDow == capDi ? "pp-dow-btn--active" : "")"
                                                                @onclick="() => { ppDow = capDi; ppFromDate = null; }">
                                                            @dowLabels[capDi]
                                                        </button>
                                                    }
                                                </div>
                                                <i class="bi bi-info-circle pp-field-info" style="margin-left:8px;"></i>
                                            </div>

                                            @* From: radio list of candidate start dates *@
                                            <div class="pp-field-row pp-field-row--top">
                                                <label class="pp-field-label">From</label>
                                                <div class="pp-from-list">
                                                    @foreach (var fd in PpFromOptions)
                                                    {
                                                        var capFd = fd;
                                                        <label class="pp-from-option">
                                                            <input type="radio" class="pp-from-radio"
                                                                   name="ppFromDate"
                                                                   checked="@(ppFromDate.HasValue && ppFromDate.Value.Date == capFd.Date)"
                                                                   @onchange="() => ppFromDate = capFd" />
                                                            <span class="pp-from-label">@capFd.ToString("dddd, yyyy-MM-dd")</span>
                                                        </label>
                                                    }
                                                </div>
                                                <i class="bi bi-info-circle pp-field-info" style="margin-left:8px;"></i>
                                            </div>
                                        }

                                        @* ── Twice a month: two day dropdowns ── *@
                                        @if (ppCycle == "Twice a month")
                                        {
                                            <div class="pp-field-row">
                                                <label class="pp-field-label">Pay periods start on</label>
                                                <div class="pp-semi-wrap" @onclick:stopPropagation="true">
                                                    @* First day dropdown *@
                                                    <div class="pp-semi-drop-wrap" style="position:relative;">
                                                        <div class="pp-field-input-wrap pp-semi-drop-trigger"
                                                             @onclick="() => { ppSemiDay1Open = !ppSemiDay1Open; ppSemiDay2Open = false; }">
                                                            <span class="pp-field-input">Day @ppSemiDay1</span>
                                                            <i class="bi bi-chevron-@(ppSemiDay1Open ? "up" : "down") pp-cycle-chevron"></i>
                                                        </div>
                                                        @if (ppSemiDay1Open)
                                                        {
                                                            <div class="pp-day-dropdown">
                                                                @for (int d = 1; d <= 31; d++)
                                                                {
                                                                    var capD = d;
                                                                    <div class="pp-day-option @(ppSemiDay1 == capD ? "pp-day-option--active" : "") @(capD == ppSemiDay2 ? "pp-day-option--disabled" : "")"
                                                                         @onclick="() => { if (capD != ppSemiDay2) { ppSemiDay1 = capD; ppSemiDay1Open = false; } }">
                                                                        Day @capD
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <span class="pp-semi-and">and</span>
                                                    @* Second day dropdown *@
                                                    <div class="pp-semi-drop-wrap" style="position:relative;">
                                                        <div class="pp-field-input-wrap pp-semi-drop-trigger"
                                                             @onclick="() => { ppSemiDay2Open = !ppSemiDay2Open; ppSemiDay1Open = false; }">
                                                            <span class="pp-field-input">Day @ppSemiDay2</span>
                                                            <i class="bi bi-chevron-@(ppSemiDay2Open ? "up" : "down") pp-cycle-chevron"></i>
                                                        </div>
                                                        @if (ppSemiDay2Open)
                                                        {
                                                            <div class="pp-day-dropdown">
                                                                @for (int d = 1; d <= 31; d++)
                                                                {
                                                                    var capD = d;
                                                                    <div class="pp-day-option @(ppSemiDay2 == capD ? "pp-day-option--active" : "") @(capD == ppSemiDay1 ? "pp-day-option--disabled" : "")"
                                                                         @onclick="() => { if (capD != ppSemiDay1) { ppSemiDay2 = capD; ppSemiDay2Open = false; } }">
                                                                        Day @capD
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                                <i class="bi bi-info-circle pp-field-info" style="margin-left:8px;"></i>
                                            </div>
                                        }

                                        @* ── Monthly: single day dropdown ── *@
                                        @if (ppCycle == "Monthly")
                                        {
                                            <div class="pp-field-row">
                                                <label class="pp-field-label">Pay periods start on</label>
                                                <div class="pp-semi-drop-wrap" style="position:relative;" @onclick:stopPropagation="true">
                                                    <div class="pp-field-input-wrap pp-semi-drop-trigger"
                                                         @onclick="() => { ppSemiDay1Open = !ppSemiDay1Open; }">
                                                        <span class="pp-field-input">Day @ppMonthDay</span>
                                                        <i class="bi bi-chevron-@(ppSemiDay1Open ? "up" : "down") pp-cycle-chevron"></i>
                                                    </div>
                                                    @if (ppSemiDay1Open)
                                                    {
                                                        <div class="pp-day-dropdown">
                                                            @for (int d = 1; d <= 31; d++)
                                                            {
                                                                var capD = d;
                                                                <div class="pp-day-option @(ppMonthDay == capD ? "pp-day-option--active" : "")"
                                                                     @onclick="() => { ppMonthDay = capD; ppSemiDay1Open = false; }">
                                                                    Day @capD
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                                <i class="bi bi-info-circle pp-field-info" style="margin-left:8px;"></i>
                                            </div>
                                        }

                                        @* Error message *@
                                        @if (!string.IsNullOrEmpty(ppSaveError))
                                        {
                                            <div class="pp-error">@ppSaveError</div>
                                        }
                                    </div>

                                    <div class="pp-card-footer">
                                        <button class="pp-cancel-btn" @onclick="() => ppCardOpen = false">Cancel</button>
                                        <button class="pp-save-btn" @onclick="PpSave" disabled="@ppSaving">
                                            @if (ppSaving) { <span>Saving…</span> } else { <span>Save</span> }
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }

                        } @* end CanManageActiveOrg setup button *@

                        @* ── Approvals table (admin/manager only) ── *@
                        @{
                            bool apvPeriodClosed = apvWeekEnd.Date < DateTime.Today;
                            bool apvIsUser       = !SessionService.CanManageActiveOrg;
                        }

                        @if (apvIsUser)
                        {
                            @* User view: nothing else to show here *@
                        }
                        else
                        {
                            @* ── ADMIN / MANAGER VIEW: all members for selected period ── *@
                            <div class="apv-table-wrap">
                                <table class="apv-table">
                                    <thead>
                                        <tr class="apv-thead-row">
                                            @if (apvPeriodClosed)
                                            {
                                                <th class="apv-th apv-th--check">
                                                    <input type="checkbox" class="apv-chk" @bind="apvAllChecked"
                                                           @bind:after="ApvToggleAll" />
                                                </th>
                                            }
                                            <th class="apv-th apv-th--name">
                                                <div class="apv-search-wrap">
                                                    <i class="bi bi-search apv-search-icon"></i>
                                                    <input class="apv-search" placeholder="Search..." @bind="apvSearch" @bind:event="oninput" />
                                                </div>
                                            </th>
                                            <th class="apv-th apv-th--sort" @onclick='() => ApvSort("tracked")'>
                                                Tracked <i class="bi bi-arrow-down-up apv-sort-icon"></i>
                                            </th>
                                            <th class="apv-th apv-th--sort" @onclick='() => ApvSort("regular")'>
                                                Regular <i class="bi bi-arrow-down-up apv-sort-icon"></i>
                                            </th>
                                            <th class="apv-th apv-th--sort" @onclick='() => ApvSort("overtime")'>
                                                Overtime <i class="bi bi-arrow-down-up apv-sort-icon"></i>
                                            </th>
                                            <th class="apv-th apv-th--sort" @onclick='() => ApvSort("timeoff")'>
                                                Time Off <i class="bi bi-arrow-down-up apv-sort-icon"></i>
                                            </th>
                                            <th class="apv-th apv-th--sort" @onclick='() => ApvSort("status")'>
                                                Status <i class="bi bi-arrow-down-up apv-sort-icon"></i>
                                            </th>
                                            @if (apvPeriodClosed)
                                            {
                                                <th class="apv-th apv-th--action"></th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var apvFiltered = rangeRows
                                                .Where(r => string.IsNullOrEmpty(apvSearch) ||
                                                            r.FullName.Contains(apvSearch, StringComparison.OrdinalIgnoreCase))
                                                .ToList();
                                        }
                                        @if (!apvFiltered.Any())
                                        {
                                            <tr><td colspan="@(apvPeriodClosed ? 8 : 6)" class="apv-empty-cell">No timesheet records for this period.</td></tr>
                                        }
                                        @foreach (var row in apvFiltered)
                                        {
                                            var apvStatus    = ApvGetStatus(row.EmployeeId);
                                            var apvStatusCss = apvStatus switch {
                                                "Approved"    => "apv-status--approved",
                                                "Reopened"    => "apv-status--reopened",
                                                "Open"        => "apv-status--open",
                                                "In progress" => "apv-status--inprogress",
                                                _             => "apv-status--none"  // "-" or unknown → no pill styling
                                            };
                                            bool rowChecked = apvCheckedRows.Contains(row.EmployeeId);
                                            var capRow      = row;
                                            <tr class="apv-row @(apvPeriodClosed ? "apv-row--selectable" : "")" @onclick="() => ApvOpenEmployee(capRow)">
                                                @if (apvPeriodClosed)
                                                {
                                                    <td class="apv-td apv-td--check" @onclick:stopPropagation="true">
                                                        <input type="checkbox" class="apv-chk" checked="@rowChecked"
                                                               @onchange="() => ApvToggleRow(capRow.EmployeeId)" />
                                                    </td>
                                                }
                                                <td class="apv-td apv-td--name">
                                                    <div class="apv-name-cell">
                                                        <div class="apv-av">@(row.FullName.Length > 0 ? row.FullName[0].ToString().ToUpper() : "?")</div>
                                                        <span class="apv-name">@row.FullName</span>
                                                    </div>
                                                </td>
                                                <td class="apv-td">
                                                    <span class="apv-hours">@(string.IsNullOrEmpty(row.TotalHours) ? "—" : row.TotalHours)</span>
                                                </td>
                                                <td class="apv-td">
                                                    <span class="apv-hours">@(string.IsNullOrEmpty(row.RegularHours) ? "—" : row.RegularHours)</span>
                                                </td>
                                                <td class="apv-td"><span class="apv-dash">-</span></td>
                                                <td class="apv-td"><span class="apv-dash">-</span></td>
                                                <td class="apv-td apv-td--status">
                                                    @if (apvStatus == "-")
                                                    {
                                                        <span class="apv-dash">-</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="apv-status @apvStatusCss">
                                                            <span class="apv-status-dot"></span>@apvStatus
                                                        </span>
                                                    }
                                                </td>
                                                @if (apvPeriodClosed)
                                                {
                                                    <td class="apv-td apv-td--action" @onclick:stopPropagation="true">
                                                        @if (apvStatus != "Approved")
                                                        {
                                                            <button class="apv-approve-btn" title="Approve"
                                                                    @onclick="() => ApvApprove(capRow.EmployeeId)">
                                                                <i class="bi bi-check-lg"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="apv-approved-icon"><i class="bi bi-check-lg"></i></span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                    </div>
                }

                @* ── Controls bar: view mode dropdown + date nav + export ── *@
                @if (activeTab == "timesheets")
                {
                <div class="dtl-controls">
                    <div class="dtl-controls-left">

                        @* View mode dropdown *@
                        <div class="dtl-view-dropdown-wrap" @onclick:stopPropagation="true">
                            <button class="dtl-view-label" @onclick="() => showViewDropdown = !showViewDropdown">
                                @(viewMode == "daily" ? "Daily Timesheets" : viewMode == "weekly" ? "Weekly Timesheets" : "Monthly Timesheets")
                                <i class="bi bi-chevron-@(showViewDropdown ? "up" : "down") dtl-chevron"></i>
                            </button>
                            @if (showViewDropdown)
                            {
                                <div class="dtl-view-dropdown">
                                    <div class="dtl-vd-item @(viewMode == "daily" ? "dtl-vd-item--active" : "")" @onclick='() => SetViewMode("daily")'>
                                        Daily Timesheets
                                        @if (viewMode == "daily") { <i class="bi bi-check dtl-vd-check"></i> }
                                    </div>
                                    <div class="dtl-vd-item @(viewMode == "weekly" ? "dtl-vd-item--active" : "")" @onclick='() => SetViewMode("weekly")'>
                                        Weekly Timesheets
                                        @if (viewMode == "weekly") { <i class="bi bi-check dtl-vd-check"></i> }
                                    </div>
                                    <div class="dtl-vd-item @(viewMode == "monthly" ? "dtl-vd-item--active" : "")" @onclick='() => SetViewMode("monthly")'>
                                        Monthly Timesheets
                                        @if (viewMode == "monthly") { <i class="bi bi-check dtl-vd-check"></i> }
                                    </div>
                                </div>
                            }
                        </div>

                        @* Date navigation *@
                        <div class="dtl-date-nav">
                            <button class="dtl-nav-btn" @onclick="NavPrev"><i class="bi bi-chevron-left"></i></button>
                            @if (viewMode == "daily")
                            {
                                <span class="dtl-date-label">@dtlSelectedDate.ToString("ddd, MMM d")</span>
                            }
                            else if (viewMode == "weekly")
                            {
                                <span class="dtl-date-label">@weekRangeFrom.ToString("MMM d") - @weekRangeTo.ToString("MMM d")</span>
                            }
                            else
                            {
                                <span class="dtl-date-label">@monthDate.ToString("MMMM yyyy")</span>
                            }
                            <button class="dtl-nav-btn" @onclick="NavNext"><i class="bi bi-chevron-right"></i></button>

                            @* Calendar icon - opens day-grid picker *@
                            <div class="dtl-cal-wrap" @onclick:stopPropagation="true">
                                <i class="bi bi-calendar3 dtl-cal-icon" @onclick="ToggleCalPicker"></i>
                                @if (showCalPicker)
                                {
                                    @* Backdrop to close on outside click *@
                                    <div class="dtl-cal-backdrop" @onclick="() => showCalPicker = false"></div>
                                    <div class="dtl-cal-picker">
                                        @if (viewMode == "monthly")
                                        {
                                            @* ── MONTHLY: Year nav + Month grid ── *@
                                            <div class="dtl-cal-picker-nav dtl-cal-picker-nav--year">
                                                <button class="dtl-cal-nav-btn" @onclick="CalPickerPrevYear"><i class="bi bi-chevron-left"></i></button>
                                                <span class="dtl-cal-year">@calPickerYear</span>
                                                <button class="dtl-cal-nav-btn" @onclick="CalPickerNextYear"><i class="bi bi-chevron-right"></i></button>
                                            </div>
                                            <div class="dtl-cal-months">
                                                @for (int mi = 1; mi <= 12; mi++)
                                                {
                                                    var captured = mi;
                                                    bool isCurrent = calPickerYear == DateTime.Today.Year && mi == DateTime.Today.Month;
                                                    bool isSelected = calPickerYear == monthDate.Year && mi == monthDate.Month;
                                                    var monthLabel = new DateTime(calPickerYear, mi, 1).ToString("MMM");
                                                    <div class="dtl-cal-month-cell @(isSelected ? "dtl-cal-month--sel" : "") @(isCurrent && !isSelected ? "dtl-cal-month--today" : "")"
                                                         @onclick="() => CalPickerSelect(captured)">
                                                        @monthLabel
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            @* ── DAILY / WEEKLY: Full day-grid ── *@
                                            <div class="dtl-cal-picker-nav">
                                                <button class="dtl-cal-nav-btn" @onclick="CalPickerPrevMonth"><i class="bi bi-chevron-left"></i></button>
                                                <span class="dtl-cal-month-label">@(new DateTime(calPickerYear, calPickerMonth, 1).ToString("MMMM"))</span>
                                                <button class="dtl-cal-nav-btn" @onclick="CalPickerNextMonth"><i class="bi bi-chevron-right"></i></button>
                                                <button class="dtl-cal-nav-btn" @onclick="CalPickerPrevYear"><i class="bi bi-chevron-left"></i></button>
                                                <span class="dtl-cal-year">@calPickerYear</span>
                                                <button class="dtl-cal-nav-btn" @onclick="CalPickerNextYear"><i class="bi bi-chevron-right"></i></button>
                                            </div>
                                            <div class="dtl-cal-dow-row">
                                                @foreach (var d in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"})
                                                {<span class="dtl-cal-dow">@d</span>}
                                            </div>
                                            <div class="dtl-cal-grid">
                                                @{
                                                    var firstOfMonth = new DateTime(calPickerYear, calPickerMonth, 1);
                                                    int startOffset = ((int)firstOfMonth.DayOfWeek + 6) % 7;
                                                    int daysInM     = DateTime.DaysInMonth(calPickerYear, calPickerMonth);
                                                    for (int bi = 0; bi < startOffset; bi++)
                                                    { <span class="dtl-cal-blank"></span> }
                                                    for (int di = 1; di <= daysInM; di++)
                                                    {
                                                        var cellDate = new DateTime(calPickerYear, calPickerMonth, di);
                                                        var capDate  = cellDate;
                                                        bool isToday = cellDate.Date == DateTime.Today;
                                                        bool isSelected = false;
                                                        bool inRange    = false;
                                                        if (viewMode == "daily")
                                                        {
                                                            isSelected = cellDate.Date == dtlSelectedDate.Date;
                                                        }
                                                        else if (viewMode == "weekly")
                                                        {
                                                            var wEnd = weekRangeFrom.AddDays(6);
                                                            isSelected = cellDate.Date == weekRangeFrom.Date || cellDate.Date == wEnd.Date;
                                                            inRange    = cellDate.Date > weekRangeFrom.Date && cellDate.Date < wEnd.Date;
                                                        }
                                                        <span class="dtl-cal-day @(isSelected ? "dtl-cal-day--sel" : "") @(inRange ? "dtl-cal-day--inrange" : "") @(isToday && !isSelected ? "dtl-cal-day--today" : "")"
                                                              @onclick="() => CalPickerSelectDay(capDate)">@di</span>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="dtl-controls-right">
                        @if (viewMode == "monthly")
                        {
                            @* Legend button *@
                            <div class="dtl-legend-wrap" @onclick:stopPropagation="true">
                                <button class="dtl-legend-btn" @onclick="() => showLegend = !showLegend">
                                    <i class="bi bi-info-circle"></i> Legend
                                </button>
                                @if (showLegend)
                                {
                                    <div class="dtl-legend-popup">
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#f3f4f6;border:1px solid #e5e7eb;"></span> 0 hours</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#fef3c7;"></span> 0-2 hours</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#fed7aa;"></span> 2-4 hours</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#bbf7d0;"></span> 4-6 hours</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#4ade80;"></span> 6-8 hours</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#be123c;"></span> 8-10 hours</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#9f1239;"></span> 10+ hours</div>
                                        <div class="dtl-legend-divider"></div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#ede9fe;border:1px solid #c4b5fd;"></span><i class="bi bi-calendar2-event dtl-leg-icon" style="color:#6366f1;"></i> Public Holiday</div>
                                        <div class="dtl-legend-row"><span class="dtl-leg-color" style="background:#d1fae5;border:1px solid #6ee7b7;"></span><i class="bi bi-person-check dtl-leg-icon" style="color:#059669;"></i> Time Off</div>
                                        <div class="dtl-legend-row"><i class="bi bi-skip-forward dtl-leg-icon"></i> Rest Day</div>
                                        <div class="dtl-legend-row"><i class="bi bi-arrow-left-right dtl-leg-icon"></i> Shortened Workday</div>
                                        <div class="dtl-legend-row"><i class="bi bi-moon dtl-leg-icon"></i> Overtime</div>
                                    </div>
                                }
                            </div>
                        }
                        <button class="dtl-export-btn" @onclick="OpenExportModal"><i class="bi bi-download"></i> Export</button>
                    </div>
                </div>

                @* ── Filter bar ── *@
                <div class="dtl-filterbar" @onclick:stopPropagation="true">
                    <button class="dtl-filter-chip @(filterPayroll ? "dtl-chip--active" : "")" @onclick="() => filterPayroll = !filterPayroll">
                        Payroll hours <i class="bi bi-chevron-down"></i>
                    </button>
                    <button class="dtl-filter-chip @(filterGroups ? "dtl-chip--active" : "")" @onclick="() => filterGroups = !filterGroups">
                        Groups <i class="bi bi-chevron-down"></i>
                    </button>
                    <button class="dtl-filter-chip @(filterMembers ? "dtl-chip--active" : "")" @onclick="() => filterMembers = !filterMembers">
                        Members <i class="bi bi-chevron-down"></i>
                    </button>

                    @* Schedules dropdown *@
                    <div class="dtl-schedules-wrap">
                        <button class="dtl-filter-chip @(selectedSchedule != null ? "dtl-chip--active" : "")"
                                @onclick="() => showSchedulesDropdown = !showSchedulesDropdown">
                            Schedules <i class="bi bi-chevron-@(showSchedulesDropdown ? "up" : "down")"></i>
                        </button>
                        @if (showSchedulesDropdown)
                        {
                            <div class="dtl-schedules-popup">
                                <div class="dtl-sched-search-wrap">
                                    <i class="bi bi-search dtl-sched-search-icon"></i>
                                    <input class="dtl-sched-search" placeholder="Search schedules"
                                           @bind="scheduleSearch" @bind:event="oninput" />
                                </div>
                                @{
                                    var schedList = availableSchedules
                                        .Where(s => string.IsNullOrEmpty(scheduleSearch) ||
                                                    s.Contains(scheduleSearch, StringComparison.OrdinalIgnoreCase))
                                        .ToList();
                                }
                                @if (!schedList.Any())
                                {
                                    <div class="dtl-sched-empty">No schedules found</div>
                                }
                                @foreach (var sched in schedList)
                                {
                                    var cap = sched;
                                    <div class="dtl-sched-item @(selectedSchedule == cap ? "dtl-sched-item--active" : "")"
                                         @onclick="() => { selectedSchedule = selectedSchedule == cap ? null : cap; showSchedulesDropdown = false; }">
                                        @cap
                                        @if (selectedSchedule == cap) { <i class="bi bi-check dtl-vd-check"></i> }
                                    </div>
                                }
                                <div class="dtl-sched-clear" @onclick="() => { selectedSchedule = null; showSchedulesDropdown = false; }">Clear selection</div>
                            </div>
                        }
                    </div>

                    @* Add filter dropdown *@
                    <div class="dtl-addfilter-wrap">
                        <button class="dtl-filter-add" @onclick="() => showAddFilter = !showAddFilter">
                            <i class="bi bi-plus-lg"></i> Add filter
                        </button>
                        @if (showAddFilter)
                        {
                            <div class="dtl-addfilter-popup">
                                @foreach (var f in new[] { "Payroll hours","Groups","Members","Schedules","Tracked hours","Member codes","Positions","Employment types" })
                                {
                                    var cap = f;
                                    bool active = (cap == "Payroll hours" && filterPayroll) || (cap == "Groups" && filterGroups) || (cap == "Members" && filterMembers);
                                    <div class="dtl-af-item @(active ? "dtl-af-item--active" : "")"
                                         @onclick="() => ToggleFilter(cap)">
                                        @cap
                                        @if (active) { <i class="bi bi-check dtl-vd-check"></i> }
                                    </div>
                                }
                                <div class="dtl-af-clear" @onclick='() => { filterPayroll = false; filterGroups = false; filterMembers = false; showAddFilter = false; }'>Clear selection</div>
                            </div>
                        }
                    </div>
                </div>

                @* ── TABLE AREA ── *@
                <div class="dtl-table-wrap" @onclick="CloseAllDropdowns">
                    @if (dtlLoading)
                    {
                        <div class="ts-init-loading" style="margin-top:60px;">
                            <div class="ts-spinner"></div><span>Loading…</span>
                        </div>
                    }
                    else if (viewMode == "daily")
                    {
                        @* ── DAILY TABLE ──
                           The API now returns ALL active employees regardless of whether they
                           clocked in. Each row carries: IsRestDay, TimeOffLabel, HasEntries.
                           Badge priority: Time Off > Public Holiday > Rest day.
                        *@
                        bool showOT       = dtlRows.Any(r => r.HasDailyOT);
                        bool showDblOT    = dtlRows.Any(r => r.HasDailyDblOT);
                        bool showWeeklyOT = dtlRows.Any(r => r.HasWeeklyOT);
                        bool showRdOT     = dtlRows.Any(r => r.HasRestDayOT);
                        bool showPhOT     = dtlRows.Any(r => r.HasPublicHolOT);
                        int  totalCols    = 4 + (showOT ? 1 : 0) + (showDblOT ? 1 : 0)
                                             + (showWeeklyOT ? 1 : 0) + (showRdOT ? 1 : 0)
                                             + (showPhOT ? 1 : 0) + 1;
                        var  dayHolidayName = GetHolidayForDate(dtlSelectedDate);

                        var filteredDaily = dtlRows
                            .Where(r => string.IsNullOrEmpty(dtlSearchText) || r.FullName.Contains(dtlSearchText, StringComparison.OrdinalIgnoreCase))
                            .ToList();

                        <table class="dtl-table">
                            <thead>
                                <tr>
                                    <th class="dtl-th dtl-th--name">Name</th>
                                    <th class="dtl-th">First in</th>
                                    <th class="dtl-th">Last out</th>
                                    <th class="dtl-th">Regular</th>
                                    @if (showOT)       { <th class="dtl-th">Daily OT</th> }
                                    @if (showDblOT)    { <th class="dtl-th dtl-th--ddo">Daily Double<br/>Overtime</th> }
                                    @if (showWeeklyOT) { <th class="dtl-th">Weekly OT</th> }
                                    @if (showRdOT)     { <th class="dtl-th">Rest Day OT</th> }
                                    @if (showPhOT)     { <th class="dtl-th">Public Holiday OT</th> }
                                    <th class="dtl-th">Tracked</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!filteredDaily.Any())
                                {
                                    <tr><td colspan="@totalCols" class="dtl-empty-cell">No timesheet records for this day.</td></tr>
                                }
                                else
                                {
                                    @foreach (var row in filteredDaily)
                                    {
                                        var cap    = row;
                                        @* All rows are always clickable — even empty ones open the Time Entries page *@
                                        @* Badge priority: time-off > public holiday > rest day *@
                                        string? badge    = row.TimeOffLabel ?? (string.IsNullOrEmpty(dayHolidayName) ? null : "Public Holiday");
                                        string  badgeCss = !string.IsNullOrEmpty(row.TimeOffLabel) ? "dtl-badge--timeoff"
                                                         : !string.IsNullOrEmpty(dayHolidayName)   ? "dtl-badge--holiday"
                                                         : "dtl-badge--rest";
                                        bool    showRest = row.IsRestDay && string.IsNullOrEmpty(badge);
                                        <tr class="dtl-row dtl-row--always-open"
                                            @onclick="() => OpenDetailView(cap)">
                                            <td class="dtl-td dtl-td--name">
                                                <div class="dtl-name-cell">
                                                    <div class="dtl-av @(!row.HasEntries ? "dtl-av--muted" : "")">@(row.FullName.Length > 0 ? row.FullName[0].ToString().ToUpper() : "?")</div>
                                                    <span class="dtl-name">@row.FullName</span>
                                                    @if (!string.IsNullOrEmpty(badge))
                                                    {
                                                        <span class="dtl-status-badge @badgeCss">@badge</span>
                                                    }
                                                    else if (showRest)
                                                    {
                                                        <span class="dtl-status-badge dtl-badge--rest">Rest day</span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="dtl-td">
                                                @if (row.FirstIn != null) { <span class="dtl-time">@row.FirstIn.Value.ToString("h:mm tt").ToLower() <span class="dtl-tz">(GMT+5:30)</span></span> }
                                                else { <span class="dtl-dash">-</span> }
                                            </td>
                                            <td class="dtl-td">
                                                @if (row.IsOngoing) { <span class="dtl-ongoing-text">ongoing</span> }
                                                else if (row.LastOut != null) { <span class="dtl-time">@row.LastOut.Value.ToString("h:mm tt").ToLower() <span class="dtl-tz">(GMT+5:30)</span></span> }
                                                else { <span class="dtl-dash">-</span> }
                                            </td>
                                            <td class="dtl-td">
                                                @if (row.HasEntries) { <span class="dtl-hours">@row.RegularHours</span> }
                                                else { <span class="dtl-dash">-</span> }
                                            </td>
                                            @if (showOT)       { <td class="dtl-td">@if (row.HasEntries) { <span class="dtl-hours">@(row.OvertimeHours        ?? "—")</span> } else { <span class="dtl-dash">-</span> }</td> }
                                            @if (showDblOT)    { <td class="dtl-td">@if (row.HasEntries) { <span class="dtl-hours">@(row.DailyDoubleOTHours   ?? "—")</span> } else { <span class="dtl-dash">-</span> }</td> }
                                            @if (showWeeklyOT) { <td class="dtl-td">@if (row.HasEntries) { <span class="dtl-hours dtl-hours--weekly-ot">@(row.WeeklyOvertimeHours  ?? "—")</span> } else { <span class="dtl-dash">-</span> }</td> }
                                            @if (showRdOT)     { <td class="dtl-td">@if (row.HasEntries) { <span class="dtl-hours dtl-hours--rd-ot">@(row.RestDayOvertimeHours  ?? "—")</span> } else { <span class="dtl-dash">-</span> }</td> }
                                            @if (showPhOT)     { <td class="dtl-td">@if (row.HasEntries) { <span class="dtl-hours dtl-hours--ph-ot">@(row.PublicHolOvertimeHours ?? "—")</span> } else { <span class="dtl-dash">-</span> }</td> }
                                            <td class="dtl-td">
                                                @if (row.HasEntries) { <span class="dtl-hours">@row.TrackedHours</span> }
                                                else { <span class="dtl-dash">-</span> }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    }
                    else if (viewMode == "weekly")
                    {
                        @* ── WEEKLY TABLE ── *@
                        var weekDays = Enumerable.Range(0, 7).Select(i => weekRangeFrom.AddDays(i)).ToList();
                        var filteredWeekly = rangeRows.Where(r => string.IsNullOrEmpty(dtlSearchText) || r.FullName.Contains(dtlSearchText, StringComparison.OrdinalIgnoreCase)).ToList();
                        bool hasAnyHoliday = weekDays.Any(wd => !string.IsNullOrEmpty(GetHolidayForDate(wd)));
                        <table class="dtl-table dtl-table--weekly">
                            <thead>
                                @* Day header row *@
                                <tr>
                                    <th class="dtl-th dtl-th--name">
                                        <div class="dtl-week-search">
                                            <i class="bi bi-search dtl-search-icon"></i>
                                            <input class="dtl-search" placeholder="Search…" @bind="dtlSearchText" @bind:event="oninput" />
                                        </div>
                                    </th>
                                    @foreach (var wd in weekDays)
                                    {
                                        bool isToday2 = wd.Date == DateTime.Today;
                                        bool isRestCol = IsRestDay(wd);
                                        <th class="dtl-th dtl-th--day @(isToday2 ? "dtl-th--today-col" : "")">
                                            @if (isRestCol)
                                            {
                                                <div class="dtl-restday-badge">Rest day</div>
                                            }
                                            <div class="dtl-day-hdr">
                                                <span class="dtl-day-letter">@wd.ToString("ddd")[..1]</span>
                                                <span class="@(isToday2 ? "dtl-day-num--today" : "dtl-day-num")">@wd.Day</span>
                                            </div>
                                        </th>
                                    }
                                    <th class="dtl-th dtl-th--total">Total</th>
                                    <th class="dtl-th dtl-th--dup"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!filteredWeekly.Any())
                                {
                                    <tr><td colspan="10" class="dtl-empty-cell">No timesheet records for this week.</td></tr>
                                }
                                @foreach (var row in filteredWeekly)
                                {
                                      
                                            var capRow = row;
                                    
                                        var weekTimeOffs = weekTimeOffsByEmp.TryGetValue(row.EmployeeId, out var wto) ? wto : new Dictionary<string,string>();
                                        var hasAnyLabel = weekDays.Any(wd => !string.IsNullOrEmpty(GetHolidayForDate(wd)) || weekTimeOffs.ContainsKey(wd.ToString("yyyy-MM-dd")));
                                    @if (hasAnyLabel)
                                    {
                                        <tr class="dtl-hol-data-row">
                                            <td class="dtl-td dtl-td--name dtl-td--hol-spacer"></td>
                                            @foreach (var wd in weekDays)
                                            {
                                                var wdKey = wd.ToString("yyyy-MM-dd");
                                                var holName = GetHolidayForDate(wd);
                                                var toLabel = weekTimeOffs.TryGetValue(wdKey, out var tol) ? tol : null;
                                                @* Time-off label takes priority over public holiday *@
                                                string? cellLabel   = toLabel ?? (string.IsNullOrEmpty(holName) ? null : "Public Holiday");
                                                string  pillCssWeek = !string.IsNullOrEmpty(toLabel)  ? "dtl-hol-pill dtl-hol-pill--timeoff"
                                                                    : !string.IsNullOrEmpty(holName)   ? "dtl-hol-pill dtl-hol-pill--holiday"
                                                                    : "dtl-hol-pill";
                                                <td class="dtl-td dtl-td--day dtl-td--hol-cell">
                                                    @if (!string.IsNullOrEmpty(cellLabel))
                                                    {
                                                        <div class="@pillCssWeek" title="@cellLabel">@(cellLabel.Length > 14 ? cellLabel[..13] + "…" : cellLabel)</div>
                                                    }
                                                    @if (string.IsNullOrEmpty(cellLabel) && IsRestDay(wd))
                                                    {
                                                        <div class="dtl-hol-pill dtl-hol-pill--rest" title="Rest day">Rest day</div>
                                                    }
                                                </td>
                                            }
                                            <td class="dtl-td"></td>
                                            <td class="dtl-td dtl-td--dup"></td>
                                        </tr>
                                    }
                                    @* ── Employee data row ── *@
                                    <tr class="dtl-row dtl-week-data-row">
                                        <td class="dtl-td dtl-td--name" @onclick="() => OpenDetailViewFromRange(capRow)">
                                            <div class="dtl-name-cell">
                                                <div class="dtl-av">@(row.FullName[0].ToString().ToUpper())</div>
                                                <span class="dtl-name">@row.FullName</span>
                                            </div>
                                        </td>
                                        @foreach (var wd in weekDays)
                                        {
                                            var key = wd.ToString("yyyy-MM-dd");
                                            var hasDay = row.Days.TryGetValue(key, out var de);
                                            var capWd = wd;
                                            var cellKey = key + "_" + row.EmployeeId;
                                            var capDe2 = de;
                                            var capName2 = row.FullName;
                                            bool isToday3 = wd.Date == DateTime.Today;
                                            bool isRestCol2 = IsRestDay(wd);
                                            <td class="dtl-td dtl-td--day dtl-td--hoverable @(isToday3 ? "dtl-td--today-col" : "") @(isRestCol2 ? "dtl-td--restday-col" : "")"
                                                @onmouseenter="(e) => OnWeekCellHover(cellKey)"
                                                @onmouseleave="OnWeekCellLeave">
                                                @if (hasDay && de != null && de.TrackedMins > 0)
                                                {
                                                    <div class="dtl-week-cell">
                                                        <span class="dtl-day-hours"
                                                              @onmouseenter="(e) => OnHoursHover(cellKey, capName2, capDe2, key, e)"
                                                              @onmouseleave="OnHoursLeave">@de.TrackedHours</span>
                                                        <button class="dtl-cell-add-btn @(hoveredCell == cellKey ? "dtl-cell-add-btn--vis" : "")"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => OpenAddTimeEntryForDate(capWd)"
                                                                @onmouseenter="(e) => OnPlusHover(cellKey, e)"
                                                                @onmouseleave="OnPlusLeave">
                                                            <i class="bi bi-plus-lg"></i>
                                                        </button>
                                                    </div>
                                                }
                                                else if (isRestCol2)
                                                {
                                                    @* Rest day cell — no hours, no add button *@
                                                    <div class="dtl-week-cell dtl-week-cell--restday">
                                                        <span class="dtl-restday-dash">-</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="dtl-week-cell dtl-week-cell--empty">
                                                        @if (hoveredCell == cellKey)
                                                        {
                                                            <button class="dtl-cell-add-btn dtl-cell-add-btn--vis"
                                                                    @onclick:stopPropagation="true"
                                                                    @onclick="() => OpenAddTimeEntryForDate(capWd)"
                                                                    @onmouseenter="(e) => OnPlusHover(cellKey, e)"
                                                                    @onmouseleave="OnPlusLeave">
                                                                <i class="bi bi-plus-lg"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="dtl-dash">-</span>
                                                        }
                                                    </div>
                                                }
                                            </td>
                                        }
                                        <td class="dtl-td dtl-td--total" @onclick="() => OpenDetailViewFromRange(capRow)">
                                            <span class="dtl-total-hours">@(string.IsNullOrEmpty(row.TotalHours) ? "—" : row.TotalHours)</span>
                                        </td>
                                        <td class="dtl-td dtl-td--dup">
                                            <button class="dtl-dup-btn dtl-dup-btn--always"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => OpenDuplicateModal(capRow)"
                                                    title="Duplicate timesheets">
                                                <i class="bi bi-copy"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        @* ── MONTHLY TABLE ── *@
                        var daysInMonth = DateTime.DaysInMonth(monthDate.Year, monthDate.Month);
                        var monthDays = Enumerable.Range(1, daysInMonth).Select(d => new DateTime(monthDate.Year, monthDate.Month, d)).ToList();
                        var filteredMonthly = rangeRows.Where(r => string.IsNullOrEmpty(dtlSearchText) || r.FullName.Contains(dtlSearchText, StringComparison.OrdinalIgnoreCase)).ToList();
                        <div class="dtl-monthly-scroll">
                            <table class="dtl-table dtl-table--monthly">
                                <thead>
                                    <tr>
                                        <th class="dtl-th dtl-th--name dtl-th--sticky">
                                            <div class="dtl-search-wrap">
                                                <i class="bi bi-search dtl-search-icon"></i>
                                                <input class="dtl-search" placeholder="Search…" @bind="dtlSearchText" @bind:event="oninput" />
                                            </div>
                                        </th>
                                        @foreach (var md in monthDays)
                                        {
                                            bool isToday = md.Date == DateTime.Today;
                                            bool isWeekend = md.DayOfWeek == DayOfWeek.Saturday || md.DayOfWeek == DayOfWeek.Sunday;
                                            <th class="dtl-th dtl-th--mday @(isToday ? "dtl-th--today" : "") @(isWeekend ? "dtl-th--weekend" : "")">
                                                <div class="dtl-mday-hdr">
                                                    <span>@md.ToString("ddd")[..1]</span>
                                                    <span>@md.Day</span>
                                                </div>
                                            </th>
                                        }
                                        <th class="dtl-th dtl-th--total dtl-th--sticky-right">Total</th>
                                        <th class="dtl-th dtl-th--dup"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!filteredMonthly.Any())
                                    {
                                        <tr><td colspan="@(daysInMonth + 3)" class="dtl-empty-cell">No timesheet records for this month.</td></tr>
                                    }
                                    @foreach (var row in filteredMonthly)
                                    {
                                        <tr class="dtl-row" @onclick="() => OpenDetailViewFromRange(row)">
                                            <td class="dtl-td dtl-td--name dtl-td--sticky">
                                                <div class="dtl-name-cell">
                                                    <div class="dtl-av">@(row.FullName[0].ToString().ToUpper())</div>
                                                    <span class="dtl-name">@row.FullName</span>
                                                </div>
                                            </td>
                                            @foreach (var md in monthDays)
                                            {
                                                var key = md.ToString("yyyy-MM-dd");
                                                var hasDay = row.Days.TryGetValue(key, out var de);
                                                var mins = hasDay && de != null ? de.TrackedMins : 0;
                                                var cellCss = GetMonthCellCss(mins);
                                                bool isWeekend = md.DayOfWeek == DayOfWeek.Saturday || md.DayOfWeek == DayOfWeek.Sunday;
                                                var capDe = de;
                                                var capKey = key;
                                                var capName = row.FullName;
                                                var monthHoliday = GetHolidayForDate(md);
                                                bool isMonthRestDay = IsRestDay(md);
                                                // Time-off: check the employee-keyed map populated by LoadRangeData()
                                                var empTimeOffsM = weekTimeOffsByEmp.TryGetValue(row.EmployeeId, out var etoM) ? etoM : new Dictionary<string,string>();
                                                var monthTimeOffLabel = empTimeOffsM.TryGetValue(key, out var motlM) ? motlM : null;
                                                bool hasTimeOff = !string.IsNullOrEmpty(monthTimeOffLabel);
                                                bool hasHoliday = !string.IsNullOrEmpty(monthHoliday);
                                                string cellTitle = hasTimeOff ? (monthTimeOffLabel ?? "") : hasHoliday ? monthHoliday : isMonthRestDay ? "Rest day" : "";
                                                <td class="dtl-td dtl-td--mday @(isWeekend ? "dtl-td--weekend" : "") @(hasHoliday ? "dtl-td--holiday" : "") @(hasTimeOff ? "dtl-td--timeoff" : "")"
                                                    title="@cellTitle"
                                                    @onmouseenter="(e) => { if (hasDay && capDe != null && mins > 0) ShowTooltipWithCoords(capName, capDe, capKey, e); }"
                                                    @onmouseleave="HideTooltip">
                                                    <div class="dtl-mcell @cellCss">
                                                        @if (hasTimeOff)
                                                        {
                                                            <i class="bi bi-person-check dtl-cell-icon dtl-cell-icon--timeoff" title="@monthTimeOffLabel"></i>
                                                        }
                                                        else if (hasHoliday)
                                                        {
                                                            <i class="bi bi-calendar2-event dtl-cell-icon dtl-cell-icon--holiday" title="@monthHoliday"></i>
                                                        }
                                                        else if (!hasDay || de == null || mins == 0)
                                                        {
                                                            if (isMonthRestDay) { <i class="bi bi-skip-forward dtl-cell-icon" title="Rest Day"></i> }
                                                            else if (isWeekend) { <i class="bi bi-arrow-repeat dtl-cell-icon" title="Rest Day"></i> }
                                                        }
                                                    </div>
                                                </td>
                                            }
                                            <td class="dtl-td dtl-td--total dtl-td--sticky-right">
                                                <span class="dtl-total-hours">@(string.IsNullOrEmpty(row.TotalHours) ? "—" : row.TotalHours)</span>
                                            </td>
                                            <td class="dtl-td dtl-td--dup">
                                                <button class="dtl-dup-btn dtl-dup-btn--always"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => OpenDuplicateModal(row)"
                                                        title="Duplicate timesheets">
                                                    <i class="bi bi-copy"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                } @* end activeTab == "timesheets" *@

                @* ── HOVER TOOLTIP (First in / Last out / Regular) - shows only when hovering hours text ── *@
                @if (tooltipVisible && tooltipEntry != null)
                {
                    <div class="dtl-tooltip" style="top:@(tooltipY)px;left:@(tooltipX)px;">
                        <div class="dtl-tt-row">
                            <span class="dtl-tt-label">First in</span>
                            <span class="dtl-tt-val">@(tooltipEntry.FirstIn.HasValue ? tooltipEntry.FirstIn.Value.ToString("h:mm tt").ToLower() + " (GMT+5:30)" : tooltipEntry.IsOngoing ? "ongoing" : "—")</span>
                        </div>
                        <div class="dtl-tt-row">
                            <span class="dtl-tt-label">Last out</span>
                            <span class="dtl-tt-val">@(tooltipEntry.LastOut.HasValue ? tooltipEntry.LastOut.Value.ToString("h:mm tt").ToLower() + " (GMT+5:30)" : tooltipEntry.IsOngoing ? "ongoing" : "—")</span>
                        </div>
                        <div class="dtl-tt-row dtl-tt-row--sep">
                            <span class="dtl-tt-label">Regular</span>
                            <span class="dtl-tt-val">@tooltipEntry.TrackedHours</span>
                        </div>
                    </div>
                }
                @* ── "Create a new entry" tooltip — shows only when hovering the + button ── *@
                @if (plusTipVisible && createTipY > 0)
                {
                    <div class="dtl-create-tip-float" style="top:@(createTipY)px;left:@(createTipX)px;">
                        Create a new entry
                    </div>
                }
            </div>
        }
        else if (currentView == "approval-detail" && apvDetailRow != null)
        {
            @* ══ TIMESHEET APPROVAL — EMPLOYEE DETAIL VIEW ══ *@
            <TimesheetApprovalDetail
                Row="@apvDetailRow"
                EmployeeId="@apvDetailRow.EmployeeId"
                PeriodStart="@apvWeekStart"
                PeriodEnd="@apvWeekEnd"
                EmployeeList="@rangeRows"
                OnBack="@(EventCallback.Factory.Create(this, () => BackToApprovals()))" />
        }
        else
        {
            @* ══ TIME ENTRIES DETAIL VIEW ══ *@
            <div class="tev-shell">

                <!-- ══ LEFT SIDEBAR ══ -->
                <div class="tev-sidebar">
                    <div class="tev-sb-header">
                        <div class="tev-sb-label">Weekly Summary</div>
                        <div class="tev-sb-range">@WeekRangeLabel</div>
                    </div>
                    <div class="tev-sb-person">
                        <div class="tev-sb-av">@GetInitial()</div>
                        <div class="tev-sb-info">
                            <div class="tev-sb-name">@(!string.IsNullOrEmpty(selectedEmployeeName) ? selectedEmployeeName : (SessionService.FullName ?? "Me"))</div>
                            <div class="tev-sb-tz">Clocked from GMT+5:30</div>
                        </div>
                    </div>
                    <div class="tev-sb-divider"></div>
                    <div class="tev-sb-meta">
                        <div class="tev-sb-meta-row">
                            <span class="tev-sb-meta-k">Timesheet Timezone</span>
                            <span class="tev-sb-meta-v">Asia/Calcutta (GMT+5:30)</span>
                        </div>
                        <div class="tev-sb-meta-row">
                            <span class="tev-sb-meta-k">Split Time</span>
                            <span class="tev-sb-meta-v">12:00 am</span>
                        </div>
                        <div class="tev-sb-meta-row">
                            <span class="tev-sb-meta-k">Work schedule</span>
                            <span class="tev-sb-meta-v">—</span>
                        </div>
                    </div>
                    <div class="tev-sb-divider"></div>
                    <div class="tev-sb-section">
                        <div class="tev-sb-section-title">Tracked Hours</div>
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Tracked hours</span>
                            <span class="tev-sb-stat-val tev-bold">@dayTrackedDisplay</span>
                        </div>
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Worked hours</span>
                            <span class="tev-sb-stat-val">@dayTrackedDisplay</span>
                        </div>
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Breaks</span>
                            <span class="tev-sb-stat-val tev-dash">—</span>
                        </div>
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Auto deductions</span>
                            <span class="tev-sb-stat-val tev-dash">—</span>
                        </div>
                    </div>
                    <div class="tev-sb-divider"></div>
                    <div class="tev-sb-section">
                        <div class="tev-sb-section-title">Payroll Hours</div>
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Payroll hours</span>
                            <span class="tev-sb-stat-val tev-bold">@dayTrackedDisplay</span>
                        </div>
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Regular hours</span>
                            <span class="tev-sb-stat-val">@dayRegularDisplay</span>
                        </div>
                        @if (dayOvertimeDisplay != null)
                        {
                            <div class="tev-sb-stat-row">
                                <span class="tev-sb-stat-lbl">Overtime hours</span>
                                <span class="tev-sb-stat-val tev-bold" style="color:var(--primary)">@dayOvertimeDisplay</span>
                            </div>
                        }
                        @if (dayDoubleOTDisplay != null)
                        {
                            <div class="tev-sb-stat-row">
                                <span class="tev-sb-stat-lbl">Double OT hours</span>
                                <span class="tev-sb-stat-val tev-bold" style="color:var(--primary)">@dayDoubleOTDisplay</span>
                            </div>
                        }
                        @if (dayWeeklyOTDisplay != null)
                        {
                            <div class="tev-sb-stat-row">
                                <span class="tev-sb-stat-lbl">Weekly OT</span>
                                <span class="tev-sb-stat-val tev-bold" style="color:#f97316">@dayWeeklyOTDisplay</span>
                            </div>
                        }
                        @if (dayRestDayOTDisplay != null)
                        {
                            <div class="tev-sb-stat-row">
                                <span class="tev-sb-stat-lbl">Rest Day OT</span>
                                <span class="tev-sb-stat-val tev-bold" style="color:#8b5cf6">@dayRestDayOTDisplay</span>
                            </div>
                        }
                        @if (dayPublicHolOTDisplay != null)
                        {
                            <div class="tev-sb-stat-row">
                                <span class="tev-sb-stat-lbl">Public Holiday OT</span>
                                <span class="tev-sb-stat-val tev-bold" style="color:#ef4444">@dayPublicHolOTDisplay</span>
                            </div>
                        }
                        <div class="tev-sb-stat-row">
                            <span class="tev-sb-stat-lbl">Time Off</span>
                            <span class="tev-sb-stat-val tev-dash">—</span>
                        </div>
                    </div>
                </div>

                <!-- ══ RIGHT MAIN PANEL ══ -->
                <div class="tev-main">

                    <div class="tev-topbar">
                        <div class="tev-topbar-left">
                            <div class="tev-topbar-titles">
                                <div class="tev-topbar-title">Time Entries</div>
                                <div class="tev-topbar-sub">Detailed list of clocked work hours and breaks</div>
                            </div>
                        </div>
                        <div class="tev-topbar-back-row">
                            <button class="tev-back-btn" @onclick="BackToList">
                                <i class="bi bi-arrow-left"></i> Back
                            </button>
                        </div>
                        <button class="tev-add-btn" @onclick="OpenAddTimeEntry">
                            <i class="bi bi-plus-lg"></i> Add Time Entry
                        </button>
                    </div>

                    <div class="tev-week-nav">
                        <button class="tev-nav-btn" @onclick="PrevWeek">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <div class="tev-days-strip">
                            @foreach (var day in WeekDays)
                            {
                                bool isTdy = day.Date == DateTime.Today;
                                bool isSel = day.Date == selectedDate.Date;
                                var dur = DayDuration(day);
                                bool has = dur > TimeSpan.Zero;
                                <button class="tev-day @(isSel ? "tev-day--sel" : "") @(isTdy ? "tev-day--today" : "")"
                                        @onclick="() => SelectDay(day)">
                                    <span class="tev-day-name">@day.ToString("ddd")</span>
                                    <span class="tev-day-num">@day.Day</span>
                                    <span class="tev-day-dur @(has ? "tev-day-dur--has" : "")">@FmtSpan(dur)</span>
                                    @if (has)
                                    {
                                        <span class="tev-day-dot"></span>
                                    }
                                </button>
                            }
                        </div>
                        <button class="tev-nav-btn" @onclick="NextWeek">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>

                    <div class="tev-date-bar">
                        <span class="tev-date-text">@selectedDate.ToString("dddd, dd MMMM yyyy")</span>
                        @if (dayEntries.Any())
                        {
                            <span class="tev-entry-count">@dayEntries.Count @(dayEntries.Count == 1 ? "entry" : "entries")</span>
                        }
                        <div class="tev-date-tracked">
                            <i class="bi bi-clock"></i>
                            <span>@dayTrackedDisplay</span>
                        </div>
                    </div>

                    <div class="tev-entries">
                        @if (entriesLoading)
                        {
                            <div class="tev-loading">
                                <div class="tev-spinner"></div>
                                <span>Loading entries…</span>
                            </div>
                        }
                        else if (!dayEntries.Any())
                        {
                            <div class="tev-empty">
                                <div class="tev-empty-icon">
                                    <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                                        <circle cx="32" cy="32" r="32" fill="#fff7ed" />
                                        <rect x="16" y="20" width="32" height="28" rx="5" fill="#fff" stroke="#fed7aa" stroke-width="1.5" />
                                        <rect x="16" y="20" width="32" height="9" rx="5" fill="#fed7aa" />
                                        <rect x="16" y="26" width="32" height="3" fill="#fed7aa" />
                                        <rect x="23" y="16" width="3" height="8" rx="1.5" fill="#f97316" />
                                        <rect x="38" y="16" width="3" height="8" rx="1.5" fill="#f97316" />
                                        <circle cx="32" cy="38" r="8" fill="#ff7a00" />
                                        <line x1="32" y1="34" x2="32" y2="38" stroke="white" stroke-width="1.5" stroke-linecap="round" />
                                        <line x1="32" y1="38" x2="35" y2="40" stroke="white" stroke-width="1.5" stroke-linecap="round" />
                                    </svg>
                                </div>
                                <div class="tev-empty-title">No entries for this day</div>
                                <div class="tev-empty-sub">@selectedDate.ToString("dddd, dd MMMM yyyy")</div>
                                <button class="tev-add-btn tev-empty-cta" @onclick="OpenAddTimeEntry">
                                    <i class="bi bi-plus-lg"></i> Add Time Entry
                                </button>
                            </div>
                        }
                        else
                        {
                            @foreach (var e in dayEntries)
                            {
                                bool open = e.ClockOut == null;
                                bool isInSel = viewEntry?.Id == e.Id && panelType == "in" && panelMode != "none";
                                bool isOutSel = viewEntry?.Id == e.Id && panelType == "out" && panelMode != "none";
                                var capturedEntry = e;

                                @if (e.IsHourEntry)
                                {
                                    @* ── Added Hours row (hour entry) ── *@
                                    <div class="tev-entry-row tev-entry-row--hour @(isInSel ? "tev-entry-row--sel" : "")"
                                         @onclick='() => OpenView(capturedEntry, "in")'>
                                        <div class="tev-er-av-cell">
                                            <div class="tev-av tev-av--hour"><i class="bi bi-plus-lg"></i></div>
                                        </div>
                                        <div class="tev-er-time-cell">
                                            <span class="tev-time tev-time--hour">Added</span>
                                        </div>
                                        <div class="tev-er-badge-cell">
                                            <span class="tev-badge tev-badge--hour"><i class="bi bi-clock-history"></i> Added hours</span>
                                            <span class="tev-badge tev-badge--manual">M</span>
                                        </div>
                                        <div class="tev-er-dur-cell">
                                            @if (!string.IsNullOrWhiteSpace(e.WorkedHours))
                                            {
                                                <span class="tev-dur">@e.WorkedHours</span>
                                            }
                                        </div>
                                        <div class="tev-er-acts-cell">
                                            <button class="tev-er-act-btn"
                                                    @onclick:stopPropagation="true"
                                                    @onclick='() => OpenView(capturedEntry, "in")'
                                                    title="View entry">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="tev-er-act-btn tev-er-act-btn--del"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => ConfirmDelete(capturedEntry)"
                                                    title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="tev-entry-sep"></div>
                                }
                                @if (e.IsBreakEntry)
                                {
                                    @* ── Break row with coffee icon ── *@
                                    <div class="tev-entry-row tev-entry-row--break @(isInSel ? "tev-entry-row--sel" : "")"
                                         @onclick='() => OpenView(capturedEntry, "in")'>
                                        <div class="tev-er-av-cell">
                                            <div class="tev-av tev-av--break"><i class="bi bi-cup-hot"></i></div>
                                        </div>
                                        <div class="tev-er-time-cell">
                                            <span class="tev-time">@e.ClockIn.ToString("h:mm")<span class="tev-ampm">@e.ClockIn.ToString("tt").ToLower()</span></span>
                                        </div>
                                        <div class="tev-er-badge-cell">
                                            <span class="tev-badge tev-badge--break"><i class="bi bi-cup-hot"></i> Break</span>
                                            @if (e.IsManual) { <span class="tev-badge tev-badge--manual">Manual</span> }
                                        </div>
                                        <div class="tev-er-dur-cell">
                                            @if (!string.IsNullOrWhiteSpace(e.WorkedHours))
                                            { <span class="tev-dur">@e.WorkedHours</span> }
                                            else { <span class="tev-dur-empty">—</span> }
                                        </div>
                                        <div class="tev-er-acts-cell">
                                            <button class="tev-er-act-btn" @onclick:stopPropagation="true"
                                                    @onclick='() => OpenView(capturedEntry, "in")' title="View">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="tev-er-act-btn tev-er-act-btn--del" @onclick:stopPropagation="true"
                                                    @onclick="() => ConfirmDelete(capturedEntry)" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="tev-entry-sep"></div>
                                }
                                @if (e.IsOvernightCarryOver)
                                {
                                    @* ── Overnight carry-over: session started previous day, clocked out today ── *@
                                    <div class="tev-entry-row tev-entry-row--out tev-entry-row--overnight"
                                         @onclick='() => OpenView(capturedEntry, "out")'>
                                        <div class="tev-er-av-cell">
                                            @if (!string.IsNullOrEmpty(e.ClockOutSelfieUrl))
                                            {
                                                <img src="@GetSelfieUrl(e.ClockOutSelfieUrl)" class="tev-av tev-av--selfie" alt="Clock-out selfie" />
                                            }
                                            else
                                            {
                                                <div class="tev-av tev-av--overnight"><i class="bi bi-moon-stars-fill"></i></div>
                                            }
                                        </div>
                                        <div class="tev-er-time-cell">
                                            <span class="tev-time">@e.ClockOut!.Value.ToString("h:mm")<span class="tev-ampm">@e.ClockOut!.Value.ToString("tt").ToLower()</span></span>
                                        </div>
                                        <div class="tev-er-badge-cell">
                                            <span class="tev-badge tev-badge--out"><i class="bi bi-box-arrow-right"></i> Clock out</span>
                                        </div>
                                        <div class="tev-er-dur-cell">
                                            @if (!string.IsNullOrWhiteSpace(e.WorkedHours))
                                            { <span class="tev-dur">@e.WorkedHours</span> }
                                            else
                                            { <span class="tev-dur-empty">—</span> }
                                        </div>
                                        <div class="tev-er-acts-cell">
                                            <button class="tev-er-act-btn"
                                                    @onclick:stopPropagation="true"
                                                    @onclick='() => OpenView(capturedEntry, "out")'
                                                    title="View entry">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="tev-entry-sep"></div>
                                }
                                @if (!e.IsOvernightCarryOver && !e.IsHourEntry && !e.IsBreakEntry)
                                {
                                    @* ── Clock In row: click → VIEW panel ── *@
                                    <div class="tev-entry-row @(isInSel ? "tev-entry-row--sel" : "")"
                                         @onclick='() => OpenView(capturedEntry, "in")'>
                                        <div class="tev-er-av-cell">
                                            @if (!string.IsNullOrEmpty(e.ClockInSelfieUrl))
                                            {
                                                <img src="@GetSelfieUrl(e.ClockInSelfieUrl)" class="tev-av tev-av--selfie" alt="Clock-in selfie" />
                                            }
                                            else
                                            {
                                                <div class="tev-av @(open ? "tev-av--live" : "")">@GetInitial()</div>
                                            }
                                        </div>
                                        <div class="tev-er-time-cell">
                                            <span class="tev-time">@e.ClockIn.ToString("h:mm")<span class="tev-ampm">@e.ClockIn.ToString("tt").ToLower()</span></span>
                                        </div>
                                        <div class="tev-er-badge-cell">
                                            <span class="tev-badge tev-badge--in"><i class="bi bi-box-arrow-in-right"></i> Clock in</span>
                                            @if (e.IsManual) { <span class="tev-badge tev-badge--manual">Manual</span> }
                                        </div>
                                        <div class="tev-er-dur-cell">
                                            @if (!string.IsNullOrWhiteSpace(e.WorkedHours))
                                            {
                                                @* WorkedHours is set: show it (covers both closed entries
                                                   AND past-day overnight sessions where ClockOut is null
                                                   because the API caps them at midnight) *@
                                                <span class="tev-dur">@e.WorkedHours</span>
                                            }
                                            else if (open && selectedDate.Date == DateTime.Today)
                                            {
                                                @* Truly live session on today — no WorkedHours yet *@
                                                <span class="tev-dur-live">Live</span>
                                            }
                                            else
                                            {
                                                <span class="tev-dur-empty">—</span>
                                            }
                                        </div>
                                        <div class="tev-er-acts-cell">
                                            <button class="tev-er-act-btn"
                                                    @onclick:stopPropagation="true"
                                                    @onclick='() => OpenView(capturedEntry, "in")'
                                                    title="View entry">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="tev-er-act-btn tev-er-act-btn--del"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => ConfirmDelete(capturedEntry)"
                                                    title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>

                                    @* ── Clock Out row: click → VIEW panel ── *@
                                    @if (!open)
                                    {
                                        <div class="tev-entry-row tev-entry-row--out @(isOutSel ? "tev-entry-row--sel" : "")"
                                             @onclick='() => OpenView(capturedEntry, "out")'>
                                            <div class="tev-er-av-cell">
                                                @if (!string.IsNullOrEmpty(e.ClockOutSelfieUrl))
                                                {
                                                    <img src="@GetSelfieUrl(e.ClockOutSelfieUrl)" class="tev-av tev-av--selfie" alt="Clock-out selfie" />
                                                }
                                                else
                                                {
                                                    <div class="tev-av">@GetInitial()</div>
                                                }
                                            </div>
                                            <div class="tev-er-time-cell">
                                                <span class="tev-time">@e.ClockOut!.Value.ToString("h:mm")<span class="tev-ampm">@e.ClockOut!.Value.ToString("tt").ToLower()</span></span>
                                            </div>
                                            <div class="tev-er-badge-cell">
                                                <span class="tev-badge tev-badge--out"><i class="bi bi-box-arrow-right"></i> Clock out</span>
                                                @if (e.IsManual) { <span class="tev-badge tev-badge--manual">Manual</span> }
                                            </div>
                                            <div class="tev-er-dur-cell">
                                                <span class="tev-dur-empty">—</span>
                                            </div>
                                            <div class="tev-er-acts-cell">
                                                <button class="tev-er-act-btn"
                                                        @onclick:stopPropagation="true"
                                                        @onclick='() => OpenView(capturedEntry, "out")'
                                                        title="View entry">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                <button class="tev-er-act-btn tev-er-act-btn--del"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ConfirmDelete(capturedEntry)"
                                                        title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="tev-entry-sep"></div>
                                    }
                                    else
                                    {
                                        <div class="tev-entry-sep"></div>
                                    }
                                }
                            }
                        }

                        <!-- Bottom accordion panels -->
                        <div class="tev-bottom-panels">

                            <!-- TRACKED HOURS -->
                            <div class="tev-accordion @(trackedExpanded ? "tev-accordion--open" : "")">
                                <button class="tev-accordion-hdr" @onclick="() => trackedExpanded = !trackedExpanded">
                                    <div class="tev-accordion-hdr-left">
                                        <span class="tev-accordion-title">TRACKED HOURS</span>
                                        <span class="tev-accordion-sub">Include worked hours, break hours and any auto deductions.</span>
                                    </div>
                                    <div class="tev-accordion-hdr-right">
                                        <span class="tev-accordion-val">@dayTrackedDisplay</span>
                                        <i class="bi bi-chevron-@(trackedExpanded ? "up" : "down") tev-accordion-chevron"></i>
                                    </div>
                                </button>
                                @if (trackedExpanded)
                                {
                                    <div class="tev-accordion-body">
                                        <div class="tev-acc-row"><span class="tev-acc-lbl">Worked Hours</span><span class="tev-acc-val tev-acc-highlight">@dayTrackedDisplay</span></div>
                                        <div class="tev-acc-row"><span class="tev-acc-lbl">Break Hours</span><span class="tev-acc-val tev-acc-dash">—</span></div>
                                        <div class="tev-acc-row"><span class="tev-acc-lbl">Auto Deductions</span><span class="tev-acc-val tev-acc-dash">—</span></div>
                                        <div class="tev-acc-row tev-acc-row--total"><span class="tev-acc-lbl tev-acc-lbl--total">Total Tracked</span><span class="tev-acc-val tev-acc-val--total">@dayTrackedDisplay</span></div>
                                    </div>
                                }
                            </div>

                            <!-- PAYROLL HOURS -->
                            <div class="tev-accordion @(payrollExpanded ? "tev-accordion--open" : "")">
                                <button class="tev-accordion-hdr" @onclick="() => payrollExpanded = !payrollExpanded">
                                    <div class="tev-accordion-hdr-left">
                                        <span class="tev-accordion-title">PAYROLL HOURS</span>
                                        <span class="tev-accordion-sub">Include regular hours, paid breaks, overtime hours and paid time off.</span>
                                    </div>
                                    <div class="tev-accordion-hdr-right">
                                        <span class="tev-accordion-val">@dayTrackedDisplay</span>
                                        <i class="bi bi-chevron-@(payrollExpanded ? "up" : "down") tev-accordion-chevron"></i>
                                    </div>
                                </button>
                                @if (payrollExpanded)
                                {
                                    <div class="tev-accordion-body">
                                        <div class="tev-acc-row"><span class="tev-acc-lbl">Regular Hours</span><span class="tev-acc-val tev-acc-highlight">@dayRegularDisplay</span></div>
                                        <div class="tev-acc-row"><span class="tev-acc-lbl">Paid Breaks</span><span class="tev-acc-val tev-acc-dash">—</span></div>
                                        @if (dayOvertimeDisplay != null)
                                        {
                                            <div class="tev-acc-row"><span class="tev-acc-lbl">Daily OT Hours</span><span class="tev-acc-val tev-acc-highlight">@dayOvertimeDisplay</span></div>
                                        }
                                        else
                                        {
                                            <div class="tev-acc-row"><span class="tev-acc-lbl">Overtime Hours</span><span class="tev-acc-val tev-acc-dash">—</span></div>
                                        }
                                        @if (dayDoubleOTDisplay != null)
                                        {
                                            <div class="tev-acc-row"><span class="tev-acc-lbl">Double OT Hours</span><span class="tev-acc-val tev-acc-highlight">@dayDoubleOTDisplay</span></div>
                                        }
                                        @if (dayWeeklyOTDisplay != null)
                                        {
                                            <div class="tev-acc-row">
                                                <span class="tev-acc-lbl">Weekly OT</span>
                                                <span class="tev-acc-val tev-acc-highlight" style="color:#f97316">@dayWeeklyOTDisplay</span>
                                            </div>
                                        }
                                        @if (dayRestDayOTDisplay != null)
                                        {
                                            <div class="tev-acc-row">
                                                <span class="tev-acc-lbl">Rest Day OT</span>
                                                <span class="tev-acc-val tev-acc-highlight" style="color:#8b5cf6">@dayRestDayOTDisplay</span>
                                            </div>
                                        }
                                        @if (dayPublicHolOTDisplay != null)
                                        {
                                            <div class="tev-acc-row">
                                                <span class="tev-acc-lbl">Public Holiday OT</span>
                                                <span class="tev-acc-val tev-acc-highlight" style="color:#ef4444">@dayPublicHolOTDisplay</span>
                                            </div>
                                        }
                                        <div class="tev-acc-row"><span class="tev-acc-lbl">Paid Time Off</span><span class="tev-acc-val tev-acc-dash">—</span></div>
                                        <div class="tev-acc-row tev-acc-row--total"><span class="tev-acc-lbl tev-acc-lbl--total">Total Payroll</span><span class="tev-acc-val tev-acc-val--total">@dayTrackedDisplay</span></div>
                                    </div>
                                }
                            </div>

                            <!-- CHANGE HISTORY -->
                            <div class="tev-accordion @(historyExpanded ? "tev-accordion--open" : "")">
                                <button class="tev-accordion-hdr" @onclick="() => historyExpanded = !historyExpanded">
                                    <div class="tev-accordion-hdr-left">
                                        <span class="tev-accordion-title">CHANGE HISTORY</span>
                                        <span class="tev-accordion-sub">View a history log of time entries that are manually added or changed.</span>
                                    </div>
                                    <div class="tev-accordion-hdr-right">
                                        @if (HistoryRowCount > 0)
                                        {
                                            <span class="tev-history-badge">@HistoryRowCount</span>
                                        }
                                        <i class="bi bi-chevron-@(historyExpanded ? "up" : "down") tev-accordion-chevron"></i>
                                    </div>
                                </button>
                                @if (historyExpanded)
                                {
                                    <div class="tev-accordion-body tev-history-body">
                                        @if (!string.IsNullOrEmpty(changeHistoryError))
                                        {
                                            <div class="tev-history-empty" style="color:#dc2626; padding:16px 20px;">
                                                <i class="bi bi-exclamation-circle"></i>
                                                <span>Error loading history: @changeHistoryError</span>
                                            </div>
                                        }
                                        else if (!changeHistory.Any())
                                        {
                                            <div class="tev-history-empty">
                                                <i class="bi bi-clock-history"></i>
                                                <span>No manual changes recorded for this day.</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="tev-hist-hdr">
                                                <span class="tev-hist-hdr-cell">Change made</span>
                                                <span class="tev-hist-hdr-cell">Reason for change</span>
                                                <span class="tev-hist-hdr-cell">Timestamp</span>
                                            </div>

                                            @* Each log entry produces rows matching Jibble screenshot exactly. *@
                                            @foreach (var h in changeHistory)
                                            {
                                                var av = string.IsNullOrEmpty(h.ChangedByName) ? "?" : h.ChangedByName[0].ToString().ToUpper();

                                                @* ── Break entry row ── *@
                                                @if (h.IsBreakEntry)
                                                {
                                                    <div class="tev-hist-row">
                                                        <div class="tev-hist-cell tev-hist-cell--change">
                                                            <div class="tev-hist-av">@av</div>
                                                            <div class="tev-hist-who-info">
                                                                <div class="tev-hist-name-row">
                                                                    <span class="tev-hist-who-name">@h.ChangedByName</span>
                                                                    <span class="tev-hist-who-action">added a time entry</span>
                                                                </div>
                                                                <div class="tev-hist-time-row">
                                                                    <i class="bi bi-cup-hot tev-hist-entry-icon" style="color:#f97316"></i>
                                                                    @if (h.OldClockIn.HasValue)
                                                                    { <span class="tev-hist-newtime">@h.OldClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span> }
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="tev-hist-cell tev-hist-cell--reason">
                                                            @if (!string.IsNullOrWhiteSpace(h.ReasonForChange))
                                                            { <span class="tev-hist-reason-text">@h.ReasonForChange</span> }
                                                            else { <span class="tev-hist-reason-empty">—</span> }
                                                        </div>
                                                        <div class="tev-hist-cell tev-hist-cell--ts">
                                                            <span class="tev-hist-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                        </div>
                                                    </div>
                                                }

                                                @* ── Hour entry row ── *@
                                                @* Note: IsBreakEntry rows are fully handled above — the else below must also exclude them *@
                                                @if (!h.IsBreakEntry && h.IsHourEntry)
                                                {
                                                    <div class="tev-hist-row">
                                                        <div class="tev-hist-cell tev-hist-cell--change">
                                                            <div class="tev-hist-av">@av</div>
                                                            <div class="tev-hist-who-info">
                                                                <div class="tev-hist-name-row">
                                                                    <span class="tev-hist-who-name">@h.ChangedByName</span>
                                                                    <span class="tev-hist-who-action">added an hour entry</span>
                                                                </div>
                                                                @if (!string.IsNullOrWhiteSpace(h.WorkedHours))
                                                                {
                                                                    <div class="tev-hist-time-row">
                                                                        <span class="tev-hour-icon"><i class="bi bi-clock-history"></i></span>
                                                                        <span class="tev-hist-newtime">@h.WorkedHours</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="tev-hist-cell tev-hist-cell--reason">
                                                            <span class="tev-hist-reason-empty">—</span>
                                                        </div>
                                                        <div class="tev-hist-cell tev-hist-cell--ts">
                                                            <span class="tev-hist-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                        </div>
                                                    </div>
                                                }
                                                else if (!h.IsBreakEntry)
                                                {
                                                    @* ── Added / Edited entry ── *@
                                                    @* Break entries are already rendered above; exclude them here to prevent double-rendering *@
                                                    @if (h.Action == "Added" && (h.OldClockIn != null || h.OldClockOut != null))
                                                    {
                                                        <div class="tev-hist-row">
                                                            <div class="tev-hist-cell tev-hist-cell--change">
                                                                <div class="tev-hist-av">@av</div>
                                                                <div class="tev-hist-who-info">
                                                                    <div class="tev-hist-name-row">
                                                                        <span class="tev-hist-who-name">@h.ChangedByName</span>
                                                                        <span class="tev-hist-who-action">added a time entry</span>
                                                                    </div>
                                                                    @if (h.OldClockOut != null)
                                                                    {
                                                                        @* Clock-out addition: show only clock-out time *@
                                                                        <div class="tev-hist-time-row">
                                                                            <i class="bi bi-box-arrow-left tev-hist-entry-icon tev-hist-entry-icon--out"></i>
                                                                            <span class="tev-hist-newtime">@h.OldClockOut.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                        </div>
                                                                    }
                                                                    else if (h.OldClockIn != null)
                                                                    {
                                                                        @* Clock-in addition: show only clock-in time *@
                                                                        <div class="tev-hist-time-row">
                                                                            <i class="bi bi-box-arrow-in-right tev-hist-entry-icon tev-hist-entry-icon--in"></i>
                                                                            <span class="tev-hist-newtime">@h.OldClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="tev-hist-cell tev-hist-cell--reason">
                                                                @if (!string.IsNullOrWhiteSpace(h.ReasonForChange))
                                                                { <span class="tev-hist-reason-text">@h.ReasonForChange</span> }
                                                                else
                                                                { <span class="tev-hist-reason-empty">—</span> }
                                                            </div>
                                                            <div class="tev-hist-cell tev-hist-cell--ts">
                                                                <span class="tev-hist-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                            </div>
                                                        </div>
                                                    }

                                                    @* ── Admin Override row ── *@
                                                    @if (h.Action == "AdminOverride")
                                                    {
                                                        <div class="tev-hist-row">
                                                            <div class="tev-hist-cell tev-hist-cell--change">
                                                                <div class="tev-hist-av" style="background:#dc2626">@av</div>
                                                                <div class="tev-hist-who-info">
                                                                    <div class="tev-hist-name-row">
                                                                        <span class="tev-hist-who-name">@h.ChangedByName</span>
                                                                        <span class="tev-hist-who-action" style="color:#dc2626;font-weight:600">admin override — back-dated session</span>
                                                                    </div>
                                                                    @if (h.OldClockIn.HasValue)
                                                                    {
                                                                        <div class="tev-hist-time-row">
                                                                            <i class="bi bi-box-arrow-in-right tev-hist-entry-icon tev-hist-entry-icon--in tev-arrow-faded"></i>
                                                                            <span class="tev-hist-oldtime">was @h.OldClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                        </div>
                                                                    }
                                                                    @if (h.NewClockIn.HasValue)
                                                                    {
                                                                        <div class="tev-hist-time-row">
                                                                            <i class="bi bi-box-arrow-in-right tev-hist-entry-icon tev-hist-entry-icon--in"></i>
                                                                            <span class="tev-hist-newtime">→ @h.NewClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="tev-hist-cell tev-hist-cell--reason">
                                                                @if (!string.IsNullOrWhiteSpace(h.ReasonForChange))
                                                                { <span class="tev-hist-reason-text">@h.ReasonForChange</span> }
                                                                else { <span class="tev-hist-reason-empty">—</span> }
                                                            </div>
                                                            <div class="tev-hist-cell tev-hist-cell--ts">
                                                                <span class="tev-hist-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                            </div>
                                                        </div>
                                                    }

                                                    @* ── Edited entry: separate row per changed field ── *@
                                                    @if (h.Action != "Added" && h.Action != "AdminOverride")
                                                    {
                                                        var actLabel = h.Action == "Edited" ? "edited a time entry" : "deleted a time entry";
                                                        var ciChanged = MinutesDiffer(h.NewClockIn,  h.OldClockIn);
                                                        var coChanged = MinutesDiffer(h.NewClockOut, h.OldClockOut);

                                                        @* Clock-In changed row *@
                                                        @if (ciChanged)
                                                        {
                                                            <div class="tev-hist-row">
                                                                <div class="tev-hist-cell tev-hist-cell--change">
                                                                    <div class="tev-hist-av">@av</div>
                                                                    <div class="tev-hist-who-info">
                                                                        <div class="tev-hist-name-row">
                                                                            <span class="tev-hist-who-name">@h.ChangedByName</span>
                                                                            <span class="tev-hist-who-action">@actLabel</span>
                                                                        </div>
                                                                        @if (h.NewClockIn != null)
                                                                        {
                                                                            <div class="tev-hist-time-row">
                                                                                <i class="bi bi-box-arrow-in-right tev-hist-entry-icon tev-hist-entry-icon--in"></i>
                                                                                <span class="tev-hist-newtime">@h.NewClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                            </div>
                                                                        }
                                                                        @if (h.OldClockIn != null)
                                                                        {
                                                                            <div class="tev-hist-time-row">
                                                                                <i class="bi bi-box-arrow-in-right tev-hist-entry-icon tev-hist-entry-icon--in tev-arrow-faded"></i>
                                                                                <span class="tev-hist-oldtime">@h.OldClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                                <div class="tev-hist-cell tev-hist-cell--reason">
                                                                    @if (!string.IsNullOrWhiteSpace(h.ReasonForChange))
                                                                    { <span class="tev-hist-reason-text">@h.ReasonForChange</span> }
                                                                    else
                                                                    { <span class="tev-hist-reason-empty">—</span> }
                                                                </div>
                                                                <div class="tev-hist-cell tev-hist-cell--ts">
                                                                    <span class="tev-hist-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                                </div>
                                                            </div>
                                                        }

                                                        @* Clock-Out changed row *@
                                                        @if (coChanged)
                                                        {
                                                            <div class="tev-hist-row">
                                                                <div class="tev-hist-cell tev-hist-cell--change">
                                                                    <div class="tev-hist-av">@av</div>
                                                                    <div class="tev-hist-who-info">
                                                                        <div class="tev-hist-name-row">
                                                                            <span class="tev-hist-who-name">@h.ChangedByName</span>
                                                                            <span class="tev-hist-who-action">@actLabel</span>
                                                                        </div>
                                                                        @if (h.NewClockOut != null)
                                                                        {
                                                                            <div class="tev-hist-time-row">
                                                                                <i class="bi bi-box-arrow-left tev-hist-entry-icon tev-hist-entry-icon--out"></i>
                                                                                <span class="tev-hist-newtime">@h.NewClockOut.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                            </div>
                                                                        }
                                                                        @if (h.OldClockOut != null)
                                                                        {
                                                                            <div class="tev-hist-time-row">
                                                                                <i class="bi bi-box-arrow-left tev-hist-entry-icon tev-hist-entry-icon--out tev-arrow-faded"></i>
                                                                                <span class="tev-hist-oldtime">@h.OldClockOut.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                                <div class="tev-hist-cell tev-hist-cell--reason">
                                                                    @if (!string.IsNullOrWhiteSpace(h.ReasonForChange))
                                                                    { <span class="tev-hist-reason-text">@h.ReasonForChange</span> }
                                                                    else
                                                                    { <span class="tev-hist-reason-empty">—</span> }
                                                                </div>
                                                                <div class="tev-hist-cell tev-hist-cell--ts">
                                                                    <span class="tev-hist-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    </div>
                                }
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        }

    </div>

    @* ══ ADD TIME ENTRY PANEL ══ *@
    @if (showAddTimeEntry)
    {
        <div class="amt-backdrop" @onclick="CloseAddTimeEntry">
            <div class="amt-panel" @onclick:stopPropagation="true">

                @* ── Panel Header ── *@
                <div class="amt-header">
                    <span class="amt-title">Add Manual Time Entry</span>
                    <button class="amt-close" @onclick="CloseAddTimeEntry"><i class="bi bi-x-lg"></i></button>
                </div>

                @* ── Scrollable Body ── *@
                <div class="amt-body">

                    @* Profile section *@
                    <div class="amt-profile">
                        <div class="amt-av">@GetInitial()</div>
                        <div class="amt-info">
                            @{
                                // Show the selected employee's name when adding entry for someone else (detail view)
                                var amtDisplayName = (currentView == "detail" && !string.IsNullOrEmpty(selectedEmployeeName))
                                    ? selectedEmployeeName.ToUpper()
                                    : (SessionService.FullName?.ToUpper() ?? "");
                            }
                            <div class="amt-name">@amtDisplayName</div>
                            <div class="amt-sub">Clocking from GMT+5:30</div>
                            <div class="amt-sub">Split time: 12:00 am</div>
                            @{
                                var _lo = dayEntries.Where(e => e.ClockOut.HasValue).OrderByDescending(e => e.ClockOut).FirstOrDefault();
                                var _loAgo = _lo != null ? GetTimeAgo(_lo.ClockOut!.Value.ToLocalTime()) : null;
                            }
                            @if (_loAgo != null) { <div class="amt-sub">Last out @_loAgo</div> }
                        </div>
                    </div>
                    <div class="amt-divider"></div>

                    @* Tabs *@
                    <div class="amt-tabs">
                        <button class="amt-tab @(addEntryTab=="time"?"amt-tab--active":"")"
                                @onclick="()=>SwitchToTimeTab()">
                            Time entry <i class="bi bi-info-circle amt-tab-icon"></i>
                        </button>
                        <button class="amt-tab @(addEntryTab=="hour"?"amt-tab--active":"")"
                                @onclick="()=>SwitchToHourTab()">
                            Hour entry <i class="bi bi-info-circle amt-tab-icon"></i>
                        </button>
                    </div>

                    @* ── Entry blocks ── *@
                    @for (int bi = 0; bi < addEntryBlocks.Count; bi++)
                    {
                        var bIdx    = bi;
                        var blk     = addEntryBlocks[bIdx];
                        bool bFirst = bIdx == 0;
                        bool bCol   = collapsedBlocks.Contains(bIdx);

                        @* ─ Block header: always shown in hour tab for all blocks; in time tab only for non-first ─ *@
                        @if (!bFirst || (addEntryTab == "hour" && addEntryBlocks.Count > 1))
                        {
                            <div class="amt-blk-hdr">
                                @if (addEntryTab == "time")
                                {
                                    <span class="amt-blk-hdr-icon">
                                        @if (blk.EntryType == "in")      { <i class="bi bi-box-arrow-in-right" style="color:#16a34a"></i> }
                                        else if (blk.EntryType == "out") { <i class="bi bi-box-arrow-left"     style="color:#d97706"></i> }
                                        else                             { <i class="bi bi-cup-hot"             style="color:#9ca3af"></i> }
                                    </span>
                                }
                                <span class="amt-blk-hdr-label">
                                    @(addEntryTab == "hour"
                                        ? $"{blk.HourH}h {blk.HourM}m, {addEntryDate.ToString("d MMM")}"
                                        : $"{(blk.TimeValue.HasValue ? FmtTime(blk.TimeValue) : "—:— —")}, {addEntryDate.ToString("d MMM")}")
                                </span>
                                <div class="amt-blk-hdr-acts">
                                    <button type="button" class="amt-blk-icon-btn" title="Delete"
                                            @onclick="()=>RemoveBlock(bIdx)" @onclick:stopPropagation="true">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                    <button type="button" class="amt-blk-icon-btn" title="Duplicate"
                                            @onclick="()=>DuplicateBlock(bIdx)" @onclick:stopPropagation="true">
                                        <i class="bi bi-files"></i>
                                    </button>
                                    <button type="button" class="amt-blk-icon-btn" title="@(bCol?"Expand":"Collapse")"
                                            @onclick="()=>ToggleCollapseBlock(bIdx)" @onclick:stopPropagation="true">
                                        <i class="bi bi-chevron-@(bCol?"down":"up")"></i>
                                    </button>
                                </div>
                            </div>
                        }

                        @* ─ Block body — hidden when collapsed ─ *@
                        @if (!bCol)
                        {
                            @if (addEntryTab == "time")
                            {
                                @* In / Break / Out toggle *@
                                <div class="amt-type-row">
                                    <button class="amt-type-btn @(blk.EntryType=="in"   ?"amt-type-btn--active":"")"
                                            @onclick='()=>{ blk.EntryType="in"; StateHasChanged(); }'>In</button>
                                    <button class="amt-type-btn @(blk.EntryType=="break"?"amt-type-btn--active":"")"
                                            @onclick='()=>{ blk.EntryType="break"; StateHasChanged(); }'>Break</button>
                                    <button class="amt-type-btn @(blk.EntryType=="out"  ?"amt-type-btn--active":"")"
                                            @onclick='()=>{ blk.EntryType="out"; StateHasChanged(); }'>Out</button>
                                </div>

                                @if (blk.EntryType == "break")
                                {
                                    <div class="amt-field amt-field--select">
                                        <select class="amt-select" @bind="blk.BreakType">
                                            <option value="Lunch break">Lunch break (0m)</option>
                                            <option value="Short break">Short break</option>
                                            <option value="Tea break">Tea break</option>
                                        </select>
                                        <i class="bi bi-chevron-down amt-field-icon"></i>
                                    </div>
                                    <div class="amt-field amt-field--date @(amtDatePickerIdx==bIdx?"amt-field--open":"")"
                                         @onclick="()=>ToggleDatePicker(bIdx)" @onclick:stopPropagation="true">
                                        <span class="amt-field-val">@addEntryDate.ToString("dd-MM-yyyy")</span>
                                        <i class="bi bi-calendar3 amt-field-icon"></i>
                                    </div>
                                    @if (amtDatePickerIdx == bIdx)
                                    {
                                        <div class="amt-datepicker" @onclick:stopPropagation="true">
                                            <div class="amt-dp-nav">
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>MoveCalMonth(-1)"><i class="bi bi-chevron-left"></i></button>
                                                <span class="amt-dp-month">@(new DateTime(amtCalYear,amtCalMonth,1).ToString("MMMM"))</span>
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>MoveCalMonth(1)"><i class="bi bi-chevron-right"></i></button>
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>amtCalYear--"><i class="bi bi-chevron-left"></i></button>
                                                <span class="amt-dp-year">@amtCalYear</span>
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>amtCalYear++"><i class="bi bi-chevron-right"></i></button>
                                            </div>
                                            <div class="amt-dp-dow">@foreach(var d in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"}){<span>@d</span>}</div>
                                            <div class="amt-dp-grid">
                                                @{ int _fd=((int)new DateTime(amtCalYear,amtCalMonth,1).DayOfWeek+6)%7;
                                                   int _dc=DateTime.DaysInMonth(amtCalYear,amtCalMonth);
                                                   for(int _=0;_<_fd;_++){<span></span>}
                                                   for(int d=1;d<=_dc;d++){var dt=new DateTime(amtCalYear,amtCalMonth,d);var dCap=dt;
                                                       bool isSel=dt.Date==addEntryDate.Date;bool isTod=dt.Date==DateTime.Today;bool isFut=dt.Date>DateTime.Today;
                                                       <span class="amt-dp-day @(isSel?"sel":"") @(isTod&&!isSel?"today":"") @(isFut?"fut":"")"
                                                             @onclick="()=>{if(!isFut){addEntryDate=dCap;amtDatePickerIdx=-1;}}">@d</span>} }
                                            </div>
                                        </div>
                                    }
                                    <div class="amt-break-row">
                                        <div class="amt-brk-half">
                                            <div class="amt-brk-field @(amtTimePickerKey==bIdx*10+1?"amt-brk-field--open":"")"
                                                 @onclick="()=>{amtTimePickerKey=amtTimePickerKey==bIdx*10+1?-1:bIdx*10+1;if(amtTimePickerKey==bIdx*10+1)LoadPicker(blk.BreakStart);}"
                                                 @onclick:stopPropagation="true">
                                                <span class="amt-brk-label">Start</span>
                                                <i class="bi bi-clock amt-brk-clock"></i>
                                                @if(blk.BreakStart.HasValue){<span class="amt-brk-val">@FmtTime(blk.BreakStart)</span>}
                                                else{<span class="amt-brk-placeholder">--:-- --</span>}
                                            </div>
                                            @if(amtTimePickerKey==bIdx*10+1)
                                            {
                                                <div class="amt-brk-picker" @onclick:stopPropagation="true">
                                                    <div class="amt-brk-pcol">
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpH=tpH>=12?1:tpH+1;ApplyBrkT(blk,true);}">▲</button>
                                                        @for(int _h=1;_h<=12;_h++){int hh=_h;<div class="amt-brk-pitem @(tpH==_h?"active":"")" @onclick="()=>{tpH=hh;ApplyBrkT(blk,true);}">@_h.ToString("D2")</div>}
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpH=tpH<=1?12:tpH-1;ApplyBrkT(blk,true);}">▼</button>
                                                    </div>
                                                    <div class="amt-brk-pcol">
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpM=tpM>=59?0:tpM+1;ApplyBrkT(blk,true);}">▲</button>
                                                        @for(int _m=0;_m<60;_m++){int mm=_m;<div class="amt-brk-pitem @(tpM==_m?"active":"")" @onclick="()=>{tpM=mm;ApplyBrkT(blk,true);}">@_m.ToString("D2")</div>}
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpM=tpM<=0?59:tpM-1;ApplyBrkT(blk,true);}">▼</button>
                                                    </div>
                                                    <div class="amt-brk-pcol amt-brk-pcol--ap">
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{ToggleTpAp();ApplyBrkT(blk,true);}">▲</button>
                                                        <div class="amt-brk-pitem @(tpAp=="am"?"active":"")" @onclick='()=>{tpAp="am";ApplyBrkT(blk,true);}'>am</div>
                                                        <div class="amt-brk-pitem @(tpAp=="pm"?"active":"")" @onclick='()=>{tpAp="pm";ApplyBrkT(blk,true);}'>pm</div>
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{ToggleTpAp();ApplyBrkT(blk,true);}">▼</button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="amt-brk-half">
                                            <div class="amt-brk-field @(blk.BreakStart.HasValue&&blk.BreakEnd.HasValue&&blk.BreakEnd<=blk.BreakStart?"amt-brk-field--err":"") @(amtTimePickerKey==bIdx*10+2?"amt-brk-field--open":"")"
                                                 @onclick="()=>{amtTimePickerKey=amtTimePickerKey==bIdx*10+2?-1:bIdx*10+2;if(amtTimePickerKey==bIdx*10+2)LoadPicker(blk.BreakEnd);}"
                                                 @onclick:stopPropagation="true">
                                                <span class="amt-brk-label">End</span>
                                                <i class="bi bi-clock amt-brk-clock"></i>
                                                @if(blk.BreakEnd.HasValue){<span class="amt-brk-val">@FmtTime(blk.BreakEnd)</span>}
                                                else{<span class="amt-brk-placeholder">--:-- --</span>}
                                            </div>
                                            @if(amtTimePickerKey==bIdx*10+2)
                                            {
                                                <div class="amt-brk-picker" @onclick:stopPropagation="true">
                                                    <div class="amt-brk-pcol">
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpH=tpH>=12?1:tpH+1;ApplyBrkT(blk,false);}">▲</button>
                                                        @for(int _h=1;_h<=12;_h++){int hh=_h;<div class="amt-brk-pitem @(tpH==_h?"active":"")" @onclick="()=>{tpH=hh;ApplyBrkT(blk,false);}">@_h.ToString("D2")</div>}
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpH=tpH<=1?12:tpH-1;ApplyBrkT(blk,false);}">▼</button>
                                                    </div>
                                                    <div class="amt-brk-pcol">
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpM=tpM>=59?0:tpM+1;ApplyBrkT(blk,false);}">▲</button>
                                                        @for(int _m=0;_m<60;_m++){int mm=_m;<div class="amt-brk-pitem @(tpM==_m?"active":"")" @onclick="()=>{tpM=mm;ApplyBrkT(blk,false);}">@_m.ToString("D2")</div>}
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{tpM=tpM<=0?59:tpM-1;ApplyBrkT(blk,false);}">▼</button>
                                                    </div>
                                                    <div class="amt-brk-pcol amt-brk-pcol--ap">
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{ToggleTpAp();ApplyBrkT(blk,false);}">▲</button>
                                                        <div class="amt-brk-pitem @(tpAp=="am"?"active":"")" @onclick='()=>{tpAp="am";ApplyBrkT(blk,false);}'>am</div>
                                                        <div class="amt-brk-pitem @(tpAp=="pm"?"active":"")" @onclick='()=>{tpAp="pm";ApplyBrkT(blk,false);}'>pm</div>
                                                        <button type="button" class="amt-brk-arrow" @onclick="()=>{ToggleTpAp();ApplyBrkT(blk,false);}">▼</button>
                                                    </div>
                                                </div>
                                            }
                                            @if(blk.BreakStart.HasValue&&blk.BreakEnd.HasValue&&blk.BreakEnd.Value<=blk.BreakStart.Value)
                                            { <div class="amt-err-msg" style="margin-top:4px;">End can't be before start.</div> }
                                        </div>
                                    </div>
                                    <div class="amt-field amt-field--note">
                                        <textarea class="amt-note" placeholder="Add a note" @bind="blk.Note"></textarea>
                                        <i class="bi bi-pencil-square amt-note-icon"></i>
                                    </div>
                                    <div class="amt-info-box">
                                        <i class="bi bi-info-circle-fill amt-info-icon"></i>
                                        <span>End break time entry is considered a Clock in. You can add the necessary info about the after-break activity below.</span>
                                    </div>
                                    <div class="amt-field amt-field--select">
                                        <select class="amt-select" @bind="blk.Activity"><option value="">Select an activity</option></select>
                                        <i class="bi bi-chevron-down amt-field-icon"></i>
                                    </div>
                                    <div class="amt-field amt-field--select">
                                        <select class="amt-select" @bind="blk.Project"><option value="">Select a project</option></select>
                                        <i class="bi bi-chevron-down amt-field-icon"></i>
                                    </div>
                                    <div class="amt-field amt-field--note">
                                        <textarea class="amt-note" placeholder="Add a note" @bind="blk.Note"></textarea>
                                        <i class="bi bi-pencil-square amt-note-icon"></i>
                                    </div>
                                }
                                else
                                {
                                    @* Time field — segmented *@
                                    var _blockErr = GetBlockError(bIdx);
                                    <div class="amt-field amt-field--time @(_blockErr!=null?"amt-field--err":"") @(amtTimePickerKey==bIdx?"amt-field--open":"")"
                                         @onclick:stopPropagation="true">
                                        <div class="amt-seg-time" id="amt-seg-@bIdx">
                                            @{ var _h12=(blk.TimeValue?.Hour??12)%12; if(_h12==0)_h12=12;
                                               var _mm=blk.TimeValue?.Minute??0;
                                               var _ap=blk.TimeValue.HasValue&&blk.TimeValue.Value.Hour>=12?"pm":"am"; }
                                            <span class="amt-seg amt-seg--h @(amtSegFocus==bIdx*10+1?"amt-seg--active":"")" tabindex="0"
                                                  @onclick='()=>{amtSegFocus=bIdx*10+1;amtSegBuf="";amtTimePickerKey=bIdx;LoadPicker(blk.TimeValue);}'
                                                  @onkeydown="e=>HandleSegKey(e,blk,bIdx,1)">@_h12.ToString("D2")</span>
                                            <span class="amt-seg-colon">:</span>
                                            <span class="amt-seg amt-seg--m @(amtSegFocus==bIdx*10+2?"amt-seg--active":"")" tabindex="0"
                                                  @onclick='()=>{amtSegFocus=bIdx*10+2;amtSegBuf="";amtTimePickerKey=bIdx;LoadPicker(blk.TimeValue);}'
                                                  @onkeydown="e=>HandleSegKey(e,blk,bIdx,2)">@_mm.ToString("D2")</span>
                                            <span class="amt-seg amt-seg--ap @(amtSegFocus==bIdx*10+3?"amt-seg--active":"")" tabindex="0"
                                                  @onclick='()=>{amtSegFocus=bIdx*10+3;amtSegBuf="";ToggleSegAp(blk);amtTimePickerKey=bIdx;LoadPicker(blk.TimeValue);}'
                                                  @onkeydown="e=>HandleSegKey(e,blk,bIdx,3)">@_ap</span>
                                        </div>
                                        <span class="amt-tz">GMT+5:30</span>
                                        <i class="bi bi-clock amt-field-icon" style="cursor:pointer"
                                           @onclick="()=>{amtTimePickerKey=amtTimePickerKey==bIdx?-1:bIdx;if(amtTimePickerKey==bIdx)LoadPicker(blk.TimeValue);}"
                                           @onclick:stopPropagation="true"></i>
                                        @if(_blockErr!=null){<div class="amt-err-msg">@_blockErr</div>}
                                    </div>
                                    @if(amtTimePickerKey==bIdx)
                                    {
                                        <div class="amt-tp" @onclick:stopPropagation="true">
                                            <div class="amt-tp-col">@for(int _h=1;_h<=12;_h++){int hh=_h;<div id="@($"tph-{_h}")" class="amt-tp-item @(tpH==_h?"on":"")" @onclick="()=>{tpH=hh;ApplyMainT(blk);}">@_h.ToString("D2")</div>}</div>
                                            <div class="amt-tp-col">@for(int _m=0;_m<60;_m++){int mm=_m;<div id="@($"tpm-{_m}")" class="amt-tp-item @(tpM==_m?"on":"")" @onclick="()=>{tpM=mm;ApplyMainT(blk);}">@_m.ToString("D2")</div>}</div>
                                            <div class="amt-tp-col amt-tp-col--ap">
                                                <div class="amt-tp-item @(tpAp=="am"?"on":"")" @onclick='()=>{tpAp="am";ApplyMainT(blk);}'>am</div>
                                                <div class="amt-tp-item @(tpAp=="pm"?"on":"")" @onclick='()=>{tpAp="pm";ApplyMainT(blk);}'>pm</div>
                                            </div>
                                        </div>
                                    }
                                    @* Date field *@
                                    <div class="amt-field amt-field--date @(amtDatePickerIdx==bIdx?"amt-field--open":"")"
                                         @onclick="()=>ToggleDatePicker(bIdx)" @onclick:stopPropagation="true">
                                        <span class="amt-field-val">@addEntryDate.ToString("dd-MM-yyyy")</span>
                                        <i class="bi bi-calendar3 amt-field-icon"></i>
                                    </div>
                                    @if(amtDatePickerIdx==bIdx)
                                    {
                                        <div class="amt-datepicker" @onclick:stopPropagation="true">
                                            <div class="amt-dp-nav">
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>MoveCalMonth(-1)"><i class="bi bi-chevron-left"></i></button>
                                                <span class="amt-dp-month">@(new DateTime(amtCalYear,amtCalMonth,1).ToString("MMMM"))</span>
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>MoveCalMonth(1)"><i class="bi bi-chevron-right"></i></button>
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>amtCalYear--"><i class="bi bi-chevron-left"></i></button>
                                                <span class="amt-dp-year">@amtCalYear</span>
                                                <button type="button" class="amt-dp-navbtn" @onclick="()=>amtCalYear++"><i class="bi bi-chevron-right"></i></button>
                                            </div>
                                            <div class="amt-dp-dow">@foreach(var d in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"}){<span>@d</span>}</div>
                                            <div class="amt-dp-grid">
                                                @{ int _fd2=((int)new DateTime(amtCalYear,amtCalMonth,1).DayOfWeek+6)%7;
                                                   int _dc2=DateTime.DaysInMonth(amtCalYear,amtCalMonth);
                                                   for(int _=0;_<_fd2;_++){<span></span>}
                                                   for(int d=1;d<=_dc2;d++){var dt=new DateTime(amtCalYear,amtCalMonth,d);var dCap=dt;
                                                       bool isSel=dt.Date==addEntryDate.Date;bool isTod=dt.Date==DateTime.Today;bool isFut=dt.Date>DateTime.Today;
                                                       <span class="amt-dp-day @(isSel?"sel":"") @(isTod&&!isSel?"tod":"") @(isFut?"fut":"")"
                                                             @onclick="()=>{if(!isFut){addEntryDate=dCap;amtDatePickerIdx=-1;}}">@d</span>} }
                                            </div>
                                        </div>
                                    }
                                    @* Activity + Project for In *@
                                    @if (blk.EntryType == "in")
                                    {
                                        <div class="amt-field amt-field--select">
                                            <select class="amt-select" @bind="blk.Activity"><option value="">Select an activity</option></select>
                                            <i class="bi bi-chevron-down amt-field-icon"></i>
                                        </div>
                                        <div class="amt-field amt-field--select">
                                            <select class="amt-select" @bind="blk.Project"><option value="">Select a project</option></select>
                                            <i class="bi bi-chevron-down amt-field-icon"></i>
                                        </div>
                                    }
                                    @* Notes *@
                                    <div class="amt-field amt-field--note">
                                        <textarea class="amt-note" placeholder="Add a note" @bind="blk.Note"></textarea>
                                        <i class="bi bi-pencil-square amt-note-icon"></i>
                                    </div>
                                    @if (blk.EntryType == "out")
                                    {
                                        <label class="amt-endwork">
                                            <input type="checkbox" class="amt-endwork-cb" @bind="blk.EndWorkForDay" />
                                            <span>End work for the day?</span>
                                            <i class="bi bi-info-circle" style="font-size:11px;color:#9ca3af;margin-left:3px;"></i>
                                        </label>
                                    }
                                    @* Duplicate-time warning — only on non-first blocks *@
                                    @if (bIdx > 0 && blk.TimeValue.HasValue && blk.EntryType != "break" &&
                                         addEntryBlocks.Where((b,ii) => ii != bIdx && b.EntryType != "break" && b.TimeValue.HasValue)
                                                        .Any(b => b.TimeValue!.Value == blk.TimeValue!.Value))
                                    {
                                        <div class="amt-dup-warn">
                                            <i class="bi bi-exclamation-circle-fill amt-dup-warn-icon"></i>
                                            <span>The time entry details are duplicated. Please edit your new time entry before saving.</span>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                @* ── Hour entry tab ── *@
                                <div class="amt-hour-row">
                                    <div class="amt-field amt-field--hour">
                                        <div class="@GetHourBoxClass(bIdx)" @onclick:stopPropagation="true">
                                            <span class="@GetHourSegClass(bIdx,1)" tabindex="0"
                                                  @onclick="()=>FocusHourSeg(bIdx,1)"
                                                  @onkeydown="e=>HandleHourSegKey(e,blk,bIdx,1)"
                                                  @onfocus="()=>FocusHourSeg(bIdx,1)"
                                                  @onblur="()=>BlurHourSeg(bIdx,1)">@blk.HourH.ToString("00")</span>
                                            <span class="amt-hm">h</span>
                                            <span class="@GetHourSegClass(bIdx,2)" tabindex="0"
                                                  @onclick="()=>FocusHourSeg(bIdx,2)"
                                                  @onkeydown="e=>HandleHourSegKey(e,blk,bIdx,2)"
                                                  @onfocus="()=>FocusHourSeg(bIdx,2)"
                                                  @onblur="()=>BlurHourSeg(bIdx,2)">@blk.HourM.ToString("00")</span>
                                            <span class="amt-hm">m</span>
                                            <i class="bi bi-clock amt-hour-clock"></i>
                                        </div>
                                    </div>
                                    <div class="amt-field amt-field--date @(amtDatePickerIdx==bIdx?"amt-field--open":"")"
                                         @onclick="()=>ToggleDatePicker(bIdx)" @onclick:stopPropagation="true">
                                        <span class="amt-field-val">@addEntryDate.ToString("dd-MM-yyyy")</span>
                                        <i class="bi bi-calendar3 amt-field-icon"></i>
                                    </div>
                                </div>
                                @if(amtDatePickerIdx==bIdx)
                                {
                                    <div class="amt-datepicker" @onclick:stopPropagation="true">
                                        <div class="amt-dp-nav">
                                            <button type="button" class="amt-dp-navbtn" @onclick="()=>MoveCalMonth(-1)"><i class="bi bi-chevron-left"></i></button>
                                            <span class="amt-dp-month">@(new DateTime(amtCalYear,amtCalMonth,1).ToString("MMMM"))</span>
                                            <button type="button" class="amt-dp-navbtn" @onclick="()=>MoveCalMonth(1)"><i class="bi bi-chevron-right"></i></button>
                                            <button type="button" class="amt-dp-navbtn" @onclick="()=>amtCalYear--"><i class="bi bi-chevron-left"></i></button>
                                            <span class="amt-dp-year">@amtCalYear</span>
                                            <button type="button" class="amt-dp-navbtn" @onclick="()=>amtCalYear++"><i class="bi bi-chevron-right"></i></button>
                                        </div>
                                        <div class="amt-dp-dow">@foreach(var d in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"}){<span>@d</span>}</div>
                                        <div class="amt-dp-grid">
                                            @{ int _fd3=((int)new DateTime(amtCalYear,amtCalMonth,1).DayOfWeek+6)%7;
                                               int _dc3=DateTime.DaysInMonth(amtCalYear,amtCalMonth);
                                               for(int _=0;_<_fd3;_++){<span></span>}
                                               for(int d=1;d<=_dc3;d++){var dt=new DateTime(amtCalYear,amtCalMonth,d);var dCap=dt;
                                                   bool isSel=dt.Date==addEntryDate.Date;bool isTod=dt.Date==DateTime.Today;bool isFut=dt.Date>DateTime.Today;
                                                   <span class="amt-dp-day @(isSel?"sel":"") @(isTod&&!isSel?"tod":"") @(isFut?"fut":"")"
                                                         @onclick="()=>{if(!isFut){addEntryDate=dCap;amtDatePickerIdx=-1;}}">@d</span>} }
                                        </div>
                                    </div>
                                }
                                <div class="amt-field amt-field--select">
                                    <select class="amt-select" @bind="blk.HourActivity"><option value="">Select an activity</option></select>
                                    <i class="bi bi-chevron-down amt-field-icon"></i>
                                </div>
                                <div class="amt-field amt-field--select">
                                    <select class="amt-select" @bind="blk.HourProject"><option value="">Select a project</option></select>
                                    <i class="bi bi-chevron-down amt-field-icon"></i>
                                </div>
                                <div class="amt-field amt-field--note">
                                    <textarea class="amt-note" placeholder="Add a note" @bind="blk.HourNote"></textarea>
                                    <i class="bi bi-pencil-square amt-note-icon"></i>
                                </div>

                            }
                        }
                    }

                </div>@* end amt-body *@

                @* ── Footer (sticky at bottom) ── *@
                <div class="amt-footer">
                    @* Left side: + Add new always; Duplicate only when single block *@
                    <div class="amt-footer-left">
                        <button class="amt-footer-addnew" @onclick="()=>AddNewBlockAfter(addEntryBlocks.Count-1)">
                            <i class="bi bi-plus-lg"></i> Add new
                        </button>
                        @if (addEntryBlocks.Count == 1)
                        {
                            <button class="amt-footer-dup" @onclick="()=>DuplicateBlock(0)">
                                <i class="bi bi-files"></i> Duplicate
                            </button>
                        }
                    </div>
                    @* Right side: error msg + Cancel + Save *@
                    <div class="amt-footer-right">
                        @if (!string.IsNullOrEmpty(addEntrySaveError))
                        {
                            <div class="amt-save-err">
                                <i class="bi bi-exclamation-triangle-fill"></i> @addEntrySaveError
                            </div>
                        }
                        <div class="amt-footer-btns">
                            <button class="amt-cancel" @onclick="CloseAddTimeEntry">Cancel</button>
                            <button class="amt-save" @onclick="SaveManualEntries"
                                    disabled="@(addEntrySaving || HasClockOutBeforeClockInError())">
                                @(addEntrySaving ? "Saving…" : "Save")
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }

    @* ══ SIDE PANEL: view / edit ══ *@
    @if (viewEntry != null && panelMode != "none")
    {
        @* Full-screen dimmed backdrop — covers sidebar + all content *@
        <div class="tep-backdrop" @onclick="ClosePanel"></div>

        <div class="tep-panel" @onclick:stopPropagation="true">

            @* ── Header ── *@
            <div class="tep-header">
                <span class="tep-title">@(panelMode == "edit" ? "Edit Time Entry" : "View Time Entry")</span>
                <button class="tep-close" @onclick="ClosePanel"><i class="bi bi-x-lg"></i></button>
            </div>

            @* ── Body ── *@
            <div class="tep-body">

                @* Profile block *@
                <div class="tep-profile-block">
                    <div class="tep-profile-left">
                        @{
                            // Resolve selfie URL for whichever panel type is open (in / out)
                            var _tepSelfieUrl = panelType == "in"
                                ? GetSelfieUrl(viewEntry?.ClockInSelfieUrl)
                                : GetSelfieUrl(viewEntry?.ClockOutSelfieUrl);
                            bool _hasTepSelfie = !string.IsNullOrEmpty(_tepSelfieUrl);
                        }
                        @if (_hasTepSelfie)
                        {
                            <div class="tep-member-av tep-member-av--photo"
                                 @onclick='() => { tepSelfieOpen = true; tepSelfieZoomUrl = _tepSelfieUrl; StateHasChanged(); }'
                                 title="View captured selfie">
                                <img src="@_tepSelfieUrl" class="tep-av-img" alt="Selfie" />
                                <div class="tep-av-hover-overlay">
                                    <i class="bi bi-eye-fill tep-av-eye"></i>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="tep-member-av">@GetInitial()</div>
                        }
                        <div class="tep-member-info">
                            <div class="tep-member-name">@(SessionService.FullName ?? "")</div>
                            <div class="tep-member-sub">
                                @(panelType == "in" ? "Clocked in from GMT+5:30" : "Clocked out from GMT+5:30")
                            </div>
                            <div class="tep-member-sub">via Jibble Web App</div>
                            <div class="tep-member-device-row">
                                <i class="bi bi-display tep-device-icon"></i>
                            </div>
                        </div>
                    </div>
                    @* Pencil only shown in view mode *@
                    @if (panelMode == "view")
                    {
                        <button class="tep-edit-pencil" @onclick="SwitchToEdit" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </button>
                    }
                </div>

                <div class="tep-divider"></div>

                @* ── VIEW SECTION *@
                @if (panelMode == "view")
                {
                    <div class="tep-view-row">
                        <div class="tep-view-icon-wrap">
                            @if (panelType == "in")
                            {
                                @* Arrow pointing right = clock in *@
                                <i class="bi bi-box-arrow-in-right tep-view-icon tep-view-icon--in"></i>
                            }
                            else
                            {
                                @* Arrow pointing left = clock out *@
                                <i class="bi bi-box-arrow-left tep-view-icon tep-view-icon--out"></i>
                            }
                        </div>
                        <span class="tep-view-time">@GetViewTime()</span>
                        <span class="tep-view-pipe">|</span>
                        <span class="tep-view-date-lbl">@GetViewDateLabel()</span>
                    </div>

                    @* Location row — shown in view mode *@
                    <div class="tep-location-row">
                        <i class="bi bi-geo-alt tep-loc-icon"></i>
                        <div class="tep-loc-info">
                            @if (!string.IsNullOrEmpty(viewEntryLocation))
                            {
                                <span class="tep-loc-name">@viewEntryLocation</span>
                                <a href="/settings/locations" class="tep-view-location-link">View Location</a>
                            }
                            else
                            {
                                <span class="tep-loc-none">No location recorded</span>
                            }
                        </div>
                    </div>
                }

                @* ── EDIT SECTION *@
                @if (panelMode == "edit")
                {
                    @* TIME field — click to open custom time picker *@
                    <div class="tep-edit-field tep-edit-field--time @(showTimePicker ? "tep-field--active" : "")"
                         @onclick="ToggleTimePicker" @onclick:stopPropagation="true">
                        <span class="tep-time-display">
                            @GetDisplayTime()
                        </span>
                        <span class="tep-tz-badge">
                            <span class="tep-tz-circle"><i class="bi bi-clock"></i></span>
                            <span class="tep-tz-text">GMT+5:30</span>
                        </span>
                    </div>

                    @* CUSTOM TIME PICKER — scrollable columns *@
                    @if (showTimePicker)
                    {
                        <div class="tep-timepicker" @onclick:stopPropagation="true">
                            @* Hour column *@
                            <div class="tep-tp-col" id="tp-col-hour">
                                @foreach (var h in Enumerable.Range(1, 12))
                                {
                                    var hStr = h.ToString("D2");
                                    bool selH = tpHour == h;
                                    var hCaptured = h;
                                    <div id="tp-h-@hStr" class="tep-tp-cell @(selH ? "tep-tp-cell--sel" : "")"
                                         @onclick="() => { tpHour = hCaptured; ApplyTimePicker(); }">@hStr</div>
                                }
                            </div>
                            @* Minute column *@
                            <div class="tep-tp-col" id="tp-col-min">
                                @foreach (var m in Enumerable.Range(0, 60))
                                {
                                    bool selM = tpMinute == m;
                                    var mCaptured = m;
                                    <div id="tp-m-@m.ToString("D2")" class="tep-tp-cell @(selM ? "tep-tp-cell--sel" : "")"
                                         @onclick="() => { tpMinute = mCaptured; ApplyTimePicker(); }">@m.ToString("D2")</div>
                                }
                            </div>
                            @* AM/PM column *@
                            <div class="tep-tp-col tep-tp-col--ampm">
                                <div class="tep-tp-cell @(tpAmPm == "AM" ? "tep-tp-cell--sel" : "")"
                                     @onclick='() => { tpAmPm = "AM"; ApplyTimePicker(); }'>AM</div>
                                <div class="tep-tp-cell @(tpAmPm == "PM" ? "tep-tp-cell--sel" : "")"
                                     @onclick='() => { tpAmPm = "PM"; ApplyTimePicker(); }'>PM</div>
                            </div>
                        </div>
                    }

                    @* DATE field — "Today"/date label + calendar icon, click opens picker *@
                    <div class="tep-edit-field tep-edit-field--date @(showCalendar ? "tep-field--active" : "")"
                         @onclick="ToggleCalendar" @onclick:stopPropagation="true">
                        <span class="tep-date-label">@GetEditDateLabel()</span>
                        <i class="bi bi-calendar3 tep-field-icon"></i>
                    </div>

                    @* INLINE CALENDAR PICKER — shown below date field when open *@
                    @if (showCalendar)
                    {
                        <div class="tep-calendar" @onclick:stopPropagation="true">
                            <div class="tep-cal-nav">
                                <button class="tep-cal-nav-btn" @onclick="CalPrevMonth"><i class="bi bi-chevron-left"></i></button>
                                <span class="tep-cal-month-label">@calViewDate.ToString("MMMM")</span>
                                <button class="tep-cal-nav-btn" @onclick="CalNextMonth"><i class="bi bi-chevron-right"></i></button>
                                <button class="tep-cal-nav-btn" @onclick="CalPrevYear"><i class="bi bi-chevron-left"></i></button>
                                <span class="tep-cal-year-label">@calViewDate.Year</span>
                                <button class="tep-cal-nav-btn" @onclick="CalNextYear"><i class="bi bi-chevron-right"></i></button>
                            </div>
                            <div class="tep-cal-grid">
                                <div class="tep-cal-dow">Mon</div>
                                <div class="tep-cal-dow">Tue</div>
                                <div class="tep-cal-dow">Wed</div>
                                <div class="tep-cal-dow">Thu</div>
                                <div class="tep-cal-dow">Fri</div>
                                <div class="tep-cal-dow">Sat</div>
                                <div class="tep-cal-dow">Sun</div>
                                @{
                                    var firstDay = new DateTime(calViewDate.Year, calViewDate.Month, 1);
                                    // Monday=0 offset
                                    int startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
                                    int daysInMonth = DateTime.DaysInMonth(calViewDate.Year, calViewDate.Month);
                                    var selectedDateStr = panelType == "in" ? editClockInDate : editClockOutDate;
                                    DateTime.TryParse(selectedDateStr, out var selectedDt);

                                    // Blank cells before first day
                                    for (int blank = 0; blank < startOffset; blank++)
                                    {
                                        <div class="tep-cal-cell tep-cal-cell--empty"></div>
                                    }
                                    for (int d = 1; d <= daysInMonth; d++)
                                    {
                                        var cellDate = new DateTime(calViewDate.Year, calViewDate.Month, d);
                                        bool isToday = cellDate.Date == DateTime.Today;
                                        bool isSelected = cellDate.Date == selectedDt.Date && selectedDt != default;
                                        bool isFuture = cellDate.Date > DateTime.Today;
                                        var captured = cellDate;
                                        <div class="tep-cal-cell @(isSelected ? "tep-cal-cell--sel" : "") @(isToday && !isSelected ? "tep-cal-cell--today" : "") @(isFuture ? "tep-cal-cell--future" : "")"
                                             @onclick="() => CalSelectDate(captured)">@d</div>
                                    }
                                }
                            </div>
                        </div>
                    }

                    @* ACTIVITY & PROJECT — only for clock-in (matches Jibble image 1) *@
                    @if (panelType == "in")
                    {
                        @* Location dropdown — matching Jibble screenshot *@
                        <div class="tep-edit-field tep-edit-field--select">
                            <i class="bi bi-geo-alt tep-field-icon" style="margin-left:4px;margin-right:0;"></i>
                            <select class="tep-select-native" @bind="editLocationName">
                                <option value="">Select a location</option>
                                <option value="Head Office">Head Office</option>
                                <option value="Branch South">Branch South</option>
                                <option value="Warehouse">Warehouse</option>
                            </select>
                            <i class="bi bi-chevron-down tep-field-icon"></i>
                        </div>

                        <div class="tep-edit-field tep-edit-field--select">
                            <select class="tep-select-native">
                                <option value="">Select an activity</option>
                            </select>
                            <i class="bi bi-chevron-down tep-field-icon"></i>
                        </div>

                        <div class="tep-edit-field tep-edit-field--select">
                            <select class="tep-select-native">
                                <option value="">Select a project</option>
                            </select>
                            <i class="bi bi-chevron-down tep-field-icon"></i>
                        </div>
                    }

                    @* NOTE textarea *@
                    <div class="tep-edit-field tep-edit-field--note">
                        <textarea class="tep-note-native" placeholder="Add a note" @bind="editNote"></textarea>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(editError))
                    {
                        <div class="tep-error">@editError</div>
                    }
                }

            </div>

            @* ── Footer *@
            <div class="tep-footer">
                @if (panelMode == "edit")
                {
                    <button class="tep-footer-del" @onclick="() => { ConfirmDeleteFromPanel(); ClosePanel(); }">Delete</button>
                    <div class="tep-footer-right">
                        <button class="tep-footer-cancel" @onclick="ClosePanel">Cancel</button>
                        <button class="tep-footer-save" @onclick="OnSaveClicked" disabled="@editSaving">
                            @(editSaving ? "Saving…" : "Save")
                        </button>
                    </div>
                }
                else
                {
                    <div></div>
                    <div class="tep-footer-right">
                        <button class="tep-footer-cancel" @onclick="ClosePanel">Close</button>
                    </div>
                }
            </div>

        </div>
    }

    @* ══ REASON FOR CHANGE MODAL ══ *@
    @if (showReasonModal)
    {
        <div class="tep-modal-backdrop" @onclick:stopPropagation="true">
            <div class="tep-modal" @onclick:stopPropagation="true">
                <div class="tep-modal-header">
                    <span class="tep-modal-title">Reason for change</span>
                    <button class="tep-close" @onclick="CancelReasonModal"><i class="bi bi-x-lg"></i></button>
                </div>
                <p class="tep-modal-sub">For transparency, changes made to time entries are logged and visible to team admins and assigned managers.</p>
                <textarea class="tep-input tep-textarea tep-modal-ta"
                          placeholder="Why are you editing this time entry?"
                          @bind="reasonForChange"></textarea>
                <div class="tep-modal-actions">
                    <button class="tep-footer-cancel" @onclick="CancelReasonModal">Cancel</button>
                    <button class="tep-footer-save" @onclick="ConfirmSaveWithReason" disabled="@editSaving">Confirm</button>
                </div>
            </div>
        </div>
    }

    @* ══ DELETE CONFIRMATION MODAL ══ *@
    @if (showDeleteModal && deleteTargetEntry != null)
    {
        <div class="tep-modal-backdrop" @onclick:stopPropagation="true">
            <div class="tep-modal" @onclick:stopPropagation="true">
                <div class="tep-modal-header">
                    <span class="tep-modal-title">Delete Time Entry</span>
                    <button class="tep-close" @onclick="CancelDelete"><i class="bi bi-x-lg"></i></button>
                </div>
                <p class="tep-modal-sub">
                    Are you sure you want to delete the entry for
                    <strong>@deleteTargetEntry.ClockIn.ToString("h:mm tt")</strong>?
                    This action cannot be undone.
                </p>
                @if (!string.IsNullOrWhiteSpace(deleteError))
                {
                    <div class="tep-error">@deleteError</div>
                }
                <div class="tep-modal-actions">
                    <button class="tep-footer-cancel" @onclick="CancelDelete">Cancel</button>
                    <button class="tep-footer-del" @onclick="ExecuteDelete" disabled="@deleteInProgress">
                        @if (deleteInProgress)
                        {
                            <span>Deleting…</span>
                        }
                        else
                        {

                            <span>Delete</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    @* ══ EXPORT TIMESHEETS PANEL (right-side slide-in) ══ *@
    @if (showExportModal)
    {
        <div class="exp-backdrop" @onclick="CloseExportModal"></div>
        <div class="exp-panel" @onclick:stopPropagation="true" @onclick="CloseAllExpDropdowns">

            @* ── Header ── *@
            <div class="exp-modal-header">
                <span class="exp-modal-title">Export @ExportModalTitle</span>
                <button class="tep-close" @onclick="CloseExportModal"><i class="bi bi-x-lg"></i></button>
            </div>

            <div class="exp-modal-body">

                @* ── File format ── *@
                <div class="exp-section-label">File format</div>
                <div class="exp-format-row">
                    @* XLS card *@
                    <div class="exp-format-card @(expFormat == "xls" ? "exp-format-card--sel" : "")"
                         @onclick='() => { expFormat = "xls"; expIncludePerMember = false; }'>
                        <div class="exp-format-radio-wrap">
                            @if (expFormat == "xls")
                            { <div class="exp-radio-dot exp-radio-dot--sel"></div> }
                            else
                            { <div class="exp-radio-dot"></div> }
                        </div>
                        <div class="exp-format-file">
                            <div class="exp-file-icon exp-file-icon--xls">
                                <div class="exp-file-lines"><span></span><span></span><span></span></div>
                                <div class="exp-file-label">XLS</div>
                            </div>
                        </div>
                    </div>
                    @* CSV card *@
                    <div class="exp-format-card @(expFormat == "csv" ? "exp-format-card--sel" : "")"
                         @onclick='() => expFormat = "csv"'>
                        <div class="exp-format-radio-wrap">
                            @if (expFormat == "csv")
                            { <i class="bi bi-check-circle-fill exp-format-check--green"></i> }
                            else
                            { <div class="exp-radio-dot"></div> }
                        </div>
                        <div class="exp-format-file">
                            <div class="exp-file-icon exp-file-icon--csv">
                                <div class="exp-file-lines"><span></span><span></span><span></span></div>
                                <div class="exp-file-label">CSV</div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── Include (XLS) / Choose (CSV) ── *@
                @if (expFormat == "xls")
                {
                    <div class="exp-section-label" style="margin-top:22px;">
                        Include (optional) <i class="bi bi-info-circle" style="font-size:12px;color:#9ca3af;vertical-align:middle;"></i>
                    </div>
                    <div class="exp-check-list">
                        <label class="exp-check-row">
                            <input type="checkbox" class="exp-checkbox exp-checkbox--green" checked="@expIncludeTimesheets"
                                   @onchange="e => expIncludeTimesheets = (bool)(e.Value ?? false)" />
                            <span>Timesheets list in single tabs</span>
                        </label>
                        <label class="exp-check-row">
                            <input type="checkbox" class="exp-checkbox exp-checkbox--green" checked="@expIncludeTimeEntries"
                                   @onchange="e => expIncludeTimeEntries = (bool)(e.Value ?? false)" />
                            <span>Time entries list in single tabs</span>
                        </label>
                        <div class="exp-check-row" style="align-items:center;gap:8px;display:flex;flex-wrap:wrap;">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;">
                                <input type="checkbox" class="exp-checkbox exp-checkbox--green" checked="@expIncludePerMember"
                                       @onchange="e => { expIncludePerMember = (bool)(e.Value ?? false); if(!expIncludePerMember) expPerMemberModeOpen = false; }" />
                                <span>Timesheets per member in individual tabs</span>
                            </label>
                            @if (expIncludePerMember)
                            {
                                <div style="position:relative;display:inline-block;">
                                    <button class="exp-custom-select" style="min-width:110px;padding:3px 10px;font-size:13px;font-weight:600;"
                                            @onclick="() => expPerMemberModeOpen = !expPerMemberModeOpen">
                                        @(expPerMemberMode == "summary" ? "Summary" : "Detailed")
                                        <i class="bi bi-chevron-@(expPerMemberModeOpen ? "up" : "down")" style="margin-left:4px;"></i>
                                    </button>
                                    @if (expPerMemberModeOpen)
                                    {
                                        <div class="exp-dropdown-menu" style="min-width:110px;left:0;top:calc(100% + 4px);">
                                            <div class="exp-dropdown-item @(expPerMemberMode=="summary"?"exp-dropdown-item--active":"")"
                                                 @onclick='() => { expPerMemberMode = "summary"; expPerMemberModeOpen = false; }'>Summary</div>
                                            <div class="exp-dropdown-item @(expPerMemberMode=="detailed"?"exp-dropdown-item--active":"")"
                                                 @onclick='() => { expPerMemberMode = "detailed"; expPerMemberModeOpen = false; }'>Detailed</div>
                                        </div>
                                    }
                                </div>
                            }
                            <i class="bi bi-info-circle" style="font-size:11px;color:#9ca3af;vertical-align:middle;"></i>
                        </div>
                    </div>
                }
                else
                {
                    <div class="exp-section-label" style="margin-top:22px;">Choose at least one format to export</div>
                    <div class="exp-check-list">
                        <label class="exp-check-row">
                            <input type="checkbox" class="exp-checkbox" checked="@expIncludeTimesheets"
                                   @onchange="e => expIncludeTimesheets = (bool)(e.Value ?? false)" />
                            <span>Timesheets list</span>
                        </label>
                        <label class="exp-check-row">
                            <input type="checkbox" class="exp-checkbox" checked="@expIncludeTimeEntries"
                                   @onchange="e => expIncludeTimeEntries = (bool)(e.Value ?? false)" />
                            <span>Time entries list</span>
                        </label>
                    </div>
                }

                @* ── Date range ── *@
                <div class="exp-section-label" style="margin-top:22px;">Date range</div>
                <div class="exp-date-row">
                    @* Period dropdown *@
                    <div class="exp-custom-select-wrap" @onclick:stopPropagation="true">
                        <button class="exp-custom-select" @onclick="() => { expShowPeriodDd = !expShowPeriodDd; expShowDateCal = false; }">
                            <span>@(expDateRange == "day" ? "Day" : expDateRange == "week" ? "Week" : expDateRange == "month" ? "Month" : "Custom")</span>
                            <i class="bi bi-chevron-@(expShowPeriodDd ? "up" : "down")"></i>
                        </button>
                        @if (expShowPeriodDd)
                        {
                            <div class="exp-dd-popup exp-dd-popup--left">
                                @foreach (var (val, label) in new[]{("day","Day"),("week","Week"),("month","Month"),("custom","Custom")})
                                {
                                    var v = val; var l = label;
                                    <div class="exp-dd-item @(expDateRange == v ? "exp-dd-item--sel" : "")"
                                         @onclick="() => { expDateRange = v; expShowPeriodDd = false; SyncExpDates(); }">
                                        @l @if (expDateRange == v) { <i class="bi bi-check" style="color:#ff7a00;margin-left:auto;"></i> }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* Date display + calendar *@
                    <div class="exp-custom-select-wrap exp-date-cal-wrap" @onclick:stopPropagation="true">
                        <button class="exp-custom-select exp-date-display-btn" @onclick="() => { expShowDateCal = !expShowDateCal; expShowPeriodDd = false; }">
                            <span>@GetExportDateRangeLabel()</span>
                            <i class="bi bi-calendar3" style="color:#9ca3af;font-size:14px;"></i>
                        </button>
                        @if (expShowDateCal)
                        {
                            <div class="exp-cal-popup" @onclick:stopPropagation="true">
                                @* Calendar nav *@
                                <div class="exp-cal-nav">
                                    <button class="exp-cal-nav-btn" @onclick="ExpCalPrevMonth"><i class="bi bi-chevron-left"></i></button>
                                    <span class="exp-cal-month-lbl">@(new DateTime(expCalYear, expCalMonth, 1).ToString("MMMM"))</span>
                                    <button class="exp-cal-nav-btn" @onclick="ExpCalNextMonth"><i class="bi bi-chevron-right"></i></button>
                                    <button class="exp-cal-nav-btn" @onclick="ExpCalPrevYear"><i class="bi bi-chevron-left"></i></button>
                                    <span class="exp-cal-year-lbl">@expCalYear</span>
                                    <button class="exp-cal-nav-btn" @onclick="ExpCalNextYear"><i class="bi bi-chevron-right"></i></button>
                                </div>
                                @* Day headers *@
                                <div class="exp-cal-dow-row">
                                    @foreach (var d in new[]{"Mon","Tue","Wed","Thu","Fri","Sat","Sun"})
                                    { <span class="exp-cal-dow">@d</span> }
                                </div>
                                @* Day grid *@
                                <div class="exp-cal-grid">
                                    @{
                                        var expFirst   = new DateTime(expCalYear, expCalMonth, 1);
                                        int expOffset  = ((int)expFirst.DayOfWeek + 6) % 7;
                                        int expDaysInM = DateTime.DaysInMonth(expCalYear, expCalMonth);
                                        for (int bi = 0; bi < expOffset; bi++) { <span class="exp-cal-blank"></span> }
                                        for (int di = 1; di <= expDaysInM; di++)
                                        {
                                            var cd  = new DateTime(expCalYear, expCalMonth, di);
                                            var cap = cd;
                                            bool isTdy  = cd.Date == DateTime.Today;
                                            bool isSel  = false;
                                            bool inRng  = false;
                                            if (expDateRange == "day")
                                            {
                                                isSel = cd.Date == expRangeStart.Date;
                                            }
                                            else
                                            {
                                                isSel = cd.Date == expRangeStart.Date || (expRangeEnd.HasValue && cd.Date == expRangeEnd.Value.Date);
                                                inRng = expRangeEnd.HasValue && cd.Date > expRangeStart.Date && cd.Date < expRangeEnd.Value.Date;
                                            }
                                            <span class="exp-cal-day @(isSel ? "exp-cal-day--sel" : "") @(inRng ? "exp-cal-day--inrange" : "") @(isTdy && !isSel ? "exp-cal-day--today" : "")"
                                                  @onclick="() => ExpCalSelectDay(cap)">@di</span>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* ── Filter by ── *@
                <div class="exp-section-label" style="margin-top:22px;">Filter by:</div>
                <div class="exp-filter-box" @onclick:stopPropagation="true">

                    @* Payroll hours filter *@
                    <div class="exp-filter-dd-wrap">
                        <button class="exp-filter-chip @(expPayrollOpen ? "exp-chip--open" : "")"
                                @onclick='() => ToggleExpFilter("payroll")'>
                            Payroll hours <i class="bi bi-chevron-@(expPayrollOpen ? "up" : "down")"></i>
                        </button>
                        @if (expPayrollOpen)
                        {
                            <div class="exp-filter-popup">
                                <label class="exp-filter-popup-row">
                                    <input type="checkbox" class="exp-checkbox" @bind="expExcludeRestDays" /> Exclude rest days &amp; public holidays
                                </label>
                                <label class="exp-filter-popup-row">
                                    <input type="checkbox" class="exp-checkbox" @bind="expExcludeTimeOffs" /> Exclude time offs
                                </label>
                                <div class="exp-filter-divider"></div>
                                @foreach (var h in new[]{"0 hours","0-2 hours","2-4 hours","4-6 hours","6-8 hours","8-10 hours","10+ hours"})
                                {
                                    var hCap = h;
                                    <div class="exp-filter-popup-item @(expSelectedHours == hCap ? "exp-filter-popup-item--sel" : "")"
                                         @onclick="() => { expSelectedHours = expSelectedHours == hCap ? null : hCap; }">
                                        @h
                                    </div>
                                }
                                <div class="exp-filter-clear" @onclick="() => { expSelectedHours = null; expExcludeRestDays = false; expExcludeTimeOffs = false; }">Clear selection</div>
                            </div>
                        }
                    </div>

                    @* Groups filter *@
                    <div class="exp-filter-dd-wrap">
                        <button class="exp-filter-chip @(expGroupsOpen ? "exp-chip--open" : "")"
                                @onclick='() => ToggleExpFilter("groups")'>
                            Groups <i class="bi bi-chevron-@(expGroupsOpen ? "up" : "down")"></i>
                        </button>
                        @if (expGroupsOpen)
                        {
                            <div class="exp-filter-popup">
                                <div class="exp-filter-search-wrap">
                                    <i class="bi bi-search exp-filter-search-icon"></i>
                                    <input class="exp-filter-search" placeholder="Search groups"
                                           @bind="expGroupSearch" @bind:event="oninput" />
                                </div>
                                @{
                                    var gList = expAllGroups.Where(g => string.IsNullOrEmpty(expGroupSearch) || g.Name.Contains(expGroupSearch, StringComparison.OrdinalIgnoreCase)).ToList();
                                }
                                @if (!gList.Any())
                                {
                                    <div class="exp-filter-empty">No data found</div>
                                }
                                @foreach (var g in gList)
                                {
                                    var gCap = g;
                                    bool gSel = expSelectedGroupIds.Contains(gCap.Id);
                                    <div class="exp-filter-popup-item @(gSel ? "exp-filter-popup-item--sel" : "")"
                                         @onclick="() => { if (gSel) expSelectedGroupIds.Remove(gCap.Id); else expSelectedGroupIds.Add(gCap.Id); }">
                                        @g.Name @if (gSel) { <i class="bi bi-check" style="color:#16a34a;margin-left:auto;"></i> }
                                    </div>
                                }
                                <div class="exp-filter-clear" @onclick="() => { expSelectedGroupIds.Clear(); expGroupSearch = string.Empty; }">Clear selection</div>
                            </div>
                        }
                    </div>

                    @* Members filter *@
                    <div class="exp-filter-dd-wrap">
                        <button class="exp-filter-chip @(expMembersOpen ? "exp-chip--open" : "")"
                                @onclick='() => ToggleExpFilter("members")'>
                            Members <i class="bi bi-chevron-@(expMembersOpen ? "up" : "down")"></i>
                        </button>
                        @if (expMembersOpen)
                        {
                            <div class="exp-filter-popup">
                                <div class="exp-filter-search-wrap">
                                    <i class="bi bi-search exp-filter-search-icon"></i>
                                    <input class="exp-filter-search" placeholder="Search members..."
                                           @bind="expMemberSearch" @bind:event="oninput" />
                                </div>
                                <label class="exp-filter-popup-row">
                                    <input type="checkbox" class="exp-checkbox" @bind="expShowArchived" /> Show archived members
                                </label>
                                <div class="exp-filter-divider"></div>
                                @{
                                    var mList = expAllMembers.Where(m => string.IsNullOrEmpty(expMemberSearch) || m.FullName.Contains(expMemberSearch, StringComparison.OrdinalIgnoreCase)).ToList();
                                }
                                @foreach (var m in mList)
                                {
                                    var mCap = m;
                                    bool mSel = expSelectedMemberIds.Contains(mCap.Id);
                                    <div class="exp-filter-member-row @(mSel ? "exp-filter-popup-item--sel" : "")"
                                         @onclick="() => { if (mSel) expSelectedMemberIds.Remove(mCap.Id); else expSelectedMemberIds.Add(mCap.Id); }">
                                        <div class="exp-member-av">@(mCap.FullName.Length > 0 ? mCap.FullName[0].ToString().ToUpper() : "?")</div>
                                        <span>@m.FullName</span>
                                        @if (mSel) { <i class="bi bi-check" style="color:#16a34a;margin-left:auto;"></i> }
                                    </div>
                                }
                                <div class="exp-filter-clear" @onclick="() => { expSelectedMemberIds.Clear(); expMemberSearch = string.Empty; }">Clear selection</div>
                            </div>
                        }
                    </div>

                    @* Schedules filter *@
                    <div class="exp-filter-dd-wrap">
                        <button class="exp-filter-chip @(expSchedulesOpen ? "exp-chip--open" : "")"
                                @onclick='() => ToggleExpFilter("schedules")'>
                            Schedules <i class="bi bi-chevron-@(expSchedulesOpen ? "up" : "down")"></i>
                        </button>
                        @if (expSchedulesOpen)
                        {
                            <div class="exp-filter-popup">
                                <div class="exp-filter-search-wrap">
                                    <i class="bi bi-search exp-filter-search-icon"></i>
                                    <input class="exp-filter-search" placeholder="Search schedules"
                                           @bind="expScheduleSearch" @bind:event="oninput" />
                                </div>
                                @{
                                    var sList = availableSchedules.Where(s => string.IsNullOrEmpty(expScheduleSearch) || s.Contains(expScheduleSearch, StringComparison.OrdinalIgnoreCase)).ToList();
                                }
                                @foreach (var s in sList)
                                {
                                    var sCap = s;
                                    bool sSel = expSelectedSchedules.Contains(sCap);
                                    <div class="exp-filter-popup-item @(sSel ? "exp-filter-popup-item--sel" : "")"
                                         @onclick="() => { if (sSel) expSelectedSchedules.Remove(sCap); else expSelectedSchedules.Add(sCap); }">
                                        @s @if (sSel) { <i class="bi bi-check" style="color:#16a34a;margin-left:auto;"></i> }
                                    </div>
                                }
                                <div class="exp-filter-clear" @onclick="() => { expSelectedSchedules.Clear(); expScheduleSearch = string.Empty; }">Clear selection</div>
                            </div>
                        }
                    </div>

                    @* Add filter *@
                    <div class="exp-filter-dd-wrap">
                        <button class="exp-filter-chip exp-chip--add @(expAddFilterOpen ? "exp-chip--open" : "")"
                                @onclick='() => ToggleExpFilter("addfilter")'>
                            <i class="bi bi-plus-lg"></i> Add filter
                        </button>
                        @if (expAddFilterOpen)
                        {
                            <div class="exp-filter-popup">
                                @foreach (var (fVal, fLabel, fActive) in new[]{
                                    ("payroll","Payroll hours", filterPayroll),
                                    ("groups","Groups", filterGroups),
                                    ("members","Members", filterMembers),
                                    ("schedules","Schedules", false),
                                    ("tracked","Tracked hours", false),
                                    ("codes","Member codes", false),
                                    ("positions","Positions", false),
                                    ("employment","Employment types", false)})
                                {
                                    var fv = fVal;
                                    <div class="exp-filter-popup-item exp-af-item">
                                        <span>@fLabel</span>
                                        @if (fActive) { <i class="bi bi-check" style="color:#16a34a;margin-left:auto;"></i> }
                                    </div>
                                }
                                <div class="exp-filter-clear" style="color:#ff7a00;" @onclick="() => expAddFilterOpen = false">Clear selection</div>
                            </div>
                        }
                    </div>
                </div>

                @* ── Time format (custom dropdown) ── *@
                <div class="exp-two-col" style="margin-top:22px;">
                    <div>
                        <div class="exp-section-label">Time format</div>
                        <div class="exp-filter-dd-wrap" @onclick:stopPropagation="true">
                            <button class="exp-custom-select exp-format-select @(expTimeFormatOpen ? "exp-custom-select--open" : "")"
                                    @onclick="() => { expTimeFormatOpen = !expTimeFormatOpen; expDurationFormatOpen = false; }">
                                <span>@(expTimeFormat == "12h" ? "12-hour h:mm am/pm" : "24-hour hh:mm")</span>
                                <span class="exp-format-preview-inline">@(expTimeFormat == "12h" ? "1:30 pm" : "13:30")</span>
                                <i class="bi bi-chevron-@(expTimeFormatOpen ? "up" : "down")"></i>
                            </button>
                            @if (expTimeFormatOpen)
                            {
                                <div class="exp-dd-popup exp-dd-popup--up">
                                    <div class="exp-dd-item @(expTimeFormat == "12h" ? "exp-dd-item--sel" : "")"
                                         @onclick='() => { expTimeFormat = "12h"; expTimeFormatOpen = false; }'>
                                        <span>12-hour h:mm am/pm</span><span class="exp-dd-preview">1:30 pm</span>
                                    </div>
                                    <div class="exp-dd-item @(expTimeFormat == "24h" ? "exp-dd-item--sel" : "")"
                                         @onclick='() => { expTimeFormat = "24h"; expTimeFormatOpen = false; }'>
                                        <span>24-hour hh:mm</span><span class="exp-dd-preview">13:30</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div>
                        <div class="exp-section-label">Duration format</div>
                        <div class="exp-filter-dd-wrap" @onclick:stopPropagation="true">
                            <button class="exp-custom-select exp-format-select @(expDurationFormatOpen ? "exp-custom-select--open" : "")"
                                    @onclick="() => { expDurationFormatOpen = !expDurationFormatOpen; expTimeFormatOpen = false; }">
                                <span>@GetDurationLabel()</span>
                                <span class="exp-format-preview-inline">@GetDurationPreview()</span>
                                <i class="bi bi-chevron-@(expDurationFormatOpen ? "up" : "down")"></i>
                            </button>
                            @if (expDurationFormatOpen)
                            {
                                <div class="exp-dd-popup exp-dd-popup--up">
                                    @foreach (var (dVal, dLabel, dPrev) in new[]{
                                        ("hmm","h:mm","7:50"),
                                        ("hmms","h:mm:ss","7:50:40"),
                                        ("dec2","Decimal h.XX","7.84"),
                                        ("dec4","Decimal h.XXXX","7.8444"),
                                        ("hm","XXh YYm","7h 50m")})
                                    {
                                        var dv = dVal;
                                        <div class="exp-dd-item @(expDurationFormat == dv ? "exp-dd-item--sel" : "")"
                                             @onclick="() => { expDurationFormat = dv; expDurationFormatOpen = false; }">
                                            <span>@dLabel</span><span class="exp-dd-preview">@dPrev</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* ── Learn more ── *@
                <div style="margin-top:20px;">
                    <a href="#" class="exp-learn-link">Learn more about Exporting Timesheets <i class="bi bi-box-arrow-up-right" style="font-size:10px;"></i></a>
                </div>

            </div>

            @* Footer *@
            <div class="exp-modal-footer">
                <button class="tep-footer-cancel" @onclick="CloseExportModal">Cancel</button>
                <button class="tep-footer-save" @onclick="ExecuteExport"
                        disabled="@(expFormat == "csv" && !expIncludeTimesheets && !expIncludeTimeEntries)">
                    Export
                </button>
            </div>

        </div>
    }

    @* ══ DUPLICATE TIMESHEETS MODAL ══ *@
    @if (showDuplicateModal && duplicateTargetRow != null)
    {
        <div class="tep-modal-backdrop" @onclick="CloseDuplicateModal">
            <div class="dup-modal" @onclick:stopPropagation="true">

                @* Header *@
                <div class="dup-modal-header">
                    <span class="dup-modal-title">Duplicate timesheets</span>
                    <button class="tep-close" @onclick="CloseDuplicateModal"><i class="bi bi-x-lg"></i></button>
                </div>

                @* Info notice — sits right under header *@
                <div class="dup-info-box">
                    <i class="bi bi-info-circle dup-info-icon"></i>
                    <span>Duplicated timesheets are independent from original time entries. Changes applied here will only reflect on the new timesheet.</span>
                </div>

                @* Day breakdown *@
                <div class="dup-days-list">
                    @for (int di = 0; di < dupDayBreakdown.Count; di++)
                    {
                        var day = dupDayBreakdown[di];
                        var capturedDi = di;
                        <div class="dup-day-row">

                            @* Left: label + sub *@
                            <div class="dup-day-left">
                                <span class="dup-day-label">@day.Label <i class="bi bi-arrow-right dup-day-arrow"></i></span>
                                <span class="dup-day-sub">Worked hours @day.WorkedHours &nbsp;&nbsp;&nbsp; Break hours @day.BreakHours</span>

                                @* Time entry inputs (shown after clicking +) *@
                                @foreach (var te in day.TimeEntries)
                                {
                                    var capTe = te;
                                    <div class="dup-te-row">
                                        <input type="time" class="dup-te-input"
                                               value="@capTe.ClockIn"
                                               @onchange="e => capTe.ClockIn = e.Value?.ToString() ?? capTe.ClockIn" />
                                        <i class="bi bi-arrow-right" style="color:#9ca3af;font-size:11px;flex-shrink:0;"></i>
                                        <input type="time" class="dup-te-input"
                                               value="@capTe.ClockOut"
                                               @onchange="e => capTe.ClockOut = e.Value?.ToString() ?? capTe.ClockOut" />
                                    </div>
                                }
                            </div>

                            @* Right: dash + plus icon (inline on same row) *@
                            <div class="dup-day-right">
                                <span class="dup-day-dash">-</span>
                                <div class="dup-plus-wrap" @onclick:stopPropagation="true">
                                    <button class="dup-plus-btn"
                                            @onclick="() => { AddDupTimeEntry(capturedDi); dupActivePlusIdx = dupActivePlusIdx == capturedDi ? -1 : capturedDi; }"
                                            title="Add time entry">
                                        +
                                    </button>
                                    @if (dupActivePlusIdx == capturedDi)
                                    {
                                        <button class="dup-add-te-btn"
                                                @onclick="() => { AddDupTimeEntry(capturedDi); dupActivePlusIdx = -1; }"
                                                @onclick:stopPropagation="true">
                                            Add Time Entry
                                        </button>
                                    }
                                </div>
                            </div>

                        </div>
                    }
                </div>

                <div class="dup-modal-footer">
                    <button class="tep-footer-cancel" @onclick="CloseDuplicateModal">Cancel</button>
                    <button class="tep-footer-save" disabled="@(dupToStart == null)">Duplicate</button>
                </div>
            </div>
        </div>
    }

<script>
    window.scrollAmtPickerToSelected = function() {
        setTimeout(function() {
            document.querySelectorAll('.amt-tp-col').forEach(function(col) {
                var sel = col.querySelector('.on');
                if (sel) sel.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            });
        }, 30);
    };
    // Select-all when time input receives focus
    document.addEventListener('focusin', function(e) {
        if (e.target && e.target.classList && e.target.classList.contains('amt-timeinput--main')) {
            setTimeout(function() { e.target.select(); }, 10);
        }
    });
</script>

@* ── Selfie lightbox — clicking the avatar in View Time Entry opens this ── *@
@if (tepSelfieOpen)
{
    <div class="tep-lightbox-backdrop" @onclick="() => { tepSelfieOpen = false; StateHasChanged(); }">
        <div class="tep-lightbox-box" @onclick:stopPropagation="true">
            <div class="tep-lightbox-header">
                <div>
                    <div class="tep-lightbox-title">Captured Face Data</div>
                    <div class="tep-lightbox-sub">
                        @(SessionService.FullName ?? "") - Selfie taken on
                        @if (panelType == "in")
                        {
                            @(viewEntry?.ClockIn.ToString("d MMMM, h:mm tt") ?? "")
                        }
                        else
                        {
                            @(viewEntry?.ClockOut?.ToString("d MMMM, h:mm tt") ?? "")
                        }
                    </div>
                </div>
                <button class="tep-lightbox-close" @onclick="() => { tepSelfieOpen = false; StateHasChanged(); }">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="tep-lightbox-body">
                <img src="@tepSelfieZoomUrl" class="tep-lightbox-img" alt="Selfie photo" />
            </div>
        </div>
    </div>
}

</BasePage>


<style>
    .ts-wrapper {
        display: flex;
        height: calc(100vh - 60px);
        overflow: hidden;
    }

    .ts-init-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
        color: #9ca3af;
        font-size: 14px;
    }

    .ts-spinner {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 2.5px solid #f3f4f6;
        border-top-color: #ff7a00;
        animation: ts-spin .7s linear infinite;
    }

    @@keyframes ts-spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ── Shell ── */
    .tev-shell {
        display: flex;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #f8f9fb;
    }

    /* ── Sidebar ── */
    .tev-sidebar {
        width: 260px;
        flex-shrink: 0;
        background: #fff;
        border-right: 1px solid #e8eaed;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        scrollbar-width: thin;
    }

    .tev-sb-header {
        padding: 24px 20px 16px;
    }

    .tev-sb-label {
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: .8px;
        text-transform: uppercase;
    }

    .tev-sb-range {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        margin-top: 4px;
    }

    .tev-sb-person {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 20px 16px;
    }

    .tev-sb-av {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg,#ff7a00,#ff9a3c);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .tev-sb-name {
        font-size: 14px;
        font-weight: 700;
        color: #111827;
    }

    .tev-sb-tz {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .tev-sb-divider {
        height: 1px;
        background: #f3f4f6;
        margin: 0 20px;
    }

    .tev-sb-meta {
        padding: 14px 20px;
    }

    .tev-sb-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 5px 0;
        gap: 8px;
    }

    .tev-sb-meta-k {
        font-size: 11px;
        color: #9ca3af;
        font-weight: 500;
        flex-shrink: 0;
    }

    .tev-sb-meta-v {
        font-size: 11px;
        color: #374151;
        font-weight: 600;
        text-align: right;
    }

    .tev-sb-section {
        padding: 14px 20px;
    }

    .tev-sb-section-title {
        font-size: 11px;
        font-weight: 700;
        color: #ff7a00;
        letter-spacing: .6px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .tev-sb-stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 0;
        border-bottom: 1px solid #f9fafb;
    }

        .tev-sb-stat-row:last-child {
            border-bottom: none;
        }

    .tev-sb-stat-lbl {
        font-size: 12px;
        color: #6b7280;
    }

    .tev-sb-stat-val {
        font-size: 13px;
        font-weight: 600;
        color: #111827;
    }

    .tev-dash {
        color: #d1d5db !important;
        font-weight: 400 !important;
    }

    .tev-bold {
        font-weight: 800 !important;
        color: #ff7a00 !important;
    }

    /* ── Main panel ── */
    .tev-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: #f8f9fb;
        overflow: hidden;
        min-width: 0;
    }

    .tev-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        background: #fff;
        border-bottom: 1px solid #e8eaed;
        flex-shrink: 0;
    }

    .tev-topbar-left {
    }

    .tev-topbar-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
    }

    .tev-topbar-sub {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .tev-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 18px;
        border-radius: 8px;
        border: none;
        background: #ff7a00;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s;
    }

        .tev-add-btn:hover {
            background: #e66c00;
        }

    .tev-week-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        background: #fff;
        border-bottom: 1px solid #e8eaed;
        flex-shrink: 0;
    }

    .tev-nav-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid #e8eaed;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
        font-size: 13px;
        transition: border-color .15s, color .15s;
        flex-shrink: 0;
    }

        .tev-nav-btn:hover {
            border-color: #ff7a00;
            color: #ff7a00;
        }

    .tev-days-strip {
        display: flex;
        gap: 4px;
        flex: 1;
        justify-content: space-between;
    }

    .tev-day {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        padding: 8px 10px;
        border-radius: 10px;
        border: 1.5px solid transparent;
        background: transparent;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s, border-color .15s;
        position: relative;
        flex: 1;
        min-width: 0;
    }

        .tev-day:hover {
            background: #f9fafb;
            border-color: #e8eaed;
        }

    .tev-day--today {
        background: #fff7ed;
        border-color: #fed7aa;
    }

    .tev-day--sel {
        background: #ff7a00 !important;
        border-color: #ff7a00 !important;
    }

        .tev-day--sel .tev-day-name,
        .tev-day--sel .tev-day-num,
        .tev-day--sel .tev-day-dur {
            color: #fff !important;
        }

    .tev-day-name {
        font-size: 10px;
        font-weight: 600;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .tev-day-num {
        font-size: 17px;
        font-weight: 700;
        color: #111827;
        line-height: 1;
    }

    .tev-day-dur {
        font-size: 10px;
        font-weight: 500;
        color: #d1d5db;
    }

    .tev-day-dur--has {
        color: #ff7a00;
        font-weight: 700;
    }

    .tev-day--sel .tev-day-dur--has {
        color: rgba(255,255,255,.9) !important;
    }

    .tev-day-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #ff7a00;
        margin-top: 1px;
    }

    .tev-day--sel .tev-day-dot {
        background: #fff;
    }

    .tev-date-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 24px;
        background: #f8f9fb;
        border-bottom: 1px solid #e8eaed;
        flex-shrink: 0;
    }

    .tev-date-text {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        flex: 1;
    }

    .tev-entry-count {
        display: inline-flex;
        align-items: center;
        padding: 2px 10px;
        border-radius: 20px;
        background: #fff3e0;
        color: #ff7a00;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid #fed7aa;
    }

    .tev-date-tracked {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
    }

        .tev-date-tracked i {
            color: #ff7a00;
        }

    .tev-entries {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: thin;
        background: #fff;
    }

    .tev-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 60px;
        color: #9ca3af;
        font-size: 14px;
    }

    .tev-spinner {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2.5px solid #f3f4f6;
        border-top-color: #ff7a00;
        animation: ts-spin .7s linear infinite;
    }

    .tev-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 24px;
        gap: 10px;
        text-align: center;
    }

    .tev-empty-title {
        font-size: 16px;
        font-weight: 700;
        color: #374151;
    }

    .tev-empty-sub {
        font-size: 13px;
        color: #9ca3af;
    }

    .tev-empty-cta {
        margin-top: 12px;
    }

    /* ── Entry rows ── */
    .tev-entry-row {
        display: flex;
        align-items: center;
        padding: 14px 20px 14px 16px;
        border-bottom: 1px solid #f3f4f6;
        cursor: pointer;
        transition: background .12s;
        position: relative;
    }

        .tev-entry-row:hover {
            background: #fafafa;
        }

    .tev-entry-row--sel {
        background: #fff7ed !important;
        border-left: 3px solid #ff7a00;
    }

    .tev-entry-row--out {
        background: #fafafa;
    }

    .tev-er-av-cell {
        width: 40px;
        flex-shrink: 0;
        margin-right: 12px;
    }

    .tev-er-time-cell {
        width: 100px;
        flex-shrink: 0;
    }

    .tev-er-badge-cell {
        flex: 1;
    }

    .tev-er-dur-cell {
        width: 80px;
        text-align: right;
        flex-shrink: 0;
    }

    .tev-er-acts-cell {
        width: 68px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 4px;
        opacity: 0;
        transition: opacity .15s;
    }

    .tev-entry-row:hover .tev-er-acts-cell {
        opacity: 1;
    }

    .tev-er-act-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1.5px solid #e8eaed;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 12px;
        color: #6b7280;
        transition: border-color .15s, color .15s, background .15s;
    }

        .tev-er-act-btn:hover {
            border-color: #ff7a00;
            color: #ff7a00;
            background: #fff7ed;
        }

    .tev-er-act-btn--del:hover {
        border-color: #ef4444;
        color: #ef4444;
        background: #fef2f2;
    }

    .tev-av {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg,#ff7a00,#ff9a3c);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 700;
    }

    .tev-av--live {
        background: linear-gradient(135deg,#bbf7d0,#dcfce7);
        color: #166534;
    }

    /* Selfie photo displayed when policy requires face verification / selfies */
    .tev-av--selfie {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #ff7a00;
        flex-shrink: 0;
        display: block;
    }

    .tev-time {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }

    .tev-ampm {
        font-size: 11px;
        font-weight: 500;
        color: #6b7280;
        margin-left: 2px;
    }

    .tev-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid;
        letter-spacing: .2px;
    }

    .tev-badge--in {
        color: #166534;
        background: #f0fdf4;
        border-color: #86efac;
    }

    .tev-badge--out {
        color: #92400e;
        background: #fffbeb;
        border-color: #fde68a;
    }

    .tev-badge--hour {
        color: #5b21b6;
        background: #f5f3ff;
        border-color: #ddd6fe;
    }

    .tev-badge--manual {
        color: #374151;
        background: #f3f4f6;
        border-color: #d1d5db;
        font-size: 10px;
        padding: 2px 7px;
        margin-left: 6px;
    }

    /* ── Overnight carry-over badge & row ── */
    .tev-badge--overnight {
        color: #5b21b6;
        background: #ede9fe;
        border-color: #c4b5fd;
        margin-left: 6px;
    }

    .tev-av--overnight {
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        color: #fff;
        font-size: 14px;
    }

    .tev-entry-row--overnight {
        border-left: 3px solid #a78bfa;
        background: #faf9ff;
    }

    .tev-entry-row--overnight:hover {
        background: #f5f3ff;
    }

    .tev-av--hour {
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        color: #fff;
        font-size: 12px;
    }

    .tev-time--hour {
        font-size: 13px;
        font-weight: 600;
        color: #7c3aed;
    }

    .tev-entry-row--hour {
        background: #faf5ff;
    }

    .tev-entry-row--hour:hover {
        background: #f3e8ff !important;
    }

    .tev-hour-icon {
        font-size: 12px;
        color: #7c3aed;
        margin-right: 4px;
    }

    .tev-dur {
        font-size: 13px;
        font-weight: 700;
        color: #111827;
    }

    .tev-dur-empty {
        font-size: 13px;
        color: #d1d5db;
    }

    .tev-dur-live {
        font-size: 13px;
        font-weight: 700;
        color: #16a34a;
    }

    .tev-entry-sep {
        height: 6px;
        background: #f8f9fb;
    }

    /* ── Accordion panels ── */
    .tev-bottom-panels {
        border-top: 2px solid #f3f4f6;
        background: #fff;
    }

    .tev-accordion {
        border-bottom: 1px solid #e8eaed;
    }

    .tev-accordion-hdr {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 24px;
        background: transparent;
        border: none;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s;
        text-align: left;
    }

        .tev-accordion-hdr:hover {
            background: #fafafa;
        }

    .tev-accordion-hdr-left {
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1;
        min-width: 0;
    }

    .tev-accordion-title {
        font-size: 13px;
        font-weight: 800;
        color: #111827;
        letter-spacing: .4px;
    }

    .tev-accordion-sub {
        font-size: 11px;
        color: #9ca3af;
    }

    .tev-accordion-hdr-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    .tev-accordion-val {
        font-size: 16px;
        font-weight: 800;
        color: #111827;
        font-variant-numeric: tabular-nums;
    }

    .tev-accordion-chevron {
        font-size: 13px;
        color: #9ca3af;
    }

    .tev-accordion-body {
        padding: 4px 24px 20px;
        background: #fafafa;
        border-top: 1px solid #f3f4f6;
    }

    .tev-acc-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 9px 0;
        border-bottom: 1px solid #f3f4f6;
    }

        .tev-acc-row:last-child {
            border-bottom: none;
        }

    .tev-acc-row--total {
        border-top: 1.5px solid #e8eaed;
        margin-top: 4px;
        padding-top: 12px;
        border-bottom: none;
    }

    .tev-acc-lbl {
        font-size: 12px;
        color: #6b7280;
    }

    .tev-acc-lbl--total {
        font-size: 12px;
        font-weight: 700;
        color: #374151;
    }

    .tev-acc-val {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
    }

    .tev-acc-val--total {
        font-size: 15px;
        font-weight: 800;
        color: #ff7a00;
    }

    .tev-acc-highlight {
        color: #16a34a !important;
    }

    .tev-acc-dash {
        color: #d1d5db !important;
        font-weight: 400 !important;
    }

    /* ── Change history badge ── */
    .tev-history-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: #374151;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .tev-history-empty {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 20px;
        color: #9ca3af;
        font-size: 13px;
    }

    /* ── Change history table ── */
    .tev-history-body {
        padding: 0 !important;
    }

    .tev-hist-hdr {
        display: grid;
        grid-template-columns: 1fr 160px 210px;
        padding: 10px 20px;
        background: #f8f9fb;
        border-bottom: 1px solid #e8eaed;
        border-top: 1px solid #e8eaed;
    }

    .tev-hist-hdr-cell {
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .tev-hist-row {
        display: grid;
        grid-template-columns: 1fr 160px 210px;
        padding: 14px 20px;
        border-bottom: 1px solid #f3f4f6;
        align-items: start;
    }

        .tev-hist-row:last-child {
            border-bottom: none;
        }

        .tev-hist-row:hover {
            background: #fafafa;
        }

    .tev-hist-cell {
        display: flex;
        align-items: flex-start;
    }

    .tev-hist-cell--change {
        gap: 10px;
    }

    .tev-hist-av {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        flex-shrink: 0;
        background: linear-gradient(135deg,#ff7a00,#ff9a3c);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
    }

    .tev-hist-who-info {
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1;
    }

    .tev-hist-name-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
        flex-wrap: wrap;
    }

    .tev-hist-who-name {
        font-size: 13px;
        font-weight: 700;
        color: #111827;
    }

    .tev-hist-who-action {
        font-size: 12px;
        color: #6b7280;
    }

    .tev-hist-time-row {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 2px;
    }

    .tev-hist-newtime {
        font-size: 12px;
        font-weight: 600;
        color: #111827;
    }

    .tev-hist-oldtime {
        font-size: 12px;
        color: #9ca3af;
        text-decoration: line-through;
        font-style: italic;
    }

    /* clock-in icon = green, clock-out icon = amber */
    .tev-icon-ci {
        color: #16a34a;
        font-size: 12px;
    }

    .tev-icon-co {
        color: #d97706;
        font-size: 12px;
    }

    .tev-icon-old {
        color: #d1d5db !important;
    }

    /* Clock-in / Clock-out icons in change history rows */
    .tev-hist-entry-icon {
        font-size: 13px;
        flex-shrink: 0;
        line-height: 1;
    }

    .tev-hist-entry-icon--in {
        color: #16a34a;
    }

    .tev-hist-entry-icon--out {
        color: #d97706;
    }

    .tev-arrow-faded {
        color: #d1d5db !important;
    }

    .tev-hist-cell--reason {
        padding-top: 2px;
    }

    .tev-hist-reason-text {
        font-size: 13px;
        color: #374151;
        font-weight: 500;
    }

    .tev-hist-reason-empty {
        font-size: 13px;
        color: #d1d5db;
    }

    .tev-hist-cell--ts {
        padding-top: 2px;
    }

    .tev-hist-ts-text {
        font-size: 12px;
        color: #6b7280;
        font-weight: 500;
    }

    /* ══ SIDE PANEL ══ */

    /* Full-screen dim — covers sidebar + page content behind the panel */
    .tep-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1100;
        background: rgba(0, 0, 0, 0.45);
        cursor: default;
    }

    .tep-panel {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: 390px; z-index: 1200;
        background: #fff;
        box-shadow: -2px 0 24px rgba(0,0,0,.12);
        display: flex; flex-direction: column;
        animation: tep-slide-in .2s ease;
    }
    @@keyframes tep-slide-in {
        from { transform: translateX(100%); opacity: 0; }
        to   { transform: translateX(0);   opacity: 1; }
    }

    /* Header */
    .tep-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 24px 18px;
        border-bottom: 1px solid #e8eaed;
    }
    .tep-title { font-size: 18px; font-weight: 700; color: #111827; }
    .tep-close {
        width: 30px; height: 30px; border-radius: 6px;
        border: none; background: transparent;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 16px; color: #6b7280;
        transition: color .15s;
    }
    .tep-close:hover { color: #111827; }

    /* Body */
    .tep-body { flex: 1; overflow-y: auto; padding: 20px 24px; }

    /* Profile block */
    .tep-profile-block {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 14px;
        margin-bottom: 20px;
    }
    .tep-profile-left { display: flex; align-items: flex-start; gap: 14px; flex: 1; }
    .tep-member-av {
        width: 52px; height: 52px; border-radius: 50%;
        background: #e5e7eb; color: #374151;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; font-weight: 700; flex-shrink: 0;
    }
    .tep-member-info { display: flex; flex-direction: column; gap: 2px; }
    .tep-member-name { font-size: 15px; font-weight: 700; color: #111827; }
    .tep-member-sub  { font-size: 12px; color: #6b7280; }
    .tep-member-device { margin-top: 4px; font-size: 14px; color: #d1d5db; }
    .tep-member-device-row { margin-top: 6px; }
    .tep-device-icon { font-size: 15px; color: #d1d5db; }

    /* Pencil — VIEW mode only */
    .tep-edit-pencil {
        width: 32px; height: 32px; border-radius: 6px;
        border: 1.5px solid #e8eaed; background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 13px; color: #6b7280; flex-shrink: 0;
        transition: border-color .15s, color .15s, background .15s;
    }
    .tep-edit-pencil:hover { border-color: #ff7a00; color: #ff7a00; background: #fff7ed; }

    /* Divider */
    .tep-divider { height: 1px; background: #e8eaed; margin: 0 0 20px; }

    /* VIEW mode: time row */
    .tep-view-row {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 16px;
        border: 1.5px solid #e8eaed; border-radius: 10px;
        background: #fff;
    }
    .tep-view-icon-wrap { display: flex; align-items: center; }
    .tep-view-icon { font-size: 16px; }
    .tep-view-icon--in  { color: #22c55e; }
    .tep-view-icon--out { color: #6b7280; }
    .tep-view-time {
        font-size: 18px; font-weight: 700; color: #111827;
        font-variant-numeric: tabular-nums;
    }
    .tep-view-pipe { font-size: 16px; color: #d1d5db; margin: 0 2px; }
    .tep-view-date-lbl { font-size: 15px; font-weight: 600; color: #111827; }

    /* EDIT mode: fields */
    .tep-edit-field {
        display: flex; align-items: center;
        border: 1.5px solid #e8eaed; border-radius: 10px;
        background: #fff; margin-bottom: 10px;
        transition: border-color .15s; position: relative;
    }
    .tep-edit-field:focus-within { border-color: #ff7a00; }
    .tep-field--active { border-color: #ff7a00 !important; }

    .tep-edit-field--time { padding: 14px 16px; justify-content: space-between; cursor: pointer; }
    .tep-edit-field--date { padding: 14px 16px; justify-content: space-between; cursor: pointer; }
    .tep-edit-field--date:hover { border-color: #d1d5db; }
    .tep-edit-field--select { padding: 0; justify-content: space-between; overflow: hidden; }
    .tep-edit-field--note { padding: 0; align-items: stretch; }

    /* Time display — no native input, just a styled span */
    .tep-time-display {
        font-size: 22px; font-weight: 700; color: #111827;
        font-variant-numeric: tabular-nums; letter-spacing: 0.5px;
        flex: 1;
    }

    /* GMT badge */
    .tep-tz-badge { display: inline-flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .tep-tz-circle {
        width: 28px; height: 28px; border-radius: 50%;
        border: 1.5px solid #e8eaed;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; color: #6b7280;
    }
    .tep-tz-text { font-size: 13px; font-weight: 600; color: #374151; }

    /* Date label */
    .tep-date-label { font-size: 15px; font-weight: 600; color: #111827; flex: 1; min-width: 0; }

    /* Select dropdowns */
    .tep-select-native {
        font-size: 14px; color: #374151;
        border: none; background: transparent; outline: none;
        font-family: inherit; flex: 1; width: 100%;
        padding: 14px 16px; cursor: pointer;
        appearance: none; -webkit-appearance: none;
    }

    /* Note textarea */
    .tep-note-native {
        font-size: 14px; color: #374151;
        border: none; background: transparent; outline: none;
        font-family: inherit; width: 100%; resize: none;
        padding: 14px 16px; min-height: 100px; border-radius: 10px;
    }
    .tep-note-native::placeholder { color: #9ca3af; }

    .tep-field-icon { font-size: 16px; color: #9ca3af; flex-shrink: 0; pointer-events: none; }

    /* ── Custom Time Picker ── */
    .tep-timepicker {
        display: flex; gap: 0;
        border: 1.5px solid #e8eaed; border-radius: 10px;
        background: #fff; margin-bottom: 10px;
        overflow: hidden;
    }
    .tep-tp-col {
        flex: 1; max-height: 200px; overflow-y: auto;
        scrollbar-width: thin; scrollbar-color: #e8eaed transparent;
        border-right: 1px solid #f3f4f6;
    }
    .tep-tp-col:last-child { border-right: none; }
    .tep-tp-col--ampm { flex: 0 0 64px; }
    .tep-tp-cell {
        padding: 10px 0; text-align: center;
        font-size: 14px; font-weight: 500; color: #374151;
        cursor: pointer; transition: background .1s, color .1s;
    }
    .tep-tp-cell:hover { background: #f9fafb; }
    .tep-tp-cell--sel {
        background: #e8eaed !important;
        font-weight: 700; color: #111827;
        border-radius: 4px;
    }

    /* ── Custom Calendar — compact ── */
    .tep-calendar {
        background: #fff; border: 1.5px solid #e8eaed; border-radius: 12px;
        padding: 12px; margin-bottom: 10px;
        box-shadow: 0 4px 16px rgba(0,0,0,.07);
    }
    .tep-cal-nav { display: flex; align-items: center; gap: 2px; margin-bottom: 10px; }
    .tep-cal-nav-btn {
        width: 24px; height: 24px; border-radius: 5px;
        border: none; background: transparent; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; color: #6b7280; transition: background .15s;
    }
    .tep-cal-nav-btn:hover { background: #f3f4f6; color: #111827; }
    .tep-cal-month-label { flex: 1; font-size: 13px; font-weight: 700; color: #111827; text-align: center; }
    .tep-cal-year-label  { flex: 1; font-size: 13px; font-weight: 700; color: #111827; text-align: center; }
    .tep-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; }
    .tep-cal-dow { font-size: 10px; font-weight: 600; color: #9ca3af; text-align: center; padding: 3px 0 6px; }
    .tep-cal-cell {
        aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
        border-radius: 50%; font-size: 12px; font-weight: 500; color: #111827;
        cursor: pointer; transition: background .12s, color .12s;
    }
    .tep-cal-cell:hover { background: #f3f4f6; }
    .tep-cal-cell--today { color: #ff7a00; font-weight: 700; }
    .tep-cal-cell--sel { background: #ff7a00 !important; color: #fff !important; font-weight: 700; }
    .tep-cal-cell--future { color: #d1d5db; cursor: default; }
    .tep-cal-cell--future:hover { background: transparent; }
    .tep-cal-cell--empty { cursor: default; }

    .tep-error {
        background: #fef2f2; border: 1px solid #fecaca;
        border-radius: 8px; padding: 10px 14px;
        font-size: 13px; color: #dc2626; margin-top: 12px;
    }

    /* ── Location row (view mode) ── */
    .tep-location-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 14px 16px;
        border: 1.5px solid #e8eaed;
        border-radius: 10px;
        background: #fff;
        margin-top: 10px;
    }
    .tep-loc-icon { font-size: 16px; color: #9ca3af; margin-top: 1px; flex-shrink: 0; }
    .tep-loc-info { display: flex; flex-direction: column; gap: 3px; flex: 1; }
    .tep-loc-name { font-size: 15px; font-weight: 600; color: #111827; }
    .tep-loc-none { font-size: 14px; color: #9ca3af; }
    .tep-view-location-link {
        font-size: 13px; color: #ff7a00; text-decoration: none; font-weight: 600;
    }
    .tep-view-location-link:hover { text-decoration: underline; }

    /* ── Location icon in edit select field ── */
    .tep-edit-field--select .bi-geo-alt {
        color: #9ca3af;
        font-size: 15px;
        flex-shrink: 0;
    }

    /* Footer */
    .tep-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; border-top: 1px solid #e8eaed; background: #fff;
    }
    .tep-footer-right { display: flex; gap: 10px; }
    .tep-footer-del {
        background: transparent; border: none; cursor: pointer;
        font-size: 14px; font-weight: 600; color: #ff7a00;
        font-family: inherit; padding: 8px 0; transition: color .15s;
    }
    .tep-footer-del:hover { color: #e66c00; }
    .tep-footer-cancel {
        padding: 9px 20px; border-radius: 8px;
        border: 1.5px solid #e8eaed; background: #fff;
        font-size: 14px; font-weight: 600; color: #374151;
        cursor: pointer; font-family: inherit; transition: border-color .15s;
    }
    .tep-footer-cancel:hover { border-color: #9ca3af; }
    .tep-footer-save {
        padding: 9px 24px; border-radius: 8px; border: none;
        background: #ff7a00; color: #fff;
        font-size: 14px; font-weight: 700; cursor: pointer;
        font-family: inherit; transition: background .15s;
    }
    .tep-footer-save:hover:not(:disabled) { background: #e66c00; }
    .tep-footer-save:disabled { opacity: .6; cursor: not-allowed; }

    /* ── Modals ── */
    /* ══════════════════════════════════════════════════════
       ADD MANUAL TIME ENTRY  (amt-)
    ════════════════════════════════════════════════════════ */
    /* ══════════════════════════════════════════
       ADD MANUAL TIME ENTRY PANEL — full restyle
       ══════════════════════════════════════════ */

    /* Backdrop */
    .amt-backdrop {
        position: fixed; inset: 0; z-index: 1400;
        background: rgba(0,0,0,.4);
        display: flex; align-items: flex-start; justify-content: flex-end;
    }

    /* Panel */
    .amt-panel {
        width: 420px; max-width: 100vw;
        height: 100vh;
        background: #fff;
        display: flex; flex-direction: column;
        box-shadow: -6px 0 40px rgba(0,0,0,.18);
        animation: amt-slide .22s cubic-bezier(.4,0,.2,1);
        overflow: hidden;
    }
    @@keyframes amt-slide {
        from { transform: translateX(100%); }
        to   { transform: translateX(0); }
    }

    /* ── Header ── */
    .amt-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 22px 24px 18px;
        border-bottom: none;
        flex-shrink: 0;
    }
    .amt-title {
        font-size: 20px; font-weight: 700; color: #111827; letter-spacing: -.2px;
    }
    .amt-close {
        width: 32px; height: 32px; border: none; background: transparent;
        cursor: pointer; font-size: 18px; color: #9ca3af;
        display: flex; align-items: center; justify-content: center;
        border-radius: 6px; transition: color .15s;
    }
    .amt-close:hover { color: #374151; }

    /* ── Scrollable body ── */
    .amt-body {
        flex: 1; padding: 0 24px 8px;
        overflow-y: auto;
        scrollbar-width: thin;
    }

    /* ── Profile row ── */
    .amt-profile {
        display: flex; align-items: center; gap: 18px; margin-bottom: 20px; padding: 4px 0;
    }
    .amt-av {
        width: 64px; height: 64px; border-radius: 50%;
        background: #e5e7eb; color: #6b7280;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; font-weight: 700; flex-shrink: 0;
        border: none;
    }
    .amt-info { display: flex; flex-direction: column; gap: 3px; }
    .amt-name { font-size: 15px; font-weight: 700; color: #111827; letter-spacing: .1px; }
    .amt-sub  { font-size: 12px; color: #6b7280; line-height: 1.5; }

    .amt-divider {
        border: none; border-top: 1px solid #ebebeb; margin: 0 0 0;
    }

    /* ── Tabs ── */
    .amt-tabs {
        display: flex;
        border-bottom: 1.5px solid #ebebeb;
        margin-top: 16px;
        margin-bottom: 16px;
    }
    .amt-tab {
        flex: 1; padding: 10px 4px 11px; border: none; background: transparent;
        font-size: 14px; font-weight: 500; color: #9ca3af;
        cursor: pointer;
        border-bottom: 2.5px solid transparent;
        margin-bottom: -1.5px;
        display: flex; align-items: center; justify-content: center; gap: 5px;
        transition: color .15s; font-family: inherit;
    }
    .amt-tab--active { color: #f97316; border-bottom-color: #f97316; font-weight: 700; }
    .amt-tab-icon { font-size: 12px; color: #c4c4c4; }

    /* ── In / Break / Out toggle ── */
    .amt-type-row {
        display: grid; grid-template-columns: 1fr 1fr 1fr;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        overflow: hidden; margin-bottom: 14px;
    }
    .amt-type-btn {
        padding: 12px 4px; border: none; background: #fff;
        font-size: 14px; font-weight: 500; color: #374151;
        cursor: pointer; transition: background .15s, color .15s;
        font-family: inherit;
    }
    .amt-type-btn + .amt-type-btn { border-left: 1.5px solid #e5e7eb; }
    /* Active: orange border inset + light orange fill */
    .amt-type-btn--active {
        background: #fff7f0;
        color: #f97316;
        font-weight: 700;
        box-shadow: inset 0 0 0 2px #f97316;
    }

    /* ── Generic field ── */
    .amt-field {
        display: flex; align-items: center; flex-wrap: wrap;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        padding: 12px 14px; margin-bottom: 10px;
        background: #fff; gap: 8px;
        cursor: pointer;
        transition: border-color .15s;
        position: relative;
    }
    .amt-field:focus-within { border-color: #f97316; }
    .amt-field--err  { border-color: #ef4444 !important; }
    .amt-field--note { align-items: flex-start; cursor: text; }
    .amt-field--half { flex: 1; margin-bottom: 0; }
    .amt-field--select { cursor: pointer; }

    /* Field text (displayed value) */
    .amt-field-text {
        flex: 1; font-size: 15px; font-weight: 600; color: #111827;
        pointer-events: none; white-space: nowrap;
    }
    .amt-field-text--time { color: #111827; }

    /* Right-side icon */
    .amt-field-icon {
        color: #9ca3af; font-size: 16px; flex-shrink: 0; margin-left: auto;
    }

    /* Timezone badge in time field */
    .amt-tz {
        font-size: 12px; color: #9ca3af; flex-shrink: 0; margin-right: 4px;
    }

    /* ── Native time/date inputs inside fields ── */
    .amt-inp {
        flex: 1; border: none; outline: none; background: transparent;
        font-family: inherit; font-size: 15px; font-weight: 600;
        color: #111827; min-width: 0; cursor: pointer;
        -webkit-appearance: none; appearance: none;
    }
    /* Hide the default browser spinner/calendar icon (we show our own BI icon) */
    .amt-inp::-webkit-calendar-picker-indicator { opacity: 0; width: 0; padding: 0; }
    .amt-inp::-webkit-inner-spin-button          { display: none; }
    .amt-inp--time { min-width: 80px; }
    .amt-inp--date { min-width: 110px; font-weight: 500; }

    /* ── Native time/date pickers — obsolete class, kept for safety ── */
    .amt-native-picker { display: none; }

    /* amt-save-err */
    .amt-save-err {
        width: 100%; font-size: 12.5px; color: #dc2626;
        background: #fef2f2; border: 1px solid #fecaca;
        border-radius: 8px; padding: 8px 12px;
        display: flex; align-items: center; gap: 7px;
    }
    .amt-save-err i { flex-shrink: 0; font-size: 13px; }

    /* Note textarea */
    .amt-note {
        flex: 1; border: none; outline: none; background: transparent;
        font-size: 14px; color: #374151; resize: none;
        min-height: 68px; font-family: inherit; cursor: text;
        width: 100%;
    }
    .amt-note::placeholder { color: #9ca3af; }
    .amt-note-icon {
        font-size: 13px; color: #c4c4c4; flex-shrink: 0;
        align-self: flex-end; margin-top: 4px;
    }

    /* Select inside field */
    .amt-select {
        flex: 1; border: none; outline: none; background: transparent;
        font-size: 15px; font-weight: 500; color: #111827;
        cursor: pointer; appearance: none; min-width: 0;
    }
    .amt-select option[value=""] { color: #9ca3af; }

    /* Break row */
    .amt-break-row {
        display: flex; gap: 10px; margin-bottom: 10px;
    }

    /* Error message inside field */
    .amt-err-msg {
        width: 100%; flex-basis: 100%;
        font-size: 11.5px; color: #ef4444;
        margin-top: 3px; line-height: 1.4;
    }

    /* Info box */
    .amt-info-box {
        background: #f9fafb; border-radius: 8px;
        padding: 10px 12px; margin: 0 0 12px;
        font-size: 12.5px; color: #6b7280; line-height: 1.55;
        display: flex; gap: 9px; align-items: flex-start;
    }
    .amt-info-icon { color: #9ca3af; flex-shrink: 0; margin-top: 1px; font-size: 14px; }

    /* End work checkbox */
    .amt-endwork {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; color: #374151; cursor: pointer;
        margin: 6px 0 4px;
    }
    .amt-endwork-cb { accent-color: #f97316; width: 16px; height: 16px; cursor: pointer; }

    /* Hour entry */
    .amt-hour-row {
        display: flex; gap: 10px; margin-bottom: 0;
    }
    .amt-field--hour {
        display: flex; align-items: center; gap: 4px; flex: 1;
    }
    .amt-hour-box {
        display: flex; align-items: center; gap: 6px;
        border: 1.5px solid #d1d5db; border-radius: 10px;
        padding: 10px 14px; flex: 1; background: #fff;
        cursor: default; transition: border-color .15s;
    }
    .amt-hour-box--active { border-color: #f97316; }
    .amt-hour-seg {
        min-width: 36px; font-size: 22px; font-weight: 700; color: #111827;
        text-align: center; border-radius: 4px; padding: 1px 3px;
        cursor: pointer; outline: none; user-select: none;
        transition: background .12s, color .12s;
    }
    .amt-hour-seg--on {
        background: #0066ff; color: #fff;
    }
    .amt-hour-seg:hover:not(.amt-hour-seg--on) { background: #f3f4f6; }
    .amt-hour-clock {
        margin-left: auto; color: #9ca3af; font-size: 14px;
    }
    .amt-hm { font-size: 15px; font-weight: 600; color: #6b7280; }

    /* Add new / Duplicate / Delete row — legacy kept for safety */
    .amt-actions { display:none; }
    .amt-action-btn { display:none; }
    .amt-action-btn--del { display:none; }

    /* Cancel / Save buttons */
    .amt-cancel {
        padding: 10px 24px; border: 1.5px solid #e5e7eb; border-radius: 8px;
        background: transparent; font-size: 14px; font-weight: 600; color: #374151;
        cursor: pointer; transition: border-color .15s; font-family:inherit;
    }
    .amt-cancel:hover { border-color: #9ca3af; }
    .amt-save {
        padding: 10px 32px; border: none; border-radius: 8px;
        background: #f97316; color: #fff;
        font-size: 14px; font-weight: 700; cursor: pointer;
        transition: background .15s; font-family:inherit;
    }
    .amt-save:hover:not(:disabled) { background: #ea6c00; }
    .amt-save:disabled { opacity: .6; cursor: not-allowed; }

    /* ── Add entry: time input ── */
    .tep-time-input {
        background: none; border: none; outline: none;
        font-size: 16px; font-weight: 600; color: #111827;
        width: 100%; cursor: pointer;
    }
    /* ── Break times row ── */
    .tep-break-times {
        display: flex; gap: 10px; margin-bottom: 0;
    }
    /* ── Error field ── */
    .tep-field--error .tep-edit-field { border-color: #ef4444; }
    .tep-error-msg {
        color: #ef4444; font-size: 11px; margin-top: 3px;
        position: absolute; bottom: -18px; left: 0;
    }
    /* ── Info box ── */
    .tep-info-box {
        background: #f9fafb; border-radius: 8px;
        padding: 10px 12px; margin: 10px 0 12px;
        font-size: 12px; color: #6b7280; line-height: 1.5;
        display: flex; gap: 8px;
    }
    .tep-info-box i { font-size: 14px; color: #9ca3af; flex-shrink: 0; margin-top: 1px; }
    /* ── End work checkbox ── */
    .tep-endwork-row {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; color: #374151; cursor: pointer;
        margin: 12px 0 4px;
    }
    .tep-endwork-cb { accent-color: #f97316; width: 16px; height: 16px; cursor: pointer; }
    /* ── Hour entry row ── */
    .tep-hour-row { display: flex; gap: 10px; }
    .tep-hour-field { display: flex; align-items: center; gap: 4px; flex: 1; }
    .tep-hour-date { flex: 1; }
    .tep-hour-input {
        width: 42px; background: none; border: none; outline: none;
        font-size: 16px; font-weight: 700; color: #111827;
        text-align: center;
    }
    .tep-hour-input::-webkit-inner-spin-button { display: none; }
    .tep-hm-label { font-size: 14px; font-weight: 600; color: #6b7280; }
    /* ── Block actions: Add new / Duplicate ── */
    .tep-block-actions {
        display: flex; gap: 20px; padding: 8px 0 4px;
    }
    .tep-action-link {
        background: none; border: none; cursor: pointer;
        color: #f97316; font-size: 13px; font-weight: 600;
        display: flex; align-items: center; gap: 5px;
        padding: 0; transition: color .15s;
    }
    .tep-action-link:hover { color: #e66c00; }

    .tep-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1300;
        background: rgba(0,0,0,.45);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tep-modal {
        background: #fff;
        border-radius: 16px;
        padding: 28px;
        width: 460px;
        max-width: calc(100vw - 32px);
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        animation: tep-modal-in .2s ease;
    }

    @@keyframes tep-modal-in {
        from {
            transform: scale(.95);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .tep-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .tep-modal-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
    }

    .tep-modal-sub {
        font-size: 13px;
        color: #6b7280;
        margin: 0 0 16px;
        line-height: 1.5;
    }

    .tep-modal-ta {
        margin-bottom: 8px;
    }

    .tep-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 16px;
    }

    /* ══ TIMESHEETS LIST ══ */
    .dtl-page { display:flex;flex-direction:column;width:100%;height:100%;background:#f8f9fb;overflow:hidden;position:relative; }

    .apv-period-label { font-size:14px; font-weight:500; color:#374151; padding-left:4px; }
    /* ── Top tab bar ── */
    .dtl-topbar { display:flex;align-items:center;justify-content:space-between;padding:0 32px;background:#fff;border-bottom:1px solid #eaedf0;flex-shrink:0;height:52px; }
    .dtl-tabs { display:flex;height:100%;gap:4px; }
    .dtl-tab { padding:0 18px;border:none;background:transparent;font-size:13px;font-weight:500;color:#9ca3af;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;font-family:inherit;letter-spacing:.1px;transition:color .15s; }
    .dtl-tab:hover { color:#374151; }
    .dtl-tab--active { color:#ff7a00 !important;border-bottom-color:#ff7a00 !important;font-weight:700; }
    .dtl-topbar-right { display:flex;align-items:center; }
    .dtl-view-toggle { display:flex;background:#f3f4f6;border-radius:8px;padding:3px;gap:2px; }
    .dtl-vtbtn { padding:5px 14px;border:none;background:transparent;font-size:12px;font-weight:500;color:#6b7280;cursor:pointer;font-family:inherit;border-radius:6px;transition:all .15s; }
    .dtl-vtbtn:hover { color:#374151; }
    .dtl-vtbtn--active { background:#fff !important;color:#111827 !important;font-weight:600;box-shadow:0 1px 4px rgba(0,0,0,.1); }

    /* ── Controls row ── */
    .dtl-controls { display:flex;align-items:center;justify-content:space-between;padding:12px 32px;background:#fff;border-bottom:1px solid #eaedf0;flex-shrink:0; }
    .dtl-controls-left { display:flex;align-items:center;gap:8px; }
    .dtl-controls-right { display:flex;align-items:center;gap:8px; }
    .dtl-view-dropdown-wrap { position:relative; }
    .dtl-view-label { display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border:none;background:transparent;font-size:16px;font-weight:700;color:#0f172a;cursor:pointer;font-family:inherit;border-radius:6px;transition:background .12s; }
    .dtl-view-label:hover { background:#f3f4f6; }
    .dtl-chevron { font-size:10px;color:#9ca3af; }
    .dtl-view-dropdown { position:absolute;top:calc(100% + 6px);left:0;background:#fff;border:1px solid #eaedf0;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:400;min-width:200px;padding:6px; }
    .dtl-vd-item { display:flex;align-items:center;justify-content:space-between;padding:10px 14px;font-size:13px;color:#374151;cursor:pointer;border-radius:6px; }
    .dtl-vd-item:hover { background:#f8f9fb; }
    .dtl-vd-item--active { font-weight:600;color:#0f172a; }
    .dtl-vd-check { color:#ff7a00;font-size:14px; }

    /* ── Date nav ── */
    .dtl-date-nav { display:flex;align-items:center;gap:4px;background:#f3f4f6;border-radius:8px;padding:3px 8px; }
    .dtl-nav-btn { width:26px;height:26px;border-radius:6px;border:none;background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#6b7280;font-size:11px;flex-shrink:0;transition:all .12s; }
    .dtl-nav-btn:hover { background:#fff;color:#111827;box-shadow:0 1px 4px rgba(0,0,0,.1); }
    .dtl-date-label { font-size:13px;font-weight:600;color:#374151;padding:0 6px;min-width:120px;text-align:center; }
    .dtl-cal-wrap { position:relative;margin-left:2px; }
    .dtl-cal-icon { color:#9ca3af;font-size:16px;cursor:pointer;vertical-align:middle;padding:2px; }
    .dtl-cal-icon:hover { color:#ff7a00; }

    /* Full-screen backdrop so clicking outside closes the picker */
    .dtl-cal-backdrop { position:fixed;inset:0;z-index:498;background:transparent; }

    /* Picker popup */
    .dtl-cal-picker { position:absolute;top:calc(100% + 8px);left:50%;transform:translateX(-50%);background:#fff;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.15);z-index:499;padding:18px 16px;min-width:280px;width:300px; }

    /* Nav row: ‹ Month › ‹ Year › */
    .dtl-cal-picker-nav { display:flex;align-items:center;justify-content:center;gap:4px;margin-bottom:12px; }
    .dtl-cal-picker-nav--year { justify-content:space-between;margin-bottom:16px; }
    .dtl-cal-month-label { font-size:15px;font-weight:600;color:#111827;min-width:80px;text-align:center; }
    .dtl-cal-year { font-size:15px;font-weight:600;color:#111827;min-width:46px;text-align:center; }
    .dtl-cal-nav-btn { width:26px;height:26px;border-radius:6px;border:none;background:transparent;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;color:#6b7280; }
    .dtl-cal-nav-btn:hover { background:#f3f4f6;color:#111; }

    /* Monthly picker — 3-column month grid */
    .dtl-cal-months { display:grid;grid-template-columns:repeat(3,1fr);gap:8px; }
    .dtl-cal-month-cell { padding:10px 6px;text-align:center;border-radius:8px;font-size:14px;font-weight:500;color:#374151;cursor:pointer; }
    .dtl-cal-month-cell:hover { background:#f3f4f6; }
    .dtl-cal-month--sel { background:#ff7a00!important;color:#fff!important;font-weight:700; }
    .dtl-cal-month--today { color:#ff7a00;font-weight:700; }

    /* Day-of-week header row */
    .dtl-cal-dow-row { display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px; }
    .dtl-cal-dow { text-align:center;font-size:11px;font-weight:500;color:#9ca3af;padding:4px 0; }

    /* Day grid */
    .dtl-cal-grid { display:grid;grid-template-columns:repeat(7,1fr);gap:2px; }
    .dtl-cal-blank { height:34px; }
    .dtl-cal-day { height:34px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:400;color:#374151;border-radius:50%;cursor:pointer;transition:background .12s; }
    .dtl-cal-day:hover { background:#f3f4f6; }
    .dtl-cal-day--today { color:#ff7a00;font-weight:700; }
    .dtl-cal-day--sel { background:#ff7a00!important;color:#fff!important;font-weight:700;border-radius:50%; }
    .dtl-cal-day--inrange { background:#fff0e5;border-radius:0;color:#111827; }

    /* ══ EXPORT PANEL (right-side slide-in) ══ */
    .exp-backdrop { position:fixed;inset:0;z-index:1200;background:rgba(0,0,0,.25); }
    .exp-panel {
        position:fixed;top:0;right:0;bottom:0;z-index:1201;
        width:740px;max-width:100vw;
        background:#fff;
        display:flex;flex-direction:column;
        box-shadow:-8px 0 40px rgba(0,0,0,.15);
        animation:exp-slide-in .22s ease;
    }
    @@keyframes exp-slide-in { from { transform:translateX(100%); } to { transform:translateX(0); } }

    .exp-modal-header { display:flex;align-items:center;justify-content:space-between;padding:28px 36px 24px;border-bottom:1px solid #f0f0f0;flex-shrink:0; }
    .exp-modal-title { font-size:20px;font-weight:700;color:#111827; }
    .exp-modal-body { padding:28px 36px;overflow-y:auto;overflow-x:visible;flex:1; }
    .exp-modal-footer { display:flex;align-items:center;justify-content:flex-end;gap:12px;padding:18px 36px;border-top:1px solid #f0f0f0;flex-shrink:0; }

    .exp-section-label { font-size:13px;font-weight:500;color:#374151;margin-bottom:10px; }

    /* ── File format cards ── */
    .exp-format-row { display:flex;gap:16px;margin-bottom:4px; }
    .exp-format-card {
        position:relative;border:1.5px solid #e5e7eb;border-radius:12px;
        padding:16px 24px 16px 20px;cursor:pointer;
        display:flex;flex-direction:row;align-items:center;gap:16px;
        min-width:140px;transition:border-color .15s,background .15s;background:#fff;
    }
    .exp-format-card--sel { border-color:#ff7a00;background:#fff8f3; }
    .exp-format-radio-wrap { position:absolute;top:10px;right:10px;font-size:18px; }
    .exp-radio-dot { width:18px;height:18px;border:2px solid #d1d5db;border-radius:50%;background:#fff; }
    .exp-radio-dot--sel { border-color:#ff7a00;background:#ff7a00; }
    .exp-format-check--green { color:#16a34a;font-size:18px; }
    /* File icon mimicking PDF look */
    .exp-format-file { display:flex;align-items:center;justify-content:center; }
    .exp-file-icon {
        width:56px;height:68px;border-radius:4px;
        border:1.5px solid #e5e7eb;background:#fff;
        display:flex;flex-direction:column;align-items:center;justify-content:flex-end;
        padding-bottom:6px;position:relative;
    }
    .exp-file-icon::before { content:'';position:absolute;top:0;right:0;width:14px;height:14px;background:#e5e7eb;border-bottom-left-radius:4px; }
    .exp-file-icon--xls { border-color:#bbf7d0; }
    .exp-file-icon--xls::before { background:#bbf7d0; }
    .exp-file-icon--csv { border-color:#bbf7d0; }
    .exp-file-icon--csv::before { background:#bbf7d0; }
    .exp-file-lines { display:flex;flex-direction:column;gap:3px;width:32px;margin-bottom:4px; }
    .exp-file-lines span { height:2px;background:#d1fae5;border-radius:1px;display:block; }
    .exp-file-label { font-size:12px;font-weight:700;color:#16a34a; }

    /* ── Checkboxes ── */
    .exp-check-list { display:flex;flex-direction:column;gap:12px; }
    .exp-check-row { display:flex;align-items:center;gap:10px;font-size:14px;color:#374151;cursor:pointer; }
    .exp-checkbox { width:16px;height:16px;border-radius:3px;cursor:pointer;flex-shrink:0;accent-color:#ff7a00; }
    .exp-checkbox--green { accent-color:#16a34a; }

    /* ── Date range row ── */
    .exp-date-row { display:flex;gap:12px;align-items:stretch; }
    .exp-custom-select-wrap { position:relative;flex:1; }
    .exp-date-cal-wrap { flex:2; }
    .exp-custom-select {
        width:100%;display:flex;align-items:center;justify-content:space-between;gap:8px;
        padding:11px 14px;border:1.5px solid #e5e7eb;border-radius:10px;
        background:#fff;font-size:14px;color:#374151;
        cursor:pointer;font-family:inherit;text-align:left;
    }
    .exp-custom-select:hover { border-color:#9ca3af; }
    .exp-custom-select--open { border-color:#ff7a00; }
    .exp-date-display-btn { background:#f9fafb; }

    /* Period + date dropdowns */
    .exp-dd-popup {
        position:absolute;top:calc(100% + 6px);left:0;
        background:#fff;border:1px solid #e5e7eb;border-radius:10px;
        box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:1500;min-width:100%;
        max-height:260px;overflow-y:auto;
    }
    .exp-dd-popup--up { top:auto;bottom:calc(100% + 6px); }
    .exp-dd-item {
        display:flex;align-items:center;gap:8px;padding:11px 16px;
        font-size:14px;color:#374151;cursor:pointer;
    }
    .exp-dd-item:hover { background:#f9fafb; }
    .exp-dd-item--sel { background:#fff8f3;color:#ff7a00;font-weight:600; }
    .exp-dd-preview { margin-left:auto;color:#9ca3af;font-size:13px; }

    /* ── Export calendar popup ── */
    .exp-cal-popup {
        position:absolute;top:calc(100% + 6px);left:0;
        background:#fff;border:1px solid #e5e7eb;border-radius:12px;
        box-shadow:0 8px 32px rgba(0,0,0,.14);z-index:1500;
        padding:16px;min-width:300px;
    }
    .exp-cal-nav { display:flex;align-items:center;gap:2px;margin-bottom:12px; }
    .exp-cal-month-lbl { font-size:14px;font-weight:600;color:#111827;flex:1;text-align:center; }
    .exp-cal-year-lbl  { font-size:14px;font-weight:600;color:#111827;min-width:46px;text-align:center; }
    .exp-cal-nav-btn { width:26px;height:26px;border:none;background:transparent;cursor:pointer;border-radius:6px;color:#6b7280;font-size:11px;display:flex;align-items:center;justify-content:center; }
    .exp-cal-nav-btn:hover { background:#f3f4f6; }
    .exp-cal-dow-row { display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px; }
    .exp-cal-dow { text-align:center;font-size:11px;color:#9ca3af;font-weight:500;padding:3px 0; }
    .exp-cal-grid { display:grid;grid-template-columns:repeat(7,1fr);gap:1px; }
    .exp-cal-blank { height:34px; }
    .exp-cal-day { height:34px;display:flex;align-items:center;justify-content:center;font-size:13px;color:#374151;border-radius:50%;cursor:pointer;transition:background .1s; }
    .exp-cal-day:hover { background:#f3f4f6; }
    .exp-cal-day--today { color:#ff7a00;font-weight:700; }
    .exp-cal-day--sel { background:#ff7a00!important;color:#fff!important;font-weight:700;border-radius:50%; }
    .exp-cal-day--inrange { background:#fff0e5;border-radius:0;color:#111827; }

    /* ── Filter by box ── */
    .exp-filter-box {
        display:flex;flex-wrap:wrap;align-items:center;gap:6px;
        padding:10px 14px;border:1.5px solid #e5e7eb;border-radius:10px;
        background:#fff;position:static;overflow:visible;
    }
    .exp-filter-dd-wrap { position:relative;display:inline-block; }
    .exp-filter-chip {
        display:inline-flex;align-items:center;gap:5px;
        padding:5px 10px;border:1px solid transparent;border-radius:6px;
        background:transparent;font-size:13px;color:#374151;cursor:pointer;
        font-family:inherit;font-weight:400;white-space:nowrap;
    }
    .exp-filter-chip:hover { background:#f9fafb; }
    .exp-chip--open { font-weight:600;color:#111827; }
    .exp-chip--add {
        border:1.5px dashed #d1d5db;border-radius:6px;color:#6b7280;
    }
    .exp-chip--add:hover { border-color:#9ca3af;background:#f9fafb; }
    .exp-filter-popup {
        position:absolute;top:calc(100% + 4px);left:0;
        background:#fff;border:1px solid #e5e7eb;border-radius:10px;
        box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:1500;
        min-width:240px;max-height:280px;overflow-y:auto;
    }
    .exp-filter-search-wrap { display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid #f0f0f0;position:sticky;top:0;background:#fff;z-index:1; }
    .exp-filter-search-icon { color:#9ca3af;font-size:13px;flex-shrink:0; }
    .exp-filter-search { border:none;outline:none;font-size:13px;color:#374151;width:100%;font-family:inherit;background:transparent; }
    .exp-filter-search::placeholder { color:#9ca3af; }
    .exp-filter-popup-row { display:flex;align-items:center;gap:10px;padding:10px 14px;font-size:14px;color:#374151;cursor:pointer; }
    .exp-filter-popup-row:hover { background:#f9fafb; }
    .exp-filter-divider { height:1px;background:#f0f0f0;margin:4px 0; }
    .exp-filter-popup-item { display:flex;align-items:center;gap:6px;padding:11px 14px;font-size:14px;color:#374151;cursor:pointer; }
    .exp-filter-popup-item:hover { background:#f9fafb; }
    .exp-filter-popup-item--sel { background:#f0fdf4; }
    .exp-filter-empty { padding:12px 14px;font-size:13px;color:#9ca3af; }
    .exp-filter-clear { padding:10px 14px;font-size:13px;color:#9ca3af;cursor:pointer;border-top:1px solid #f0f0f0;position:sticky;bottom:0;background:#fff; }
    .exp-filter-clear:hover { color:#374151; }
    .exp-filter-member-row { display:flex;align-items:center;gap:10px;padding:10px 14px;font-size:14px;color:#374151;cursor:pointer; }
    .exp-filter-member-row:hover { background:#f9fafb; }
    .exp-member-av { width:30px;height:30px;border-radius:50%;background:#e5e7eb;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:#374151;flex-shrink:0; }

    /* ── Time / Duration format selects ── */
    .exp-two-col { display:grid;grid-template-columns:1fr 1fr;gap:16px; }
    .exp-format-select {
        width:100%;border:1.5px solid #e5e7eb;border-radius:10px;
        padding:13px 14px;font-size:14px;
    }
    .exp-format-preview-inline { color:#9ca3af;font-size:13px;margin-left:auto;white-space:nowrap; }

    /* Learn more */
    .exp-learn-link { font-size:13px;color:#ff7a00;text-decoration:none; }
    .exp-learn-link:hover { text-decoration:underline; }

    /* Legend */
    .dtl-legend-wrap { position:relative; }
    .dtl-legend-btn { display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border:1px solid #eaedf0;border-radius:8px;background:#fff;font-size:12px;font-weight:500;color:#374151;cursor:pointer;font-family:inherit;transition:all .12s; }
    .dtl-legend-btn:hover { background:#f8f9fb;border-color:#d1d5db; }
    .dtl-legend-wrap { position:relative; }
    .dtl-legend-popup { position:absolute;top:calc(100% + 6px);right:0;background:#1e293b;color:#f1f5f9;border-radius:12px;box-shadow:0 12px 32px rgba(0,0,0,.2);z-index:500;padding:16px 20px;min-width:230px; }
    .dtl-legend-row { display:flex;align-items:center;gap:10px;padding:5px 0;font-size:12px; }
    .dtl-leg-color { width:16px;height:16px;border-radius:4px;flex-shrink:0; }
    .dtl-leg-icon { font-size:14px;width:18px;text-align:center;color:#94a3b8; }
    .dtl-legend-divider { height:1px;background:#334155;margin:8px 0; }
    .dtl-export-btn { display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border:1px solid #eaedf0;border-radius:8px;background:#fff;font-size:13px;font-weight:500;color:#374151;cursor:pointer;font-family:inherit;transition:all .12s; }
    .dtl-export-btn:hover { background:#f8f9fb;border-color:#d1d5db; }

    /* ── Filter bar ── */
    .dtl-filterbar { display:flex;align-items:center;gap:6px;padding:10px 32px;background:#fff;border-bottom:1px solid #eaedf0;flex-shrink:0;flex-wrap:wrap; }
    .dtl-filter-chip { display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border:1px solid #eaedf0;border-radius:20px;background:#fff;font-size:12px;font-weight:500;color:#374151;cursor:pointer;font-family:inherit;transition:all .12s; }
    .dtl-filter-chip:hover { background:#f8f9fb;border-color:#d1d5db; }
    .dtl-chip--active { border-color:#ff7a00;color:#ff7a00;background:#fff7f0; }
    .dtl-filter-add { display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border:1px dashed #d1d5db;border-radius:20px;background:transparent;font-size:12px;font-weight:500;color:#64748b;cursor:pointer;font-family:inherit;transition:all .12s; }
    .dtl-filter-add:hover { background:#f8f9fb;border-color:#9ca3af;color:#374151; }
    .dtl-schedules-wrap,.dtl-addfilter-wrap { position:relative; }
    .dtl-schedules-popup,.dtl-addfilter-popup { position:absolute;top:calc(100% + 6px);left:0;background:#fff;border:1px solid #eaedf0;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:400;min-width:220px;padding:6px; }
    .dtl-sched-search-wrap { display:flex;align-items:center;gap:6px;padding:8px 12px;border-bottom:1px solid #f0f0f0; }
    .dtl-sched-search-icon { color:#9ca3af;font-size:12px; }
    .dtl-sched-search { border:none;outline:none;font-size:12px;color:#374151;font-family:inherit;width:100%;background:transparent; }
    .dtl-sched-item,.dtl-af-item { display:flex;align-items:center;justify-content:space-between;padding:10px 14px;font-size:13px;color:#374151;cursor:pointer; }
    .dtl-sched-item:hover,.dtl-af-item:hover { background:#f9fafb; }
    .dtl-sched-item--active,.dtl-af-item--active { font-weight:600; }
    .dtl-sched-empty { padding:12px 14px;font-size:12px;color:#9ca3af; }
    .dtl-sched-clear,.dtl-af-clear { padding:9px 14px;font-size:12px;color:#ff7a00;cursor:pointer;border-top:1px solid #f0f0f0;margin-top:4px; }
    .dtl-search-wrap { display:flex;align-items:center;gap:6px; }
    .dtl-week-search { display:flex;align-items:center;gap:6px;padding:2px 0; }
    .dtl-search-icon { color:#ccc;font-size:13px; }
    .dtl-search { border:none;outline:none;font-size:13px;color:#374151;font-family:inherit;background:transparent;width:160px; }
    .dtl-search::placeholder { color:#bbb; }

    /* ══ TABLE WRAPPER ══ */
    .dtl-table-wrap { flex:1;overflow-y:auto;overflow-x:hidden;background:#f8f9fb;scrollbar-width:thin; }
    .dtl-monthly-scroll { overflow:auto;height:100%;background:#f8f9fb; }

    /* ══ SHARED TABLE BASE ══ */
    .dtl-table,.dtl-table--weekly,.dtl-table--monthly {
        width:100%;border-collapse:separate;border-spacing:0;background:#fff;
        border-radius:0;
    }

    /* ══ COLUMN HEADERS ══ */
    .dtl-th {
        padding:0 16px;height:44px;text-align:left;
        font-size:11px;font-weight:600;color:#64748b;
        background:#f8f9fb;border-bottom:1px solid #eaedf0;
        white-space:nowrap;letter-spacing:.5px;text-transform:uppercase;
    }
    .dtl-th--name  { padding-left:28px;min-width:220px; }
    .dtl-th--day   { min-width:112px;text-align:center;vertical-align:bottom;padding-bottom:10px;padding-top:10px; }
    .dtl-th--total { text-align:right;padding-right:28px;min-width:90px;font-weight:700;color:#374151; }
    .dtl-th--mday  { min-width:42px;max-width:48px;text-align:center;padding:10px 2px;background:#f8f9fb; }
    .dtl-th--sticky {
        position:sticky;left:0;z-index:3;background:#f8f9fb;
        border-right:1px solid #eaedf0;
    }
    .dtl-th--sticky-right {
        position:sticky;right:0;z-index:3;background:#f8f9fb;
        border-left:1px solid #eaedf0;
    }
    .dtl-th--today-col { background:#f8f9fb; }
    .dtl-th--today     { background:#fff7f0 !important; }
    .dtl-th--weekend   { color:#cbd5e1; }

    /* ══ WEEKLY — day column header ══ */
    .dtl-day-hdr    { display:flex;flex-direction:column;align-items:center;gap:5px;padding:4px 0; }
    .dtl-day-letter { font-size:10px;font-weight:700;color:#94a3b8;letter-spacing:1px;text-transform:uppercase; }
    .dtl-day-num    { font-size:17px;color:#374151;font-weight:600;line-height:1; }
    .dtl-day-num--today {
        width:32px;height:32px;background:#ff7a00;color:#fff;border-radius:50%;
        display:flex;align-items:center;justify-content:center;
        font-size:15px;font-weight:700;box-shadow:0 2px 8px rgba(255,122,0,.35);
    }

    /* ══ MONTHLY — compact day column header ══ */
    .dtl-mday-hdr {
        display:flex;flex-direction:column;align-items:center;gap:3px;
        font-size:9px;font-weight:700;color:#94a3b8;letter-spacing:.5px;text-transform:uppercase;
        line-height:1;
    }
    .dtl-mday-hdr span:last-child { font-size:13px;font-weight:600;color:#475569;letter-spacing:0; }
    .dtl-th--today .dtl-mday-hdr span { color:#ff7a00 !important; }

    /* ══ HOLIDAY PILL ROW (weekly) ══ */
    .dtl-hol-data-row { background:#f8f9fb;border-bottom:1px solid #eaedf0; }
    .dtl-td--hol-spacer { padding-top:4px;padding-bottom:2px; }
    .dtl-td--hol-cell   { padding:4px 6px;text-align:center;vertical-align:middle; }
    .dtl-hol-pill {
        display:inline-flex;align-items:center;
        font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:108px;letter-spacing:.2px;
    }
    .dtl-hol-pill--holiday { background:#eef2ff;color:#6366f1;border:1px solid #c7d2fe; }
    .dtl-hol-pill--timeoff { background:#ecfdf5;color:#059669;border:1px solid #a7f3d0; }
    .dtl-hol-pill--rest    { background:#f1f5f9;color:#94a3b8;border:1px solid #e2e8f0; }

    /* ══ TABLE ROWS ══ */
    .dtl-row                  { cursor:pointer;border-bottom:1px solid #f1f5f9;transition:background .1s; }
    .dtl-row:hover            { background:#fefaf7; }
    .dtl-row--always-open     { cursor:pointer; }
    .dtl-row--no-entry        { cursor:pointer; }
    .dtl-row--no-entry:hover  { background:#fefaf7 !important; }
    .dtl-week-data-row td { vertical-align:middle; }

    /* ══ CELLS ══ */
    .dtl-td         { padding:0 16px;height:56px;vertical-align:middle;font-size:13px;color:#374151; }
    .dtl-td--name   { padding-left:28px;padding-right:16px; }
    .dtl-td--day    { text-align:center;padding:0 10px;position:relative; }
    .dtl-td--mday   { text-align:center;padding:8px 2px;position:relative; }
    .dtl-td--total  { text-align:right;padding-right:28px; }
    .dtl-td--weekend{ background:#f9fafb; }
    .dtl-td--today-col  { background:#fffaf5; }
    .dtl-td--hoverable:hover { background:#fff4ec !important; }
    .dtl-td--sticky {
        position:sticky;left:0;z-index:1;background:#fff;
        border-right:1px solid #f1f5f9;
    }
    .dtl-td--sticky-right {
        position:sticky;right:0;z-index:1;background:#fff;
        border-left:1px solid #f1f5f9;
    }
    .dtl-row:hover .dtl-td--sticky,
    .dtl-row:hover .dtl-td--sticky-right { background:#fefaf7; }

    /* ══ NAME CELL ══ */
    .dtl-name-cell { display:flex;align-items:center;gap:12px;flex-wrap:nowrap; }
    .dtl-av {
        width:36px;height:36px;border-radius:10px;
        background:linear-gradient(135deg,#667eea,#764ba2);
        color:#fff;display:flex;align-items:center;justify-content:center;
        font-size:14px;font-weight:700;flex-shrink:0;letter-spacing:0;
    }
    /* Give each letter a distinct color using nth-child-like approach via CSS variables */
    .dtl-av--muted { background:linear-gradient(135deg,#e2e8f0,#cbd5e1);color:#94a3b8; }
    .dtl-name { font-size:14px;font-weight:600;color:#0f172a;white-space:nowrap; }

    /* ══ STATUS BADGES (daily) ══ */
    .dtl-status-badge   { display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.6;border:1px solid transparent; }
    .dtl-badge--holiday { background:#eef2ff;color:#6366f1;border-color:#c7d2fe; }
    .dtl-badge--timeoff { background:#ecfdf5;color:#059669;border-color:#a7f3d0; }
    .dtl-badge--rest    { background:#f1f5f9;color:#64748b;border-color:#e2e8f0; }
    .dtl-holiday-badge         { display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;border:1px solid transparent; }
    .dtl-holiday-badge--public { background:#eef2ff;color:#6366f1;border-color:#c7d2fe; }
    .dtl-holiday-badge--rest   { background:#f1f5f9;color:#64748b;border-color:#e2e8f0; }

    /* ══ VALUE TEXT ══ */
    .dtl-time         { font-size:13px;color:#374151;font-weight:500; }
    .dtl-tz           { font-size:10px;color:#94a3b8;margin-left:3px; }
    .dtl-ongoing-text       { font-size:12px;color:#10b981;font-weight:700;letter-spacing:.2px; }
    .dtl-hours              { font-size:13px;font-weight:600;color:#0f172a; }
    .dtl-hours--weekly-ot  { color:#f97316; }   /* orange — weekly overtime */
    .dtl-hours--rd-ot      { color:#8b5cf6; }   /* purple — rest day overtime */
    .dtl-hours--ph-ot      { color:#ef4444; }   /* red    — public holiday overtime */
    .dtl-day-hours    { font-size:14px;font-weight:700;color:#0f172a; }
    .dtl-total-hours  { font-size:14px;font-weight:700;color:#0f172a;white-space:nowrap; }
    .dtl-dash         { font-size:14px;color:#9ca3af;font-weight:400; }
    .dtl-empty-cell   { text-align:center;padding:80px 24px;color:#94a3b8;font-size:14px; }
    .dtl-total-cell   { display:flex;align-items:center;justify-content:flex-end; }
    .dtl-dash--hidden { visibility:hidden; }

    /* ══ WEEKLY CELLS ══ */
    .dtl-week-cell          { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;min-height:40px; }
    .dtl-week-cell--empty   { flex-direction:row;justify-content:center; }
    .dtl-week-cell--restday { display:flex;align-items:center;justify-content:center; }
    .dtl-restday-dash       { font-size:18px;color:#e2e8f0;font-weight:200; }
    .dtl-cell-add-btn {
        width:24px;height:24px;border-radius:50%;border:none;
        background:#ff7a00;color:#fff;cursor:pointer;
        display:flex;align-items:center;justify-content:center;
        font-size:12px;padding:0;flex-shrink:0;line-height:1;
        opacity:0;transition:opacity .15s,transform .12s;
        box-shadow:0 2px 6px rgba(255,122,0,.3);
    }
    .dtl-cell-add-btn--vis  { opacity:1 !important; }
    .dtl-cell-add-btn:hover { background:#e06800;transform:scale(1.12); }

    /* ══ DUPLICATE BUTTON ══ */
    .dtl-th--dup  { width:44px;min-width:44px;padding:0; }
    .dtl-td--dup  { width:44px;min-width:44px;padding:0 8px;text-align:center;vertical-align:middle; }
    .dtl-dup-btn  { background:transparent;border:none;color:#cbd5e1;cursor:pointer;padding:6px;font-size:14px;border-radius:6px;opacity:0;transition:all .12s; }
    .dtl-dup-btn--always { opacity:0; }
    .dtl-row:hover .dtl-dup-btn { opacity:1; }
    .dtl-dup-btn:hover { color:#ff7a00;background:#fff4ee; }

    /* ══ "Create new entry" floating tooltip ══ */
    .dtl-create-tip-float { position:fixed;background:#0f172a;color:#f8fafc;font-size:12px;font-weight:500;padding:7px 14px;border-radius:8px;white-space:nowrap;pointer-events:none;z-index:9000;box-shadow:0 4px 14px rgba(0,0,0,.25); }

    /* ══ MONTHLY HEAT CELLS ══ */
    .dtl-mcell {
        width:36px;height:28px;border-radius:5px;margin:0 auto;
        display:flex;align-items:center;justify-content:center;
    }
    .dtl-mcell--zero  { background:#f1f5f9;border:1px solid #e2e8f0; }
    .dtl-mcell--0to2  { background:#fef9c3; }
    .dtl-mcell--2to4  { background:#fde68a; }
    .dtl-mcell--4to6  { background:#6ee7b7; }
    .dtl-mcell--6to8  { background:#10b981; }
    .dtl-mcell--8to10 { background:#f97316; }
    .dtl-mcell--10plus{ background:#ef4444; }

    .dtl-cell-icon          { font-size:11px;color:#94a3b8; }
    .dtl-cell-icon--holiday { font-size:12px;color:#818cf8; }
    .dtl-cell-icon--timeoff { font-size:12px;color:#10b981; }

    /* ══ REST DAY BADGE (weekly header) ══ */
    .dtl-restday-badge {
        display:inline-block;background:#f1f5f9;color:#94a3b8;
        font-size:9px;font-weight:700;padding:2px 8px;border-radius:20px;
        margin-bottom:5px;white-space:nowrap;letter-spacing:.4px;text-transform:uppercase;
        border:1px solid #e2e8f0;
    }

    /* ══ REST / HOLIDAY / TIMEOFF COLUMN TINTS ══ */
    .dtl-td--restday-col       { background:#f8fafc !important; }
    .dtl-td--restday-col:hover { background:#f1f5f9 !important; }
    .dtl-td--holiday           { background:#eef2ff !important; }
    .dtl-td--holiday:hover     { background:#e0e7ff !important; }
    .dtl-td--timeoff           { background:#ecfdf5 !important; }
    .dtl-td--timeoff:hover     { background:#d1fae5 !important; }

    /* ══ HOVER TOOLTIP ══ */
    .dtl-tooltip {
        position:fixed;background:#0f172a;color:#f8fafc;
        border-radius:12px;padding:14px 18px;font-size:12px;
        z-index:8000;box-shadow:0 12px 32px rgba(0,0,0,.25);
        min-width:210px;pointer-events:none;
        border:1px solid rgba(255,255,255,.08);
    }
    .dtl-tt-row     { display:flex;justify-content:space-between;align-items:center;gap:28px;padding:3px 0; }
    .dtl-tt-row--sep{ border-top:1px solid #1e293b;margin-top:8px;padding-top:8px; }
    .dtl-tt-label   { color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px; }
    .dtl-tt-val     { font-weight:700;color:#f8fafc;font-size:13px;text-align:right; }

    /* Back button in detail view */
    .tev-back-btn { display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border:1.5px solid #e0e0e0;border-radius:6px;background:#fff;font-size:12px;font-weight:500;color:#374151;cursor:pointer;font-family:inherit;margin-right:12px; }
    .tev-back-btn:hover { background:#f9fafb;color:#ff7a00;border-color:#ff7a00; }

    /* ══ DUPLICATE TIMESHEETS MODAL ══ */
    .dup-modal {
        background:#fff;border-radius:16px;width:580px;max-width:calc(100vw - 32px);
        max-height:calc(100vh - 80px);overflow-y:auto;overflow-x:hidden;
        box-shadow:0 20px 60px rgba(0,0,0,.22);animation:tep-modal-in .2s ease;
    }
    .dup-modal-header { display:flex;align-items:center;justify-content:space-between;padding:24px 28px 20px; }
    .dup-modal-title { font-size:17px;font-weight:700;color:#111827; }

    /* Info box sits right under header */
    .dup-info-box { display:flex;align-items:flex-start;gap:10px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:12px 16px;margin:0 28px 16px; }
    .dup-info-icon { color:#0284c7;font-size:14px;flex-shrink:0;margin-top:1px; }
    .dup-info-box span { font-size:13px;color:#374151;line-height:1.5; }

    /* Day list */
    .dup-days-list { padding:0 28px 8px; }

    /* Each day row: left (label+sub+entries) + right (dash + plus) */
    .dup-day-row { display:flex;align-items:flex-start;justify-content:space-between;padding:16px 0;border-bottom:1px solid #f0f0f0;gap:12px; }
    .dup-day-row:last-child { border-bottom:none; }

    .dup-day-left { display:flex;flex-direction:column;gap:4px;flex:1;min-width:0; }
    .dup-day-label { font-size:14px;font-weight:700;color:#111827;display:flex;align-items:center;gap:6px; }
    .dup-day-arrow { font-size:11px;color:#6b7280; }
    .dup-day-sub { font-size:12px;color:#9ca3af;white-space:nowrap; }

    /* Right side: dash + plus icon inline */
    .dup-day-right { display:flex;align-items:center;gap:10px;flex-shrink:0;padding-top:2px; }
    .dup-day-dash { font-size:14px;color:#9ca3af;font-weight:400;min-width:8px;text-align:center; }
    .dup-plus-wrap { display:flex;align-items:center;gap:8px;position:relative; }
    .dup-plus-btn {
        width:24px;height:24px;border-radius:50%;
        border:1.5px solid #ff7a00;background:#fff;color:#ff7a00;
        font-size:16px;font-weight:700;line-height:1;
        display:flex;align-items:center;justify-content:center;
        cursor:pointer;padding:0;flex-shrink:0;
        transition:background .15s,color .15s;
    }
    .dup-plus-btn:hover { background:#ff7a00;color:#fff; }

    /* "Add Time Entry" dark pill button (appears next to +) */
    .dup-add-te-btn {
        padding:7px 16px;border-radius:8px;border:none;
        background:#374151;color:#fff;
        font-size:13px;font-weight:600;cursor:pointer;
        font-family:inherit;white-space:nowrap;
        transition:background .15s;
    }
    .dup-add-te-btn:hover { background:#1f2937; }

    /* Time entry input row inside dup modal */
    .dup-te-row { display:flex;align-items:center;gap:8px;margin-top:6px; }
    .dup-te-input { border:1.5px solid #e8eaed;border-radius:6px;padding:5px 8px;font-size:13px;color:#374151;font-family:inherit;outline:none;width:105px;min-width:0; }
    .dup-te-input:focus { border-color:#ff7a00; }

    /* Footer */
    .dup-modal-footer { display:flex;align-items:center;justify-content:flex-end;gap:10px;padding:16px 28px;border-top:1px solid #f0f0f0;margin-top:4px; }

    /* ── Break row in time entries ───────────────────────── */
    .tev-av--break              { background: linear-gradient(135deg,#f59e0b,#fbbf24); color:#fff; font-size:15px; }
    .tev-badge--break           { background:#fef3c7; color:#92400e; border-color:#fcd34d; }
    .tev-entry-row--break       { background:#fffbeb; }
    .tev-entry-row--break:hover { background:#fef3c7 !important; }

    /* ── Custom time picker ──────────────────────────────── */
    /* ── Segmented time input ────────────────────────────── */
    .amt-seg-time               { display:flex; align-items:center; gap:1px; flex:1; }
    .amt-seg                    { display:inline-block; min-width:22px; padding:2px 4px;
                                  border-radius:4px; text-align:center; font-size:15px;
                                  font-weight:600; color:#111827; cursor:pointer; outline:none;
                                  transition:background .1s; user-select:none; }
    .amt-seg:hover              { background:#fff3e8; }
    .amt-seg--active            { background:#f97316; color:#fff; }
    .amt-seg-colon              { font-size:15px; font-weight:600; color:#111827; padding:0 1px; }
    .amt-seg--ap                { font-size:14px; min-width:28px; }

    .amt-timeinput              { flex:1; border:none; outline:none; background:transparent;
                                  font-family:inherit; font-size:14px; font-weight:600; color:#111827; min-width:0; }
    .amt-timeinput--main        { min-width:70px; }
    .amt-field--open            { border-color:#f97316; box-shadow:0 0 0 2px rgba(249,115,22,.15); }

    /* ── Main time picker (compact horizontal, scroll-snap) ─ */
    .amt-tp                     { display:flex; border:1.5px solid #e5e7eb; border-radius:8px;
                                  background:#fff; box-shadow:0 4px 14px rgba(0,0,0,.09);
                                  overflow:hidden; margin-bottom:6px; }
    .amt-tp-col                 { flex:1; max-height:150px; overflow-y:auto; scrollbar-width:none;
                                  border-right:1px solid #f3f4f6;
                                  scroll-snap-type:y mandatory; }
    .amt-tp-col::-webkit-scrollbar { display:none; }
    .amt-tp-col:last-child      { border-right:none; }
    .amt-tp-col--ap             { flex:0 0 44px; }
    .amt-tp-item                { padding:8px 0; text-align:center; font-size:13px; font-weight:500;
                                  color:#374151; cursor:pointer; transition:background .1s;
                                  scroll-snap-align:start; }
    .amt-tp-item:hover          { background:#f9fafb; }
    .amt-tp-item.on             { background:#f97316; color:#fff; font-weight:700;
                                  scroll-margin-top:0; }

    /* ── Custom date picker (compact) ────────────────────── */
    .amt-field-val              { flex:1; font-size:14px; font-weight:600; color:#111827; }
    .amt-datepicker             { background:#fff; border:1.5px solid #e5e7eb; border-radius:10px;
                                  padding:10px; margin-bottom:8px; box-shadow:0 4px 14px rgba(0,0,0,.09); }
    .amt-dp-nav                 { display:flex; align-items:center; gap:2px; margin-bottom:6px; }
    .amt-dp-navbtn              { width:22px; height:22px; border:none; background:transparent;
                                  border-radius:5px; cursor:pointer; display:flex; align-items:center;
                                  justify-content:center; font-size:10px; color:#6b7280; }
    .amt-dp-navbtn:hover        { background:#f3f4f6; color:#111; }
    .amt-dp-month               { flex:1; text-align:center; font-size:12px; font-weight:700; color:#111827; }
    .amt-dp-year                { font-size:12px; font-weight:700; color:#111827; min-width:36px; text-align:center; }
    .amt-dp-dow                 { display:grid; grid-template-columns:repeat(7,1fr); gap:0; margin-bottom:2px; }
    .amt-dp-dow span            { text-align:center; font-size:9px; font-weight:600; color:#9ca3af; padding:1px 0; }
    .amt-dp-grid                { display:grid; grid-template-columns:repeat(7,1fr); gap:1px; }
    .amt-dp-day                 { display:flex; align-items:center; justify-content:center;
                                  height:26px; border-radius:50%; font-size:11px; font-weight:500;
                                  color:#111827; cursor:pointer; transition:background .12s; }
    .amt-dp-day:hover           { background:#f3f4f6; }
    .amt-dp-day.sel             { background:#f97316; color:#fff; font-weight:700; }
    .amt-dp-day.tod             { color:#f97316; font-weight:700; }
    .amt-dp-day.fut             { color:#d1d5db; cursor:default; }
    .amt-dp-day.fut:hover       { background:transparent; }

    /* ── Break time picker (Image 3 style: vertical with arrows) */
    .amt-brk-half               { flex:1; min-width:0; position:relative; }
    .amt-brk-field              { display:flex; align-items:center; gap:6px; padding:11px 12px;
                                  border:1.5px solid #e5e7eb; border-radius:9px; cursor:pointer;
                                  background:#fff; transition:border-color .15s; }
    .amt-brk-field--open        { border-color:#f97316; box-shadow:0 0 0 2px rgba(249,115,22,.15); }
    .amt-brk-field--err         { border-color:#ef4444; }
    .amt-brk-label              { font-size:12px; color:#9ca3af; flex-shrink:0; }
    .amt-brk-clock              { color:#9ca3af; font-size:13px; flex-shrink:0; }
    .amt-brk-val                { font-size:14px; font-weight:600; color:#111827; margin-left:auto; }
    .amt-brk-placeholder        { font-size:13px; color:#d1d5db; margin-left:auto; }
    .amt-brk-picker             { position:absolute; top:calc(100% + 4px); left:0; z-index:200;
                                  display:flex; background:#fff; border:1.5px solid #e5e7eb;
                                  border-radius:10px; box-shadow:0 6px 20px rgba(0,0,0,.12);
                                  overflow:hidden; min-width:160px; }
    .amt-brk-pcol               { flex:1; display:flex; flex-direction:column; align-items:center;
                                  border-right:1px solid #f3f4f6; max-height:200px; overflow:hidden; }
    .amt-brk-pcol:last-child    { border-right:none; }
    .amt-brk-pcol--ap           { flex:0 0 50px; }
    .amt-brk-arrow              { width:100%; padding:4px 0; border:none; background:transparent;
                                  cursor:pointer; font-size:10px; color:#9ca3af; flex-shrink:0;
                                  transition:color .1s; }
    .amt-brk-arrow:hover        { color:#f97316; background:#fff8f0; }
    .amt-brk-pitem              { width:100%; padding:6px 4px; text-align:center; font-size:13px;
                                  font-weight:500; color:#374151; cursor:pointer;
                                  transition:background .1s; overflow-y:auto; flex-shrink:0; }
    .amt-brk-pitem:hover        { background:#f9fafb; }
    .amt-brk-pitem.active       { background:#f97316; color:#fff; font-weight:700; }

    /* ── Duplicate header + warning (Image 4) ───────────── */
    /* ── Block header (shown for 2nd+ blocks) ── */
    /* ── Block header (shown for every block after the first) ── */
    .amt-blk-hdr                { display:flex; align-items:center; gap:8px;
                                  padding:14px 0 12px;
                                  border-top:1.5px solid #ebebeb; margin-top:4px; }
    /* Orange arrow icon — matches image exactly */
    .amt-blk-hdr-icon           { font-size:20px; flex-shrink:0; color:#f97316; line-height:1; }
    .amt-blk-hdr-label          { flex:1; font-size:14px; font-weight:700; color:#111827; }
    .amt-blk-hdr-acts           { display:flex; align-items:center; gap:0px; flex-shrink:0; }
    /* No border, no background — plain icon buttons as in image */
    .amt-blk-icon-btn           { width:32px; height:32px; border:none; background:transparent;
                                  cursor:pointer; display:flex; align-items:center;
                                  justify-content:center; font-size:14px; color:#9ca3af;
                                  border-radius:6px; transition:color .12s; padding:0; }
    .amt-blk-icon-btn:hover     { color:#374151; }

    /* ── Duplicate warning box — light pink background exactly as in image ── */
    .amt-dup-warn               { display:flex; align-items:flex-start; gap:12px;
                                  background:#fdf0ef; border:none;
                                  border-radius:10px; padding:14px 16px; margin-top:14px;
                                  font-size:13px; color:#7c3030; line-height:1.6; }
    .amt-dup-warn-icon          { color:#ef4444; font-size:17px; flex-shrink:0; margin-top:1px; }

    /* ── Footer: sticky bottom, full-width separator ── */
    .amt-footer                 { display:flex; align-items:center; justify-content:space-between;
                                  padding:14px 20px 18px; border-top:1px solid #ebebeb;
                                  flex-shrink:0; background:#fff; }
    .amt-footer-left            { display:flex; align-items:center; gap:20px; }
    .amt-footer-right           { display:flex; align-items:center; gap:10px; }
    .amt-footer-btns            { display:flex; gap:10px; align-items:center; }
    /* + Add new — orange, left side */
    .amt-footer-addnew          { background:none; border:none; cursor:pointer; color:#f97316;
                                  font-size:14px; font-weight:600; display:flex; align-items:center;
                                  gap:6px; padding:0; font-family:inherit; transition:color .15s; }
    .amt-footer-addnew:hover    { color:#ea6c00; }
    /* Duplicate — orange, next to Add new, only shown for single block */
    .amt-footer-dup             { background:none; border:none; cursor:pointer; color:#f97316;
                                  font-size:14px; font-weight:600; display:flex; align-items:center;
                                  gap:6px; padding:0; font-family:inherit; transition:color .15s; }
    .amt-footer-dup:hover       { color:#ea6c00; }

    /* legacy */
    .amt-dup-hdr                { display:none; }
    .amt-dup-hdr-icon           { }
    .amt-dup-hdr-time           { }
    .amt-dup-hdr-acts           { }
    .amt-dup-act                { width:28px; height:28px; border:1.5px solid #e5e7eb; border-radius:6px;
                                  background:#fff; cursor:pointer; display:flex; align-items:center;
                                  justify-content:center; font-size:12px; color:#6b7280; }
    .amt-dup-act:hover          { border-color:#f97316; color:#f97316; }

    /* ═══════════════════════════════════════════════════════════════════
       APPROVALS TAB
    ═══════════════════════════════════════════════════════════════════ */

    /* ── Page container ── */
    .apv-page { display:flex;flex-direction:column;width:100%;height:100%;background:#fff;overflow:hidden;position:relative; }

    /* ── Controls bar ── */
    .apv-controls { display:flex;align-items:center;justify-content:space-between;padding:14px 28px;background:#fff;border-bottom:1px solid #ebebeb;flex-shrink:0;flex-wrap:wrap;gap:10px; }
    .apv-controls-left  { display:flex;align-items:center;gap:6px; }
    .apv-controls-right { display:flex;align-items:center;gap:8px;flex-wrap:wrap; }

    /* ── Prev / Next nav buttons ── */
    .apv-nav-btn { width:28px;height:28px;border-radius:50%;border:1.5px solid #e0e0e0;background:#fff;
                   display:flex;align-items:center;justify-content:center;cursor:pointer;
                   color:#374151;font-size:11px;flex-shrink:0;transition:background .15s,border-color .15s; }
    .apv-nav-btn:hover { background:#f5f5f5;border-color:#d0d0d0; }

    /* ── Date range label + calendar toggle ── */
    .apv-cal-wrap { position:relative; }
    .apv-date-label { display:inline-flex;align-items:center;gap:8px;padding:5px 12px;
                      border:1.5px solid #e0e0e0;border-radius:6px;background:#fff;
                      font-size:14px;font-weight:500;color:#374151;cursor:pointer;
                      font-family:inherit;transition:border-color .15s;white-space:nowrap; }
    .apv-date-label:hover    { border-color:#d0d0d0; }
    .apv-date-label--open    { border-color:#ff7a00; }
    .apv-cal-icon { color:#9ca3af;font-size:14px; }

    /* ── Calendar picker dropdown ── */
    .apv-cal-backdrop { position:fixed;inset:0;z-index:498;background:transparent; }
    .apv-cal-picker   { position:absolute;top:calc(100% + 8px);left:0;z-index:499;
                         background:#fff;border-radius:12px;
                         box-shadow:0 8px 32px rgba(0,0,0,.15);
                         padding:18px 16px;min-width:280px;width:300px; }

    /* Nav row inside picker */
    .apv-cal-nav { display:flex;align-items:center;justify-content:center;gap:4px;margin-bottom:12px; }
    .apv-cal-nav-btn { width:26px;height:26px;border-radius:6px;border:none;background:transparent;
                       cursor:pointer;font-size:11px;display:flex;align-items:center;
                       justify-content:center;color:#6b7280;transition:background .12s; }
    .apv-cal-nav-btn:hover { background:#f3f4f6;color:#111; }
    .apv-cal-month-lbl { font-size:15px;font-weight:600;color:#111827;min-width:80px;text-align:center; }
    .apv-cal-year-lbl  { font-size:15px;font-weight:600;color:#111827;min-width:46px;text-align:center; }

    /* Day-of-week row */
    .apv-cal-dow-row { display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px; }
    .apv-cal-dow     { text-align:center;font-size:11px;font-weight:500;color:#9ca3af;padding:4px 0; }

    /* Day grid */
    .apv-cal-grid  { display:grid;grid-template-columns:repeat(7,1fr);gap:2px; }
    .apv-cal-blank { height:34px; }
    .apv-cal-day   { height:34px;display:flex;align-items:center;justify-content:center;
                     font-size:13px;font-weight:400;color:#374151;border-radius:50%;
                     cursor:pointer;transition:background .12s; }
    .apv-cal-day:hover         { background:#f3f4f6; }
    .apv-cal-day--today        { color:#ff7a00;font-weight:700; }
    .apv-cal-day--sel          { background:#ff7a00!important;color:#fff!important;font-weight:700;border-radius:50%; }
    .apv-cal-day--range        { background:#fff0e5;border-radius:0;color:#111827; }

    /* ── Filter chips ── */
    .apv-filter-chip { display:inline-flex;align-items:center;gap:4px;padding:5px 10px;
                       border:1.5px solid #e0e0e0;border-radius:6px;background:#fff;
                       font-size:13px;font-weight:500;color:#374151;cursor:pointer;
                       font-family:inherit;white-space:nowrap;transition:border-color .15s; }
    .apv-filter-chip:hover  { background:#f5f5f5; }
    .apv-chip--active        { border-color:#ff7a00!important;color:#ff7a00!important; }
    .apv-chip-chevron        { font-size:10px; }

    /* ── Add filter button ── */
    .apv-add-filter-btn { display:inline-flex;align-items:center;gap:5px;padding:5px 12px;
                          border:1.5px solid #e0e0e0;border-radius:6px;background:#fff;
                          font-size:13px;font-weight:500;color:#374151;cursor:pointer;
                          font-family:inherit;white-space:nowrap;transition:background .15s; }
    .apv-add-filter-btn:hover { background:#f5f5f5; }

    /* ── Dropdown wrapper ── */
    .apv-dd-wrap { position:relative; }
    .apv-dd-popup { position:absolute;top:calc(100% + 4px);left:0;z-index:500;
                    background:#fff;border:1.5px solid #e0e0e0;border-radius:10px;
                    box-shadow:0 6px 24px rgba(0,0,0,.12);min-width:180px;padding:4px 0; }
    .apv-dd-popup--right { left:auto;right:0; }
    .apv-dd-item { display:flex;align-items:center;justify-content:space-between;
                   padding:10px 16px;font-size:14px;color:#374151;cursor:pointer;
                   transition:background .1s; }
    .apv-dd-item:hover     { background:#f9fafb; }
    .apv-dd-item--sel      { color:#374151; }
    .apv-dd-item--af       { color:#374151; }
    .apv-dd-check          { color:#22c55e;font-size:14px;flex-shrink:0; }
    .apv-dd-clear          { padding:10px 16px;font-size:13px;color:#ff7a00;font-weight:600;
                              cursor:pointer;border-top:1px solid #f3f4f6;transition:background .1s; }
    .apv-dd-clear:hover    { background:#fff7ed; }

    /* ── Table wrapper ── */
    .apv-table-wrap { flex:1;overflow-y:auto;overflow-x:auto;background:#fff;scrollbar-width:thin; }
    .apv-table      { width:100%;border-collapse:collapse;table-layout:fixed; }

    /* ── Table header ── */
    .apv-thead-row  { border-bottom:1px solid #ebebeb; }
    .apv-th         { padding:14px 20px;font-size:13px;font-weight:600;color:#6b7280;
                      text-align:left;background:#fff;white-space:nowrap; }
    .apv-th--name   { padding-left:28px;width:260px; }
    .apv-th--sort   { cursor:pointer;user-select:none;transition:color .12s; }
    .apv-th--sort:hover { color:#374151; }
    .apv-sort-icon  { font-size:10px;color:#9ca3af;margin-left:3px; }

    /* ── Search inside name header ── */
    .apv-search-wrap { display:flex;align-items:center;gap:8px; }
    .apv-search-icon { color:#9ca3af;font-size:13px;flex-shrink:0; }
    .apv-search      { border:none;outline:none;font-size:13px;color:#111827;
                       background:transparent;font-family:inherit;width:180px; }
    .apv-search::placeholder { color:#9ca3af; }

    /* ── Table rows ── */
    .apv-row { border-bottom:1px solid #f2f2f2;cursor:pointer;transition:background .1s; }
    .apv-row:hover { background:#fff8f3; }
    .apv-row--selectable:hover .apv-approve-btn { opacity:1; }

    /* ── Table cells ── */
    .apv-td         { padding:18px 20px;font-size:14px;color:#374151;vertical-align:middle; }
    .apv-td--name   { padding-left:28px; }
    .apv-td--status { text-align:left; }
    .apv-td--check  { padding:0 0 0 16px;width:36px; }
    .apv-td--action { width:44px;padding:0 12px 0 0;text-align:right; }
    .apv-th--check  { width:36px;padding:0 0 0 16px; }
    .apv-th--action { width:44px; }

    /* ── Checkbox ── */
    .apv-chk { width:16px;height:16px;accent-color:#ff7a00;cursor:pointer;flex-shrink:0; }

    /* ── Approve button (shown on closed-period rows) ── */
    .apv-approve-btn { width:32px;height:32px;border-radius:50%;border:none;
                       background:#22c55e;color:#fff;font-size:16px;font-weight:700;
                       display:inline-flex;align-items:center;justify-content:center;
                       cursor:pointer;transition:background .15s,opacity .15s;
                       opacity:1; }
    .apv-approve-btn:hover { background:#16a34a; }

    /* ── Approved icon (tick shown after approval) ── */
    .apv-approved-icon { width:32px;height:32px;border-radius:50%;background:#22c55e;
                         color:#fff;font-size:16px;display:inline-flex;align-items:center;
                         justify-content:center; }

    /* ── Name cell ── */
    .apv-name-cell { display:flex;align-items:center;gap:12px; }
    .apv-av        { width:36px;height:36px;border-radius:50%;background:#e5e7eb;
                     color:#6b7280;display:flex;align-items:center;justify-content:center;
                     font-size:14px;font-weight:700;flex-shrink:0; }
    .apv-name      { font-size:14px;font-weight:700;color:#111827; }

    /* ── Hours / dash values ── */
    .apv-hours { font-size:14px;font-weight:500;color:#111827; }
    .apv-dash  { font-size:14px;color:#9ca3af; }

    /* ── Status pill ── */
    .apv-status { display:inline-flex;align-items:center;gap:6px;
                  font-size:13px;font-weight:500; }
    .apv-status-dot { width:10px;height:10px;border-radius:50%;flex-shrink:0;
                      border:2px solid currentColor;background:transparent; }

    .apv-status--inprogress { color:#f97316; }
    .apv-status--inprogress .apv-status-dot { border-color:#f97316; }

    .apv-status--open { color:#9ca3af; }
    .apv-status--open .apv-status-dot { border-color:#9ca3af; }

    .apv-status--approved { color:#22c55e; }
    .apv-status--approved .apv-status-dot { border-color:#22c55e;background:#22c55e; }

    .apv-status--reopened { color:#6366f1; }
    .apv-status--reopened .apv-status-dot { border-color:#6366f1; }

    /* ── Empty cell ── */
    .apv-empty-cell { text-align:center;padding:60px 24px;color:#9ca3af;font-size:14px; }

    /* ── Loading spinner (reused for Approvals) ── */
    .apv-loading { display:flex;align-items:center;justify-content:center;
                   gap:12px;padding:60px;color:#9ca3af;font-size:14px; }

    /* ── Selfie avatar in View Time Entry panel ── */
    .tep-member-av--photo {
        position: relative; cursor: pointer; overflow: hidden;
        border: 2px solid #e5e7eb; transition: border-color .18s;
    }
    .tep-member-av--photo:hover { border-color: #ff7a00; }
    .tep-av-img {
        width: 100%; height: 100%; object-fit: cover;
        border-radius: 50%; display: block;
    }
    .tep-av-hover-overlay {
        position: absolute; inset: 0; border-radius: 50%;
        background: rgba(0,0,0,0.45);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: opacity .18s;
    }
    .tep-member-av--photo:hover .tep-av-hover-overlay { opacity: 1; }
    .tep-av-eye { font-size: 18px; color: #fff; }

    /* ══ PAY PERIOD SETUP AREA ══ */
    /* ── Setup Pay Period button — inline in controls bar ── */
    .pp-setup-btn--inline {
        margin-left: 6px;
    }
    .pp-setup-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 18px;
        border-radius: 8px;
        border: none;
        background: #ff7a00;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s;
        box-shadow: 0 2px 8px rgba(255,122,0,.22);
        white-space: nowrap;
        flex-shrink: 0;
    }
    .pp-setup-btn:hover { background: #e66c00; }
    .pp-setup-btn-icon  { font-size: 13px; }

    /* ── Modal backdrop ── */
    .pp-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1400;
        background: rgba(0,0,0,.35);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── Card — fixed stable size, never jumps ── */
    .pp-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        width: 660px;
        max-width: calc(100vw - 32px);
        /* Fixed height so card never resizes when cycle changes */
        height: 520px;
        display: flex;
        flex-direction: column;
        animation: pp-card-in .18s ease;
        overflow: hidden;
    }
    @@keyframes pp-card-in {
        from { transform: scale(.96); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }

    .pp-card-header {
        padding: 22px 32px 14px;
        border-bottom: 1px solid #f0f0f0;
        flex-shrink: 0;
    }
    .pp-card-title-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .pp-card-title {
        font-size: 12px;
        font-weight: 700;
        color: #374151;
        letter-spacing: .8px;
        text-transform: uppercase;
    }
    .pp-card-info-icon {
        font-size: 13px;
        color: #9ca3af;
    }

    .pp-card-body {
        padding: 20px 32px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        flex: 1;
        overflow-y: auto;
        /* Custom scrollbar so it stays subtle */
        scrollbar-width: thin;
        scrollbar-color: #e5e7eb transparent;
    }
    .pp-card-body::-webkit-scrollbar { width: 5px; }
    .pp-card-body::-webkit-scrollbar-track { background: transparent; }
    .pp-card-body::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 10px; }


    /* ── Field row: label + input ── */
    .pp-field-row {
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .pp-field-label {
        font-size: 14px;
        font-weight: 500;
        color: #374151;
        min-width: 170px;
        flex-shrink: 0;
    }
    .pp-field-input-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        padding: 10px 14px;
        background: #fff;
        transition: border-color .15s;
    }
    .pp-field-input-wrap:focus-within { border-color: #ff7a00; }
    .pp-field-input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 14px;
        color: #111827;
        font-family: inherit;
        background: transparent;
    }
    .pp-field-input::placeholder { color: #9ca3af; }
    .pp-field-info {
        font-size: 13px;
        color: #9ca3af;
        flex-shrink: 0;
    }

    /* ── Cycle select ── */
    .pp-cycle-select {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        user-select: none;
        font-size: 14px;
        color: #111827;
        background: transparent;
        gap: 8px;
    }
    .pp-cycle-value  { flex: 1; }
    .pp-cycle-chevron { font-size: 11px; color: #9ca3af; flex-shrink: 0; }

    .pp-cycle-dropdown {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        background: #fff;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        z-index: 1500;
        overflow: hidden;
        min-width: 200px;
    }
    .pp-cycle-option {
        padding: 12px 16px;
        font-size: 14px;
        color: #374151;
        cursor: pointer;
        transition: background .1s;
    }
    .pp-cycle-option:hover { background: #f9fafb; }
    .pp-cycle-option--active {
        background: #fff8f0;
        color: #ff7a00;
        font-weight: 600;
    }

    .pp-card-footer {
        padding: 14px 32px 22px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        border-top: 1px solid #f0f0f0;
        flex-shrink: 0;
        background: #fff;
    }
    .pp-cancel-btn {
        padding: 10px 24px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        background: #fff;
        color: #374151;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: border-color .15s, color .15s;
    }
    .pp-cancel-btn:hover { border-color: #9ca3af; color: #111827; }
    .pp-save-btn {
        padding: 10px 32px;
        border: none;
        border-radius: 8px;
        background: #ff7a00;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s;
    }
    .pp-save-btn:hover { background: #e66c00; }
    .pp-save-btn:disabled { background: #fdba74; cursor: not-allowed; }

    /* ── Periods hint ── */
    .pp-periods-hint {
        margin-left: 190px;
        font-size: 12px;
        color: #9ca3af;
        margin-top: -8px;
        margin-bottom: 2px;
    }

    /* ── DOW weekday selector ── */
    .pp-dow-wrap {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }
    .pp-dow-btn {
        width: 36px; height: 36px;
        border-radius: 8px;
