    .tev-badge--out  { color: #92400e; background: #fffbeb; border-color: #fde68a; }
    .tev-badge--live { color: #166534; background: #f0fdf4; border-color: #86efac; }
    .tev-live-dot    { font-size: 6px; color: #22c55e; animation: tev-pulse 1.2s ease-in-out infinite; }
    @@keyframes tev-pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* Duration */
    .tev-dur       { font-size: 14px; font-weight: 700; color: #111827; }
    .tev-dur-empty { font-size: 14px; color: #d1d5db; }

    /* Actions */
    .tev-acts {
        display: flex; gap: 4px;
        opacity: 0; transition: opacity .15s;
        justify-content: flex-end;
    }
    .tev-act {
        width: 30px; height: 30px; border-radius: 8px;
        border: 1.5px solid #e8eaed; background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 12px; color: #6b7280;
        transition: border-color .15s, color .15s, background .15s;
    }
    .tev-act:hover { border-color: #ff7a00; color: #ff7a00; background: #fff7ed; }
    .tev-act--del:hover { border-color: #ef4444; color: #ef4444; background: #fef2f2; }

    .configure-widgets {
        display: flex; align-items: center; justify-content: center;
        gap: 8px; padding: 16px; color: #6b7280;
        font-size: 14px; font-weight: 500; cursor: pointer;
        transition: color 0.2s; margin-top: 20px;
    }
    .configure-widgets:hover { color: #ff7a00; }
    .configure-widgets i { font-size: 16px; }

    /* ══ ENTRY ROWS (separate Clock In / Clock Out rows) ══ */
    .tev-entry-row {
        display: flex; align-items: center;
        padding: 12px 20px;
        border-bottom: 1px solid #f3f4f6;
        cursor: pointer;
        transition: background .12s;
        gap: 0;
    }
    .tev-entry-row:hover { background: #fafafa; }
    .tev-entry-row--sel  { background: #fff7ed !important; }
    .tev-entry-row--sel:hover { background: #fff0d8 !important; }
    .tev-entry-row--out  { border-top: none; }

    .tev-er-av-cell    { width: 50px; flex-shrink: 0; }
    .tev-er-time-cell  { flex: 0 0 120px; }
    .tev-er-badge-cell { flex: 1; }
    .tev-er-copy-cell  { display: none; }
    .tev-er-dur-cell   { width: 80px; text-align: right; }

    /* Hover action buttons (pencil + trash) on each row */
    .tev-er-acts-cell  {
        width: 72px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: flex-end; gap: 4px;
        opacity: 0; transition: opacity .15s;
    }
    .tev-entry-row:hover .tev-er-acts-cell { opacity: 1; }

    .tev-er-act-btn {
        width: 28px; height: 28px; border-radius: 6px;
        border: 1.5px solid #e8eaed; background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 12px; color: #6b7280;
        transition: border-color .15s, color .15s, background .15s;
    }
    .tev-er-act-btn:hover              { border-color: #ff7a00; color: #ff7a00; background: #fff7ed; }
    .tev-er-act-btn--del:hover         { border-color: #ef4444; color: #ef4444; background: #fef2f2; }

    .tev-dur-live { font-size: 13px; font-weight: 700; color: #16a34a; }

    .tev-er-icon {
        width: 28px; height: 28px; border-radius: 6px;
        border: 1.5px solid #e8eaed; background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 11px; color: #9ca3af;
        transition: border-color .15s, color .15s;
    }
    .tev-er-icon:hover { border-color: #ff7a00; color: #ff7a00; }

    .tev-entry-sep { height: 6px; background: #f8f9fb; }

    /* ══ EDIT SIDE PANEL ══ */
    .tep-overlay {
        position: fixed; inset: 0; z-index: 400;
        background: rgba(0,0,0,.25);
    }

    /* Full-screen dim — covers sidebar + all page content */
    .tep-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1100;
        background: rgba(0, 0, 0, 0.45);
        cursor: default;
    }
    .tep-panel {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: 390px; z-index: 1200;
        background: #fff;
        box-shadow: -4px 0 32px rgba(0,0,0,.15);
        display: flex; flex-direction: column;
        animation: tep-slide-in .22s ease;
    }
    @@keyframes tep-slide-in {
        from { transform: translateX(100%); opacity: 0; }
        to   { transform: translateX(0);   opacity: 1; }
    }

    /* Header */
    .tep-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 22px 24px 18px;
        border-bottom: 1px solid #e8eaed;
        flex-shrink: 0;
    }
    .tep-title { font-size: 18px; font-weight: 700; color: #111827; }
    .tep-close {
        width: 32px; height: 32px; border-radius: 8px;
        border: none; background: transparent;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #9ca3af; font-size: 14px;
        transition: background .15s, color .15s;
    }
    .tep-close:hover { background: #f3f4f6; color: #374151; }

    /* Body */
    .tep-body {
        flex: 1; overflow-y: auto; padding: 20px 24px;
        scrollbar-width: thin; scrollbar-color: #e8eaed transparent;
    }

    .tep-divider { height: 1px; background: #e8eaed; margin: 16px 0; }

    /* Profile block */
    .tep-profile-block {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 14px;
    }
    .tep-profile-left { display: flex; align-items: flex-start; gap: 12px; flex: 1; }
    .tep-member-av {
        width: 50px; height: 50px; border-radius: 50%;
        background: #e5e7eb; color: #374151;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; font-weight: 700; flex-shrink: 0;
    }
    .tep-member-info { flex: 1; padding-top: 2px; display: flex; flex-direction: column; gap: 2px; }
    .tep-member-name { font-size: 15px; font-weight: 700; color: #111827; }
    .tep-member-sub  { font-size: 12px; color: #9ca3af; line-height: 1.4; }
    .tep-member-device { margin-top: 4px; font-size: 15px; color: #d1d5db; }

    /* Pencil — VIEW mode only */
    .tep-edit-pencil {
        width: 32px; height: 32px; border-radius: 6px;
        border: 1.5px solid #e8eaed; background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 13px; color: #6b7280; flex-shrink: 0;
        transition: border-color .15s, color .15s, background .15s;
    }
    .tep-edit-pencil:hover { border-color: #ff7a00; color: #ff7a00; background: #fff7ed; }

    /* VIEW mode: time row */
    .tep-view-row {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 16px;
        border: 1.5px solid #e8eaed; border-radius: 10px;
        background: #fff;
    }
    .tep-view-icon-wrap { display: flex; align-items: center; }
    .tep-view-icon { font-size: 16px; }
    .tep-view-icon--in  { color: #22c55e; }
    .tep-view-icon--out { color: #6b7280; }
    .tep-view-time {
        font-size: 18px; font-weight: 700; color: #111827;
        font-variant-numeric: tabular-nums;
    }
    .tep-view-pipe { font-size: 16px; color: #d1d5db; margin: 0 2px; }
    .tep-view-date-lbl { font-size: 15px; font-weight: 600; color: #111827; }

    /* EDIT mode: fields */
    .tep-edit-field {
        display: flex; align-items: center;
        border: 1.5px solid #e8eaed; border-radius: 10px;
        background: #fff; margin-bottom: 10px;
        transition: border-color .15s; position: relative;
    }
    .tep-edit-field:focus-within { border-color: #ff7a00; }
    .tep-field--active { border-color: #ff7a00 !important; }
    .tep-edit-field--time { padding: 14px 16px; justify-content: space-between; cursor: pointer; }
    .tep-edit-field--date { padding: 14px 16px; justify-content: space-between; cursor: pointer; }
    .tep-edit-field--date:hover { border-color: #d1d5db; }
    .tep-edit-field--select { padding: 0; justify-content: space-between; overflow: hidden; }
    .tep-edit-field--note { padding: 0; align-items: stretch; }

    .tep-time-display {
        font-size: 22px; font-weight: 700; color: #111827;
        font-variant-numeric: tabular-nums; letter-spacing: 0.5px; flex: 1;
    }
    .tep-tz-badge { display: inline-flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .tep-tz-circle {
        width: 28px; height: 28px; border-radius: 50%;
        border: 1.5px solid #e8eaed;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; color: #6b7280;
    }
    .tep-tz-text { font-size: 13px; font-weight: 600; color: #374151; }

    .tep-date-label { font-size: 15px; font-weight: 600; color: #111827; flex: 1; min-width: 0; }
    .tep-select-native {
        font-size: 14px; color: #374151;
        border: none; background: transparent; outline: none;
        font-family: inherit; flex: 1; width: 100%;
        padding: 14px 16px; cursor: pointer;
        appearance: none; -webkit-appearance: none;
    }
    .tep-note-native {
        font-size: 14px; color: #374151;
        border: none; background: transparent; outline: none;
        font-family: inherit; width: 100%; resize: none;
        padding: 14px 16px; min-height: 100px; border-radius: 10px;
    }
    .tep-note-native::placeholder { color: #9ca3af; }
    .tep-field-icon { font-size: 16px; color: #9ca3af; flex-shrink: 0; pointer-events: none; }

    /* Time field wrapper — positions picker as dropdown overlay */
    .tep-time-field-wrap { position: relative; margin-bottom: 10px; }
    .tep-time-field-wrap .tep-edit-field--time { margin-bottom: 0; cursor: default; }

    /* Segmented HH : MM am/pm time display */
    .tep-seg-wrap { display: flex; align-items: center; gap: 2px; flex: 1; }
    .tep-seg-input {
        border: none; outline: none; background: transparent;
        font-size: 22px; font-weight: 700; color: #111827;
        font-family: inherit; font-variant-numeric: tabular-nums;
        width: 2ch; text-align: center; padding: 0; cursor: text;
    }
    .tep-seg-input:focus { color: #111827; }
    .tep-seg-input::selection { background: #3b82f6; color: #fff; }
    .tep-seg-colon {
        font-size: 22px; font-weight: 700; color: #111827;
        line-height: 1; padding: 0 1px; user-select: none;
    }
    .tep-seg-ampm {
        font-size: 15px; font-weight: 600; color: #6b7280;
        margin-left: 4px; cursor: pointer; user-select: none;
        padding: 2px 4px; border-radius: 4px; transition: background .1s;
    }
    .tep-seg-ampm:hover { background: #f3f4f6; color: #111827; }

    /* Dropdown time picker — overlays below the field */
    .tep-timepicker {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 200;
        display: flex;
        border: 1.5px solid #e8eaed; border-radius: 12px;
        background: #fff; overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
    }
    .tep-tp-col {
        flex: 1; height: 210px; overflow-y: auto;
        scrollbar-width: none; border-right: 1px solid #f0f0f0;
    }
    .tep-tp-col::-webkit-scrollbar { display: none; }
    .tep-tp-col:last-child { border-right: none; }
    .tep-tp-col--ampm { flex: 0 0 64px; }
    .tep-tp-cell {
        padding: 10px 0; text-align: center;
        font-size: 15px; font-weight: 500; color: #9ca3af;
        cursor: pointer; transition: color .1s; user-select: none;
    }
    .tep-tp-cell:hover { color: #374151; }
    .tep-tp-cell--sel {
        background: #2d3748 !important; color: #fff !important;
        font-weight: 700; border-radius: 8px; margin: 2px 6px; padding: 8px 0;
    }
    .tep-tp-cell--ampm-gap { padding: 4px 0; cursor: default; }
    .tep-tp-col--ampm .tep-tp-cell { font-size: 13px; padding: 12px 0; font-weight: 600; }
    .tep-tp-col--ampm .tep-tp-cell--sel { font-size: 13px; padding: 10px 0; }

    /* Custom Calendar — compact */
    .tep-calendar {
        background: #fff; border: 1.5px solid #e8eaed; border-radius: 12px;
        padding: 12px; margin-bottom: 10px;
        box-shadow: 0 4px 16px rgba(0,0,0,.07);
    }
    .tep-cal-nav { display: flex; align-items: center; gap: 2px; margin-bottom: 10px; }
    .tep-cal-nav-btn {
        width: 24px; height: 24px; border-radius: 5px;
        border: none; background: transparent; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; color: #6b7280; transition: background .15s;
    }
    .tep-cal-nav-btn:hover { background: #f3f4f6; color: #111827; }
    .tep-cal-month-label { flex: 1; font-size: 13px; font-weight: 700; color: #111827; text-align: center; }
    .tep-cal-year-label  { flex: 1; font-size: 13px; font-weight: 700; color: #111827; text-align: center; }
    .tep-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; }
    .tep-cal-dow { font-size: 10px; font-weight: 600; color: #9ca3af; text-align: center; padding: 3px 0 6px; }
    .tep-cal-cell {
        aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
        border-radius: 50%; font-size: 12px; font-weight: 500; color: #111827;
        cursor: pointer; transition: background .12s, color .12s;
    }
    .tep-cal-cell:hover { background: #f3f4f6; }
    .tep-cal-cell--today { color: #ff7a00; font-weight: 700; }
    .tep-cal-cell--sel { background: #ff7a00 !important; color: #fff !important; font-weight: 700; }
    .tep-cal-cell--future { color: #d1d5db; cursor: default; }
    .tep-cal-cell--future:hover { background: transparent; }
    .tep-cal-cell--empty { cursor: default; }

    .tep-error {
        background: #fef2f2; border: 1px solid #fecaca;
        border-radius: 8px; padding: 10px 14px;
        font-size: 13px; color: #dc2626; margin-top: 12px;
    }

    /* Footer */
    .tep-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; border-top: 1px solid #e8eaed; background: #fff;
        flex-shrink: 0;
    }
    .tep-footer-right { display: flex; gap: 10px; margin-left: auto; }
    .tep-footer-del {
        background: transparent; border: none; cursor: pointer;
        font-size: 14px; font-weight: 600; color: #ff7a00;
        font-family: inherit; padding: 8px 0; transition: color .15s;
    }
    .tep-footer-del:hover { color: #e66c00; }
    .tep-footer-cancel {
        padding: 9px 20px; border-radius: 8px;
        border: 1.5px solid #e8eaed; background: #fff;
        font-size: 14px; font-weight: 600; color: #374151;
        cursor: pointer; font-family: inherit; transition: border-color .15s;
    }
    .tep-footer-cancel:hover { border-color: #9ca3af; }
    .tep-footer-save {
        padding: 9px 24px; border-radius: 8px; border: none;
        background: #ff7a00; color: #fff;
        font-size: 14px; font-weight: 700; cursor: pointer;
        font-family: inherit; transition: background .15s;
    }
    .tep-footer-save:hover:not(:disabled) { background: #e66c00; }
    .tep-footer-save:disabled { opacity: .6; cursor: not-allowed; }

    .tep-error { color: #ef4444; font-size: 12px; margin-top: 8px; padding: 8px 12px; background: #fef2f2; border-radius: 6px; }

    /* Panel footer */
    .tep-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px;
        border-top: 1px solid #e8eaed;
        flex-shrink: 0; background: #fff;
    }
    .tep-footer-right { display: flex; gap: 10px; }
    .tep-footer-del {
        background: none; border: none; cursor: pointer;
        font-size: 14px; font-weight: 600; color: #ef4444;
        font-family: inherit; transition: color .15s; padding: 0;
    }
    .tep-footer-del:hover { color: #b91c1c; }
    .tep-footer-cancel {
        padding: 9px 20px; border-radius: 8px;
        border: 1.5px solid #e8eaed; background: #fff;
        font-size: 13px; font-weight: 600; color: #374151;
        cursor: pointer; font-family: inherit; transition: border-color .15s, background .15s;
    }
    .tep-footer-cancel:hover { border-color: #d1d5db; background: #f9fafb; }
    .tep-footer-save {
        padding: 9px 22px; border-radius: 8px; border: none;
        background: #ff7a00; color: #fff;
        font-size: 13px; font-weight: 700; cursor: pointer;
        font-family: inherit; transition: background .15s;
    }
    .tep-footer-save:hover { background: #e66c00; }
    .tep-footer-save:disabled { background: #fbd5a7; cursor: not-allowed; }

    /* ══ REASON MODAL ══ */
    /* Input used in modals */
    .tep-input {
        width: 100%; padding: 10px 12px; border-radius: 8px;
        border: 1.5px solid #e8eaed; background: #fff;
        font-size: 14px; color: #111827; font-family: inherit;
        transition: border-color .15s; box-sizing: border-box;
    }
    .tep-input:focus { outline: none; border-color: #ff7a00; }
    .tep-textarea { resize: vertical; min-height: 90px; }

    .tep-modal-backdrop {
        position: fixed; inset: 0; z-index: 1300;
        background: rgba(0,0,0,.4);
        display: flex; align-items: center; justify-content: center;
    }
    .tep-modal {
        background: #fff; border-radius: 14px;
        padding: 28px; width: 480px; max-width: calc(100vw - 32px);
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        animation: tep-fade-in .18s ease;
    }
    @@keyframes tep-fade-in { from { opacity: 0; transform: scale(.95); } to { opacity: 1; transform: scale(1); } }
    .tep-modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .tep-modal-title  { font-size: 18px; font-weight: 700; color: #111827; }
    .tep-modal-sub    { font-size: 13px; color: #6b7280; margin-bottom: 16px; line-height: 1.5; }
    .tep-modal-ta     { margin-bottom: 0; min-height: 100px; }
    .tep-modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 16px; }

    /* ══ BOTTOM ACCORDION PANELS ══ */
    .tev-bottom-panels {
        border-top: 2px solid #f3f4f6;
        background: #fff;
    }

    .tev-accordion {
        border-bottom: 1px solid #e8eaed;
    }
    .tev-accordion--open {}

    .tev-accordion-hdr {
        width: 100%; display: flex; align-items: center;
        justify-content: space-between; gap: 16px;
        padding: 18px 24px;
        background: transparent; border: none;
        cursor: pointer; font-family: inherit;
        transition: background .15s;
        text-align: left;
    }
    .tev-accordion-hdr:hover { background: #fafafa; }

    .tev-accordion-hdr-left {
        display: flex; flex-direction: column; gap: 3px; flex: 1; min-width: 0;
    }
    .tev-accordion-title {
        font-size: 13px; font-weight: 800; color: #111827;
        letter-spacing: .4px;
    }
    .tev-accordion-sub {
        font-size: 11px; color: #9ca3af; font-weight: 400;
    }
    .tev-accordion-hdr-right {
        display: flex; align-items: center; gap: 12px; flex-shrink: 0;
    }
    .tev-accordion-val {
        font-size: 16px; font-weight: 800; color: #111827;
        font-variant-numeric: tabular-nums;
    }
    .tev-accordion-chevron {
        font-size: 13px; color: #9ca3af;
        transition: transform .2s;
    }

    .tev-accordion-body {
        padding: 4px 24px 20px;
        background: #fafafa;
        border-top: 1px solid #f3f4f6;
    }

    .tev-acc-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: 9px 0;
        border-bottom: 1px solid #f3f4f6;
    }
    .tev-acc-row:last-child { border-bottom: none; }
    .tev-acc-row--total {
        border-top: 1.5px solid #e8eaed; margin-top: 4px; padding-top: 12px;
        border-bottom: none;
    }

    .tev-acc-lbl { font-size: 12px; color: #6b7280; }
    .tev-acc-lbl--total { font-size: 12px; font-weight: 700; color: #374151; }
    .tev-acc-val { font-size: 13px; font-weight: 600; color: #374151; }
    .tev-acc-val--total { font-size: 15px; font-weight: 800; color: #ff7a00; }
    .tev-acc-highlight { color: #16a34a !important; }
    .tev-acc-dash { color: #d1d5db !important; font-weight: 400 !important; }

    /* History badge */
    .tev-history-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 50%;
        background: #ff7a00; color: #fff;
        font-size: 11px; font-weight: 700;
    }

    /* History empty state */
    .tev-history-empty {
        display: flex; align-items: center; gap: 10px;
        padding: 20px 0; color: #9ca3af; font-size: 13px;
    }
    .tev-history-empty i { font-size: 16px; }

    /* History table-style layout */
    .tev-history-body { padding: 0 24px 16px !important; }

    .tev-history-table-hdr {
        display: flex; gap: 0;
        padding: 10px 0 6px;
        border-bottom: 1px solid #e8eaed;
    }
    .tev-hth {
        font-size: 11px; font-weight: 700; color: #9ca3af;
        text-transform: uppercase; letter-spacing: .5px;
    }
    .tev-hth-change { flex: 2; }
    .tev-hth-reason { flex: 1; padding-left: 12px; }
    .tev-hth-ts     { flex: 1.2; padding-left: 12px; text-align: right; }

    .tev-history-row {
        display: flex; gap: 0;
