@page "/dashboard"
@using APM.StaffZen.Blazor.Components.Pages.Dashboard.Components
@inject AttendanceService AttendanceService
@inject NavigationManager NavManager
@inject SessionService SessionService
@inject IJSRuntime JSRuntime
@implements IDisposable

<BasePage Title="@(selectedMember == null ? "Dashboard" : "Timesheets")" OnClockAction="OnClockActionFired">

    <div class="dashboard-wrapper">

        <!-- ── Fixed Header — only shown on normal dashboard view ── -->
        @if (selectedMember == null)
        {
        <div class="dashboard-header">
            <div class="dashboard-tabs">
                <div class="tabs-left">
                    <span class="tab @(activeTab == "Day" ? "active" : "")" @onclick='() => SetTab("Day")'>Day</span>
                    <span class="tab @(activeTab == "Week" ? "active" : "")" @onclick='() => SetTab("Week")'>Week</span>
                    <span class="tab @(activeTab == "Month" ? "active" : "")" @onclick='() => SetTab("Month")'>Month</span>
                </div>
                @* Admin-only: org/managed-by-me/personal pills *@
                @if (!IsUserRole)
                {
                    <div class="tabs-right">
                        <span class="tab-pill @(activePill == "Organization" ? "active" : "")" @onclick='() => SetPill("Organization")'>Organization</span>
                        <span class="tab-pill @(activePill == "Managed by me" ? "active" : "")" @onclick='() => SetPill("Managed by me")'>Managed by me</span>
                        <span class="tab-pill @(activePill == "Personal" ? "active" : "")" @onclick='() => SetPill("Personal")'>Personal</span>
                    </div>
                }
            </div>
            @* Admin-only: filters *@
            @if (!IsUserRole)
            {
                <div class="dashboard-filters">
                    <span class="filter-item">All locations ▾</span>
                    <span class="filter-item">All groups ▾</span>
                    <span class="filter-item">All schedules ▾</span>
                </div>
            }
        </div>
        }

        <!-- ── Scrollable Content ── -->
        <div class="dashboard-content @(selectedMember != null ? "te-content-wrap" : "") @(IsUserRole && selectedMember == null ? "dash-user-mode" : "")">
            <div class="@(selectedMember == null ? "container-fluid px-2 px-md-3 py-3" : "h-100")"  >

                @if (selectedMember == null)
                {
                    <!-- ═══════════════════════════
                         NORMAL DASHBOARD VIEW
                         ═══════════════════════════ -->
                    @if (IsUserRole)
                    {
                        @* User role: full-width personal widgets only, no RightPanel — whole page scrolls *@
                        <div class="row g-2 g-md-3">
                            <div class="col-12 dash-user-col">
                                <GreetingCard />
                                <Holidaycard />
                                <Trackedhours />
                                <ActivitiesCard />
                                <ProjectsCard />
                                <LocationsCard />
                                <div class="configure-widgets text-center">
                                    <i class="bi bi-gear"></i>
                                    <span>Configure widgets</span>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* Admin/TeamLead/HR: two-column layout — each column scrolls independently *@
                        <div class="row g-2 g-md-3 dash-two-col-row">
                            <div class="col-12 col-xl-8 order-1 order-xl-1 dash-left-scroll">
                                <GreetingCard />
                                <Holidaycard />
                                <Trackedhours />
                                <ActivitiesCard />
                                <ProjectsCard />
                                <LocationsCard />
                                <div class="configure-widgets text-center">
                                    <i class="bi bi-gear"></i>
                                    <span>Configure widgets</span>
                                </div>
                            </div>
                            <div class="col-12 col-xl-4 order-2 order-xl-2 dash-right-scroll">
                                <RightPanel @ref="rightPanelRef" OnMemberSelected="OpenTimeEntries" />
                            </div>
                        </div>
                    }
                }
                else
                {
                    <!-- TIME ENTRIES VIEW -->
                    <div class="tev-shell">

                        <!-- ══ LEFT SIDEBAR ══ -->
                        <div class="tev-sidebar">
                            <div class="tev-sb-header">
                                <div class="tev-sb-label">Weekly Summary</div>
                                <div class="tev-sb-range">@WeekRangeLabel</div>
                            </div>

                            <div class="tev-sb-person">
                                <div class="tev-sb-av">@char.ToUpper(selectedMember.FullName[0])</div>
                                <div class="tev-sb-info">
                                    <div class="tev-sb-name">@selectedMember.FullName</div>
                                    <div class="tev-sb-tz">GMT+5:30</div>
                                </div>
                            </div>

                            <div class="tev-sb-divider"></div>

                            <div class="tev-sb-meta">
                                <div class="tev-sb-meta-row">
                                    <span class="tev-sb-meta-k">Timezone</span>
                                    <span class="tev-sb-meta-v">Asia/Calcutta (GMT+5:30)</span>
                                </div>
                                <div class="tev-sb-meta-row">
                                    <span class="tev-sb-meta-k">Split Time</span>
                                    <span class="tev-sb-meta-v">12:00 am</span>
                                </div>
                                <div class="tev-sb-meta-row">
                                    <span class="tev-sb-meta-k">Schedule</span>
                                    <span class="tev-sb-meta-v">—</span>
                                </div>
                            </div>

                            <div class="tev-sb-divider"></div>

                            <div class="tev-sb-section">
                                <div class="tev-sb-section-title">Tracked Hours</div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Tracked</span>
                                    <span class="tev-sb-stat-val">@weekTrackedDisplay</span>
                                </div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Worked</span>
                                    <span class="tev-sb-stat-val">@weekTrackedDisplay</span>
                                </div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Breaks</span>
                                    <span class="tev-sb-stat-val tev-dash">—</span>
                                </div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Deductions</span>
                                    <span class="tev-sb-stat-val tev-dash">—</span>
                                </div>
                            </div>

                            <div class="tev-sb-divider"></div>

                            <div class="tev-sb-section">
                                <div class="tev-sb-section-title">Payroll Hours</div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Payroll</span>
                                    <span class="tev-sb-stat-val tev-bold">@weekTrackedDisplay</span>
                                </div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Regular</span>
                                    <span class="tev-sb-stat-val">@weekTrackedDisplay</span>
                                </div>
                                <div class="tev-sb-stat-row">
                                    <span class="tev-sb-stat-lbl">Time Off</span>
                                    <span class="tev-sb-stat-val tev-dash">—</span>
                                </div>
                            </div>
                        </div>

                        <!-- ══ RIGHT MAIN PANEL ══ -->
                        <div class="tev-main">

                            <!-- Top bar -->
                            <div class="tev-topbar">
                                <div class="tev-topbar-left">
                                    <button class="tev-back" @onclick="CloseTimeEntries">
                                        <i class="bi bi-arrow-left"></i>
                                    </button>
                                    <div class="tev-topbar-titles">
                                        <div class="tev-topbar-title">Time Entries</div>
                                        <div class="tev-topbar-sub">Detailed list of clocked work hours and breaks</div>
                                    </div>
                                </div>
                                <button class="tev-add-btn">
                                    <i class="bi bi-plus-lg"></i> Add Entry
                                </button>
                            </div>

                            <!-- Week navigation -->
                            <div class="tev-week-nav">
                                <button class="tev-nav-btn" @onclick="PrevWeek">
                                    <i class="bi bi-chevron-left"></i>
                                </button>

                                <div class="tev-days-strip">
                                    @foreach (var day in WeekDays)
                                    {
                                        bool isTdy = day.Date == DateTime.Today;
                                        bool isSel = day.Date == selectedDate.Date;
                                        var  dur   = DayDuration(day);
                                        bool hasSessions = dur > TimeSpan.Zero;

                                        <button class="tev-day @(isSel ? "tev-day--sel" : "") @(isTdy ? "tev-day--today" : "")"
                                                @onclick="() => SelectDay(day)">
                                            <span class="tev-day-name">@day.ToString("ddd")</span>
                                            <span class="tev-day-num">@day.Day</span>
                                            <span class="tev-day-dur @(hasSessions ? "tev-day-dur--has" : "")">@FmtSpan(dur)</span>
                                            @if (hasSessions)
                                            {
                                                <span class="tev-day-dot"></span>
                                            }
                                        </button>
                                    }
                                </div>

                                <button class="tev-nav-btn" @onclick="NextWeek">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>

                            <!-- Date label bar -->
                            <div class="tev-date-bar">
                                <span class="tev-date-text">@selectedDate.ToString("dddd, dd MMMM yyyy")</span>
                                @if (dayEntries.Any())
                                {
                                    <span class="tev-entry-count">@dayEntries.Count @(dayEntries.Count == 1 ? "entry" : "entries")</span>
                                }
                                <div class="tev-date-tracked">
                                    <i class="bi bi-clock"></i>
                                    <span>@dayTrackedDisplay</span>
                                </div>
                            </div>

                            <!-- Entry list + Bottom accordion panels -->
                            <div class="tev-entries">
                                @if (entriesLoading)
                                {
                                    <div class="tev-loading">
                                        <div class="tev-spinner"></div>
                                        <span>Loading entries…</span>
                                    </div>
                                }
                                else if (!dayEntries.Any())
                                {
                                    <div class="tev-empty">
                                        <div class="tev-empty-icon">
                                            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                                                <circle cx="32" cy="32" r="32" fill="#fff7ed"/>
                                                <rect x="16" y="20" width="32" height="28" rx="5" fill="#fff" stroke="#fed7aa" stroke-width="1.5"/>
                                                <rect x="16" y="20" width="32" height="9" rx="5" fill="#fed7aa"/>
                                                <rect x="16" y="26" width="32" height="3" fill="#fed7aa"/>
                                                <rect x="23" y="16" width="3" height="8" rx="1.5" fill="#f97316"/>
                                                <rect x="38" y="16" width="3" height="8" rx="1.5" fill="#f97316"/>
                                                <circle cx="32" cy="38" r="8" fill="#ff7a00"/>
                                                <line x1="32" y1="34" x2="32" y2="38" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                                                <line x1="32" y1="38" x2="35" y2="40" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                                            </svg>
                                        </div>
                                        <div class="tev-empty-title">No entries for this day</div>
                                        <div class="tev-empty-sub">@selectedDate.ToString("dddd, dd MMMM yyyy")</div>
                                        <button class="tev-add-btn tev-empty-cta">
                                            <i class="bi bi-plus-lg"></i> Add Time Entry
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    @* Each entry = two clickable rows: Clock In row + Clock Out row *@
                                    @foreach (var e in dayEntries)
                                    {
                                        bool open = e.ClockOut == null;
                                        bool isInSel  = viewEntry?.Id == e.Id && editType == "in";
                                        bool isOutSel = viewEntry?.Id == e.Id && editType == "out";
                                        var capturedEntry = e;

                                        @* ── Clock In row ── *@
                                        <div class="tev-entry-row @(isInSel ? "tev-entry-row--sel" : "")"
                                             @onclick="() => OpenEditForClockIn(capturedEntry)">
                                            <div class="tev-er-av-cell">
                                                <div class="tev-av">@char.ToUpper(selectedMember.FullName[0])</div>
                                            </div>
                                            <div class="tev-er-time-cell">
                                                <span class="tev-time">@e.ClockIn.ToString("h:mm")<span class="tev-ampm">@e.ClockIn.ToString("tt").ToLower()</span></span>
                                            </div>
                                            <div class="tev-er-badge-cell">
                                                <span class="tev-badge tev-badge--in"><i class="bi bi-box-arrow-in-right"></i> Clock in</span>
                                            </div>
                                            <div class="tev-er-dur-cell">
                                                @if (!open && !string.IsNullOrWhiteSpace(e.WorkedHours))
                                                {
                                                    <span class="tev-dur">@e.WorkedHours</span>
                                                }
                                                else if (open)
                                                {
                                                    <span class="tev-dur-live">Live</span>
                                                }
                                                else
                                                {
                                                    <span class="tev-dur-empty">—</span>
                                                }
                                            </div>
                                            <div class="tev-er-acts-cell">
                                                <button class="tev-er-act-btn" @onclick:stopPropagation="true"
                                                        @onclick="() => OpenEditForClockInDirect(capturedEntry)" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="tev-er-act-btn tev-er-act-btn--del" @onclick:stopPropagation="true"
                                                        @onclick="() => ConfirmDelete(capturedEntry)" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>

                                        @* ── Clock Out row (or live row) ── *@
                                        @if (!open)
                                        {
                                            <div class="tev-entry-row tev-entry-row--out @(isOutSel ? "tev-entry-row--sel" : "")"
                                                 @onclick="() => OpenEditForClockOut(capturedEntry)">
                                                <div class="tev-er-av-cell">
                                                    <div class="tev-av">@char.ToUpper(selectedMember.FullName[0])</div>
                                                </div>
                                                <div class="tev-er-time-cell">
                                                    <span class="tev-time">@e.ClockOut!.Value.ToString("h:mm")<span class="tev-ampm">@e.ClockOut!.Value.ToString("tt").ToLower()</span></span>
                                                </div>
                                                <div class="tev-er-badge-cell">
                                                    <span class="tev-badge tev-badge--out"><i class="bi bi-box-arrow-right"></i> Clock out</span>
                                                </div>
                                                <div class="tev-er-dur-cell">
                                                    <span class="tev-dur-empty">—</span>
                                                </div>
                                                <div class="tev-er-acts-cell">
                                                    <button class="tev-er-act-btn" @onclick:stopPropagation="true"
                                                            @onclick="() => OpenEditForClockOutDirect(capturedEntry)" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="tev-er-act-btn tev-er-act-btn--del" @onclick:stopPropagation="true"
                                                            @onclick="() => ConfirmDelete(capturedEntry)" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            @* thin separator between entries *@
                                            <div class="tev-entry-sep"></div>
                                        }
                                        else
                                        {
                                            @* Live / still clocked in — no out row *@
                                            <div class="tev-entry-sep"></div>
                                        }
                                    }
                                }

                                @* ── BOTTOM ACCORDION PANELS ── *@
                                <div class="tev-bottom-panels">

                                    @* TRACKED HOURS accordion *@
                                    <div class="tev-accordion @(trackedExpanded ? "tev-accordion--open" : "")">
                                        <button class="tev-accordion-hdr" @onclick="() => trackedExpanded = !trackedExpanded">
                                            <div class="tev-accordion-hdr-left">
                                                <span class="tev-accordion-title">TRACKED HOURS</span>
                                                <span class="tev-accordion-sub">Include worked hours, break hours and any auto deductions.</span>
                                            </div>
                                            <div class="tev-accordion-hdr-right">
                                                <span class="tev-accordion-val">@dayTrackedDisplay</span>
                                                <i class="bi bi-chevron-@(trackedExpanded ? "up" : "down") tev-accordion-chevron"></i>
                                            </div>
                                        </button>
                                        @if (trackedExpanded)
                                        {
                                            <div class="tev-accordion-body">
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Worked Hours</span>
                                                    <span class="tev-acc-val tev-acc-highlight">@dayTrackedDisplay</span>
                                                </div>
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Break Hours</span>
                                                    <span class="tev-acc-val tev-acc-dash">—</span>
                                                </div>
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Auto Deductions</span>
                                                    <span class="tev-acc-val tev-acc-dash">—</span>
                                                </div>
                                                <div class="tev-acc-row tev-acc-row--total">
                                                    <span class="tev-acc-lbl tev-acc-lbl--total">Total Tracked</span>
                                                    <span class="tev-acc-val tev-acc-val--total">@dayTrackedDisplay</span>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @* PAYROLL HOURS accordion *@
                                    <div class="tev-accordion @(payrollExpanded ? "tev-accordion--open" : "")">
                                        <button class="tev-accordion-hdr" @onclick="() => payrollExpanded = !payrollExpanded">
                                            <div class="tev-accordion-hdr-left">
                                                <span class="tev-accordion-title">PAYROLL HOURS</span>
                                                <span class="tev-accordion-sub">Include regular hours, paid breaks, overtime hours and paid time off.</span>
                                            </div>
                                            <div class="tev-accordion-hdr-right">
                                                <span class="tev-accordion-val">@dayTrackedDisplay</span>
                                                <i class="bi bi-chevron-@(payrollExpanded ? "up" : "down") tev-accordion-chevron"></i>
                                            </div>
                                        </button>
                                        @if (payrollExpanded)
                                        {
                                            <div class="tev-accordion-body">
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Regular Hours</span>
                                                    <span class="tev-acc-val tev-acc-highlight">@dayTrackedDisplay</span>
                                                </div>
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Paid Breaks</span>
                                                    <span class="tev-acc-val tev-acc-dash">—</span>
                                                </div>
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Overtime Hours</span>
                                                    <span class="tev-acc-val tev-acc-dash">—</span>
                                                </div>
                                                <div class="tev-acc-row">
                                                    <span class="tev-acc-lbl">Paid Time Off</span>
                                                    <span class="tev-acc-val tev-acc-dash">—</span>
                                                </div>
                                                <div class="tev-acc-row tev-acc-row--total">
                                                    <span class="tev-acc-lbl tev-acc-lbl--total">Total Payroll</span>
                                                    <span class="tev-acc-val tev-acc-val--total">@dayTrackedDisplay</span>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @* CHANGE HISTORY accordion *@
                                    <div class="tev-accordion @(historyExpanded ? "tev-accordion--open" : "")">
                                        <button class="tev-accordion-hdr" @onclick="() => historyExpanded = !historyExpanded">
                                            <div class="tev-accordion-hdr-left">
                                                <span class="tev-accordion-title">CHANGE HISTORY</span>
                                                <span class="tev-accordion-sub">View a history log of time entries that are manually added or changed.</span>
                                            </div>
                                            <div class="tev-accordion-hdr-right">
                                                @if (changeHistory.Any())
                                                {
                                                    <span class="tev-history-badge">@changeHistory.Count</span>
                                                }
                                                <i class="bi bi-chevron-@(historyExpanded ? "up" : "down") tev-accordion-chevron"></i>
                                            </div>
                                        </button>
                                        @if (historyExpanded)
                                        {
                                            <div class="tev-accordion-body tev-history-body">
                                                @if (!string.IsNullOrWhiteSpace(changeHistoryError))
                                                {
                                                    <div class="tev-history-api-err">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        <span>@changeHistoryError</span>
                                                    </div>
                                                }
                                                else if (!changeHistory.Any())
                                                {
                                                    <div class="tev-history-empty">
                                                        <i class="bi bi-clock-history"></i>
                                                        <span>No manual changes recorded for this day.</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="tev-history-table-hdr">
                                                        <span class="tev-hth tev-hth-change">Change made</span>
                                                        <span class="tev-hth tev-hth-reason">Reason for change</span>
                                                        <span class="tev-hth tev-hth-ts">Timestamp</span>
                                                    </div>
                                                    @foreach (var h in changeHistory)
                                                    {
                                                        <div class="tev-history-row">
                                                            <div class="tev-history-cell tev-history-cell--change">
                                                                <div class="tev-history-who">
                                                                    <div class="tev-hav">@char.ToUpper((h.ChangedByName ?? selectedMember!.FullName)[0])</div>
                                                                    <div class="tev-hwho-info">
                                                                        <span class="tev-hwho-name">@(h.ChangedByName ?? selectedMember!.FullName)</span>
                                                                        <span class="tev-hwho-action">@(h.Action == "Edited" ? "edited a time entry" : h.Action == "Added" ? "added a time entry" : "deleted a time entry")</span>

                                                                        @* Clock-In change — only shown when clock-in was the edited field *@
                                                                        @if (h.NewClockIn != null)
                                                                        {
                                                                            <span class="tev-hwho-new">
                                                                                <i class="bi bi-box-arrow-in-right tev-ci-icon"></i>
                                                                                @h.NewClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()
                                                                            </span>
                                                                            @if (h.OldClockIn != null && h.OldClockIn.Value != h.NewClockIn.Value)
                                                                            {
                                                                                <span class="tev-hwho-old">@h.OldClockIn.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                            }
                                                                        }

                                                                        @* Clock-Out change — only shown when clock-out was the edited field *@
                                                                        @if (h.NewClockOut != null)
                                                                        {
                                                                            <span class="tev-hwho-new">
                                                                                <i class="bi bi-box-arrow-right tev-co-icon"></i>
                                                                                @h.NewClockOut.Value.ToString("ddd, MMM d, h:mm tt").ToLower()
                                                                            </span>
                                                                            @if (h.OldClockOut != null && h.OldClockOut.Value != h.NewClockOut.Value)
                                                                            {
                                                                                <span class="tev-hwho-old">@h.OldClockOut.Value.ToString("ddd, MMM d, h:mm tt").ToLower()</span>
                                                                            }
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="tev-history-cell tev-history-cell--reason">
                                                                @if (!string.IsNullOrWhiteSpace(h.ReasonForChange))
                                                                {
                                                                    <span class="tev-reason-text">@h.ReasonForChange</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="tev-reason-empty">—</span>
                                                                }
                                                            </div>
                                                            <div class="tev-history-cell tev-history-cell--ts">
                                                                <span class="tev-ts-text">@h.ChangedAt.ToString("MMM d, h:mm tt") (GMT+5:30)</span>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                }

            </div>
        </div>

    </div>

    @* ══ EDIT TIME ENTRY SIDE PANEL ══ *@
    @if (viewEntry != null && panelMode != "none")
    {
        @* Full-screen dimmed backdrop — covers sidebar + all content *@
        <div class="tep-backdrop" @onclick="CancelEdit"></div>
        <div class="tep-panel">

            @* ── Header ── *@
            <div class="tep-header">
                <span class="tep-title">@(panelMode == "edit" ? "Edit Time Entry" : "View Time Entry")</span>
                <button class="tep-close" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
            </div>

            @* ── Body ── *@
            <div class="tep-body">

                @* Profile block *@
                <div class="tep-profile-block">
                    <div class="tep-profile-left">
                        <div class="tep-member-av">@char.ToUpper((selectedMember?.FullName ?? "U")[0])</div>
                        <div class="tep-member-info">
                            <div class="tep-member-name">@(selectedMember?.FullName ?? "")</div>
                            <div class="tep-member-sub">
                                @(editType == "in" ? "Clocked in from GMT+5:30" : "Clocked out from GMT+5:30")
                            </div>
                            <div class="tep-member-sub">via ApmStaffZen Web App</div>
                            <div class="tep-member-device"><i class="bi bi-display"></i></div>
                        </div>
                    </div>
                    @* Pencil only shown in view mode *@
                    @if (panelMode == "view")
                    {
                        <button class="tep-edit-pencil" @onclick="SwitchToEdit" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </button>
                    }
                </div>

                <div class="tep-divider"></div>

                @* ── VIEW SECTION ── *@
                @if (panelMode == "view")
                {
                    <div class="tep-view-row">
                        <div class="tep-view-icon-wrap">
                            @if (editType == "in")
                            {
                                <i class="bi bi-box-arrow-in-right tep-view-icon tep-view-icon--in"></i>
                            }
                            else
                            {
                                <i class="bi bi-box-arrow-left tep-view-icon tep-view-icon--out"></i>
                            }
                        </div>
                        <span class="tep-view-time">
                            @if (editType == "in")
                            {
                                @viewEntry.ClockIn.ToString("h:mm tt").ToLower()
                            }
                            else
                            {
                                @((viewEntry.ClockOut?.ToString("h:mm tt") ?? "—").ToLower())
                            }
                        </span>
                        <span class="tep-view-pipe">|</span>
                        <span class="tep-view-date-lbl">
                            @{
                                var viewDt = editType == "in" ? viewEntry.ClockIn : (viewEntry.ClockOut ?? viewEntry.ClockIn);
                                if (viewDt.Date == DateTime.Today) { <text>Today</text> }
                                else if (viewDt.Date == DateTime.Today.AddDays(-1)) { <text>Yesterday</text> }
                                else { @viewDt.ToString("d MMM yyyy") }
                            }
                        </span>
                    </div>
                }

                @* ── EDIT SECTION ── *@
                @if (panelMode == "edit")
                {
                    @* TIME field — segmented HH : MM am/pm inputs *@
                    <div class="tep-time-field-wrap" @onclick:stopPropagation="true">
                        <div class="tep-edit-field tep-edit-field--time @(showTimePicker2 ? "tep-field--active" : "")">
                            <div class="tep-seg-wrap">
                                @* Hour segment *@
                                <input id="tep-seg-h"
                                       class="tep-seg-input"
                                       type="text" inputmode="numeric" maxlength="2"
                                       value="@GetSegHour()"
                                       @onfocus='() => OnSegFocus("h")'
                                       @onchange='@(e => OnSegChange("h", e.Value?.ToString() ?? ""))'
                                       @onclick:stopPropagation="true" />
                                <span class="tep-seg-colon">:</span>
                                @* Minute segment *@
                                <input id="tep-seg-m"
                                       class="tep-seg-input"
                                       type="text" inputmode="numeric" maxlength="2"
                                       value="@GetSegMin()"
                                       @onfocus='() => OnSegFocus("m")'
                                       @onchange='@(e => OnSegChange("m", e.Value?.ToString() ?? ""))'
                                       @onclick:stopPropagation="true" />
                                @* AM/PM toggle *@
                                <span class="tep-seg-ampm" @onclick="ToggleAmPm" @onclick:stopPropagation="true">@tpAmPm2.ToLower()</span>
                            </div>
                            <span class="tep-tz-badge" @onclick="ToggleTimePicker2">
                                <span class="tep-tz-circle"><i class="bi bi-clock"></i></span>
                                <span class="tep-tz-text">GMT+5:30</span>
                            </span>
                        </div>

                        @* DROPDOWN TIME PICKER — Jibble-style, overlays below the field *@
                        @if (showTimePicker2)
                        {
                            <div class="tep-timepicker" @onclick:stopPropagation="true">
                                @* Hours column (1-12) *@
                                <div class="tep-tp-col" id="tp-col-h">
                                    @foreach (var h in Enumerable.Range(1, 12))
                                    {
                                        bool selH = tpHour2 == h;
                                        <div class="tep-tp-cell @(selH ? "tep-tp-cell--sel" : "")"
                                             @onclick="() => { tpHour2 = h; ApplyTimePicker2(); }">@h</div>
                                    }
                                </div>
                                @* Minutes column (00-59) *@
                                <div class="tep-tp-col" id="tp-col-m">
                                    @foreach (var m in Enumerable.Range(0, 60))
                                    {
                                        bool selM = tpMinute2 == m;
                                        <div class="tep-tp-cell @(selM ? "tep-tp-cell--sel" : "")"
                                             @onclick="() => { tpMinute2 = m; ApplyTimePicker2(); }">@m.ToString("D2")</div>
                                    }
                                </div>
                                @* AM/PM column *@
                                <div class="tep-tp-col tep-tp-col--ampm" id="tp-col-ap">
                                    <div class="tep-tp-cell @(tpAmPm2 == "AM" ? "tep-tp-cell--sel" : "")"
                                         @onclick='() => { tpAmPm2 = "AM"; ApplyTimePicker2(); }'>am</div>
                                    <div class="tep-tp-cell tep-tp-cell--ampm-gap"></div>
                                    <div class="tep-tp-cell @(tpAmPm2 == "PM" ? "tep-tp-cell--sel" : "")"
                                         @onclick='() => { tpAmPm2 = "PM"; ApplyTimePicker2(); }'>pm</div>
                                </div>
                            </div>
                        }
                    </div>

                    @* DATE field — click opens custom calendar *@
                    <div class="tep-edit-field tep-edit-field--date @(showCalendar ? "tep-field--active" : "")"
                         @onclick="ToggleDateCal" @onclick:stopPropagation="true">
                        @{
                            var editDateStr = editType == "in" ? editClockInDate : editClockOutDate;
                            string editDateLabel = "Today";
                            if (DateTime.TryParse(editDateStr, out var edDt))
                            {
                                if (edDt.Date == DateTime.Today) editDateLabel = "Today";
                                else if (edDt.Date == DateTime.Today.AddDays(-1)) editDateLabel = "Yesterday";
                                else editDateLabel = edDt.ToString("d MMM yyyy");
                            }
                        }
                        <span class="tep-date-label">@editDateLabel</span>
                        <i class="bi bi-calendar3 tep-field-icon"></i>
                    </div>

                    @* INLINE CALENDAR PICKER *@
                    @if (showCalendar)
                    {
                        <div class="tep-calendar" @onclick:stopPropagation="true">
                            <div class="tep-cal-nav">
                                <button class="tep-cal-nav-btn" @onclick="CalPrevMonth2"><i class="bi bi-chevron-left"></i></button>
                                <span class="tep-cal-month-label">@calViewDate.ToString("MMMM")</span>
                                <button class="tep-cal-nav-btn" @onclick="CalNextMonth2"><i class="bi bi-chevron-right"></i></button>
                                <button class="tep-cal-nav-btn" @onclick="CalPrevYear2"><i class="bi bi-chevron-left"></i></button>
                                <span class="tep-cal-year-label">@calViewDate.Year</span>
                                <button class="tep-cal-nav-btn" @onclick="CalNextYear2"><i class="bi bi-chevron-right"></i></button>
                            </div>
                            <div class="tep-cal-grid">
                                <div class="tep-cal-dow">Mon</div>
                                <div class="tep-cal-dow">Tue</div>
                                <div class="tep-cal-dow">Wed</div>
                                <div class="tep-cal-dow">Thu</div>
                                <div class="tep-cal-dow">Fri</div>
                                <div class="tep-cal-dow">Sat</div>
                                <div class="tep-cal-dow">Sun</div>
                                @{
                                    var firstDay = new DateTime(calViewDate.Year, calViewDate.Month, 1);
                                    int startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
                                    int daysInMonth = DateTime.DaysInMonth(calViewDate.Year, calViewDate.Month);
                                    var selStr = editType == "in" ? editClockInDate : editClockOutDate;
                                    DateTime.TryParse(selStr, out var selDt);
                                    for (int blank = 0; blank < startOffset; blank++) { <div class="tep-cal-cell tep-cal-cell--empty"></div> }
                                    for (int d = 1; d <= daysInMonth; d++)
                                    {
                                        var cellDate = new DateTime(calViewDate.Year, calViewDate.Month, d);
                                        bool isToday = cellDate.Date == DateTime.Today;
                                        bool isSel = cellDate.Date == selDt.Date && selDt != default;
                                        bool isFut = cellDate.Date > DateTime.Today;
                                        var cap = cellDate;
                                        <div class="tep-cal-cell @(isSel ? "tep-cal-cell--sel" : "") @(isToday && !isSel ? "tep-cal-cell--today" : "") @(isFut ? "tep-cal-cell--future" : "")"
                                             @onclick="() => CalSelectDate2(cap)">@d</div>
                                    }
                                }
                            </div>
                        </div>
                    }

                    @* ACTIVITY & PROJECT — only for clock-in *@
                    @if (editType == "in")
                    {
                        <div class="tep-edit-field tep-edit-field--select">
                            <select class="tep-select-native">
                                <option value="">Select an activity</option>
                            </select>
                            <i class="bi bi-chevron-down tep-field-icon"></i>
                        </div>

                        <div class="tep-edit-field tep-edit-field--select">
                            <select class="tep-select-native">
                                <option value="">Select a project</option>
                            </select>
                            <i class="bi bi-chevron-down tep-field-icon"></i>
                        </div>
                    }

                    @* NOTE textarea *@
                    <div class="tep-edit-field tep-edit-field--note">
                        <textarea class="tep-note-native" placeholder="Add a note" @bind="editNote"></textarea>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(editError))
                    {
                        <div class="tep-error">@editError</div>
                    }
                }
            </div>

            @* ── Footer ── *@
            <div class="tep-footer">
                @if (panelMode == "edit")
                {
                    <button class="tep-footer-del" @onclick="() => { if (viewEntry != null) ConfirmDelete(viewEntry); ClosePanel(); }">Delete</button>
                    <div class="tep-footer-right">
                        <button class="tep-footer-cancel" @onclick="CancelEdit">Cancel</button>
                        <button class="tep-footer-save" @onclick="SaveEdit" disabled="@editSaving">
                            @if (editSaving) { <span>Saving…</span> } else { <span>Save</span> }
                        </button>
                    </div>
                }
                else
                {
                    <div></div>
                    <div class="tep-footer-right">
                        <button class="tep-footer-cancel" @onclick="CancelEdit">Close</button>
                    </div>
                }
            </div>
        </div>
    }

    @* ══ REASON FOR CHANGE MODAL ══ *@
    @if (showReasonModal)
    {
        <div class="tep-modal-backdrop" @onclick:stopPropagation="true">
            <div class="tep-modal" @onclick:stopPropagation="true">
                <div class="tep-modal-header">
                    <span class="tep-modal-title">Reason for change</span>
                    <button class="tep-close" @onclick="CancelReasonModal"><i class="bi bi-x-lg"></i></button>
                </div>
                <p class="tep-modal-sub">For transparency, changes made to time entries are logged and visible to team admins and assigned managers.</p>
                <textarea class="tep-input tep-textarea tep-modal-ta" placeholder="Why are you editing this time entry?" @bind="reasonForChange"></textarea>
                <div class="tep-modal-actions">
                    <button class="tep-footer-cancel" @onclick="CancelReasonModal">Cancel</button>
                    <button class="tep-footer-save" @onclick="ConfirmSaveWithReason" disabled="@editSaving">Confirm</button>
                </div>
            </div>
        </div>
    }

    @* ══ DELETE CONFIRMATION MODAL ══ *@
    @if (showDeleteModal && deleteTargetEntry != null)
    {
        <div class="tep-modal-backdrop" @onclick:stopPropagation="true">
            <div class="tep-modal" @onclick:stopPropagation="true">
                <div class="tep-modal-header">
                    <span class="tep-modal-title">Delete Time Entry</span>
                    <button class="tep-close" @onclick="CancelDelete"><i class="bi bi-x-lg"></i></button>
                </div>
                <p class="tep-modal-sub">
                    Are you sure you want to delete the entry for
                    <strong>@deleteTargetEntry.ClockIn.ToString("h:mm tt")</strong>?
                    This action cannot be undone.
                </p>
                @if (!string.IsNullOrWhiteSpace(deleteError))
                {
                    <div class="tep-error">@deleteError</div>
                }
                <div class="tep-modal-actions">
                    <button class="tep-footer-cancel" @onclick="CancelDelete">Cancel</button>
                    <button class="tep-footer-del" @onclick="ExecuteDelete" disabled="@deleteInProgress">
                        @if (deleteInProgress) { <span>Deleting…</span> } else { <span>Delete</span> }
                    </button>
                </div>
            </div>
        </div>
    }

</BasePage>

@code {
    // ── View state ───────────────────────────────────────────────
    private RightPanel.WiosMember? selectedMember;
    private RightPanel? rightPanelRef;

    // Use the role within the ACTIVE org — falls back to global role when no org is selected
    private bool IsUserRole =>
        string.Equals(SessionService.ActiveOrgRole ?? SessionService.Role, "user", StringComparison.OrdinalIgnoreCase);

    private string activeTab  = "Week";
    private string activePill = "Organization";

    private void SetTab(string tab) => activeTab = tab;
    private void SetPill(string pill) => activePill = pill;

    // ── Week/day state ───────────────────────────────────────────
    private DateTime               weekStart;
    private DateTime               selectedDate;

    // All entries for the whole week (used for day-pill duration dots)
    private List<TimeEntryRecord>  weekEntries    = new();
    // Entries for the currently selected day (shown in the list)
    private List<TimeEntryRecord>  dayEntries     = new();

    private bool   entriesLoading    = false;
    private string weekTrackedDisplay = "0h 0m";
    private string dayTrackedDisplay  = "0h 0m";

    // ── Accordion panel state ────────────────────────────────────
    private bool trackedExpanded = false;
    private bool payrollExpanded = false;
    private bool historyExpanded = false;
    private List<ChangeHistoryEntry> changeHistory = new();

    private IEnumerable<DateTime> WeekDays =>
        Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i));

    private string WeekRangeLabel =>
        $"{weekStart:d MMM} - {weekStart.AddDays(6):d MMM}";

    // ── Init ─────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        int dow   = (int)DateTime.Today.DayOfWeek;
        weekStart    = DateTime.Today.AddDays(-(dow == 0 ? 6 : dow - 1));
        selectedDate = DateTime.Today;

        // When the user clicks "Dashboard" in the sidebar while already on /dashboard,
        // Blazor won't recreate the component. We listen for navigation events so we
        // can detect this and reset the time entries view back to the dashboard.
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var path = NavManager.ToBaseRelativePath(e.Location).Trim('/').ToLower();
        if (path == "dashboard" || path == "")
        {
            // Reset to normal dashboard view
            selectedMember = null;
            weekEntries.Clear();
            dayEntries.Clear();
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    // ── Called by BasePage whenever clock in/out is saved ────────
    private async Task OnClockActionFired()
    {
        // Always refresh the who's in/out panel so status dots update immediately
        if (rightPanelRef != null)
            await rightPanelRef.RefreshAsync();

        // If viewing time entries, reload the week so the new entry appears
        if (selectedMember != null)
            await LoadWeekAndDay();
    }

    // ── Open time entries for selected member ────────────────────
    private async Task OpenTimeEntries(RightPanel.WiosMember member)
    {
        selectedMember = member;
        await LoadWeekAndDay();
    }

    // ── Close — back to dashboard ────────────────────────────────
    private void CloseTimeEntries()
    {
        selectedMember = null;
        weekEntries.Clear();
        dayEntries.Clear();
    }

    // ── Day pill click ───────────────────────────────────────────
    private async Task SelectDay(DateTime day)
    {
        if (selectedDate.Date == day.Date) return;   // already selected
        selectedDate = day;

        entriesLoading = true;
        StateHasChanged();

        dayEntries = weekEntries.Where(e => e.ClockIn.Date == day.Date).ToList();
        dayTrackedDisplay = ComputeTracked(dayEntries);
        await BuildChangeHistory();

        // Reset accordion panels when switching day
        trackedExpanded = false;
        payrollExpanded = false;
        historyExpanded = false;   // will be re-opened by BuildChangeHistory if there are logs

        entriesLoading = false;
        StateHasChanged();
    }

    // ── Week navigation ──────────────────────────────────────────
    private async Task PrevWeek()
    {
        weekStart    = weekStart.AddDays(-7);
        selectedDate = weekStart;           // jump to Monday of new week
        await LoadWeekAndDay();
    }

    private async Task NextWeek()
    {
        weekStart    = weekStart.AddDays(7);
        selectedDate = weekStart;
        await LoadWeekAndDay();
    }

    // ── Core loader ──────────────────────────────────────────────
    private async Task LoadWeekAndDay()
    {
        if (selectedMember == null) return;

        entriesLoading = true;
        StateHasChanged();

        // Load all entries for the full week in one API call
        weekEntries = await AttendanceService.GetHistoryByWeekAsync(selectedMember.Id, weekStart, SessionService.ActiveOrganizationId);

        // Compute week total
        weekTrackedDisplay = ComputeTracked(weekEntries);

        // Filter to selected day
        dayEntries = weekEntries.Where(e => e.ClockIn.Date == selectedDate.Date).ToList();
        dayTrackedDisplay = ComputeTracked(dayEntries);
        await BuildChangeHistory();

        entriesLoading = false;
        StateHasChanged();
    }

    // ── Helpers ──────────────────────────────────────────────────

    // Duration for a given day (used by day pills)
    private TimeSpan DayDuration(DateTime day) =>
        weekEntries
            .Where(e => e.ClockIn.Date == day.Date && e.ClockOut != null)
            .Aggregate(TimeSpan.Zero, (acc, e) => acc + (e.ClockOut!.Value - e.ClockIn));

    private static string ComputeTracked(List<TimeEntryRecord> src)
    {
        var total = src
            .Where(e => e.ClockOut != null)
            .Aggregate(TimeSpan.Zero, (acc, e) => acc + (e.ClockOut!.Value - e.ClockIn));
        var running = src.FirstOrDefault(e => e.ClockOut == null);
        if (running != null) total += DateTime.Now - running.ClockIn;
        return FmtSpan(total);
    }

    private static string FmtSpan(TimeSpan ts)
    {
        if (ts == TimeSpan.Zero) return "0h 0m";
        int h = (int)ts.TotalHours, m = ts.Minutes;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    // ═══════════════════════════════════════════════════════════
    // EDIT PANEL + REASON MODAL STATE
    // ═══════════════════════════════════════════════════════════

    private TimeEntryRecord? viewEntry     = null;  // which entry is open in the panel
    private string           editType      = "in";  // "in" = clock-in row, "out" = clock-out row
    private string           panelMode     = "none"; // "none" | "view" | "edit"
    private bool             editMode      => panelMode == "edit"; // kept for compat
    private bool             editSaving    = false;
    private string           editError     = "";
    private string           editNote      = "";
    private bool             showReasonModal = false;
    private string           reasonForChange = "";

    // Calendar picker state
    private bool showCalendar = false;
    private DateTime calViewDate = DateTime.Today;

    // Custom time picker state
    private bool showTimePicker2 = false;
    private int tpHour2 = 12;
    private int tpMinute2 = 0;
    private string tpAmPm2 = "AM";

    // Delete state
    private TimeEntryRecord? deleteTargetEntry  = null;
    private bool             showDeleteModal    = false;
    private bool             deleteInProgress   = false;
    private string           deleteError        = "";

    // Bound to the form inputs
    // Plain strings that match exactly what <input type="time"> / <input type="date"> produce.
    // Using string avoids Blazor's unreliable TimeOnly/DateOnly binding across cultures.
    private string editClockInTime  = "";   // "HH:mm"
    private string editClockInDate  = "";   // "yyyy-MM-dd"
    private string editClockOutTime = "";   // "HH:mm"
    private string editClockOutDate = "";   // "yyyy-MM-dd"


    // ── Called when user clicks a Clock In row ────────────────────
    private void OpenEditForClockIn(TimeEntryRecord entry)
    {
        viewEntry        = entry;
        editType         = "in";
        // Pre-fill form with current clock-in values
        editClockInTime  = entry.ClockIn.ToString("HH:mm", System.Globalization.CultureInfo.InvariantCulture);
        editClockInDate  = entry.ClockIn.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
        // Also store clock-out so we send it unchanged when saving
        var refOut = entry.ClockOut ?? DateTime.Now;
        editClockOutTime = refOut.ToString("HH:mm", System.Globalization.CultureInfo.InvariantCulture);
        editClockOutDate = refOut.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
        editNote         = "";
        editError        = "";
        reasonForChange  = "";
        panelMode        = "view";  // ← always VIEW first
        showReasonModal  = false;
    }

    // ── Called when user clicks a Clock Out row ───────────────────
    private void OpenEditForClockOut(TimeEntryRecord entry)
    {
        viewEntry        = entry;
        editType         = "out";
        // Pre-fill form with current clock-out values
        var refOut2 = entry.ClockOut ?? DateTime.Now;
        editClockOutTime = refOut2.ToString("HH:mm", System.Globalization.CultureInfo.InvariantCulture);
        editClockOutDate = refOut2.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
        // Also store clock-in so we send it unchanged when saving
        editClockInTime  = entry.ClockIn.ToString("HH:mm", System.Globalization.CultureInfo.InvariantCulture);
        editClockInDate  = entry.ClockIn.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
        editNote         = "";
        editError        = "";
        reasonForChange  = "";
        panelMode        = "view";  // ← always VIEW first
        showReasonModal  = false;
    }

    // ── Pencil clicked → switch to edit ──────────────────────────
    private void SwitchToEdit()
    {
        panelMode = "edit";
        editError = "";
        showCalendar = false;
        var dateStr = editType == "in" ? editClockInDate : editClockOutDate;
        calViewDate = DateTime.TryParse(dateStr, out var dt) ? dt : DateTime.Today;
    }

    // ── Calendar + Time Picker ────────────────────────────────────
    private void ToggleCalendar2() { } // unused, kept for compat
    private void ToggleDateCal()
    {
        showTimePicker2 = false;
        showCalendar = !showCalendar;
        if (showCalendar)
        {
            var dateStr = editType == "in" ? editClockInDate : editClockOutDate;
            calViewDate = DateTime.TryParse(dateStr, out var dt) ? dt : DateTime.Today;
        }
    }
    private void CalPrevMonth2() { calViewDate = calViewDate.AddMonths(-1); }
    private void CalNextMonth2() { calViewDate = calViewDate.AddMonths(1); }
    private void CalPrevYear2()  { calViewDate = calViewDate.AddYears(-1); }
    private void CalNextYear2()  { calViewDate = calViewDate.AddYears(1); }
    private void CalSelectDate2(DateTime date)
    {
        var fmt = date.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
        if (editType == "in") editClockInDate = fmt;
        else editClockOutDate = fmt;
        showCalendar = false;
        StateHasChanged();
    }

    // ── Custom Time Picker ────────────────────────────────────────
    private void ToggleTimePicker2()
    {
        showCalendar = false;
        showTimePicker2 = !showTimePicker2;
        if (showTimePicker2)
        {
            InitTimePicker2();
            _ = ScrollPickerToSelected();
        }
    }

    // ── Segmented time input helpers ─────────────────────────────
    private string GetSegHour()
    {
        var t = editType == "in" ? editClockInTime : editClockOutTime;
        if (TimeSpan.TryParse(t, out var ts))
        { int h = ts.Hours % 12; return (h == 0 ? 12 : h).ToString(); }
        return "12";
    }
    private string GetSegMin()
    {
        var t = editType == "in" ? editClockInTime : editClockOutTime;
        if (TimeSpan.TryParse(t, out var ts)) return ts.Minutes.ToString("D2");
        return "00";
    }
    private void OnSegFocus(string seg)
    {
        showCalendar = false;
        if (!showTimePicker2) { showTimePicker2 = true; InitTimePicker2(); _ = ScrollPickerToSelected(); }
        // Highlight the focused column in the picker
        if (seg == "h") _ = JSRuntime.InvokeVoidAsync("selectInputText", "tep-seg-h");
        else             _ = JSRuntime.InvokeVoidAsync("selectInputText", "tep-seg-m");
    }
    private void OnSegChange(string seg, string raw)
    {
        if (!int.TryParse(raw.Trim(), out int val)) return;
        if (seg == "h")
        {
            val = Math.Clamp(val, 1, 12);
            tpHour2 = val;
        }
        else
        {
            val = Math.Clamp(val, 0, 59);
            tpMinute2 = val;
        }
        ApplyTimePicker2();
        _ = ScrollPickerToSelected();
    }
    private void ToggleAmPm()
    {
        tpAmPm2 = tpAmPm2 == "AM" ? "PM" : "AM";
        ApplyTimePicker2();
    }

    // ── Direct-to-edit from list pencil icon ─────────────────────
    private void OpenEditForClockInDirect(TimeEntryRecord entry)
    {
        OpenEditForClockIn(entry);
        panelMode = "edit";
        var dateStr = editClockInDate;
        calViewDate = DateTime.TryParse(dateStr, out var dt) ? dt : DateTime.Today;
    }
    private void OpenEditForClockOutDirect(TimeEntryRecord entry)
    {
        OpenEditForClockOut(entry);
        panelMode = "edit";
        var dateStr = editClockOutDate;
        calViewDate = DateTime.TryParse(dateStr, out var dt) ? dt : DateTime.Today;
    }

    // Open picker + select segment when user focuses
    private void OnTimeFocus()
    {
        showCalendar = false;
        if (!showTimePicker2) { showTimePicker2 = true; InitTimePicker2(); _ = ScrollPickerToSelected(); }
        _ = JSRuntime.InvokeVoidAsync("selectInputText", "tep-seg-h");
    }

    private async Task ScrollPickerToSelected()
    {
        // Give Blazor one render cycle then scroll each column to its selected cell
        await Task.Delay(30);
        await JSRuntime.InvokeVoidAsync("scrollPickerColumns");
    }
    private void InitTimePicker2()
    {
        var timeStr = editType == "in" ? editClockInTime : editClockOutTime;
        if (TimeSpan.TryParse(timeStr, out var ts))
        {
            int h24 = ts.Hours;
            tpAmPm2 = h24 >= 12 ? "PM" : "AM";
            tpHour2 = h24 % 12; if (tpHour2 == 0) tpHour2 = 12;
            tpMinute2 = ts.Minutes;
        }
        else { tpHour2 = 12; tpMinute2 = 0; tpAmPm2 = "AM"; }
    }
    private void ApplyTimePicker2()
    {
        // Convert 12h picker values to 24h "HH:mm" string stored in editClockInTime/editClockOutTime
        int h24 = tpAmPm2 == "PM" ? (tpHour2 == 12 ? 12 : tpHour2 + 12)
                                   : (tpHour2 == 12 ? 0  : tpHour2);
        var result = $"{h24:D2}:{tpMinute2:D2}";
        if (editType == "in") editClockInTime = result;
        else editClockOutTime = result;
        StateHasChanged();
    }

    // Handle manual text input — parse formats like "11:35 am", "11:35", "1135"
    private void OnManualTimeInput(string raw)
    {
        var ic = System.Globalization.CultureInfo.InvariantCulture;
        raw = raw.Trim().ToLower();
        DateTime parsed = default;
        bool ok =
            DateTime.TryParseExact(raw, new[]{ "h:mm tt", "hh:mm tt", "h:mm t", "hh:mm t",
                                               "h:mmtt",  "hh:mmtt",  "H:mm",   "HH:mm" },
                ic, System.Globalization.DateTimeStyles.None, out parsed)
            || DateTime.TryParse(raw, ic, System.Globalization.DateTimeStyles.NoCurrentDateDefault, out parsed);
        if (ok)
        {
            var result = parsed.ToString("HH:mm", ic);
            if (editType == "in") editClockInTime = result;
            else editClockOutTime = result;
            // Sync picker state to match
            InitTimePicker2();
        }
        // If parse fails, leave the existing value — do not blank it out
        StateHasChanged();
    }

    private string GetDisplayTime2()
    {
        var timeStr = editType == "in" ? editClockInTime : editClockOutTime;
        if (!string.IsNullOrEmpty(timeStr) && TimeSpan.TryParse(timeStr, out var ts))
        {
            int h = ts.Hours % 12; if (h == 0) h = 12;
            return $"{h}:{ts.Minutes:D2} {(ts.Hours >= 12 ? "pm" : "am")}";
        }
        return "";
    }

    // ── Close the panel completely ──────────────────────────
    private void ClosePanel()
    {
        viewEntry       = null;
        panelMode       = "none";
        editError       = "";
        showCalendar    = false;
        showTimePicker2 = false;
        showReasonModal = false;
    }

    // ── Cancel edit — close panel, hide modal ─────────────────────
    private void CancelEdit()
    {
        ClosePanel();
    }

    // ── Cancel the reason modal — go back to edit panel ──────────
    private void CancelReasonModal()
    {
        showReasonModal = false;
        // panelMode stays "edit" so the panel stays open
    }

    // ── Delete flow ───────────────────────────────────────────────
    private void ConfirmDelete(TimeEntryRecord entry)
    {
        deleteTargetEntry = entry;
        deleteError       = "";
        showDeleteModal   = true;
        // Close edit panel if open
        ClosePanel();
    }

    private void CancelDelete()
    {
        showDeleteModal   = false;
        deleteTargetEntry = null;
        deleteError       = "";
    }

    private async Task ExecuteDelete()
    {
        if (deleteTargetEntry == null) return;

        deleteInProgress = true;
        deleteError      = "";
        StateHasChanged();

        var empId   = selectedMember?.Id ?? SessionService.Id;
        var success = await AttendanceService.DeleteEntryAsync(deleteTargetEntry.Id, empId);

        if (success)
        {
            showDeleteModal   = false;
            deleteTargetEntry = null;
            await LoadWeekAndDay();
        }
        else
        {
            deleteError = "Delete failed — please try again.";
        }

        deleteInProgress = false;
        StateHasChanged();
    }

    // ── Save clicked → show reason modal ─────────────────────────
    private void SaveEdit()
    {
        if (viewEntry == null) return;
        editError       = "";
        reasonForChange = "";
        showReasonModal = true;
    }

    // ── Confirm clicked in modal → call API, close everything ────
    private async Task ConfirmSaveWithReason()
    {
        if (viewEntry == null) return;

        editSaving      = true;
        showReasonModal = false;
        StateHasChanged();

        try
        {
            // Parse the plain strings from the HTML inputs ("yyyy-MM-dd" + "HH:mm"),
            // combine into a local DateTime, convert to UTC, then format as strict ISO-8601.
            // Using InvariantCulture throughout so colons are always used as time separators.
            static DateTime ParseLocalDT(string date, string time)
            {
                var ic = System.Globalization.CultureInfo.InvariantCulture;

                // Normalize time: keep only HH:mm (strip seconds/ms if present)
                var timePart = string.IsNullOrWhiteSpace(time) ? "00:00"
                             : time.Length > 5 ? time.Substring(0, 5) : time;

                // Try strict ISO format first, then lenient fallback
                if (DateTime.TryParseExact($"{date}T{timePart}", "yyyy-MM-ddTHH:mm", ic,
                        System.Globalization.DateTimeStyles.None, out var dt))
                    return DateTime.SpecifyKind(dt, DateTimeKind.Local);

                // Fallback: try parsing date and time separately
                if (DateTime.TryParse(date, ic, System.Globalization.DateTimeStyles.None, out var datePart)
                    && TimeSpan.TryParse(timePart, ic, out var timeSpan))
                    return DateTime.SpecifyKind(datePart.Date.Add(timeSpan), DateTimeKind.Local);

                throw new FormatException($"Cannot parse date='{date}' time='{time}'");
            }

            var newClockInStr = ParseLocalDT(editClockInDate, editClockInTime)
                                    .ToUniversalTime()
                                    .ToString("yyyy-MM-ddTHH:mm:ss.fffZ",
                                        System.Globalization.CultureInfo.InvariantCulture);

            string? newClockOutStr = null;
            if (viewEntry.ClockOut.HasValue)
            {
                newClockOutStr = ParseLocalDT(editClockOutDate, editClockOutTime)
                                     .ToUniversalTime()
                                     .ToString("yyyy-MM-ddTHH:mm:ss.fffZ",
                                         System.Globalization.CultureInfo.InvariantCulture);
            }

            var empId = selectedMember?.Id ?? SessionService.Id;

            var (updated, apiError) = await AttendanceService.UpdateEntryAsync(
                viewEntry.Id, empId, newClockInStr, newClockOutStr,
                string.IsNullOrWhiteSpace(reasonForChange) ? null : reasonForChange,
                editType);

            if (updated != null)
            {
                // ✅ Close panel + reload data so changes appear immediately
                ClosePanel();
                await LoadWeekAndDay();
            }
            else
            {
                editError       = $"Save failed — {apiError ?? "please try again."}";
                panelMode       = "edit";
                showReasonModal = false;
            }
        }
        catch (Exception ex)
        {
            editError       = $"Error: {ex.Message}";
            panelMode       = "edit";
            showReasonModal = false;
        }
        finally
        {
            editSaving = false;
            StateHasChanged();
        }
    }

    // ── Build change history — fetched fresh from API ─────────────
    private string changeHistoryError = "";

    private async Task BuildChangeHistory()
    {
        if (selectedMember == null) return;
        changeHistoryError = "";
        try
        {
            var logs = await AttendanceService.GetChangeLogByDateAsync(selectedMember.Id, selectedDate);
            changeHistory = logs.Select(l => new ChangeHistoryEntry
            {
                ChangedByName   = l.ChangedByName,
                Action          = l.Action,
                OldClockIn      = l.OldClockIn,
                OldClockOut     = l.OldClockOut,
                NewClockIn      = l.NewClockIn,
                NewClockOut     = l.NewClockOut,
                ReasonForChange = l.ReasonForChange,
                ChangedAt       = l.ChangedAt
            }).ToList();

            // Auto-expand change history accordion when there are results
            if (changeHistory.Any())
                historyExpanded = true;
        }
        catch (Exception ex)
        {
            changeHistoryError = $"Could not load change history: {ex.Message}";
            changeHistory = new();
        }
    }

    public class ChangeHistoryEntry
    {
        public string    ChangedByName   { get; set; } = "";
        public string    Action          { get; set; } = "";
        public DateTime? OldClockIn      { get; set; }
        public DateTime? OldClockOut     { get; set; }
        public DateTime? NewClockIn      { get; set; }
        public DateTime? NewClockOut     { get; set; }
        public string?   ReasonForChange { get; set; }
        public DateTime  ChangedAt       { get; set; }
    }
}

