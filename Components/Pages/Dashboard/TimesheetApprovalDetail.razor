@code {
    // ── Parameters ────────────────────────────────────────────────────
    [Parameter] public RangeTimesheetRow?       Row            { get; set; }
    [Parameter] public int                      EmployeeId     { get; set; }
    [Parameter] public DateTime                 PeriodStart    { get; set; }
    [Parameter] public DateTime                 PeriodEnd      { get; set; }
    [Parameter] public EventCallback            OnBack         { get; set; }
    /// <summary>Full list of approval rows — used for Prev / Next employee navigation</summary>
    [Parameter] public List<RangeTimesheetRow>  EmployeeList   { get; set; } = new();

    // ── Local state ───────────────────────────────────────────────────
    private bool isLoading           = false;
    private bool showAddEntry        = false;
    private bool trackedExpanded     = false;
    private bool payrollExpanded     = false;
    private bool historyExpanded     = false;
    // Tracks last loaded employee — prevents OnParametersSetAsync from
    // reloading data on every parent StateHasChanged (was causing blinking)
    private int  lastLoadedEmployeeId = 0;

    private DateTime weekStart;
    private DateTime selectedDate;

    private List<TimeEntryRecord>    weekEntries   = new();
    private List<TimeEntryRecord>    dayEntries    = new();
    private List<ChangeHistoryEntry> changeHistory = new();

    private string dayTrackedDisplay = "0h 0m";
    private string periodTracked     = "0h 0m";
    private string periodWorked      = "0h 0m";
    private string periodBreaks      = "—";

    // ── Data model (mirrors Timesheets.State.cs ChangeHistoryEntry) ──
    public class ChangeHistoryEntry
    {
        public string    ChangedByName   { get; set; } = "";
        public string    Action          { get; set; } = "";
        public DateTime? OldClockIn      { get; set; }
        public DateTime? OldClockOut     { get; set; }
        public DateTime? NewClockIn      { get; set; }
        public DateTime? NewClockOut     { get; set; }
        public string?   ReasonForChange { get; set; }
        public DateTime  ChangedAt       { get; set; }
        public bool      IsHourEntry     => Action == "AddedHour";
        public bool      IsBreakEntry    => Action == "AddedBreak";
    }

    // ── Computed ──────────────────────────────────────────────────────
    private string Initials =>
        string.IsNullOrEmpty(Row?.FullName) ? "?" : Row.FullName[0].ToString().ToUpper();

    private IEnumerable<DateTime> WeekDays =>
        Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i));

    // ── Lifecycle ─────────────────────────────────────────────────────
    // Use OnInitializedAsync so this fires ONCE when the component mounts.
    // OnParametersSetAsync fires on every parent StateHasChanged — that caused
    // the continuous blinking / reload loop.
    protected override async Task OnInitializedAsync()
    {
        // Initialise week/day from the period start
        selectedDate = PeriodStart;
        int dow = (int)selectedDate.DayOfWeek;
        weekStart = selectedDate.AddDays(-(dow == 0 ? 6 : dow - 1));

        // Populate sidebar totals from the row passed in
        if (Row != null)
        {
            // Don't use Row.TotalHours — it's the single-day value from the org API.
            // LoadWeekAndDay() will compute the correct weekly total from actual entries.
            periodTracked = "…";
            periodWorked  = "…";
            periodBreaks  = "—";
        }

        await LoadWeekAndDay();
    }

    // Called when the parent switches to a different employee via prev/next
    protected override async Task OnParametersSetAsync()
    {
        // Only reload if the employee actually changed — prevents blinking
        // on every parent StateHasChanged while viewing the same employee
        if (EmployeeId != lastLoadedEmployeeId && EmployeeId != 0)
        {
            selectedDate = PeriodStart;
            int dow = (int)selectedDate.DayOfWeek;
            weekStart = selectedDate.AddDays(-(dow == 0 ? 6 : dow - 1));

            if (Row != null)
            {
                // Don't use Row.TotalHours — LoadWeekAndDay() computes correct weekly total.
                periodTracked = "…";
                periodWorked  = "…";
                periodBreaks  = "—";
            }

            trackedExpanded = payrollExpanded = historyExpanded = false;
            await LoadWeekAndDay();
        }
    }

    // ── Data loading ──────────────────────────────────────────────────
    private async Task LoadWeekAndDay()
    {
        if (EmployeeId == 0) return;
        lastLoadedEmployeeId = EmployeeId;   // ← record so OnParametersSetAsync skips re-load
        isLoading = true; StateHasChanged();
        try
        {
            weekEntries = await AttendanceService.GetHistoryByWeekAsync(EmployeeId, weekStart, SessionService.ActiveOrganizationId);
            dayEntries  = weekEntries.Where(e => e.ClockIn.Date == selectedDate.Date).ToList();
            dayTrackedDisplay = ComputeTracked(dayEntries);

            // Recompute weekly totals from actual entries (not from Row.TotalHours which
            // only covers the single selected day from the org-level API).
            var weekTotal = ComputeWeekTracked(weekEntries);
            periodTracked = weekTotal;
            periodWorked  = weekTotal;

            await BuildChangeHistory();
        }
        catch { /* silently handle — show empty state */ }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task BuildChangeHistory()
    {
        try
        {
            var logs = await AttendanceService.GetChangeLogByDateAsync(EmployeeId, selectedDate);
            changeHistory = logs.Select(l => new ChangeHistoryEntry
            {
                ChangedByName   = l.ChangedByName,
                Action          = l.Action,
                OldClockIn      = l.OldClockIn,
                OldClockOut     = l.OldClockOut,
                NewClockIn      = l.NewClockIn,
                NewClockOut     = l.NewClockOut,
                ReasonForChange = l.ReasonForChange,
                ChangedAt       = l.ChangedAt
            }).ToList();
        }
        catch { changeHistory = new(); }
    }

    // ── Navigation ────────────────────────────────────────────────────
    private async Task SelectDay(DateTime day)
    {
        selectedDate     = day;
        trackedExpanded  = payrollExpanded = historyExpanded = false;
        dayEntries       = weekEntries.Where(e => e.ClockIn.Date == day.Date).ToList();
        dayTrackedDisplay = ComputeTracked(dayEntries);
        await BuildChangeHistory();
        StateHasChanged();
    }

    private async Task PrevWeek()
    {
        weekStart    = weekStart.AddDays(-7);
        selectedDate = weekStart;
        await LoadWeekAndDay();
    }

    private async Task NextWeek()
    {
        weekStart    = weekStart.AddDays(7);
        selectedDate = weekStart;
        await LoadWeekAndDay();
    }

    private async Task HandleBack() => await OnBack.InvokeAsync();

    // ── Add entry ─────────────────────────────────────────────────────
    private void OpenAddTimeEntry() { showAddEntry = true; StateHasChanged(); }
    private void CloseAddEntry()    { showAddEntry = false; StateHasChanged(); }

    // ── Prev / Next employee ───────────────────────────────────────────
    private int CurrentEmployeeIndex =>
        EmployeeList.FindIndex(r => r.EmployeeId == EmployeeId);

    private bool HasPrevEmployee => CurrentEmployeeIndex > 0;
    private bool HasNextEmployee => CurrentEmployeeIndex >= 0 && CurrentEmployeeIndex < EmployeeList.Count - 1;

    private async Task NavPrevEmployee()
    {
        int idx = CurrentEmployeeIndex;
        if (idx <= 0) return;
        await SwitchToEmployee(EmployeeList[idx - 1]);
    }

    private async Task NavNextEmployee()
    {
        int idx = CurrentEmployeeIndex;
        if (idx < 0 || idx >= EmployeeList.Count - 1) return;
        await SwitchToEmployee(EmployeeList[idx + 1]);
    }

    private async Task SwitchToEmployee(RangeTimesheetRow newRow)
    {
        // Update local binding — parent will propagate via parameter on next render,
        // but we reset lastLoadedEmployeeId so OnParametersSetAsync picks it up
        lastLoadedEmployeeId = 0;
        Row        = newRow;
        EmployeeId = newRow.EmployeeId;

        selectedDate = PeriodStart;
        int dow = (int)selectedDate.DayOfWeek;
        weekStart = selectedDate.AddDays(-(dow == 0 ? 6 : dow - 1));

        // Don't pre-fill from newRow.TotalHours — LoadWeekAndDay will compute
        // correct totals from actual weekEntries (including live sessions).
        periodTracked = "…";
        periodWorked  = "…";
        periodBreaks  = "—";

        trackedExpanded = payrollExpanded = historyExpanded = false;
        await LoadWeekAndDay();
    }

    // ── Static helpers (mirror Timesheets.ListData.cs) ────────────────
    private static string GetHolidayForDate(DateTime date)
    {
        var cals = APM.StaffZen.Blazor.Components.Pages.TimeOff.HolidaysTabState.SharedCalendars;
        if (cals == null) return "";
        foreach (var cal in cals)
        {
            var h = cal.Holidays.FirstOrDefault(h => h.Date.Date == date.Date);
            if (h != null) return h.Name;
        }
        return "";
    }

    private static bool IsRestDay(DateTime date)
        => APM.StaffZen.Blazor.Services.WorkScheduleState.IsRestDay(date);

    private TimeSpan DayDuration(DateTime day)
    {
        var entries = weekEntries.Where(e => e.ClockIn.Date == day.Date).ToList();
        var total   = TimeSpan.Zero;
        foreach (var e in entries)
        {
            if (e.IsBreakEntry) continue;
            DateTime effectiveOut;
            if (e.ClockOut.HasValue)
            {
                effectiveOut = e.ClockOut.Value;
            }
            else if (!e.IsManual && !e.IsHourEntry && day.Date == DateTime.Today)
            {
                // Live session — use current time as effective clock-out
                effectiveOut = DateTime.Now;
            }
            else
            {
                continue; // open manual / past-day open → skip
            }
            var dur = effectiveOut - e.ClockIn;
            if (dur > TimeSpan.Zero) total += dur;
        }
        return total;
    }

    private static string ComputeTracked(List<TimeEntryRecord> src)
    {
        var total   = src.Where(e => e.ClockOut != null)
                         .Aggregate(TimeSpan.Zero, (acc, e) => acc + (e.ClockOut!.Value - e.ClockIn));
        var running = src.FirstOrDefault(e => e.ClockOut == null && !e.IsManual);
        if (running != null)
        {
            var elapsed = DateTime.Now - running.ClockIn;
            if (elapsed > TimeSpan.Zero) total += elapsed;
        }
        return FmtSpan(total);
    }

    /// <summary>
    /// Compute total tracked hours for the entire week from raw weekEntries,
    /// properly handling live (ongoing) sessions so the weekly summary panel
    /// always shows accurate totals even when someone is currently clocked in.
    /// </summary>
    private static string ComputeWeekTracked(List<TimeEntryRecord> src)
    {
        var total = TimeSpan.Zero;
        foreach (var e in src)
        {
            if (e.IsBreakEntry) continue;
            if (e.ClockOut.HasValue)
            {
                var dur = e.ClockOut.Value - e.ClockIn;
                if (dur > TimeSpan.Zero) total += dur;
            }
            else if (!e.IsManual && !e.IsHourEntry)
            {
                // Live session — use current time as effective clock-out
                var elapsed = DateTime.Now - e.ClockIn;
                if (elapsed > TimeSpan.Zero) total += elapsed;
            }
        }
        return FmtSpan(total);
    }

    private static string FmtSpan(TimeSpan ts)
    {
        if (ts <= TimeSpan.Zero) return "0h 0m";
        int h = (int)ts.TotalHours, m = ts.Minutes;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    private static string GetHistoryActionLabel(ChangeHistoryEntry h) => h.Action switch
    {
        "AddedBreak" => "added a break entry",
        "AddedHour"  => "added an hour entry",
        "Added"      => "added a time entry",
        "Edited"     => "edited a time entry",
        "Deleted"    => "deleted a time entry",
        _            => h.Action.ToLower()
    };
}


