@page "/set-password"

@inject NavigationManager Nav
@inject IHttpClientFactory ClientFactory
@using Microsoft.AspNetCore.WebUtilities

<h3>Set Password</h3>

<input type="password" @bind="password" placeholder="Password" class="form-control" />

<button class="btn btn-primary mt-2" @onclick="SavePassword">
    Save Password
</button>

@code {

    string token = string.Empty;
    string password = string.Empty;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var tokenValue))
        {
            token = tokenValue.ToString();
        }
    }

    async Task SavePassword()
    {
        var client = ClientFactory.CreateClient("API");

        await client.PostAsJsonAsync("api/invite/set-password", new
        {
            Token = token,
            Password = password
        });

        Nav.NavigateTo("/login");
    }
}
