@* Getting Started — Org setup form matching Jibble reference exactly *@

<div class="gsof-root">

    <!-- Left panel: light grey + vertically centred illustration -->
    <div class="gsof-left">
        <img src="Images/Dashboard/greeting-illustration.png" class="gsof-illustration" alt="Illustration" />
    </div>

    <!-- Right panel: white, form centred vertically -->
    <div class="gsof-right">
        <div class="gsof-inner">

            <h1 class="gsof-title">Let's start your team on the right track</h1>
            <p class="gsof-sub">Help us create the best experience for you</p>

            <!-- Organization name — floating label, red border on error -->
            <div class="gsof-field">
                <div class="gsof-input-wrap @(OrgNameError ? "gsof-error-wrap" : "")">
                    <input class="gsof-input"
                           placeholder=" "
                           value="@OrgName"
                           @oninput="e => { OrgName = e.Value?.ToString() ?? string.Empty; OrgNameChanged.InvokeAsync(OrgName); if (OrgNameError && !string.IsNullOrWhiteSpace(OrgName)) OrgNameError = false; }"
                           @onblur="ValidateOrgName" />
                    <label class="gsof-label @(OrgNameError ? "gsof-label-error" : "")">Organization name</label>
                </div>
                @if (OrgNameError)
                {
                    <span class="gsof-error-msg">Name is required</span>
                }
            </div>

            <!-- Password — set login password for this admin account -->
            <div class="gsof-field">
                <div class="gsof-input-wrap @(PasswordError ? "gsof-error-wrap" : "")">
                    <input type="@_passwordType"
                           class="gsof-input"
                           placeholder=" "
                           style="padding-right:44px;"
                           value="@Password"
                           @oninput="e => { Password = e.Value?.ToString() ?? string.Empty; PasswordChanged.InvokeAsync(Password); if (PasswordError && Password.Length >= 6) PasswordError = false; }"
                           @onblur="ValidatePassword" />
                    <label class="gsof-label @(PasswordError ? "gsof-label-error" : "")">
                        @(IsGoogleAccount ? "Set a password to log in with email *" : "Set a login password")
                    </label>
                    <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);cursor:pointer;" @onclick="TogglePassword">
                        @if (_passwordType == "password")
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        }
                    </span>
                </div>
                @if (PasswordError)
                {
                    <span class="gsof-error-msg">@(IsGoogleAccount ? "Password is required to log in with email (min 6 characters)" : "Password must be at least 6 characters")</span>
                }
                @if (IsGoogleAccount && !PasswordError && string.IsNullOrWhiteSpace(Password))
                {
                    <span style="font-size:11px;color:#888;padding-left:2px;display:block;margin-top:4px;">Required — lets you log in with email &amp; password in addition to Google</span>
                }
            </div>

            <!-- Country — bold selected value, × clear + | + ▾ -->
            <div class="gsof-field">
                <div class="gsof-select-wrap">
                    <select class="gsof-select gsof-select-bold" @onchange="OnCountryChange">
                        @foreach (var c in Countries)
                        {
                            <option value="@c" selected="@(c == SelectedCountry)">@c</option>
                        }
                    </select>
                    <div class="gsof-select-icons">
                        <span class="gsof-clear-btn" @onclick="ClearCountry" @onclick:stopPropagation="true">×</span>
                        <span class="gsof-icon-vline"></span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2.5">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Phone — flag + code + ▾ prefix, then input -->
            <div class="gsof-field">
                <div class="gsof-phone-wrap">
                    <div class="gsof-phone-prefix">
                        <span class="gsof-flag">@CountryFlag</span>
                        <span class="gsof-phone-code">@CountryCode</span>
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2.5" style="margin-left:2px;">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </div>
                    <input class="gsof-phone-input"
                           placeholder="Phone Number"
                           value="@OrgPhone"
                           @oninput="e => OrgPhoneChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)" />
                </div>
            </div>

            <!-- Industry -->
            <div class="gsof-field">
                <div class="gsof-select-wrap">
                    <select class="gsof-select @(string.IsNullOrEmpty(SelectedIndustry) ? "gsof-placeholder" : "")"
                            @onchange="e => SelectedIndustryChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)">
                        <option value="">Industry</option>
                        @foreach (var i in Industries)
                        {
                            <option value="@i" selected="@(i == SelectedIndustry)">@i</option>
                        }
                    </select>
                    <svg class="gsof-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            </div>

            <!-- Organization size -->
            <div class="gsof-field">
                <div class="gsof-select-wrap">
                    <select class="gsof-select @(string.IsNullOrEmpty(SelectedOrgSize) ? "gsof-placeholder" : "")"
                            @onchange="e => SelectedOrgSizeChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)">
                        <option value="">Organization size</option>
                        @foreach (var s in OrgSizes)
                        {
                            <option value="@s" selected="@(s == SelectedOrgSize)">@s</option>
                        }
                    </select>
                    <svg class="gsof-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            </div>

            <!-- Your role or field -->
            <div class="gsof-field">
                <div class="gsof-select-wrap">
                    <select class="gsof-select @(string.IsNullOrEmpty(SelectedUserRole) ? "gsof-placeholder" : "")"
                            @onchange="e => SelectedUserRoleChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)">
                        <option value="">Your role or field</option>
                        @foreach (var r in UserRoles)
                        {
                            <option value="@r" selected="@(r == SelectedUserRole)">@r</option>
                        }
                    </select>
                    <svg class="gsof-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            </div>

            <!-- Continue -->
            <button class="gsof-btn-continue" @onclick="OnContinue" disabled="@ContinueLoading">
                @(ContinueLoading ? "Setting up..." : "Continue")
            </button>

        </div>
    </div>
</div>

<style>
    /* ── Root: full viewport minus nav ── */
    .gsof-root {
        display: flex;
        height: calc(100vh - 57px);
        overflow: hidden;
        background: #f0f2f5;
    }

    /* ── Left panel ── */
    .gsof-left {
        flex: 0 0 50%;
        background: #eef0f5;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 40px;
        overflow: hidden;
    }

    .gsof-illustration {
        width: 100%;
        max-width: 300px;
        object-fit: contain;
    }

    /* ── Right panel ── */
    .gsof-right {
        flex: 0 0 50%;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 56px;
        overflow: hidden;
    }

    .gsof-inner {
        width: 100%;
        max-width: 480px;
    }

    /* ── Title & subtitle ── */
    .gsof-title {
        font-size: 28px;
        font-weight: 900;
        color: #111;
        line-height: 1.15;
        margin: 0 0 6px;
        letter-spacing: -0.5px;
        outline: none !important;
        border: none !important;
        box-shadow: none !important;
    }

    .gsof-sub {
        font-size: 13px;
        color: #aaa;
        margin: 0 0 18px;
        font-weight: 400;
    }

    /* ── Field spacing ── */
    .gsof-field {
        margin-bottom: 10px;
    }

    /* ── Org name floating label input ── */
    .gsof-input-wrap {
        position: relative;
        border: 1.5px solid #e0e3e8;
        border-radius: 8px;
        background: #fff;
        transition: border-color 0.15s;
    }

    .gsof-input-wrap:focus-within {
        border-color: #aaa;
    }

    .gsof-error-wrap {
        border-color: #e53e3e !important;
    }

    .gsof-input {
        width: 100%;
        padding: 18px 16px 6px 16px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        color: #111;
        outline: none;
        background: transparent;
        box-sizing: border-box;
    }

    .gsof-label {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 15px;
        color: #bbb;
        pointer-events: none;
        transition: all 0.15s ease;
        background: transparent;
        line-height: 1;
    }

    .gsof-input:focus ~ .gsof-label,
    .gsof-input:not(:placeholder-shown) ~ .gsof-label {
        top: 10px;
        transform: none;
        font-size: 11px;
        color: #aaa;
        font-weight: 500;
    }

    .gsof-label-error {
        color: #e53e3e !important;
    }

    .gsof-input:focus ~ .gsof-label-error,
    .gsof-input:not(:placeholder-shown) ~ .gsof-label-error {
        color: #e53e3e !important;
    }

    .gsof-error-msg {
        display: block;
        font-size: 12px;
        color: #e53e3e;
        margin-top: 5px;
        padding-left: 2px;
    }

    /* ── Select wrapper ── */
    .gsof-select-wrap {
        position: relative;
        width: 100%;
    }

    .gsof-select {
        width: 100%;
        padding: 12px 52px 12px 16px;
        border: 1.5px solid #e0e3e8;
        border-radius: 8px;
        font-size: 14px;
        color: #111;
        background: #fff;
        appearance: none;
        -webkit-appearance: none;
        outline: none;
        cursor: pointer;
        box-sizing: border-box;
        transition: border-color 0.15s;
    }

    .gsof-select:focus {
        border-color: #aaa;
    }

    .gsof-select-bold {
        font-weight: 700;
        color: #111;
    }

    .gsof-placeholder {
        color: #aaa !important;
        font-weight: 400 !important;
    }

    /* SVG caret for plain selects */
    .gsof-caret {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
    }

    /* Country select: × | ▾ group */
    .gsof-select-icons {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        align-items: center;
        gap: 6px;
        pointer-events: none;
    }

    .gsof-clear-btn {
        font-size: 18px;
        color: #bbb;
        line-height: 1;
        cursor: pointer;
        pointer-events: all;
        padding: 0 2px;
        transition: color 0.15s;
    }

    .gsof-clear-btn:hover {
        color: #666;
    }

    .gsof-icon-vline {
        width: 1px;
        height: 16px;
        background: #ddd;
        display: inline-block;
        flex-shrink: 0;
    }

    /* ── Phone field ── */
    .gsof-phone-wrap {
        display: flex;
        border: 1.5px solid #e0e3e8;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
        transition: border-color 0.15s;
    }

    .gsof-phone-wrap:focus-within {
        border-color: #aaa;
    }

    .gsof-phone-prefix {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 12px 14px;
        border-right: 1.5px solid #e0e3e8;
        cursor: pointer;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .gsof-flag {
        font-size: 18px;
        line-height: 1;
    }

    .gsof-phone-code {
        font-weight: 700;
        font-size: 14px;
        color: #111;
    }

    .gsof-phone-input {
        flex: 1;
        padding: 12px 16px;
        border: none;
        outline: none;
        font-size: 14px;
        color: #111;
        background: transparent;
    }

    .gsof-phone-input::placeholder {
        color: #bbb;
    }

    /* ── Continue button ── */
    .gsof-btn-continue {
        width: 100%;
        margin-top: 6px;
        padding: 13px;
        background: #ff6600;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.2px;
        transition: background 0.2s;
    }

    .gsof-btn-continue:hover:not(:disabled) {
        background: #e55a00;
    }

    .gsof-btn-continue:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    /* ── Responsive ── */
    @@media (max-width: 900px) {
        .gsof-left { display: none; }
        .gsof-right { padding: 40px 28px; }
        .gsof-title { font-size: 28px; }
    }
</style>

@code {
    [Parameter] public string OrgName { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OrgNameChanged { get; set; }

    [Parameter] public string OrgPhone { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OrgPhoneChanged { get; set; }

    [Parameter] public string SelectedCountry { get; set; } = "India";
    [Parameter] public EventCallback<string> SelectedCountryChanged { get; set; }

    [Parameter] public string SelectedIndustry { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedIndustryChanged { get; set; }

    [Parameter] public string SelectedOrgSize { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedOrgSizeChanged { get; set; }

    [Parameter] public string SelectedUserRole { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedUserRoleChanged { get; set; }

    [Parameter] public bool ContinueLoading { get; set; }
    [Parameter] public EventCallback OnContinue { get; set; }

    [Parameter] public string Password { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> PasswordChanged { get; set; }

    [Parameter] public bool IsGoogleAccount { get; set; } = false;

    bool OrgNameError = false;
    bool PasswordError = false;
    string _passwordType = "password";

    void ValidateOrgName() => OrgNameError = string.IsNullOrWhiteSpace(OrgName);
    void ValidatePassword()
    {
        if (IsGoogleAccount)
            PasswordError = string.IsNullOrWhiteSpace(Password) || Password.Length < 6;
        else
            PasswordError = !string.IsNullOrWhiteSpace(Password) && Password.Length < 6;
    }
    void TogglePassword() => _passwordType = _passwordType == "password" ? "text" : "password";

    void OnCountryChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        SelectedCountry = val;
        SelectedCountryChanged.InvokeAsync(val);
    }

    void ClearCountry()
    {
        SelectedCountry = string.Empty;
        SelectedCountryChanged.InvokeAsync(string.Empty);
    }

    string CountryFlag => SelectedCountry switch {
        "India"          => "🇮🇳",
        "United States"  => "🇺🇸",
        "United Kingdom" => "🇬🇧",
        "Australia"      => "🇦🇺",
        "Canada"         => "🇨🇦",
        "Singapore"      => "🇸🇬",
        "UAE"            => "🇦🇪",
        "Germany"        => "🇩🇪",
        "France"         => "🇫🇷",
        "Japan"          => "🇯🇵",
        "Brazil"         => "🇧🇷",
        _                => "🌐"
    };

    string CountryCode => SelectedCountry switch {
        "India"          => "+91",
        "United States"  => "+1",
        "United Kingdom" => "+44",
        "Australia"      => "+61",
        "Canada"         => "+1",
        "Singapore"      => "+65",
        "UAE"            => "+971",
        "Germany"        => "+49",
        "France"         => "+33",
        "Japan"          => "+81",
        "Brazil"         => "+55",
        _                => ""
    };

    static readonly List<string> Countries = new() {
        "India","United States","United Kingdom","Australia",
        "Canada","Singapore","UAE","Germany","France","Japan","Brazil","Other"
    };
    static readonly List<string> Industries = new() {
        "Technology","Healthcare","Finance","Education","Retail",
        "Manufacturing","Construction","Hospitality","Transportation","Media","Legal","Other"
    };
    static readonly List<string> OrgSizes = new() {
        "Just me","2–10","11–50","51–200","201–500","500+"
    };
    static readonly List<string> UserRoles = new() {
        "Owner / CEO","HR Manager","Team Lead","Project Manager",
        "Operations","Finance","IT","Other"
    };
}
