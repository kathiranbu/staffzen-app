@page "/get-started"
@using APM.StaffZen.Blazor.Services
@inject SessionService SessionService
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<BasePage Title="Get Started">

    <div class="gs-page">

        <!-- ── Hero Banner ── -->
        <div class="gs-hero">
            <div class="gs-hero-text">
                <h1 class="gs-hero-title">Set up StaffZen like a pro.</h1>
                <p class="gs-hero-sub">Complete the steps below to get your team up and running.</p>
            </div>
            <div class="gs-hero-img">
                <img src="Images/Dashboard/greeting-illustration.png" alt="Setup" />
            </div>
        </div>

        <!-- ── Progress Bar ── -->
        <div class="gs-progress-wrap">
            <div class="gs-progress-circle">
                <svg viewBox="0 0 36 36" width="64" height="64">
                    <path class="gs-prog-bg"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                          fill="none" stroke="#e5e7eb" stroke-width="3" />
                    <path class="gs-prog-fill"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                          fill="none" stroke="#e5e7eb" stroke-width="3"
                          stroke-dasharray="@ProgressPercent, 100" stroke-linecap="round" />
                    <text x="18" y="20.5" text-anchor="middle" font-size="9" font-weight="700" fill="#111">@CompletedCount%</text>
                </svg>
            </div>
            <div class="gs-progress-info">
                <div class="gs-progress-title">Complete setting up StaffZen</div>
                <div class="gs-progress-sub">@CompletedCount of @TotalSteps steps completed</div>
            </div>
        </div>

        <!-- ── Steps Cards ── -->
        <div class="gs-cards-scroll">
            <div class="gs-cards-track">

                @foreach (var step in Steps)
                {
                    var s = step;
                    <div class="gs-step-card @(s.Done ? "gs-step-card--done" : "")">

                        <!-- Card image -->
                        <div class="gs-card-img">
                            @((MarkupString)s.SvgIllustration)
                        </div>

                        <!-- Card body -->
                        <div class="gs-card-body">
                            <div class="gs-card-title">@s.Title</div>
                            <div class="gs-card-desc">@s.Description</div>

                            <div class="gs-card-footer">
                                <div class="gs-card-time">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    <span>@s.Time</span>
                                </div>
                                @if (s.Done)
                                {
                                    <span class="gs-card-done-badge">
                                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                            <polyline points="2,6 5,9 10,3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        Done
                                    </span>
                                }
                                else
                                {
                                    <a class="gs-card-start" href="@s.Href">
                                        Start
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <line x1="5" y1="12" x2="19" y2="12"/>
                                            <polyline points="12 5 19 12 12 19"/>
                                        </svg>
                                    </a>
                                }
                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>

    </div>

</BasePage>

<style>
    .gs-page {
        padding: 0;
        background: #f8f9fb;
        min-height: calc(100vh - 60px);
    }

    /* ── Hero ── */
    .gs-hero {
        background: linear-gradient(135deg, #ff6600 0%, #ff8c38 60%, #ffa040 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 32px 48px;
        position: relative;
        overflow: hidden;
        min-height: 180px;
    }

    .gs-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='20'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .gs-hero-text { position: relative; z-index: 1; }

    .gs-hero-title {
        font-size: 28px;
        font-weight: 900;
        color: #fff;
        margin: 0 0 8px;
        letter-spacing: -0.5px;
    }

    .gs-hero-sub {
        font-size: 14px;
        color: rgba(255,255,255,0.85);
        margin: 0;
    }

    .gs-hero-img {
        position: relative; z-index: 1;
        flex-shrink: 0;
    }

    .gs-hero-img img {
        width: 160px;
        height: 130px;
        object-fit: contain;
        filter: brightness(1.1);
    }

    /* ── Progress ── */
    .gs-progress-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
        background: #fff;
        padding: 24px 48px;
        border-bottom: 1px solid #e5e7eb;
    }

    .gs-progress-circle { flex-shrink: 0; }

    .gs-prog-fill {
        stroke: #e5e7eb;
        transition: stroke-dasharray 0.4s ease;
    }

    /* override fill color if progress > 0 */
    .gs-progress-circle svg path:last-child {
        stroke: @(CompletedCount > 0 ? "#ff6600" : "#e5e7eb");
    }

    .gs-progress-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
    }

    .gs-progress-sub {
        font-size: 13px;
        color: #9ca3af;
        margin-top: 4px;
    }

    /* ── Cards ── */
    .gs-cards-scroll {
        padding: 28px 48px;
        overflow-x: auto;
    }

    .gs-cards-track {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 20px;
        min-width: 0;
    }

    .gs-step-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.2s, transform 0.15s;
    }

    .gs-step-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.09);
        transform: translateY(-2px);
    }

    .gs-step-card--done {
        opacity: 0.75;
    }

    /* Card illustration area */
    .gs-card-img {
        background: #f8f9fb;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        min-height: 140px;
        border-bottom: 1px solid #f3f4f6;
    }

    /* Card text area */
    .gs-card-body {
        padding: 18px 20px 16px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .gs-card-title {
        font-size: 15px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
        line-height: 1.3;
    }

    .gs-card-desc {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.5;
        flex: 1;
        margin-bottom: 16px;
    }

    .gs-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid #f3f4f6;
        padding-top: 12px;
    }

    .gs-card-time {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: #9ca3af;
    }

    .gs-card-start {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
        font-weight: 700;
        color: #ff6600;
        text-decoration: none;
        border: 1.5px solid #ff6600;
        border-radius: 8px;
        padding: 6px 14px;
        transition: background 0.15s, color 0.15s;
    }

    .gs-card-start:hover {
        background: #ff6600;
        color: #fff;
    }

    .gs-card-done-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        background: #22c55e;
        border-radius: 20px;
        padding: 4px 12px;
    }

    @@media (max-width: 768px) {
        .gs-hero { padding: 24px 20px; }
        .gs-hero-img { display: none; }
        .gs-progress-wrap { padding: 20px; }
        .gs-cards-scroll { padding: 20px; }
    }
</style>

@code {
    int CompletedCount => Steps.Count(s => s.Done);
    int TotalSteps => Steps.Count;
    double ProgressPercent => TotalSteps == 0 ? 0 : Math.Round((double)CompletedCount / TotalSteps * 100);

    protected override void OnInitialized()
