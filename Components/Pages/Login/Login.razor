@page "/"
@page "/login"
@layout EmptyLayout

@using APM.StaffZen.Blazor.Components.Layout
@using APM.StaffZen.Blazor.Services
@using APM.StaffZen.Blazor.ViewModels
@using APM.StaffZen.Blazor.Components.Pages.Login.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject SessionService SessionService
@inject IJSRuntime JS
@rendermode RenderMode.InteractiveServer

<div class="login-page-root">
    <div class="row g-0 h-100">

        <LoginLeftPanel />

        <!-- Vertical divider -->
        <div class="d-none d-lg-block container-fluid" style="width:1px; background:#e5e7eb; flex-shrink:0;"></div>

        <!-- ========== RIGHT PANEL ========== -->
        <div class="col-12 col-lg right-panel d-flex justify-content-center align-items-start bg-white">
            <div class="right-inner px-4 px-sm-5 py-5 w-100">

                <!-- Mobile-only logo -->
                <div class="d-flex d-lg-none align-items-center justify-content-center gap-2 mb-4">
                    <span style="font-size:22px;">⏳</span>
                    <span class="fw-bolder fs-4">StaffZen</span>
                </div>

                @if (!ShowSignup)
                {
                    <LoginForm
                        Email="@Email"
                        EmailChanged="v => Email = v"
                        Password="@Password"
                        PasswordChanged="v => Password = v"
                        Error="@Error"
                        GoogleLoading="@GoogleLoading"
                        OnLogin="HandleLogin"
                        OnGoogleLogin="TriggerGoogleLogin"
                        OnShowSignup="ShowSignupPanel" />
                }
                else
                {
                    <SignupForm
                        SignupFullName="@SignupFullName"
                        SignupFullNameChanged="v => SignupFullName = v"
                        SignupTab="@SignupTab"
                        SignupTabChanged="v => SignupTab = v"
                        SignupEmail="@SignupEmail"
                        SignupEmailChanged="v => SignupEmail = v"
                        SignupPhone="@SignupPhone"
                        SignupPhoneChanged="v => SignupPhone = v"
                        SignupPassword="@SignupPassword"
                        SignupPasswordChanged="v => SignupPassword = v"
                        SignupAgreeOffers="@SignupAgreeOffers"
                        SignupAgreeOffersChanged="v => SignupAgreeOffers = v"
                        SignupAgreeTerms="@SignupAgreeTerms"
                        SignupAgreeTermsChanged="v => SignupAgreeTerms = v"
                        SignupError="@SignupError"
                        SignupLoading="@SignupLoading"
                        GoogleSignupLoading="@GoogleSignupLoading"
                        OnSignup="HandleSignup"
                        OnGoogleSignup="TriggerGoogleSignup"
                        OnShowLogin="ShowLoginPanel" />
                }

            </div>
        </div>

    </div>
</div>

<AccountExistsModal
    Show="@ShowExistsModal"
    OnClose="CloseExistsModal"
    OnGoToLogin="GoToLoginFromModal" />

@code {
    private LoginRequest loginModel = new();
    private bool _initialised = false;
    private DotNetObjectReference<Login>? _dotNetRef;

    // ── Login state ──
    bool GoogleLoading = false;
    string Email = string.Empty;
    string Password = string.Empty;
    string Error = string.Empty;

    // ── Signup state ──
    bool ShowSignup = false;
    bool SignupLoading = false;
    bool GoogleSignupLoading = false;
    string SignupTab = "email";
    string SignupFullName = string.Empty;
    string SignupEmail = string.Empty;
    string SignupPhone = string.Empty;
    string SignupPassword = string.Empty;
    bool SignupAgreeOffers = true;
    bool SignupAgreeTerms = false;
    string SignupError = string.Empty;

    // ── Modal state ──
    bool ShowExistsModal = false;

    void ShowSignupPanel() => ShowSignup = true;
    void ShowLoginPanel() => ShowSignup = false;

    void CloseExistsModal() => ShowExistsModal = false;

    void GoToLoginFromModal()
    {
        ShowExistsModal = false;
        Email = SignupTab == "email" ? SignupEmail : string.Empty;
        ShowSignup = false;
    }

    private async Task HandleSignup()
    {
        SignupError = string.Empty;
        if (string.IsNullOrWhiteSpace(SignupFullName))
        { SignupError = "Please enter your full name."; return; }
        if (SignupTab == "email" && string.IsNullOrWhiteSpace(SignupEmail))
        { SignupError = "Please enter your email."; return; }
        if (SignupTab == "phone" && string.IsNullOrWhiteSpace(SignupPhone))
        { SignupError = "Please enter your phone number."; return; }
        if (string.IsNullOrWhiteSpace(SignupPassword))
        { SignupError = "Please enter a password."; return; }
        if (!SignupAgreeTerms)
        { SignupError = "You must agree to the Terms of Service."; return; }

        SignupLoading = true;
        StateHasChanged();

        var email = SignupTab == "email" ? SignupEmail : string.Empty;
        var phone = SignupTab == "phone" ? SignupPhone : null;

        var (result, error) = await AuthService.RegisterAsync(
            SignupFullName, email, SignupPassword, phone);

        SignupLoading = false;

        if (result != null)
        {
            await SessionService.SetSessionAsync(result);
            var dest = result.IsOnboarded ? "/organization/switcher" : "/getting-started";
            Navigation.NavigateTo(dest);
        }
        else
        {
            if (error != null && error.Contains("already exists", StringComparison.OrdinalIgnoreCase))
            {
                ShowExistsModal = true;
            }
            else
            {
                SignupError = error ?? "Registration failed. Please try again.";
            }
            StateHasChanged();
        }
    }

    private async Task TriggerGoogleSignup()
    {
        SignupError = string.Empty;
        GoogleSignupLoading = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("GoogleAuth.openSignup");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialised)
        {
            _initialised = true;

            await JS.InvokeVoidAsync("eval", @"
                document.documentElement.style.overflow = 'auto';
                document.documentElement.style.height = 'auto';
                document.body.style.overflow = 'auto';
                document.body.style.height = 'auto';
            ");

            await JS.InvokeVoidAsync("eval", @"
                (function(){
                    var el = document.getElementById('testimonialCarousel');
                    if(el && typeof bootstrap !== 'undefined'){
                        var existing = bootstrap.Carousel.getInstance(el);
                        if(!existing) new bootstrap.Carousel(el,{interval:4000,ride:'carousel',wrap:true});
                    }
                })();
            ");

            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("GoogleAuth.registerCallback", _dotNetRef);
        }
    }

    private async Task TriggerGoogleLogin()
    {
        Error = string.Empty;
        GoogleLoading = true;
        await JS.InvokeVoidAsync("GoogleAuth.openLogin");
    }

    [JSInvokable]
    public async Task OnGoogleSignIn(string googleEmail, bool isSignup)
    {
        GoogleLoading = false;
        GoogleSignupLoading = false;

        Error = string.Empty;
        SignupError = string.Empty;

        if (isSignup)
        {
            var (result, error) = await AuthService.GoogleRegisterAsync(googleEmail, null);
            if (result != null)
            {
                await SessionService.SetSessionAsync(result);
                // Existing account → organization/switcher; new account → getting-started
                var dest = !result.IsNewAccount
                    ? "/organization/switcher"
                    : "/getting-started";
                await InvokeAsync(() => Navigation.NavigateTo(dest));
            }
            else
            {
                SignupError = error ?? "Google sign-up failed.";
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            var (result, loginError) = await AuthService.GoogleLoginAsync(googleEmail);
            if (result != null)
            {
                await SessionService.SetSessionAsync(result);
                var dest = result.IsOnboarded
                    ? "/organization/switcher"
                    : "/getting-started";
                await InvokeAsync(() => Navigation.NavigateTo(dest));
            }
            else
            {
                Error = loginError ?? $"No StaffZen account found for {googleEmail}. Try signing up first.";
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    [JSInvokable]
    public async Task OnGoogleError(string message)
    {
        GoogleLoading = false;
        GoogleSignupLoading = false;

        Error = string.IsNullOrEmpty(message) ? string.Empty : message;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogin()
    {
        Error = string.Empty;

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            Error = "Please enter both email and password";
            return;
        }

        loginModel.Email = Email;
        loginModel.Password = Password;

        var (result, error) = await AuthService.LoginAsync(loginModel);

        if (result != null)
        {
            await SessionService.SetSessionAsync(result);
            if (!result.IsOnboarded)
                Navigation.NavigateTo("/getting-started");
            else
                Navigation.NavigateTo("/organization/switcher");
        }
        else
        {
            Error = error ?? "Invalid email or password";
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        _ = JS.InvokeVoidAsync("eval", @"
            document.documentElement.style.overflow = '';
            document.documentElement.style.height = '';
            document.body.style.overflow = '';
            document.body.style.height = '';
        ");
    }
}
