<!-- ========== LEFT PANEL (desktop only) ========== -->
<div class="col-lg-6 d-none d-lg-flex flex-column align-items-center left-panel px-5 py-4">

    <!-- Logo — top left -->
    <div class="align-self-start d-flex align-items-center gap-2 mb-3">
        <span style="font-size:22px;">⏳</span>
        <span class="fw-bolder fs-5 text-dark" style="letter-spacing:-0.5px;">StaffZen</span>
    </div>

    <!-- Illustration — centered -->
    <div class="w-100 d-flex justify-content-center mb-3">
        <img src="Images/Login/Jibble1.png" class="img-fluid"
             style="max-width:340px;" />
    </div>

    <!-- Tagline -->
    <div class="text-center mb-4" style="max-width:460px;">
        <h2 class="fw-bold lh-base" style="font-size:20px; color:#111; letter-spacing:-0.3px;">
            Track when your staff are at work for payroll,<br />
            attendance, compliance. It's free.
        </h2>
        <p class="text-muted mt-2 mb-0" style="font-size:13px;">
            Thousands of users worldwide, from SME to Enterprise
        </p>
    </div>

    <!-- Client Logos -->
    <div class="mb-4">
        <img src="https://web.jibble.io/assets/client-logos.64cdadef.png"
             class="img-fluid opacity-50" style="max-width:400px;" />
    </div>

    <!-- Testimonial Carousel -->
    <div id="testimonialCarousel" class="carousel slide w-100"
         style="max-width:520px;" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <div class="bg-white rounded-4 shadow-sm text-center p-4 mx-1">
                    <h6 class="fw-bold mb-3" style="font-size:15px;">Jibble Rocks!</h6>
                    <p class="text-secondary mb-3" style="font-size:13px;line-height:1.65;">
                        "As a remote employee, I've loved tracking my time and being able to generate reports.
                        I've tried multiple platforms but stuck with Jibble as it is easy to use and integrates well with Slack."
                    </p>
                    <p class="mb-0" style="font-size:13px;"><strong>Louren Camballa,</strong> <span class="text-muted">AREA</span></p>
                </div>
            </div>
            <div class="carousel-item">
                <div class="bg-white rounded-4 shadow-sm text-center p-4 mx-1">
                    <h6 class="fw-bold mb-3" style="font-size:15px;">Very user friendly</h6>
                    <p class="text-secondary mb-3" style="font-size:13px;line-height:1.65;">
                        "I've switched between multiple apps and wasn't satisfied until I came across Jibble.
                        This app had all the great features and is very user friendly."
                    </p>
                    <p class="mb-0" style="font-size:13px;"><strong>Shilles Steven Albert,</strong> <span class="text-muted">Maxis</span></p>
                </div>
            </div>
            <div class="carousel-item">
                <div class="bg-white rounded-4 shadow-sm text-center p-4 mx-1">
                    <h6 class="fw-bold mb-3" style="font-size:15px;">I can't thank Jibble enough</h6>
                    <p class="text-secondary mb-3" style="font-size:13px;line-height:1.65;">
                        "I like the intuitive nature of the interface. It is very easy to use and is pretty much idiot-proof.
                        It has saved so much time recording in/outs, I can't thank Jibble enough for the program."
                    </p>
                    <p class="mb-0" style="font-size:13px;"><strong>Heidi Sobol,</strong> <span class="text-muted">Royal Ontario Museum</span></p>
                </div>
            </div>
        </div>
        <div class="carousel-indicators position-relative mt-3">
            <button type="button" data-bs-target="#testimonialCarousel"
                    data-bs-slide-to="0" class="active carousel-dot"></button>
            <button type="button" data-bs-target="#testimonialCarousel"
                    data-bs-slide-to="1" class="carousel-dot"></button>
            <button type="button" data-bs-target="#testimonialCarousel"
                    data-bs-slide-to="2" class="carousel-dot"></button>
        </div>
    </div>

    <!-- Footer links -->
    <div class="d-flex gap-5 mt-auto pt-4 border-top w-100 justify-content-center"
         style="max-width:480px;">
        <a href="#" class="text-muted text-decoration-none" style="font-size:13px;">Privacy Policy</a>
        <a href="#" class="text-muted text-decoration-none" style="font-size:13px;">
            Help center
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
        </a>
    </div>
</div>
