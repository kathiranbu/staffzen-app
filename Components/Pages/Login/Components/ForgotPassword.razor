@page "/forgot-password"
@layout EmptyLayout

@using APM.StaffZen.Blazor.Components.Layout
@using APM.StaffZen.Blazor.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode RenderMode.InteractiveServer
@implements IDisposable

<div class="fp-root">
    <div class="row g-0 min-vh-100">

        <!-- ===== LEFT PANEL ===== -->
        <div class="col-lg-6 d-none d-lg-flex fp-left">
            <div class="fp-left-inner">

                <!-- Logo -->
                <div class="fp-logo">
                    <span class="fp-logo-icon">⏳</span>
                    <span class="fp-logo-text">StaffZen</span>
                </div>

                <!-- Illustration card -->
                <div class="fp-illustration-wrap">
                    <div class="fp-illustration-card">
                        <div class="fp-orb fp-orb-1"></div>
                        <div class="fp-orb fp-orb-2"></div>
                        <div class="fp-orb fp-orb-3"></div>
                        <img src="Images/Login/Jibble1.png" class="fp-illustration-img" alt="Reset password" />
                    </div>
                    <div class="fp-left-tagline">
                        <h3 class="fp-tagline-title">Forgot your password?</h3>
                        <p class="fp-tagline-sub">No worries — it happens to the best of us. We'll send you a reset link right away.</p>
                    </div>
                </div>

                <!-- Step indicator -->
                <div class="fp-steps">
                    <div class="fp-step fp-step-active">
                        <div class="fp-step-dot"></div>
                        <span>Request link</span>
                    </div>
                    <div class="fp-step-line"></div>
                    <div class="fp-step">
                        <div class="fp-step-dot"></div>
                        <span>Check inbox</span>
                    </div>
                    <div class="fp-step-line"></div>
                    <div class="fp-step">
                        <div class="fp-step-dot"></div>
                        <span>Set new password</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT PANEL ===== -->
        <div class="col-12 col-lg-6 d-flex fp-right">
            <div class="fp-right-inner">

                <!-- Mobile logo -->
                <div class="d-flex d-lg-none align-items-center justify-content-center gap-2 mb-4">
                    <span style="font-size:22px;">⏳</span>
                    <span class="fw-bolder fs-4">StaffZen</span>
                </div>

                <!-- Header -->
                <div class="fp-header mb-4">
                    <div class="fp-icon-badge mb-3">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <h1 class="fp-title">Reset your password</h1>
                    <p class="fp-subtitle">Enter the email or phone number linked to your account and we'll send you a reset link.</p>
                </div>

                <!-- Email field -->
                <div class="fp-field-group mb-3">
                    <label class="fp-label">Email address</label>
                    <div class="fp-input-wrap">
                        <span class="fp-input-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>
                        <input class="fp-input @(focusedEmail ? "fp-input-focused" : "")"
                               placeholder="you@example.com"
                               @bind="Email"
                               @bind:event="oninput"
                               @onfocus="() => focusedEmail = true"
                               @onblur="() => focusedEmail = false" />
                    </div>
                </div>

                <!-- Divider -->
                <div class="fp-or-divider">
                    <span class="fp-or-line"></span>
                    <span class="fp-or-text">or</span>
                    <span class="fp-or-line"></span>
                </div>

                <!-- Phone field -->
                <div class="fp-field-group mb-4">
                    <label class="fp-label">Phone number</label>
                    <div class="fp-input-wrap">
                        <span class="fp-input-icon fp-flag-prefix">
                            🇮🇳&nbsp;<span class="fp-country-code">+91</span>
                        </span>
                        <input class="fp-input fp-input-phone @(focusedPhone ? "fp-input-focused" : "")"
                               placeholder="98765 43210"
                               @bind="Phone"
                               @bind:event="oninput"
                               @onfocus="() => focusedPhone = true"
                               @onblur="() => focusedPhone = false" />
                    </div>
                    <p class="fp-phone-note">By providing your number, you agree to receive reset SMS from StaffZen. Msg &amp; data rates may apply.</p>
                </div>

                <!-- Error -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="fp-alert mb-3">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>@ErrorMessage</span>
                    </div>
                }

                <!-- Submit button -->
                <button class="fp-btn @(CanSubmit ? "fp-btn-active" : "") @(IsLoading ? "fp-btn-loading" : "")"
                        disabled="@(!CanSubmit || IsLoading)"
                        @onclick="HandleSubmit">
                    @if (IsLoading)
                    {
                        <span class="fp-spinner"></span>
                        <span>Sending reset link...</span>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="22" y1="2" x2="11" y2="13"/>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                        </svg>
                        <span>Send Reset Link</span>
                    }
                </button>

                <!-- Back link -->
                <div class="text-center mt-4">
                    <a href="/login" class="fp-back-link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="15 18 9 12 15 6"/>
                        </svg>
                        Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    string Email = string.Empty;
    string Phone = string.Empty;
    string ErrorMessage = string.Empty;
    bool IsLoading = false;
    bool focusedEmail = false;
    bool focusedPhone = false;

    bool CanSubmit => !string.IsNullOrWhiteSpace(Email) || !string.IsNullOrWhiteSpace(Phone);

    private async Task HandleSubmit()
    {
        ErrorMessage = string.Empty;
        IsLoading = true;
        StateHasChanged();

        try
        {
            var (success, error) = await AuthService.ForgotPasswordAsync(Email.Trim(), Phone.Trim());
            IsLoading = false;
            StateHasChanged();

            if (success)
                Navigation.NavigateTo("/forgot-password-sent");
            else
                ErrorMessage = error ?? "Something went wrong. Please try again.";
        }
        catch (Exception ex)
        {
            IsLoading = false;
            ErrorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                document.documentElement.style.overflow = 'auto';
                document.documentElement.style.height = 'auto';
                document.body.style.overflow = 'auto';
                document.body.style.height = 'auto';
            ");
        }
    }

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("eval", @"
            document.documentElement.style.overflow = '';
            document.documentElement.style.height = '';
            document.body.style.overflow = '';
            document.body.style.height = '';
        ");
    }

}