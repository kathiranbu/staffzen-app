@* Social icons row for signup panel — same style as login *@

<p class="text-center mb-3" style="font-size:13px; color:#999;">Connect with</p>

<div class="d-flex align-items-center justify-content-center gap-2 mb-4">

    <!-- Facebook -->
    <div class="social-icon-btn" title="Facebook">
        <svg width="38" height="38" viewBox="0 0 38 38">
            <circle cx="19" cy="19" r="19" fill="#1877F2"/>
            <path d="M21.5 20.5h2.5l1-4H21.5v-2c0-1.1.4-2 1.6-2H25V9s-1.2-.2-2.8-.2c-3 0-4.7 1.8-4.7 5v2.7H15v4h2.5V30h4V20.5z" fill="white"/>
        </svg>
    </div>

    <!-- Google -->
    <div class="social-icon-btn social-icon-border" title="Sign up with Google" @onclick="OnGoogleClicked" style="cursor:pointer;">
        <svg width="38" height="38" viewBox="0 0 38 38">
            <circle cx="19" cy="19" r="18" fill="white" stroke="#e0e0e0" stroke-width="1"/>
            <g transform="translate(9, 9)">
                <path d="M19.6 10.23c0-.82-.07-1.42-.23-2.05H10v3.72h5.46c-.11.93-.72 2.33-2.07 3.27l-.02.12 3 2.33.21.02c1.91-1.77 3.02-4.36 3.02-7.41z" fill="#4285F4"/>
                <path d="M10 20c2.7 0 4.96-.89 6.62-2.41l-3.16-2.45c-.84.59-1.97 1-3.46 1-2.64 0-4.88-1.77-5.68-4.21l-.11.01-3.12 2.42-.04.1C2.96 17.75 6.23 20 10 20z" fill="#34A853"/>
                <path d="M4.32 11.93A6.16 6.16 0 0 1 4 10c0-.68.12-1.34.31-1.93l-.01-.13L1.14 5.48l-.1.04A9.96 9.96 0 0 0 0 10c0 1.61.39 3.13 1.04 4.48l3.28-2.55z" fill="#FBBC05"/>
                <path d="M10 3.96c1.87 0 3.13.81 3.85 1.48l2.81-2.74C14.95.99 12.7 0 10 0 6.23 0 2.96 2.25 1.04 5.52l3.27 2.55C5.12 5.73 7.36 3.96 10 3.96z" fill="#EA4335"/>
            </g>
        </svg>
    </div>

    <!-- Microsoft -->
    <div class="social-icon-btn social-icon-border" title="Microsoft" style="cursor:pointer;">
        <svg width="38" height="38" viewBox="0 0 38 38">
            <circle cx="19" cy="19" r="18" fill="white" stroke="#e0e0e0" stroke-width="1"/>
            <rect x="11" y="11" width="7.5" height="7.5" fill="#F25022"/>
            <rect x="19.5" y="11" width="7.5" height="7.5" fill="#7FBA00"/>
            <rect x="11" y="19.5" width="7.5" height="7.5" fill="#00A4EF"/>
            <rect x="19.5" y="19.5" width="7.5" height="7.5" fill="#FFB900"/>
        </svg>
    </div>

    <!-- Apple -->
    <div class="social-icon-btn social-icon-border" title="Apple" style="cursor:pointer;">
        <svg width="38" height="38" viewBox="0 0 38 38">
            <circle cx="19" cy="19" r="18" fill="white" stroke="#e0e0e0" stroke-width="1"/>
            <g transform="translate(11.5, 9)">
                <path d="M13.26 7.55c-.02-2.57 2.1-3.82 2.2-3.88-1.2-1.75-3.07-1.99-3.73-2.02-1.59-.16-3.1.94-3.91.94-.8 0-2.03-.92-3.35-.89C2.8 1.74 1.17 2.67.35 4.14c-1.67 2.88-.43 7.14 1.2 9.48.8 1.15 1.74 2.44 2.99 2.39 1.2-.05 1.66-.77 3.11-.77s1.87.77 3.14.74c1.29-.02 2.11-1.17 2.9-2.32.92-1.33 1.29-2.62 1.31-2.68-.03-.01-2.52-.97-2.54-3.43z" fill="#111"/>
                <path d="M10.81 1.2c.67-.81 1.12-1.94 1-3.07-.96.04-2.13.64-2.82 1.45-.62.71-1.16 1.86-1.02 2.96 1.07.08 2.17-.54 2.84-1.34z" fill="#111" transform="translate(0, 2)"/>
            </g>
        </svg>
    </div>

    <span class="text-muted and-more-btn" style="font-size:13px; cursor:pointer; user-select:none;">
        and more ▼
    </span>
</div>

@code {
    [Parameter] public EventCallback OnGoogleSignup { get; set; }
    private async Task OnGoogleClicked() => await OnGoogleSignup.InvokeAsync();
}
