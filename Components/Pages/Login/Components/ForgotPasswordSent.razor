@page "/forgot-password-sent"
@layout EmptyLayout

@using APM.StaffZen.Blazor.Components.Layout
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode RenderMode.InteractiveServer
@implements IDisposable

<div class="fps-root">
    <div class="row g-0 min-vh-100">

        <!-- ===== LEFT PANEL ===== -->
        <div class="col-lg-6 d-none d-lg-flex fps-left">
            <div class="fps-left-inner">

                <!-- Logo -->
                <div class="fps-logo">
                    <span class="fps-logo-icon">⏳</span>
                    <span class="fps-logo-text">StaffZen</span>
                </div>

                <!-- Central illustration -->
                <div class="fps-illustration-wrap">
                    <div class="fps-mail-scene">
                        <!-- Monitor base -->
                        <div class="fps-monitor">
                            <div class="fps-monitor-screen">
                                <!-- Inbox UI mockup -->
                                <div class="fps-inbox-header">
                                    <div class="fps-inbox-dot fps-dot-red"></div>
                                    <div class="fps-inbox-dot fps-dot-yellow"></div>
                                    <div class="fps-inbox-dot fps-dot-green"></div>
                                    <span class="fps-inbox-title">Inbox</span>
                                </div>
                                <div class="fps-inbox-row fps-inbox-row-new">
                                    <div class="fps-inbox-avatar fps-avatar-orange">S</div>
                                    <div class="fps-inbox-content">
                                        <div class="fps-inbox-from">StaffZen</div>
                                        <div class="fps-inbox-subject">Reset Your Password</div>
                                    </div>
                                    <div class="fps-inbox-badge">New</div>
                                </div>
                                <div class="fps-inbox-row">
                                    <div class="fps-inbox-avatar fps-avatar-grey">T</div>
                                    <div class="fps-inbox-content">
                                        <div class="fps-inbox-from">Team</div>
                                        <div class="fps-inbox-subject">Weekly update</div>
                                    </div>
                                </div>
                                <div class="fps-inbox-row">
                                    <div class="fps-inbox-avatar fps-avatar-blue">M</div>
                                    <div class="fps-inbox-content">
                                        <div class="fps-inbox-from">Manager</div>
                                        <div class="fps-inbox-subject">Schedule review</div>
                                    </div>
                                </div>
                            </div>
                            <div class="fps-monitor-stand"></div>
                            <div class="fps-monitor-base"></div>
                        </div>

                        <!-- Flying envelope animations -->
                        <div class="fps-envelope fps-env-1">✉</div>
                        <div class="fps-envelope fps-env-2">✉</div>
                        <div class="fps-envelope fps-env-3">✉</div>
                        <div class="fps-plane">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="#10b981">
                                <line x1="22" y1="2" x2="11" y2="13"/>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </div>
                    </div>

                    <div class="fps-left-tagline">
                        <h3 class="fps-tagline-title">Email is on its way!</h3>
                        <p class="fps-tagline-sub">Usually arrives within a few seconds. Check your spam folder if you don't see it.</p>
                    </div>
                </div>

                <!-- Step indicator — step 2 active -->
                <div class="fps-steps">
                    <div class="fps-step fps-step-done">
                        <div class="fps-step-dot">
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <span>Request sent</span>
                    </div>
                    <div class="fps-step-line fps-line-done"></div>
                    <div class="fps-step fps-step-active">
                        <div class="fps-step-dot"></div>
                        <span>Check inbox</span>
                    </div>
                    <div class="fps-step-line"></div>
                    <div class="fps-step">
                        <div class="fps-step-dot"></div>
                        <span>Set new password</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT PANEL ===== -->
        <div class="col-12 col-lg-6 d-flex fps-right">
            <div class="fps-right-inner">

                <!-- Mobile logo -->
                <div class="d-flex d-lg-none align-items-center justify-content-center gap-2 mb-4">
                    <span style="font-size:22px;">⏳</span>
                    <span class="fw-bolder fs-4">StaffZen</span>
                </div>

                <!-- Success icon -->
                <div class="fps-success-icon mb-4">
                    <div class="fps-success-ring fps-ring-outer"></div>
                    <div class="fps-success-ring fps-ring-inner"></div>
                    <div class="fps-success-core">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ff6b00" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                </div>

                <!-- Text -->
                <h1 class="fps-title">Check your inbox</h1>
                <p class="fps-subtitle">
                    A password reset link was sent successfully. Please check your email
                    (or spam folder) and click the link to set your new password.
                </p>

                <!-- Info card -->
                <div class="fps-info-card mb-4">
                    <div class="fps-info-row">
                        <div class="fps-info-icon fps-icon-clock">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <span>The link expires in <strong>1 hour</strong></span>
                    </div>
                    <div class="fps-info-row">
                        <div class="fps-info-icon fps-icon-shield">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                        </div>
                        <span>The link can only be used <strong>once</strong></span>
                    </div>
                    <div class="fps-info-row">
                        <div class="fps-info-icon fps-icon-spam">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="11" cy="11" r="8"/>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            </svg>
                        </div>
                        <span>Check your <strong>spam / junk</strong> folder too</span>
                    </div>
                </div>

                <!-- Go to login -->
                <button class="fps-btn fps-btn-primary mb-3"
                        @onclick='() => Navigation.NavigateTo("/login")'>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    Go to Login
                </button>

                <!-- Try again -->
                <div class="text-center">
                    <span class="fps-resend-text">Didn't receive it?</span>
                    <a href="/forgot-password" class="fps-resend-link">Send again</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                document.documentElement.style.overflow = 'auto';
                document.documentElement.style.height = 'auto';
                document.body.style.overflow = 'auto';
                document.body.style.height = 'auto';
            ");
        }
    }

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("eval", @"
            document.documentElement.style.overflow = '';
            document.documentElement.style.height = '';
            document.body.style.overflow = '';
            document.body.style.height = '';
        ");
    }
}