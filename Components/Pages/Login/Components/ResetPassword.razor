@page "/reset-password"
@layout EmptyLayout

@using APM.StaffZen.Blazor.Components.Layout
@using APM.StaffZen.Blazor.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode RenderMode.InteractiveServer
@implements IDisposable

<div class="rp-root">
    <div class="row g-0 min-vh-100">

        <!-- ===== LEFT PANEL ===== -->
        <div class="col-lg-6 d-none d-lg-flex rp-left">
            <div class="rp-left-inner">

                <!-- Logo -->
                <div class="rp-logo">
                    <span class="rp-logo-icon">⏳</span>
                    <span class="rp-logo-text">StaffZen</span>
                </div>

                <div class="rp-illustration-wrap">
                    <div class="rp-shield-scene">
                        <!-- Central shield -->
                        <div class="rp-shield">
                            <svg width="80" height="96" viewBox="0 0 24 24" fill="none">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                      fill="url(#shieldGrad)" stroke="none"/>
                                <polyline points="9 12 11 14 15 10" stroke="white" stroke-width="1.8"
                                          stroke-linecap="round" stroke-linejoin="round"/>
                                <defs>
                                    <linearGradient id="shieldGrad" x1="0" y1="0" x2="1" y2="1">
                                        <stop offset="0%" stop-color="#ff6b00"/>
                                        <stop offset="100%" stop-color="#ff8c00"/>
                                    </linearGradient>
                                </defs>
                            </svg>
                        </div>
                        <!-- Orbiting dots -->
                        <div class="rp-orbit rp-orbit-1">
                            <div class="rp-orbit-dot"></div>
                        </div>
                        <div class="rp-orbit rp-orbit-2">
                            <div class="rp-orbit-dot rp-dot-sm"></div>
                        </div>
                        <!-- Lock illustration -->
                        <div class="rp-lock-card">
                            <img src="Images/Login/Jibble1.png" class="rp-illustration-img" alt="Reset password" />
                        </div>
                    </div>

                    <div class="rp-left-tagline">
                        <h3 class="rp-tagline-title">Create a strong password</h3>
                        <p class="rp-tagline-sub">Use at least 8 characters, mixing letters, numbers and symbols for best security.</p>
                    </div>

                    <!-- Password tips -->
                    <div class="rp-tips">
                        <div class="rp-tip">
                            <div class="rp-tip-dot"></div>
                            <span>At least 6 characters</span>
                        </div>
                        <div class="rp-tip">
                            <div class="rp-tip-dot"></div>
                            <span>Mix upper &amp; lowercase letters</span>
                        </div>
                        <div class="rp-tip">
                            <div class="rp-tip-dot"></div>
                            <span>Include numbers or symbols</span>
                        </div>
                    </div>
                </div>

                <!-- Step indicator — step 3 active -->
                <div class="rp-steps">
                    <div class="rp-step rp-step-done">
                        <div class="rp-step-dot">
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <span>Request sent</span>
                    </div>
                    <div class="rp-step-line rp-line-done"></div>
                    <div class="rp-step rp-step-done">
                        <div class="rp-step-dot">
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <span>Link clicked</span>
                    </div>
                    <div class="rp-step-line rp-line-done"></div>
                    <div class="rp-step rp-step-active">
                        <div class="rp-step-dot"></div>
                        <span>Set new password</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT PANEL ===== -->
        <div class="col-12 col-lg-6 d-flex rp-right">
            <div class="rp-right-inner">

                <!-- Mobile logo -->
                <div class="d-flex d-lg-none align-items-center justify-content-center gap-2 mb-4">
                    <span style="font-size:22px;">⏳</span>
                    <span class="fw-bolder fs-4">StaffZen</span>
                </div>

                @if (IsTokenInvalid)
                {
                    <!-- Expired state -->
                    <div class="rp-state-card rp-state-error">
                        <div class="rp-state-icon rp-icon-error">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                        </div>
                        <h2 class="rp-state-title">Link expired or invalid</h2>
                        <p class="rp-state-body">This password reset link has either expired or already been used. Links are valid for 1 hour.</p>
                        <a href="/forgot-password" class="rp-btn rp-btn-primary rp-btn-block text-decoration-none text-center">
                            Request a new link
                        </a>
                        <a href="/login" class="rp-link-secondary">← Back to Login</a>
                    </div>
                }
                else if (IsSuccess)
                {
                    <!-- Success state -->
                    <div class="rp-state-card rp-state-success">
                        <div class="rp-state-icon rp-icon-success">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <h2 class="rp-state-title">Password updated!</h2>
                        <p class="rp-state-body">Your password has been reset successfully. You can now sign in with your new password.</p>
                        <button class="rp-btn rp-btn-primary rp-btn-block"
                                @onclick='() => Navigation.NavigateTo("/login")'>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                                <polyline points="10 17 15 12 10 7"/>
                                <line x1="15" y1="12" x2="3" y2="12"/>
                            </svg>
                            Sign in now
                        </button>
                    </div>
                }
                else if (IsValidating)
                {
                    <div class="rp-validating">
                        <div class="rp-validating-spinner"></div>
                        <p class="rp-validating-text">Verifying your reset link...</p>
                    </div>
                }
                else
                {
                    <!-- Form state -->
                    <div class="rp-header mb-4">
                        <div class="rp-icon-badge mb-3">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                        </div>
                        <h1 class="rp-title">Set new password</h1>
                        <p class="rp-subtitle">Enter your new password twice to confirm the change.</p>
                    </div>

                    <!-- Email display -->
                    @if (!string.IsNullOrEmpty(EmailDisplay))
                    {
                        <div class="rp-email-chip mb-4">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span>@EmailDisplay</span>
                        </div>
                    }

                    <!-- New Password -->
                    <div class="rp-field-group mb-3">
                        <label class="rp-label">New password</label>
                        <div class="rp-input-wrap">
                            <span class="rp-input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </span>
                            <input type="@NewPasswordType"
                                   class="rp-input @(focusedNew ? "rp-input-focused" : "")"
                                   placeholder="Min. 6 characters"
                                   @bind="NewPassword"
                                   @bind:event="oninput"
                                   @onfocus="() => focusedNew = true"
                                   @onblur="() => focusedNew = false" />
                            <button type="button" class="rp-eye-btn" @onclick="ToggleNewPassword">
                                @if (NewPasswordType == "password")
                                {
                                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                    </svg>
                                }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(NewPassword))
                        {
                            <div class="rp-strength-bar mt-2">
                                <div class="rp-strength-fill rp-strength-@GetStrength()"></div>
                            </div>
                            <p class="rp-strength-label">Strength: <strong>@GetStrengthLabel()</strong></p>
                        }
                    </div>

                    <!-- Confirm Password -->
                    <div class="rp-field-group mb-4">
                        <label class="rp-label">Confirm new password</label>
                        <div class="rp-input-wrap">
                            <span class="rp-input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                </svg>
                            </span>
                            <input type="@ConfirmPasswordType"
                                   class="rp-input @(focusedConfirm ? "rp-input-focused" : "") @(PasswordMismatch ? "rp-input-error" : "") @(PasswordMatch ? "rp-input-success" : "")"
                                   placeholder="Re-enter your password"
                                   @bind="ConfirmPassword"
                                   @bind:event="oninput"
                                   @onfocus="() => focusedConfirm = true"
                                   @onblur="() => focusedConfirm = false" />
                            <button type="button" class="rp-eye-btn" @onclick="ToggleConfirmPassword">
                                @if (ConfirmPasswordType == "password")
                                {
                                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                    </svg>
                                }
                            </button>
                        </div>
                        @if (PasswordMatch)
                        {
                            <p class="rp-match-ok">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Passwords match
                            </p>
                        }
                    </div>

                    <!-- Error -->
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="rp-alert mb-3">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <span>@ErrorMessage</span>
                        </div>
                    }

                    <!-- Submit -->
                    <button class="rp-btn rp-btn-primary rp-btn-block @(IsLoading ? "rp-btn-loading" : "")"
                            disabled="@(!CanSubmit || IsLoading)"
                            @onclick="HandleSubmit">
                        @if (IsLoading)
                        {
                            <span class="rp-spinner"></span>
                            <span>Updating password...</span>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                            <span>Save new password</span>
                        }
                    </button>

                    <div class="text-center mt-4">
                        <a href="/login" class="rp-back-link">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <polyline points="15 18 9 12 15 6"/>
                            </svg>
                            Back to Login
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    string NewPassword = string.Empty;
    string ConfirmPassword = string.Empty;
    string NewPasswordType = "password";
    string ConfirmPasswordType = "password";
    string ErrorMessage = string.Empty;
    string EmailDisplay = string.Empty;
    bool focusedNew = false;
    bool focusedConfirm = false;

    bool IsValidating = true;
    bool IsTokenInvalid = false;
    bool IsSuccess = false;
    bool IsLoading = false;

    bool CanSubmit => !string.IsNullOrWhiteSpace(NewPassword) && !string.IsNullOrWhiteSpace(ConfirmPassword);
    bool PasswordMismatch => !string.IsNullOrEmpty(ConfirmPassword) && NewPassword != ConfirmPassword;
    bool PasswordMatch => !string.IsNullOrEmpty(ConfirmPassword) && NewPassword == ConfirmPassword && NewPassword.Length >= 6;

    void ToggleNewPassword() => NewPasswordType = NewPasswordType == "password" ? "text" : "password";
    void ToggleConfirmPassword() => ConfirmPasswordType = ConfirmPasswordType == "password" ? "text" : "password";

    string GetStrength()
    {
        var p = NewPassword;
        int score = 0;
        if (p.Length >= 6) score++;
        if (p.Length >= 10) score++;
        if (p.Any(char.IsUpper) && p.Any(char.IsLower)) score++;
        if (p.Any(char.IsDigit)) score++;
        if (p.Any(c => !char.IsLetterOrDigit(c))) score++;
        return score <= 1 ? "weak" : score <= 3 ? "medium" : "strong";
    }

    string GetStrengthLabel()
    {
        return GetStrength() switch { "weak" => "Weak", "medium" => "Medium", _ => "Strong" };
    }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            IsTokenInvalid = true;
            IsValidating = false;
            return;
        }

        var email = await AuthService.ValidateResetTokenAsync(Token);
        IsValidating = false;

        if (email == null)
            IsTokenInvalid = true;
        else
            EmailDisplay = email;
    }

    private async Task HandleSubmit()
    {
        ErrorMessage = string.Empty;

        if (NewPassword.Length < 6)
        {
            ErrorMessage = "Password must be at least 6 characters.";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        IsLoading = true;
        StateHasChanged();

        var success = await AuthService.ResetPasswordAsync(Token!, NewPassword);
        IsLoading = false;

        if (success)
            IsSuccess = true;
        else
            ErrorMessage = "Failed to reset password. The link may have expired.";

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                document.documentElement.style.overflow = 'auto';
                document.documentElement.style.height = 'auto';
                document.body.style.overflow = 'auto';
                document.body.style.height = 'auto';
            ");
        }
    }

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("eval", @"
            document.documentElement.style.overflow = '';
            document.documentElement.style.height = '';
            document.body.style.overflow = '';
            document.body.style.height = '';
        ");
    }

}