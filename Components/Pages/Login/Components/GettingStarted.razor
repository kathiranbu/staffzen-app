@page "/getting-started"
@layout EmptyLayout
@rendermode RenderMode.InteractiveServer

@using APM.StaffZen.Blazor.Components.Layout
@using APM.StaffZen.Blazor.Components.Pages.GettingStarted
@using APM.StaffZen.Blazor.Services
@inject SessionService SessionService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="gs-root">

    <!-- Top nav -->
    <nav class="gs-nav">
        <div class="gs-nav-logo">
            <span style="font-size:22px;">⏳</span>
            <span class="fw-bolder fs-5">StaffZen</span>
        </div>
        <div class="gs-nav-user" @onclick="ToggleUserMenu">
            <span>@SessionService.FullName</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#444" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9" />
            </svg>
            @if (ShowUserMenu)
            {
                <div class="gs-user-dropdown">
                    <button class="gs-dropdown-item text-danger" @onclick="Logout">Logout</button>
                </div>
            }
        </div>
    </nav>

    <!-- VIEW 1: Cards -->
    @if (CurrentView == "cards")
    {
        <main class="gs-main">
            <h1 class="gs-welcome">Welcome to StaffZen!</h1>
            <div class="gs-cards-row">

                <div class="gs-section">
                    <p class="gs-section-label">For business owners and freelancers</p>
                    <div class="gs-card">
                        <div class="gs-card-body">
                            <h2 class="gs-card-title">Create a new organization</h2>
                            <p class="gs-card-sub">Simplify time &amp; attendance management</p>
                            <ul class="gs-feature-list">
                                <li>Invite and manage your team with ease</li>
                                <li>Stay on top of time tracking and projects</li>
                                <li><span class="gs-freelancer-tag">Freelancer?</span> Set up a workspace that's just for you</li>
                            </ul>
                            <div class="gs-card-bottom">
                                <button class="gs-btn-create" @onclick="OpenRoleModal">Create</button>
                                <img src="Images/Login/Jibble1.png" class="gs-card-illustration" alt="Team illustration" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="gs-section">
                    <p class="gs-section-label">For employees and team members</p>
                    <div class="gs-card">
                        <div class="gs-card-body">
                            <h2 class="gs-card-title">Join an organization</h2>
                            <p class="gs-card-sub">Accept invitations to join as a team member</p>
                            <ul class="gs-feature-list">
                                <li>Log hours anytime, anywhere</li>
                                <li>Stay in control of your productivity</li>
                            </ul>
                            <div class="gs-card-bottom gs-card-invite">
                                <div class="gs-no-invite-text">
                                    <p>You don't have any invitations yet.</p>
                                    <p>Check with your manager if they've<br />sent you an invite!</p>
                                </div>
                                <img src="Images/Login/Jibble1.png" class="gs-card-illustration gs-card-illustration-team" alt="Team illustration" />
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    }

    <!-- VIEW 2: Org Setup Form — separate component -->
    @if (CurrentView == "orgform")
    {
        <GsOrgForm
            OrgName="@OrgName"
            OrgNameChanged="v => OrgName = v"
            OrgPhone="@OrgPhone"
            OrgPhoneChanged="v => OrgPhone = v"
            Password="@OrgPassword"
            PasswordChanged="v => OrgPassword = v"
            SelectedCountry="@SelectedCountry"
            SelectedCountryChanged="v => SelectedCountry = v"
            SelectedIndustry="@SelectedIndustry"
            SelectedIndustryChanged="v => SelectedIndustry = v"
            SelectedOrgSize="@SelectedOrgSize"
            SelectedOrgSizeChanged="v => SelectedOrgSize = v"
            SelectedUserRole="@SelectedUserRole"
            SelectedUserRoleChanged="v => SelectedUserRole = v"
            ContinueLoading="@ContinueLoading"
            OnContinue="HandleOrgContinue" />
    }

    <!-- VIEW 3: Device selection -->
    @if (CurrentView == "devices")
    {
        <GsDevicesForm
            MobileApps="@DevMobileApps"
            MobileAppsChanged="v => DevMobileApps = v"
            SharedKiosk="@DevSharedKiosk"
            SharedKioskChanged="v => DevSharedKiosk = v"
            WebBrowser="@DevWebBrowser"
            WebBrowserChanged="v => DevWebBrowser = v"
            DesktopApps="@DevDesktopApps"
            DesktopAppsChanged="v => DevDesktopApps = v"
            ContinueLoading="@ContinueLoading"
            OnContinue="HandleDevicesContinue" />
    }

</div>

<!-- Welcome Modal -->
@if (ShowWelcomeModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:9999;">
        <div style="background:#fff;border-radius:20px;padding:0;max-width:480px;width:94%;box-shadow:0 24px 64px rgba(0,0,0,0.2);overflow:hidden;position:relative;">

            <!-- Close button -->
            <button @onclick="CloseWelcomeAndGo"
                    style="position:absolute;top:16px;right:16px;background:none;border:none;cursor:pointer;color:#888;z-index:2;padding:4px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>

            <!-- Illustration area -->
            <div style="background:#f7f8fa;display:flex;align-items:center;justify-content:center;padding:48px 40px 32px;min-height:260px;">
                <svg viewBox="0 0 260 220" width="240" height="200" xmlns="http://www.w3.org/2000/svg">
                    <!-- cloud blobs -->
                    <ellipse cx="130" cy="150" rx="90" ry="50" fill="#eef0f5" opacity="0.8"/>
                    <ellipse cx="80" cy="140" rx="50" ry="30" fill="#e8eaf0" opacity="0.6"/>
                    <!-- confetti ribbons -->
                    <path d="M60 80 Q50 100 70 120" stroke="#f48fb1" stroke-width="5" fill="none" stroke-linecap="round"/>
                    <path d="M200 60 Q220 90 195 115" stroke="#a5d6a7" stroke-width="5" fill="none" stroke-linecap="round"/>
                    <!-- small confetti pieces -->
                    <rect x="95" y="55" width="6" height="6" rx="1" fill="#ff6600" transform="rotate(20 95 55)" opacity="0.8"/>
                    <rect x="175" y="75" width="5" height="5" rx="1" fill="#4fc3f7" transform="rotate(-15 175 75)" opacity="0.8"/>
                    <rect x="155" y="50" width="5" height="5" rx="1" fill="#a5d6a7" transform="rotate(30 155 50)" opacity="0.9"/>
                    <circle cx="85" cy="65" r="4" fill="#f48fb1" opacity="0.8"/>
                    <circle cx="185" cy="55" r="3.5" fill="#ff6600" opacity="0.6"/>
                    <circle cx="210" cy="120" r="4" fill="#4fc3f7" opacity="0.6"/>
                    <circle cx="165" cy="130" r="3" fill="#f48fb1" opacity="0.5"/>
                    <!-- dots -->
                    <circle cx="215" cy="80" r="3" fill="#4fc3f7" opacity="0.5"/>
                    <circle cx="225" cy="95" r="2.5" fill="#a5d6a7" opacity="0.5"/>
                    <!-- Person body -->
                    <!-- legs (blue pants) -->
                    <path d="M125 165 Q115 185 108 195" stroke="#1565c0" stroke-width="14" fill="none" stroke-linecap="round"/>
                    <path d="M140 168 Q148 185 152 192" stroke="#1565c0" stroke-width="14" fill="none" stroke-linecap="round"/>
                    <!-- shoes -->
                    <ellipse cx="106" cy="197" rx="9" ry="5" fill="#4a148c" transform="rotate(-10 106 197)"/>
                    <ellipse cx="153" cy="194" rx="9" ry="5" fill="#4a148c" transform="rotate(10 153 194)"/>
                    <!-- torso (orange shirt) -->
                    <ellipse cx="132" cy="145" rx="22" ry="26" fill="#ff6600"/>
                    <!-- left arm raised -->
                    <path d="M115 135 Q90 110 80 85" stroke="#ff6600" stroke-width="13" fill="none" stroke-linecap="round"/>
                    <!-- right arm down/out -->
                    <path d="M150 140 Q168 155 175 165" stroke="#ff6600" stroke-width="13" fill="none" stroke-linecap="round"/>
                    <!-- hand raised -->
                    <circle cx="79" cy="82" r="9" fill="#ffd180"/>
                    <!-- hand right -->
                    <circle cx="177" cy="168" r="9" fill="#ffd180"/>
                    <!-- neck -->
                    <rect x="126" y="112" width="12" height="14" rx="5" fill="#ffd180"/>
                    <!-- head -->
                    <ellipse cx="132" cy="103" rx="19" ry="21" fill="#ffd180"/>
                    <!-- hair -->
                    <path d="M113 100 Q112 75 132 73 Q160 72 151 100" fill="#212121"/>
                    <path d="M151 100 Q160 115 155 130 Q145 118 140 108" fill="#212121"/>
                    <!-- face -->
                    <ellipse cx="125" cy="105" rx="2.5" ry="3" fill="#555"/>
                    <ellipse cx="139" cy="105" rx="2.5" ry="3" fill="#555"/>
                    <path d="M125 115 Q132 121 139 115" stroke="#e57373" stroke-width="2" fill="none" stroke-linecap="round"/>
                </svg>
            </div>

            <!-- Text + button -->
            <div style="padding:28px 40px 36px;text-align:center;">
                <h2 style="font-size:22px;font-weight:800;color:#111;margin:0 0 10px;outline:none;border:none;">
                    Welcome to StaffZen! 🎉
                </h2>
                <p style="font-size:14px;color:#888;margin:0 0 28px;line-height:1.6;">
                    You're in! Let's find the best way to get you started.
                </p>
                <button @onclick="CloseWelcomeAndGo"
                        style="background:#ff6600;color:#fff;border:none;border-radius:8px;padding:14px 48px;font-size:15px;font-weight:700;cursor:pointer;width:100%;transition:background 0.2s;">
                    Start onboarding
                </button>
            </div>

        </div>
    </div>
}

<!-- Role Modal -->
@if (ShowRoleModal)
{
    <div @onclick="CloseRoleModal"
         style="position:fixed;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:9999;">
        <div @onclick:stopPropagation="true"
             style="background:#fff;border-radius:16px;padding:40px 40px 0 40px;max-width:720px;width:95%;box-shadow:0 24px 64px rgba(0,0,0,0.18);overflow:hidden;">

            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;">
                <h2 style="font-size:22px;font-weight:800;color:#111;margin:0;outline:none;border:none;">
                    Let's get started: Which best describes you?
                </h2>
                <button @onclick="CloseRoleModal" style="background:none;border:none;cursor:pointer;color:#888;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
                <div style="display:flex;flex-direction:column;padding-right:24px;border-right:1px solid #f0f0f0;">
                    <h3 style="font-size:17px;font-weight:800;color:#111;margin:0 0 20px;">I'm managing a team</h3>
                    <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:28px;">
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            <span style="font-size:14px;color:#444;">Manage and monitor attendance</span>
                        </div>
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span style="font-size:14px;color:#444;">Review timesheets for payroll</span>
                        </div>
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                            <span style="font-size:14px;color:#444;">Streamline time off and schedules</span>
                        </div>
                    </div>
                    <button @onclick="GoToOrgForm" style="width:100%;background:#4a5568;color:#fff;border:none;border-radius:8px;padding:14px;font-size:15px;font-weight:700;cursor:pointer;">
                        Create an organization
                    </button>
                    <div style="margin-top:20px;">
                        <img src="Images/Login/Jibble1.png" style="width:100%;max-height:160px;object-fit:contain;" alt="Team" />
                    </div>
                </div>

                <div style="display:flex;flex-direction:column;padding-left:24px;">
                    <h3 style="font-size:17px;font-weight:800;color:#111;margin:0 0 20px;">I'm a freelancer</h3>
                    <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:28px;">
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <span style="font-size:14px;color:#444;">Unlock your freelance productivity</span>
                        </div>
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            <span style="font-size:14px;color:#444;">Track your own time</span>
                        </div>
                        <div style="display:flex;gap:12px;align-items:flex-start;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                            <span style="font-size:14px;color:#444;">Enhance project efficiency</span>
                        </div>
                    </div>
                    <button @onclick="GoToOrgForm" style="width:100%;background:#4a5568;color:#fff;border:none;border-radius:8px;padding:14px;font-size:15px;font-weight:700;cursor:pointer;">
                        Create your workspace
                    </button>
                    <div style="margin-top:20px;">
                        <img src="Images/Login/Jibble1.png" style="width:100%;max-height:160px;object-fit:contain;filter:hue-rotate(190deg) saturate(0.7);" alt="Freelancer" />
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .gs-root {
        min-height: 100vh;
        background: #f7f8fa;
        display: flex;
        flex-direction: column;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .gs-root h1, .gs-root h2, .gs-root h3 {
        outline: none !important;
        border: none !important;
        box-shadow: none !important;
    }

    .gs-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 36px;
        background: #fff;
        border-bottom: 1px solid #e9eaec;
        flex-shrink: 0;
    }

    .gs-nav-logo { display: flex; align-items: center; gap: 8px; color: #111; }

    .gs-nav-user {
        display: flex; align-items: center; gap: 6px;
        font-size: 14px; font-weight: 600; color: #222;
        cursor: pointer; position: relative; user-select: none;
    }

    .gs-user-dropdown {
        position: absolute; top: calc(100% + 8px); right: 0;
        background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1); min-width: 120px; z-index: 100;
    }

    .gs-dropdown-item {
        display: block; width: 100%; padding: 10px 16px;
        background: none; border: none; text-align: left;
        font-size: 14px; cursor: pointer; border-radius: 8px;
    }

    .gs-dropdown-item:hover { background: #f5f5f5; }

    .gs-main { flex: 1; padding: 60px 48px; max-width: 1100px; margin: 0 auto; width: 100%; }

    .gs-welcome { font-size: 28px; font-weight: 800; color: #111; margin-bottom: 48px; }

    .gs-cards-row { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }

    .gs-section-label { font-size: 13px; font-weight: 600; color: #888; margin-bottom: 12px; }

    .gs-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; min-height: 320px; }

    .gs-card-body { padding: 28px 28px 24px; display: flex; flex-direction: column; height: 100%; }

    .gs-card-title { font-size: 20px; font-weight: 800; color: #111; margin: 0 0 6px; }

    .gs-card-sub { font-size: 13px; color: #888; margin: 0 0 20px; }

    .gs-feature-list { list-style: disc; padding-left: 20px; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px; }

    .gs-feature-list li { font-size: 14px; color: #333; line-height: 1.5; }

    .gs-freelancer-tag { color: #ff6b00; font-weight: 700; }

    .gs-card-bottom { display: flex; align-items: flex-end; justify-content: space-between; margin-top: auto; gap: 16px; }

    .gs-btn-create { background: #ff6b00; color: #fff; border: none; border-radius: 8px; padding: 14px 36px; font-size: 16px; font-weight: 700; cursor: pointer; }

    .gs-btn-create:hover { background: #e55e00; }

    .gs-card-illustration { width: 160px; height: 120px; object-fit: contain; flex-shrink: 0; }

    .gs-card-illustration-team { filter: hue-rotate(30deg) saturate(0.8); }

    .gs-card-invite { align-items: flex-end; }

    .gs-no-invite-text { font-size: 13px; color: #666; line-height: 1.6; align-self: flex-end; }

    .gs-no-invite-text p { margin: 0; }

    @@media (max-width: 900px) {
        .gs-cards-row { grid-template-columns: 1fr; }
        .gs-main { padding: 32px 20px; }
        .gs-welcome { font-size: 22px; }
    }
</style>

@code {
    bool ShowUserMenu    = false;
    bool ShowRoleModal   = false;
    bool ShowWelcomeModal = false;
    string CurrentView   = "cards";
    bool ContinueLoading = false;

    string OrgName          = string.Empty;
    string OrgPassword      = string.Empty;
    string SelectedCountry  = "India";
    string OrgPhone         = string.Empty;
    string SelectedIndustry = string.Empty;
    string SelectedOrgSize  = string.Empty;
    string SelectedUserRole = string.Empty;

    // Device selections
    bool DevMobileApps  = false;
    bool DevSharedKiosk = false;
    bool DevWebBrowser  = false;
    bool DevDesktopApps = false;

    protected override void OnInitialized()
    {
        if (!SessionService.IsLoggedIn)
            Navigation.NavigateTo("/login");
        else if (SessionService.IsOnboarded)
            Navigation.NavigateTo("/organization/switcher");
    }

    void ToggleUserMenu() => ShowUserMenu = !ShowUserMenu;
    void OpenRoleModal()  => ShowRoleModal = true;
    void CloseRoleModal() => ShowRoleModal = false;

    void GoToOrgForm()
    {
        ShowRoleModal = false;
        CurrentView   = "orgform";
    }

    async Task Logout()
    {
        await SessionService.ClearSessionAsync();
        Navigation.NavigateTo("/login");
    }

    // Step 1 complete: org form → go to devices page
    async Task HandleOrgContinue()
    {
        if (string.IsNullOrWhiteSpace(OrgName)) return;

        ContinueLoading = true;
        StateHasChanged();

        var orgId = await AuthService.CreateOrganizationAsync(
            employeeId:  SessionService.Id,
            orgName:     OrgName,
            country:     SelectedCountry,
            phone:       OrgPhone,
            countryCode: GetCountryCode(SelectedCountry),
            industry:    SelectedIndustry,
            orgSize:     SelectedOrgSize,
            ownerRole:   SelectedUserRole);

        if (orgId == null)
            await AuthService.CompleteOnboardingAsync(SessionService.Id);

        // Save password if provided — allows the Google-signup user to also log in via email+password.
        // set-password is idempotent: it will create or overwrite the hash safely.
        if (!string.IsNullOrWhiteSpace(OrgPassword))
            await AuthService.SetPasswordAsync(SessionService.Email ?? string.Empty, OrgPassword);

        // Store org ID and name in session so devices step and sidebar have it
        if (orgId.HasValue)
            await SessionService.SwitchOrganizationAsync(orgId.Value, OrgName, "Admin");
        else
            SessionService.OrganizationName = OrgName;

        ContinueLoading = false;
        CurrentView = "devices";
        StateHasChanged();
    }

    // Step 2 complete: save devices → show welcome modal
    async Task HandleDevicesContinue()
    {
        ContinueLoading = true;
        StateHasChanged();

        // Build comma-separated device string and save to DB
        var devices = new List<string>();
        if (DevMobileApps)  devices.Add("MobileApps");
        if (DevSharedKiosk) devices.Add("SharedKiosk");
        if (DevWebBrowser)  devices.Add("WebBrowser");
        if (DevDesktopApps) devices.Add("DesktopApps");

        if (SessionService.OrganizationId.HasValue && devices.Count > 0)
        {
            await AuthService.SaveDevicesAsync(
                SessionService.OrganizationId.Value,
                string.Join(",", devices));
        }

        // Mark session as onboarded with Admin role (org creator is always Admin)
        await SessionService.SetSessionAsync(new APM.StaffZen.Blazor.ViewModels.LoginResponse
        {
            Id                   = SessionService.Id,
            FullName             = SessionService.FullName           ?? string.Empty,
            Email                = SessionService.Email              ?? string.Empty,
            Role                 = "Admin",
            IsOnboarded          = true,
            IsNewAccount         = false,
            OrganizationName     = SessionService.ActiveOrganizationName,
            ActiveOrganizationId = SessionService.ActiveOrganizationId,
            ActiveOrgRole        = "Admin"
        });

        ContinueLoading    = false;
        ShowWelcomeModal   = true;
        StateHasChanged();
    }

    void CloseWelcomeAndGo()
    {
        ShowWelcomeModal = false;
        // Go to organization/switcher so the newly created org appears in the list
        Navigation.NavigateTo("/organization/switcher");
    }

    // Mirrors the logic in GsOrgForm.razor
    static string GetCountryCode(string country) => country switch
    {
        "India"          => "+91",
        "United States"  => "+1",
        "United Kingdom" => "+44",
        "Australia"      => "+61",
        "Canada"         => "+1",
        "Singapore"      => "+65",
        "UAE"            => "+971",
        "Germany"        => "+49",
        "France"         => "+33",
        "Japan"          => "+81",
        "Brazil"         => "+55",
        _                => ""
    };
}
